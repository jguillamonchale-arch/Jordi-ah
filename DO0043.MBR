     C                   EVAL      MSGER='MSG0022'                                                  
     C                   IF        PXNMER=1                                                         
     C                   EVAL      MSGER='MSG0023'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=2                                                         
     C                   EVAL      MSGER='MSG0024'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=3                                                         
     C                   EVAL      MSGER='MSG0025'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=4                                                         
     C                   EVAL      MSGER='MSG0026'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=5                                                         
     C                   EVAL      MSGER='MSG0032'                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
     C                   MOVE      PXALPH        P2APSMA                                            
     C                   EVAL      ZXPSMA=PXNUM                                                     
                                                                                                    
     C     TP2ACHK       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE ACTUALIZACION DEL FMT P2A                     *                                
      *------------------------------------------------------------*                                
     C     P2AUPD        BEGSR                                                                      
     C                   EVAL      Z_P=Z_P+1                                                        
     C                   IF        SSSECPA(Z_P)=*BLANKS                                             
     C                   EVAL      ZXOPT='END'                                                      
     C                   IF        INDCRT=*ON AND @POPCI<>'1B'                                      
     C                   EVAL      ZXOPT='P10CLR'                                                   
     C                   ENDIF                                                                      
     C                   ELSE                                                                       
     C                   EVAL      ZXOPT1='P2 '                                                     
     C                   MOVE      SSSECPA(Z_P)  ZXOPT1                                             
     C                   EVAL      ZXOPT2='CLR'                                                     
     C                   ENDIF                                                                      
                                                                                                    
      * En el caso de la opción de visualiza no actualizo                                           
     C                   IF        INDDSP=*ON                                                       
     C                   GOTO      P2AUPDT                                                          
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      XACIAS=@PCIAS                                                    
     C                   EVAL      XADLGA=P2ADLGA                                                   
     C                   EVAL      XADLG2=P2ADLG2                                                   
     C     KMSDDOM       CHAIN     MSDDOM                             81                            
      *                                                                                             
     C                   EXSR      P2AMPF                                                           
                                                                                                    
     C                   IF        CHAIN=*OFF                                                       
     C                   UPDATE    RMSDDOM                                                          
     C                   ELSE                                                                       
     C                   EVAL      XADAT8=*DATE                                                     
     C                   WRITE     RMSDDOM                                                          
     C                   ENDIF                                                                      
                                                                                                    
     C     P2AUPDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PASAR DE PANTALLA P2A A FICHERO                  *                                
      *------------------------------------------------------------*                                
     C     P2AMPF        BEGSR                                                                      
      *                                                                                             
     C                   EVAL      XAPR01=P2APR01                                                   
     C                   EVAL      XAPR02=P2APR02                                                   
     C                   EVAL      XAPR03=P2APR03                                                   
     C*                  EVAL      XAPRIS=P2APR03                                                   
     C                   EVAL      XAPR04=P2APR04                                                   
                                                                                                    
     C                   MOVE      ZXPSMA        XAPSMA                                             
     C                   EVAL      XAMO01=P2AMO01                                                   
     C                   EVAL      XAMO02=P2AMO02                                                   
     C                   EVAL      XAMO03=P2AMO03                                                   
     C                   EVAL      XAMO04=P2AMO04                                                   
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   MOVE      P2AIR01       PXALPH                                             
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                                              
     C                   PARM                    PXALPH                                             
     C                   PARM                    PXFLDD                                             
     C                   PARM      2             PXDCCD                                             
     C                   PARM                    PXFMD1                                             
     C                   PARM                    PXEDTC                                             
     C                   PARM                    PXNMER                                             
     C                   PARM                    PXTIPA                                             
     C                   EVAL      XAIR01=PXNUM                                                     
      *                                                                                             
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   MOVE      P2AIR02       PXALPH                                             
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                                              
     C                   PARM                    PXALPH                                             
     C                   PARM                    PXFLDD                                             
     C                   PARM      2             PXDCCD                                             
     C                   PARM                    PXFMD1                                             
     C                   PARM                    PXEDTC                                             
     C                   PARM                    PXNMER                                             
     C                   PARM                    PXTIPA                                             
     C                   EVAL      XAIR02=PXNUM                                                     
      *                                                                                             
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   MOVE      P2AIR03       PXALPH                                             
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                                              
     C                   PARM                    PXALPH                                             
     C                   PARM                    PXFLDD                                             
     C                   PARM      2             PXDCCD                                             
     C                   PARM                    PXFMD1                                             
     C                   PARM                    PXEDTC                                             
     C                   PARM                    PXNMER                                             
     C                   PARM                    PXTIPA                                             
     C                   EVAL      XAIR03=PXNUM                                                     
      *                                                                                             
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   MOVE      P2AIR04       PXALPH                                             
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                                              
     C                   PARM                    PXALPH                                             
     C                   PARM                    PXFLDD                                             
     C                   PARM      2             PXDCCD                                             
     C                   PARM                    PXFMD1                                             
     C                   PARM                    PXEDTC                                             
     C                   PARM                    PXNMER                                             
     C                   PARM                    PXTIPA                                             
     C                   EVAL      XAIR04=PXNUM                                                     
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   MOVE      P2ADIST       PXALPH                                             
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                                              
     C                   PARM                    PXALPH                                             
     C                   PARM                    PXFLDD                                             
     C                   PARM      2             PXDCCD                                             
     C                   PARM                    PXFMD1                                             
     C                   PARM                    PXEDTC                                             
     C                   PARM                    PXNMER                                             
     C                   PARM                    PXTIPA                                             
     C                   EVAL      XADIST=PXNUM                                                     
                                                                                                    
     C                   EVAL      XAMO01=P7MONE                                                    
     C                   EVAL      XAMO02=P7MONE                                                    
     C                   EVAL      XAMO04=P7MONE                                                    
     C                   EVAL      XAMO03=P7MONE                                                    
                                                                                                    
     C                   EVAL      XAOE01=P2AOE01                                                   
     C                   EVAL      XAOE02=P2AOE02                                                   
L1078C*                  EVAL      XAOE04=P2AOE03                                                   
L1078C*                  EVAL      XAOE03=P2AOE04                                                   
L1078C                   EVAL      XAOE03=P2AOE03                                                   
L1078C                   EVAL      XAOE04=P2AOE04                                                   
      *                                                                                             
     C                   EVAL      XADAT8=ZZDATS                                                    
     C                   IF        XADAT8=0                                                         
     C                   EVAL      XADAT8=*DATE                                                     
     C                   ENDIF                                                                      
     C                   TIME                    PEHORA                                             
     C                   EVAL      XAUSUA=ZZUSUA                                                    
     C                   EVAL      XAPANT=SDSJOB                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL FMT P30                              *                                
      *------------------------------------------------------------*                                
     C     P30MAIN       BEGSR                                                                      
     C                   DOW       ZXOPT1='P30'                                                     
     C     ZXOPT2        CASEQ     'CLR'         P30CLR                                             
     C     ZXOPT2        CASEQ     'INZ'         P30INZ                                             
     C     ZXOPT2        CASEQ     'DSP'         P30DSP                                             
     C     ZXOPT2        CASEQ     'CMD'         P30CMD                                             
     C     ZXOPT2        CASEQ     'CHK'         P30CHK                                             
     C     ZXOPT2        CASEQ     'UPD'         P30UPD                                             
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA LIMPIEZA  DE P30                                 *                                
      *------------------------------------------------------------*                                
     C     P30CLR        BEGSR                                                                      
     C                   EVAL      ZXOPT2='INZ'                                                     
     C                   RESET                   Z_P                                                
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO10      *IN(60)                                            
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C     P30CLRT       ENDSR                                                                      
      *                                                                                             
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ DEL FMT P30                       *                                
      *------------------------------------------------------------*                                
     C     P30INZ        BEGSR                                                                      
      *                                                                                             
     C                   EVAL      ZXOPT2='DSP'                                                     
     C     *NOKEY        CLEAR     *ALL          RMSDDOM                                            
     C     KMSDDOM       CHAIN     MSDDOM                             81                            
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      ZXOPT='END'                                                      
     C                   GOTO      P30INZT                                                          
     C                   ENDIF                                                                      
                                                                                                    
     C                   EXSR      P30MFP                                                           
                                                                                                    
     C     P30INZT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PASAR DE FICHERO A PANTALLA P30                  *                                
      *------------------------------------------------------------*                                
     C     P30MFP        BEGSR                                                                      
      *                                                                                             
     C                   EVAL      P30DLG2=XADLG2                                                   
     C                   EVAL      P30DLGA=XADLGA                                                   
     C                   EVAL      P30DESC=ZXDESC                                                   
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VISUALITZACIÓ DEL FMT P30                        *                                
      *------------------------------------------------------------*                                
     C     P30DSP        BEGSR                                                                      
      * ENS ENCARREGUEM QUE EL PROPER PAS SIGUI COMPROVAR ENTRADA CMD                               
     C                   EVAL      ZXOPT2='CMD'                                                     
     C                   EVAL      PPPCMD1='CMD3012'                                                
     C                   EXFMT     P30                                                              
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO10      *IN(60)                                            
     C                   EVAL      ERRGRL=*OFF                                                      
     C                   EVAL      MSGER=*BLANKS                                                    
     C     P30DSPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CMDS  DEL FMT P30                 *                                
      *------------------------------------------------------------*                                
     C     P30CMD        BEGSR                                                                      
     C                   EVAL      ZXOPT2='CHK'                                                     
      *VALIDACIONES TECLAS DE FUNCION                                                               
     C                   SELECT                                                                     
      * FINALITZAR EL PROGRAMA                                                                      
     C                   WHEN      EXIT=*ON                                                         
     C                   EVAL      ZXOPT1='END'                                                     
      * SOL·LICITUD AJUDA D'ARTICLES                                                                
     C                   WHEN      HELP=*ON                                                         
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   EXSR      CS_POCUR2                                                        
     C                   EXSR      P30F4                                                            
      * RETROCESO PANTALLA                                                                          
     C                   WHEN      RETRO=*ON                                                        
     C                   EVAL      ZXOPT1='END'                                                     
     C                   ENDSL                                                                      
                                                                                                    
     C     TP30CMD       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CAMPS DEL FMT P30                 *                                
      *------------------------------------------------------------*                                
     C     P30CHK        BEGSR                                                                      
     C                   EVAL      ZXOPT2='UPD'                                                     
                                                                                                    
      * El CLTA  no puede existir                                                                   
     C                   EVAL      XADLG2=P3CDLG3                                                   
     C     KMSDDOM       CHAIN (N) MSDDOM                             81                            
     C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP30CHK                                            
                                                                                                    
     C     TP30CHK       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MSG0008'                                                  
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE AYUDA PARA FMT P30                            *                                
      *------------------------------------------------------------*                                
     C     P30F4         BEGSR                                                                      
     C* No se permite acceso a consulta si estamos en opcion de visualizar                          
     C                   IF        INDDSP=*ON                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           P30F4T                                             
     C* F4 PARA VALORES QUE UNICAMENTE SE ACCEDE POR PROMPT SEGUN REFERENCIA                        
     C* DEL DICCIONARIO                                                                             
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEFMT=*BLANKS                                                   
                                                                                                    
      *                                                                                             
      * Si no han realizado ninguna selección no tocamos nada                                       
     C                   IF        @PEERR='A'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C                   EVAL      P10DLGA=@PCLTA                                                   
     C     ERRGRL        CABEQ     *ON           P30F4T                                             
      *                                                                                             
     C     P30F4T        ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE ACTUALIZACION DEL FMT P30                     *                                
      *------------------------------------------------------------*                                
     C     P30UPD        BEGSR                                                                      
     C                   EVAL      ZXOPT1='P2 '                                                     
     C                   RESET                   Z_P                                                
     C                   MOVE      SSSECPA(Z_P)  ZXOPT1                                             
     C                   EVAL      ZXOPT2='CLR'                                                     
                                                                                                    
     C                   EVAL      XADLGA=P30DLGA                                                   
     C                   EVAL      XADLG2=P3CDLG3                                                   
     C     P30UPDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL FMT P40                              *                                
      *------------------------------------------------------------*                                
     C     P40MAIN       BEGSR                                                                      
     C                   DOW       ZXOPT1='P40'                                                     
     C     ZXOPT2        CASEQ     'CLR'         P40CLR                                             
     C     ZXOPT2        CASEQ     'INZ'         P40INZ                                             
     C     ZXOPT2        CASEQ     'DSP'         P40DSP                                             
     C     ZXOPT2        CASEQ     'CMD'         P40CMD                                             
     C     ZXOPT2        CASEQ     'CHK'         P40CHK                                             
     C     ZXOPT2        CASEQ     'UPD'         P40UPD                                             
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA LIMPIEZA  DE P40                                 *                                
      *------------------------------------------------------------*                                
     C     P40CLR        BEGSR                                                                      
     C                   EVAL      ZXOPT2='INZ'                                                     
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO10      *IN(60)                                            
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C     P40CLRT       ENDSR                                                                      
      *                                                                                             
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ DEL FMT P40                       *                                
      *------------------------------------------------------------*                                
     C     P40INZ        BEGSR                                                                      
      *                                                                                             
     C                   EVAL      ZXOPT2='DSP'                                                     
     C     *NOKEY        CLEAR     *ALL          RMSDDOM                                            
     C     KMSDDOM       CHAIN     MSDDOM                             81                            
     C                   EXSR      P40MFP                                                           
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PASAR DE FICHERO A PANTALLA P40                  *                                
      *------------------------------------------------------------*                                
     C     P40MFP        BEGSR                                                                      
      *                                                                                             
     C                   EVAL      P40DLGA=XADLGA                                                   
     C                   EVAL      P40DESC=PEDESC                                                   
     C                   EVAL      P40DLG2=XADLG2                                                   
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VISUALITZACIÓ DEL FMT P40                        *                                
      *------------------------------------------------------------*                                
     C     P40DSP        BEGSR                                                                      
      * ENS ENCARREGUEM QUE EL PROPER PAS SIGUI COMPROVAR ENTRADA CMD                               
     C                   EVAL      ZXOPT2='CMD'                                                     
     C                   EVAL      PPPCMD1='CMD3029'                                                
     C                   EXFMT     P40                                                              
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO10      *IN(60)                                            
     C                   EVAL      ERRGRL=*OFF                                                      
     C                   EVAL      MSGER=*BLANKS                                                    
     C     P40DSPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CMDS  DEL FMT P40                 *                                
      *------------------------------------------------------------*                                
     C     P40CMD        BEGSR                                                                      
     C                   EVAL      ZXOPT2='CHK'                                                     
      *VALIDACIONES TECLAS DE FUNCION                                                               
     C                   SELECT                                                                     
      * FINALITZAR EL PROGRAMA                                                                      
     C                   WHEN      EXIT=*ON                                                         
     C                   EVAL      ZXOPT1='END'                                                     
      * RETROCESO PANTALLA                                                                          
     C                   WHEN      RETRO=*ON                                                        
     C                   EVAL      ZXOPT1='END'                                                     
     C                   ENDSL                                                                      
                                                                                                    
     C     TP40CMD       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C     P40CMDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CAMPS DEL FMT P40                 *                                
      *------------------------------------------------------------*                                
     C     P40CHK        BEGSR                                                                      
     C                   EVAL      ZXOPT2='UPD'                                                     
      * Si en el campo PEBL66='@' Tampoco permito borrar                                            
     C                   IF        PEBL66='@'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MSG0064'                                                  
     C                   ENDIF                                                                      
     C     TP40CHK       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C     P40CHKT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE AYUDA PARA FMT P40                            *                                
      *------------------------------------------------------------*                                
     C     P40F4         BEGSR                                                                      
     C     P40F4T        ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE ACTUALIZACION DEL FMT P40                     *                                
      *------------------------------------------------------------*                                
     C     P40UPD        BEGSR                                                                      
      * Las bajas serán bajas lógicas y no físicas                                                  
     C                   EVAL      XACIAS=@PCIAS                                                    
     C                   EVAL      XADLGA=@PDLGA                                                    
     C                   EVAL      XADLG2=@PCLAB                                                    
     C     KMSDDOM       CHAIN     MSDDOM                             81                            
     C                   IF        CHAIN=*OFF                                                       
     C                   DELETE    RMSDDOM                                                          
     C                   ENDIF                                                                      
     C                   EVAL      ZXOPT='END'                                                      
                                                                                                    
     C     P40UPDT       ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA DE POSICIONAMENT DEL CURSOR                      *                                
      *------------------------------------------------------------*                                
     C     CS_POCUR2     BEGSR                                                                      
      * OBTENIM LA POSICIO DEL CURSOR                                                               
     C     FMTPOCUR      DIV       256           CSRFILA                                            
     C                   MVR                     CSRCOLU                                            
     C                   ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA DE PROXIMA PANTALLA SI NO RESPONDE               *                                
      * UNA PANTALLA A NINGUNA DE LAS PANTALLA CONSIDERADAS        *                                
      *------------------------------------------------------------*                                
     C     PANNEXT       BEGSR                                                                      
     C                   EVAL      Z_P=Z_P+1                                                        
     C                   IF        SSSECPA(Z_P)=*BLANKS                                             
     C                   EVAL      ZXOPT='END'                                                      
     C                   ELSE                                                                       
     C                   EVAL      ZXOPT1='P2 '                                                     
     C                   MOVE      SSSECPA(Z_P)  ZXOPT1                                             
     C                   EVAL      ZXOPT2='CLR'                                                     
     C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE AYUDA EN CAMPOS DEL   FMT P2A                 *                                
      *------------------------------------------------------------*                                
     C     P10F4         BEGSR                                                                      
     C* No se permite acceso a consulta si estamos en opcion de visualizar                          
     C                   IF        INDDSP=*ON                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
      *                                                                                             
                                                                                                    
     C     P10F4T        ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE CONTROLA ELS POSSIBLES ERRORS DE PROGRAMA    *                                
      *------------------------------------------------------------*                                
     c/copy *LIBL/qSRDsrc,srd020                                                                    
