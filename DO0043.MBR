      * TITOL: DO0043  © ASTRAL GRUP                               *                                
      * DATA CREACIO:  04/08/1997    AUTOR: DEPARTAMENTO INFORMATICA*                               
      * FUNCIO DEL PROGRAMA: MANTENIMIENTO INTERDELEGACIONES       *                                
      * (DSP/CRT/DLT/CPY/CHG)                                      *                                
      * DOCUMENTACIO:                                              *                                
      *                                                            *                                
      * ZXOPT1 = NOM DEL PROCÉS                                    *                                
      *        - PN = FORMAT DE PANTALLA N.(N=[01,02,...,99])      *                                
      *        - WN = WINDOWS N.(N=[01,02,...,99])                 *                                
      * ZXOPT2 = RUTINA DINTRE DEL PROCÉS                          *                                
      *        - 'INZ'= INICILITZAR                                *                                
      *        - 'DSP'= VISUALITZAR LA PANTALLA                    *                                
      *        - 'CMD'= VALIDACIÓ DE LES TECLES DE FUNCIÓ          *                                
      *        - 'CHK'= VALIDACIÓ DE LA PANTALLA                   *                                
      *        - 'CLR'= NETEJA LA PANTALLA                         *                                
      *        - 'UPD'= ACTUALITZACIONS DELS FITXERS               *                                
      *                                                            *                                
      **************************************************************                                
      * DATA DE MODIFICACIÓ: 01/09/2014  MARCA: L1078              *                                
      * AUTOR: JMARTINEZP                                          *                                
      * DOCUMENTACIÓ: INCIDENCIA MANTENIMIENTO EXCEPCIONES         *                                
      **************************************************************                                
                                                                                                    
     H DATEDIT(*YMD/)                                                                               
                                                                                                    
     FDO0043FM  CF   E             WORKSTN INFDS(FMTDS)                                             
     FPMTABD    IF   E           K DISK    INFDS(FMFDS) INFSR(*PSSR)                                
     FMSDDOM    UF A E           K DISK                                                             
     FPMTABL    IF   E           K DISK                                                             
     FPMSETP    IF   E           K DISK                                                             
     FPMEMPR    IF   E           K DISK                                                             
                                                                                                    
     D* AREA DE DADES DE PROGRAMA I INICIALITZACIO DE VALORS COMUNS                                 
     D                SDS                                                                           
     D  SDSPGM                 1     10                                                             
     D    CCCPGM                     10    OVERLAY(SDSPGM)                                          
     D  SDSJOB               244    253                                                             
     D    CCCJOB                     10    OVERLAY(SDSJOB)                                          
     D  SDSUSR               254    263                                                             
     D  SDSJNBR              264    269                                                             
                                                                                                    
     D* AREA DE DADES D'INFORMACIÓ ARXIU                                                            
     D  FMTDS          DS                                                                           
     D    FMTPOCUR           370    371B 0                                                          
     D    FMTPOS             378    379B 0                                                          
     D    FMTRCD         *RECORD                                                                    
     D  FMFDS          DS                                                                           
     D    FMFFILE        *FILE                                                                      
     D    FMFSTS         *STATUS                                                                    
                                                                                                    
     D* AREA DE DADES LOCAL I INICIALITZACIO DE VALORS COMUNS                                       
     D  DSLDA        E DS                  EXTNAME(PURLDADS)                                        
     D    CCCDEEM                    30    OVERLAY(ZZDEEM)                                          
                                                                                                    
     D* AREA DE PARAMETRES DE PROGRAMA                                                              
     D CN0040        E DS                  EXTNAME(CN0040DS)                                        
     D* CONTROL DEL FLUXE DEL PROGRAMA                                                              
     D                 DS                                                                           
     D  ZXOPT                  1      6                                                             
     D    ZXOPT1               1      3                                                             
     D    ZXOPT2               4      6                                                             
                                                                                                    
     D                 DS                                                                           
     D  ZXBL62                 1     10                                                             
     D   ZXDESDE               1      5                                                             
     D   ZXHASTA               6     10                                                             
     D                 DS                                                                           
     D  ZXBL63                 1     15                                                             
     D   ZXFMAXI               1      5                                                             
     D   ZXFMINI               6     10                                                             
     D   ZXMESSS              12     13                                                             
     D   ZXSSTOK              14     15                                                             
     D                 DS                                                                           
     D  ZXBL65                 1      5                                                             
     D   ZXCENT                1      1                                                             
     D   ZXMPLA                2      3                                                             
     D                 DS                                                                           
     D  ZXBL61                 1      5                                                             
     D   ZXTEND                1      1                                                             
     D                 DS                                                                           
     D  ZXBL64                 1     10                                                             
     D   ZXMAXI                1      5                                                             
     D   ZXMINI                6     10                                                             
     D* Descomposicion de FIELD para tomar la parte del diccionario                                 
     D                 DS                                                                           
     D  FIELD                  1     10                                                             
     D    ZXFMTO               1      3                                                             
     D    ZXFIE2               2      5                                                             
     D    ZXFIE4               4      7                                                             
     D* SERIES A UTILITZAR EN PROGRAMA                                                              
     DSSSECPA          S              1A   DIM(10)                                                  
     DSSSEC            S              1A   DIM(10)                                                  
      * PLANTILLA D'INDICADORS DEL PROGRAMA (ELS RESERVATS NO SURTEN)                               
     D  INDICADORS   E DS                  BASED(INDICADORP)                                        
     D                                     EXTNAME(INDDS:RIND0199)                                  
     D    INDCHG                      1    OVERLAY(WRK25)                                           
     D    INDCPY                      1    OVERLAY(WRK26)                                           
     D    INDDLT                      1    OVERLAY(WRK27)                                           
     D    INDDSP                      1    OVERLAY(WRK28)                                           
     D    INDCRT                      1    OVERLAY(WRK29)                                           
     D    INDPROT                     1    OVERLAY(SETL00)                                          
     D  INDICADORP     S               *   INZ(%ADDR(*IN))                                          
                                                                                                    
     D                 DS                                                                           
     D  ZXPOSCUR               1      4  2                                                          
     D    ZXPOSX               1      2  0                                                          
     D    ZXPOSY               3      4  0                                                          
      * Definicion de algunas constantes                                                            
     D  ZXZERO10       C                   '0000000000'                                             
      *IMPORTACIÓ DE PARÀMETRES                                                                     
     D  @PCIAS         S                   LIKE(PECIAS)                                             
     D  @POPCI         S              2                                                             
     D  @PERRO         S              1                                                             
     D  @PDAT8         S                   LIKE(PEDAT8)                                             
     D  @PDLGA         S                   LIKE(ZZDLGA)                                             
     D  @PCLAB         S                   LIKE(XADLG2)                                             
     D  @PHORA         S                   LIKE(PEHORA)                                             
                                                                                                    
     D    @PEOPT       S              2                                                             
     D    @PEPGM       S                   LIKE(SDSPGM) INZ                                         
     D    @PEFMT       S                   LIKE(RECORD) INZ                                         
     D    @PEFLD       S                   LIKE(FIELD)  INZ                                         
     D    @PEERR       S              1                 INZ                                         
     D    @PCLTA       S                   LIKE(PECLTA)                                             
     D    @PCTAB       S                   LIKE(PECTAB)                                             
     D    @PCLT2       S                   LIKE(PECLTA)                                             
     D    @PCTA2       S                   LIKE(PECTAB)                                             
     D  @PFILE         S             10                                                             
     D  @PPGM          S             10                                                             
                                                                                                    
                                                                                                    
     D* DEFINICIO DE CAMPS DE TREBALL                                                               
     D  ZXDESD         S              5  0                                                          
     D  ZXHAST         S              5  0                                                          
     D  Z_P            S              2  0 INZ(1)                                                   
     D  ZXPTRETORN     S              6A   INZ                                                      
                                                                                                    
      * DEFINICIO DE CAMPS DE PARÀMETRES PER CALL (SENSE IMPORT/EXPORT)                             
      * PARÀMETRES PEL PRD650 I CAMPS DE TREBALL ASSOCIATS                                          
      * VALOR NUMÈRIC                                                                               
     D   PXNUM         S             29  9                                                          
      * VALOR ALFANUMÈRIC                                                                           
     D   PXALPH        S             29                                                             
      * LONGITUD TOTAL DEL CAMP (Nº CARÀCTERS INCLÒS CODI EDICIÓ)                                   
     D   PXFLDD        S              2  0 INZ(20)                                                  
      * Nº DE DECIMALS DEL CAMP                                                                     
     D  PXDCCD         S              1  0 INZ(0)                                                   
      * TIPUS DE FORMAT DECIMAL (.,)                                                                
     D  PXFMD1         S                   LIKE(ZZFMD1)INZ                                          
      * CODI D'EDICIÓ (4,M,Q,Z)                                                                     
     D  PXEDTC         S                   LIKE(ZZEDTC)INZ(' ')                                     
      * RETORN CODI D'ERROR                                                                         
     D  PXNMER         S              1  0 INZ(0)                                                   
      * TIPUS D'AJUST DECIMAL (0=MIG 1=PER SOBRE 2=PER SOTA)                                        
     D  PXTIPA         S              1                                                             
     D  ZXDESC         S                   LIKE(PEDESC)                                             
     D                 DS                                                                           
     D  ZXCLTAX                1     10                                                             
     D    ZXDLGA               1      5                                                             
     D    ZXPRVR               6     10                                                             
     D  ZXMAX          S              5  0                                                          
     D  ZXMIN          S              5  0                                                          
     D   ZXCLTAP       S                   LIKE(PECLTA)                                             
     D   ZXCLAB        S                   LIKE(XADLG2)                                             
      *                                                                                             
     D  XAAMPL         DS                                                                           
     D     XAPSMA              1      5                                                             
      *                                                                                             
     D  ZXPSMA         S              5  2                                                          
      **************************************************************                                
      * RUTINA PRINCIPAL DEL PGM : DISTRIBUCIÓ DEL PAS PELS FMTS   *                                
      *------------------------------------------------------------*                                
     C     ZXOPT1        DOWNE     'END'                                                            
     C     ZXOPT1        CASEQ     'P10'         P10MAIN                                            
     C     ZXOPT1        CASEQ     'P2A'         P2AMAIN                                            
     C     ZXOPT1        CASEQ     'P30'         P30MAIN                                            
     C     ZXOPT1        CASEQ     'P40'         P40MAIN                                            
     C                   CAS                     PANNEXT                                            
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
     C                   SETON                                        LR                            
      **************************************************************                                
      * SUBRUTINA INICIAL                                          *                                
      *------------------------------------------------------------*                                
     C     *INZSR        BEGSR                                                                      
                                                                                                    
      * DEFINICIO DE LES KLIST DEL PGM                                                              
                                                                                                    
     C     KPMTABL       KLIST                                                                      
     C                   KFLD                    PDCIAS                                             
     C                   KFLD                    PDCTAB                                             
     C     KPMTABD       KLIST                                                                      
     C                   KFLD                    PECIAS                                             
     C                   KFLD                    PECTAB                                             
     C                   KFLD                    PECLTA                                             
     C     KPMTABD_S     KLIST                                                                      
     C                   KFLD                    PECIAS                                             
     C                   KFLD                    PECTAB                                             
                                                                                                    
     C     KMSDDOM       KLIST                                                                      
     C                   KFLD                    XACIAS                                             
     C                   KFLD                    XADLGA                                             
     C                   KFLD                    XADLG2                                             
                                                                                                    
     C     KMSDDOM0      KLIST                                                                      
     C                   KFLD                    XACIAS                                             
     C                   KFLD                    XADLGA                                             
                                                                                                    
     C     KMSSETP       KLIST                                                                      
     C                   KFLD                    PICIAS                                             
     C                   KFLD                    PIPROG                                             
     C                   KFLD                    PIUSU1                                             
                                                                                                    
     C     KPMEMPR       KLIST                                                                      
     C                   KFLD                    P7CIAS                                             
     C                   KFLD                    P7DLGA                                             
                                                                                                    
     C     *DTAARA       DEFINE    PURLDA        DSLDA                                              
     C                   IN        DSLDA                                                            
      * Entrada de parámetros                                                                       
     C     *ENTRY        PLIST                                                                      
     C                   PARM                    @PCIAS                                             
     C                   PARM                    @PDLGA                                             
     C                   PARM                    @PCLAB                                             
     C                   PARM                    @POPCI                                             
     C                   PARM                    @PERRO                                             
                                                                                                    
     C                   EVAL      PXFMD1=ZZFMD1                                                    
     C* TITOLS DE PANTALLES (CODIS D'ARXIU DE MISSATGES)                                            
     C                   EVAL      CCCCTIT='TDO0042'                                                
      * BUSQUEDA DE PARAMETROS DE SETUP                                                             
     C                   EVAL      PICIAS=ZZCIAS                                                    
     C                   EVAL      PIPROG='CN0040    '                                              
     C                   EVAL      PIUSU1=ZZUSUA                                                    
     C     KMSSETP       CHAIN     PMSETP                             81                            
     C                   CLEAR                   CN0040                                             
     C     PIDATR        CAT       CN0040:0      CN0040                                             
     C                   MOVEA     MÑSECP        SSSECPA                                            
     C                   IF        MÑSECP=*BLANKS OR @POPCI='1 ' OR                                 
     C                             @POPCI=' 1' OR @POPCI='3 ' OR                                    
     C                             @POPCI=' 3' OR @POPCI='1B'                                       
     C                   EVAL      SSSECPA(1)='A'                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      PDCIAS=@PCIAS                                                    
     C                   EVAL      PDCTAB='PCOM'                                                    
     C                   EVAL      PECIAS=@PCIAS                                                    
     C                   EVAL      PECTAB='PCOM'                                                    
     C                   EVAL      XACIAS=@PCIAS                                                    
     C                   EVAL      XADLGA=@PDLGA                                                    
     C                   EVAL      XADLG2=@PCLAB                                                    
                                                                                                    
      * ENS POSICIONEM EN EL FORMAT DE PANT. SEGONS NECESSITAT.                                     
      * POR DEFECTO IREMOS A LA 2ª PANTALLA                                                         
     C                   EVAL      INDCHG=*ON                                                       
     C                   EVAL      ZXOPT='P2ACLR'                                                   
     C                   IF        SSSECPA(1)='A'                                                   
     C                   EVAL      ZXOPT='P2ACLR'                                                   
     C                   ENDIF                                                                      
     C                   SELECT                                                                     
      * CRT                                                                                         
     C                   WHEN      @POPCI=' 1' OR @POPCI='1 '                                       
     C                   EVAL      ZXOPT='P10CLR'                                                   
     C                   EVAL      INDCRT=*ON                                                       
                                                                                                    
     C                   WHEN      @POPCI='1B'                                                      
     C                   EVAL      ZXOPT='P2ACLR'                                                   
     C                   EVAL      INDCRT=*ON                                                       
      * CPY                                                                                         
     C                   WHEN      @POPCI=' 3' OR @POPCI='3 '                                       
     C                   EVAL      ZXOPT='P30CLR'                                                   
     C                   EVAL      INDCPY=*ON                                                       
      * DLT                                                                                         
     C                   WHEN      @POPCI=' 4' OR @POPCI='4 '                                       
     C                   EVAL      ZXOPT='P40CLR'                                                   
     C                   EVAL      INDDLT=*ON                                                       
      * DSP                                                                                         
     C                   WHEN      @POPCI=' 5' OR @POPCI='5 '                                       
     C                   EVAL      INDDSP=*ON                                                       
     C                   EVAL      INDPROT=*ON                                                      
     C                   ENDSL                                                                      
      *                                                                                             
     C                   EVAL      P7CIAS=@PCIAS                                                    
     C                   EVAL      P7DLGA=@PDLGA                                                    
     C     KPMEMPR       CHAIN     PMEMPR                                                           
      *                                                                                             
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL FMT P10                              *                                
      *------------------------------------------------------------*                                
     C     P10MAIN       BEGSR                                                                      
     C                   DOW       ZXOPT1='P10'                                                     
     C     ZXOPT2        CASEQ     'CLR'         P10CLR                                             
     C     ZXOPT2        CASEQ     'INZ'         P10INZ                                             
     C     ZXOPT2        CASEQ     'DSP'         P10DSP                                             
     C     ZXOPT2        CASEQ     'CMD'         P10CMD                                             
     C     ZXOPT2        CASEQ     'CHK'         P10CHK                                             
     C     ZXOPT2        CASEQ     'UPD'         P10UPD                                             
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ DEL FMT P10                       *                                
      *------------------------------------------------------------*                                
     C     P10CLR        BEGSR                                                                      
      * ENS ENCARREGUEM QUE EL PROPER PAS SIGUI VISUALITZAR P10                                     
     C                   EVAL      ZXOPT2='INZ'                                                     
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO10      *IN(60)                                            
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C                   RESET                   Z_P                                                
     C     P10CLRT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ DEL FMT P10                       *                                
      *------------------------------------------------------------*                                
     C     P10INZ        BEGSR                                                                      
      * ENS ENCARREGUEM QUE EL PROPER PAS SIGUI VISUALITZAR P10                                     
     C                   EVAL      ZXOPT2='DSP'                                                     
     C     P10INZT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VISUALITZACIÓ DEL FMT P10                        *                                
      *------------------------------------------------------------*                                
     C     P10DSP        BEGSR                                                                      
      * ENS ENCARREGUEM QUE EL PROPER PAS SIGUI COMPROVAR ENTRADA CMD                               
     C                   EVAL      ZXOPT2='CMD'                                                     
     C                   EVAL      PPPCMD1='CMD7801'                                                
     C                   EVAL      P10DLGA=@PDLGA                                                   
     C                   EXFMT     P10                                                              
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO10      *IN(60)                                            
     C                   EVAL      ERRGRL=*OFF                                                      
     C                   EVAL      MSGER=*BLANKS                                                    
     C     P10DSPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CAMPS DEL FMT P10                 *                                
      *------------------------------------------------------------*                                
     C     P10CMD        BEGSR                                                                      
     C                   EVAL      ZXOPT2='CHK'                                                     
      *VALIDACIONES TECLAS DE FUNCION                                                               
     C                   SELECT                                                                     
      * FINALITZAR EL PROGRAMA                                                                      
     C                   WHEN      EXIT=*ON                                                         
     C                   EVAL      ZXOPT1='END'                                                     
      * SOL·LICITUD AJUDA D'ARTICLES                                                                
     C                   WHEN      HELP=*ON                                                         
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   EXSR      CS_POCUR2                                                        
     C                   EXSR      P10F4                                                            
                                                                                                    
     C                   WHEN      RETRO=*ON                                                        
     C                   EVAL      ZXOPT1='END'                                                     
     C                   ENDSL                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CAMPS DEL FMT P10                 *                                
      *------------------------------------------------------------*                                
     C     P10CHK        BEGSR                                                                      
     C                   EVAL      ZXOPT2='UPD'                                                     
     C                   EVAL      XACIAS=@PCIAS                                                    
     C                   EVAL      XADLG2=P10DLG2                                                   
     C                   EVAL      XADLGA=P10DLGA                                                   
     C     KMSDDOM       CHAIN     MSDDOM                             81                            
     C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   EVAL      WRK31=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP10CHK                                            
      * LA DELEGACIÓN DEBE EXISTIR                                                                  
      *                                                                                             
     C                   IF        P10DLG2='*ALL'                                                   
     C                   ELSE                                                                       
     C                   EVAL      PECIAS=@PCIAS                                                    
     C                   EVAL      PECTAB='DLGA'                                                    
     C                   EVAL      PECLTA=P10DLG2                                                   
     C     KPMTABD       CHAIN (N) PMTABD                             81                            
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP10CHK                                            
     C                   EVAL      ZXDESC=PEDESC                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C     TP10CHK       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C     P10CHKT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE ACTUALIZACION DATOS DE  P10                   *                                
      *------------------------------------------------------------*                                
     C     P10UPD        BEGSR                                                                      
      * PASA A LAS PANTALLAS P2X                                                                    
     C                   EVAL      ZXOPT='P2ACLR'                                                   
     C*                  EVAL      PECLTA=P10DLGA                                                   
     C                   EVAL      XADLGA=P10DLGA                                                   
      *                                                                                             
     C                   IF        P10DLG2='*ALL'                                                   
     C                   EVAL      PECIAS=@PCIAS                                                    
     C                   EVAL      PECTAB='DLGA'                                                    
     C     KPMTABD_S     SETLL     PMTABD                                                           
     C     KPMTABD_S     READE     PMTABD                                                           
     C                   DOW       NOT%EOF                                                          
     C                   EVAL      XADLG2=PECLTA                                                    
     C                   EVAL      XADLGA=P10DLGA                                                   
     C     KMSDDOM       CHAIN     MSDDOM                             81                            
     C                   IF        NOT%FOUND                                                        
     C     *NOKEY        CLEAR                   RMSDDOM                                            
     C                   EVAL      XAMO01=P7MONE                                                    
     C                   EVAL      XAMO02=P7MONE                                                    
     C                   EVAL      XAMO04=P7MONE                                                    
     C                   EVAL      XAMO03=P7MONE                                                    
     C                   WRITE     RMSDDOM                                                          
     C                   ENDIF                                                                      
     C     KPMTABD_S     READE     PMTABD                                                           
     C                   ENDDO                                                                      
     C                   EVAL      ZXOPT='ENDEND'                                                   
     C                   ENDIF                                                                      
      *                                                                                             
     C     P10UPDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL FMT P2A                              *                                
      *------------------------------------------------------------*                                
     C     P2AMAIN       BEGSR                                                                      
     C                   EVAL      ZXOPT1='P2A'                                                     
     C                   DOW       ZXOPT1='P2A'                                                     
     C     ZXOPT2        CASEQ     'CLR'         P2ACLR                                             
     C     ZXOPT2        CASEQ     'INZ'         P2AINZ                                             
     C     ZXOPT2        CASEQ     'DSP'         P2ADSP                                             
     C     ZXOPT2        CASEQ     'CMD'         P2ACMD                                             
     C     ZXOPT2        CASEQ     'CHK'         P2ACHK                                             
     C     ZXOPT2        CASEQ     'UPD'         P2AUPD                                             
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA LIMPIEZA  DE P2A                                 *                                
      *------------------------------------------------------------*                                
     C     P2ACLR        BEGSR                                                                      
     C                   EVAL      ZXOPT2='INZ'                                                     
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO10      *IN(60)                                            
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C                   MOVE      *BLANKS       MSGER                                              
     C     P2ACLRT       ENDSR                                                                      
      *                                                                                             
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ DEL FMT P2A                       *                                
      *------------------------------------------------------------*                                
     C     P2AINZ        BEGSR                                                                      
      *                                                                                             
     C                   EVAL      ZXOPT2='DSP'                                                     
     C     *NOKEY        CLEAR     *ALL          RMSDDOM                                            
     C     KMSDDOM       CHAIN     MSDDOM                             81                            
     C                   IF        *IN81=*ON                                                        
     C                   EVAL      ZXCLAB=XADLG2                                                    
     C                   EVAL      PECLTA=*BLANKS                                                   
     C     KMSDDOM0      CHAIN     MSDDOM                             81                            
     C                   if        p30DLG2 <> *blanks                                               
     C                   EVAL      PECLTA=p30DLG2                                                   
     C     KMSDDOM       CHAIN     MSDDOM                             81                            
     C                   endif                                                                      
     C                   EVAL      PECLTA=ZXCLAB                                                    
     C                   EVAL      XADLG2=ZXCLAB                                                    
     C                   ENDIF                                                                      
     C                   EXSR      P2AMFP                                                           
      * En el caso de altas se pasan los valores por defecto de PURLDA                              
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PASAR DE FICHERO A PANTALLA P2A                  *                                
      *------------------------------------------------------------*                                
     C     P2AMFP        BEGSR                                                                      
      *                                                                                             
      *                                                                                             
     C                   EVAL      P2ADLGA=XADLGA                                                   
