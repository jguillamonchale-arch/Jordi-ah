     A            G1MODE         6          TEXT('Modelo')                                          
     A                                      COLHDG('Modelo')                                        
     A            G1CALI         2          TEXT('Calidad')                                         
     A                                      COLHDG('Calidad')                                       
     A            G1SACT        15P 5       TEXT('Stk. fisico')                                     
     A                                      COLHDG('Stk. fisico')                                   
     A                                      EDTCDE(4)                                               
     A                                      REFFLD(PRDLIB/CANT                                      
     A                                             PRDLIB)                                          
     A            G1SKRE        15P 5       TEXT('Stk. reservado')                                  
     A                                      COLHDG('Stk. reservado')                                
     A                                      EDTCDE(4)                                               
     A                                      REFFLD(PRDLIB/CANT                                      
     A                                             PRDLIB)                                          
