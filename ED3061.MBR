F-2OL /free                                                                                         
        dcl-s pPointer pointer;                                                                     
        dcl-s pDsPgmOL pointer;                                                                     
        dcl-ds DsPgmOL based(pDsPgmOL);                                                             
              zoldl like(M0MAGA);                                                                   
              loEdl like(M0LOGE) ;                                                                  
              loSdl like(M0LOGS) ;                                                                  
              zolem like(M0MAGA);                                                                   
              loEem like(M0LOGE) ;                                                                  
              loSem like(M0LOGS) ;                                                                  
              zolgc like(M0MAGA);                                                                   
              loEgc like(M0LOGE) ;                                                                  
              loSgc like(M0LOGS) ;                                                                  
              zolgm like(M0MAGA);                                                                   
              loEgm like(M0LOGE) ;                                                                  
              loSgm like(M0LOGS) ;                                                                  
              zolgt like(M0MAGA);                                                                   
              loEgt like(M0LOGE) ;                                                                  
              loSgt like(M0LOGS) ;                                                                  
        end-ds;                                                                                     
        dcl-pr pgmOL   extpgm('MM1410');                                                            
           xCIAS   like(@PECIAS) const;   // cia                                                    
           xDLGA   like(@PEDLGA) const;   // delega                                                 
           xptr    pointer       ;        // pointer                                                
        end-pr;                                                                                     
F-2OL /end-free                                                                                     
       dcl-s cresp like(@peresp);                                                                   
