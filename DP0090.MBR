79419c                   eval      zxDlgaTr = *blanks                                               
79419 *                                                                                             
79419c                   Eval      File_PMTABD = %Trim(PPBICC) + '/PMTABD  '                        
79419c                   Eval      File_MSALMA = %Trim(PPBICC) + '/MSALMA  '                        
79419 *                                                                                             
79419c                   Open(E)   PMTABD                                                           
79419c                   Open(E)   MSALMA                                                           
79419 *                                                                                             
79419c                   If        Not %ERROR                                                       
79419c                   Eval      PECIAS = M5CIAS                                                  
79419c                   Eval      PECTAB = 'INO2'                                                  
79419c                   Eval      PECLTA = 'MAGA'                                                  
79419c     KPmtabd       Chain     Pmtabd                                                           
79419c                   if        %found(Pmtabd)                                                   
79419c                   movel(p)  pedesc        zxMagaTr                                           
79419c                   Eval      M0CIAS = M5CIAS                                                  
79419c                   Eval      M0MAGA = zxMagaTr                                                
79419c     KMsalma       Chain     Msalma                                                           
79419c                   if        %found(Msalma)                                                   
79419c                   movel(p)  m0dlga        zxDlgaTr                                           
79419c                   if        m0dlga =  *blanks and                                            
79419c                             m0m003 <> *blanks                                                
79419c                   movel(p)  m0m003        zxDlgaTr                                           
79419c                   endif                                                                      
79419c                   endif                                                                      
79419c                   endif                                                                      
79419c                   endif                                                                      
79419 *                                                                                             
79419 * Buscamos la clasificación en función del método de replanificación                          
79419c                   Eval      File_MSSTOK = %Trim(PPBICC) + '/MSSTOK  '                        
79419c                   Eval      File_MSSTST = %Trim(PPBICC) + '/MSSTST  '                        
79419 *                                                                                             
79419c                   Open(E)   MSSTOK                                                           
79419c                   Open(E)   MSSTST                                                           
79419 *                                                                                             
79419c                   if        Not %ERROR                                                       
79419 *                                                                                             
79419c                   If        %subst(ppampl:6:1) = '1'                                         
79419 *===  Por Propuesta de compra                                                                 
79419c                   Eval      M1CIAS = M5CIAS                                                  
79419c                   Eval      M1MAGA = zxMagaTr                                                
79419c                   Eval      M1ARTI = M5ARTI                                                  
79419c                   Eval      M1VARI = M5VARI                                                  
79419c                   Eval      M1MODE = M5MODE                                                  
79419c     KMsstok       Chain     Msstok                                                           
79419c                   if        %found(Msstok)                                                   
79419c                   eval      @PCLAS = M1CROT                                                  
79419c                   endif                                                                      
79419 *                                                                                             
79419c                   else                                                                       
79419 *===  Por MRP                                                                                 
79419c                   Eval      M6CIAS = M5CIAS                                                  
79419c                   Eval      M6ARTI = M5ARTI                                                  
79419c                   Eval      M6VARI = M5VARI                                                  
79419c                   Eval      M6MODE = M5MODE                                                  
79419c                   if        zxFABOL = *on                                                    
79419c                   Eval      M6DLGA = *blanks                                                 
79419c                   Eval      M6NETL = 2                                                       
79419c                   Else                                                                       
79419c                   Eval      M6DLGA = zxDlgaTr                                                
79419c                   Eval      M6NETL = 1                                                       
79419c                   endif                                                                      
79419c     KMsstst       Chain     Msstst                                                           
79419c                   if        %found(Msstst) And m6omit <> '1'                                 
79419c                   eval      @PCLAS = M6CLAS                                                  
79419c                   endif                                                                      
79419 *                                                                                             
79419c                   endif                                                                      
79419c                   endif                                                                      
79419 *                                                                                             
79419c                   Close(E)  MSSTOK                                                           
79419c                   Close(E)  MSSTST                                                           
79419c                   Close(E)  PMTABD                                                           
79419c                   Close(E)  MSALMA                                                           
79419 *                                                                                             
79419c                   Endsr                                                                      
C1489 **************************************************************                                
C1489 * CARREGA DE LA BIBLIOTECA DE MOVEX DEL PARÀMETRE            *                                
C1489 *------------------------------------------------------------*                                
C1489C     CS_EXTFILE    BEGSR                                                                      
C1489C*                                                                                             
C1489C                   EVAL      PECTAB='A400'                                                    
C1489C                   EVAL      PECLTA='AQA'                                                     
C1489C     KPMTAB2       CHAIN     PMTAB2                                                           
C1489C                   IF        %FOUND(PMTAB2)                                                   
C1489C                   EVAL      FILE_BIBAQA=%TRIM(PEDESC)                                        
C1489C                   ENDIF                                                                      
C1489C                   EVAL      PECLTA='MVX'                                                     
C1489C     KPMTAB2       CHAIN     PMTAB2                                                           
C1489C                   IF        %FOUND(PMTAB2)                                                   
C1489C                   EVAL      FILE_BIBMVX=%TRIM(PEDESC)                                        
C1489C                   ENDIF                                                                      
C1489C                   EVAL      PECLTA='M3A'                                                     
C1489C     KPMTAB2       CHAIN     PMTAB2                                                           
C1489C                   IF        %FOUND(PMTAB2)                                                   
C1489C                   EVAL      FILE_BIBM3A=%TRIM(PEDESC)                                        
C1489C                   ENDIF                                                                      
C1489C                   EVAL      PECLTA='M3E'                                                     
C1489C     KPMTAB2       CHAIN     PMTAB2                                                           
C1489C                   IF        %FOUND(PMTAB2)                                                   
C1489C                   EVAL      FILE_BIBM3E=%TRIM(PEDESC)                                        
C1489C                   ENDIF                                                                      
C1489 *                                                                                             
I0184C                   EVAL       FILE_ZAQITN00=%TRIM(FILE_BIBAQA)+                               
I0184C                                            %TRIM(FILE_ZAQITN00)                              
I0184C                   EVAL       FILE_GMTABD01=%TRIM(FILE_BIBAQA)+                               
I0184C                                            %TRIM(FILE_GMTABD01)                              
I0184C                   EVAL       FILE_CFACIL00=%TRIM(FILE_BIBM3E)+                               
I0184C                                            %TRIM(FILE_CFACIL00)                              
C1489C                   EVAL       FILE_ZAQBAL00=%TRIM(FILE_BIBAQA)+                               
C1489C                                            %TRIM(FILE_ZAQBAL00)                              
C1489C                   EVAL       FILE_AQPEDI00=%TRIM(FILE_BIBAQA)+                               
C1489C                                            %TRIM(FILE_AQPEDI00)                              
C1489C                   EVAL       FILE_MITBAL10=%TRIM(FILE_BIBM3E)+                               
C1489C                                            %TRIM(FILE_MITBAL10)                              
C1489C                   EVAL       FILE_MITFAC00=%TRIM(FILE_BIBM3E)+                               
C1489C                                            %TRIM(FILE_MITFAC00)                              
C1489C                   EVAL       FILE_CMNDIV00=%TRIM(FILE_BIBM3E)+                               
C1489C                                            %TRIM(FILE_CMNDIV00)                              
C1489C*                                                                                             
C1489C     CS_EXTFILET   ENDSR                                                                      
C1489 **************************************************************                                
I0184 * OBTENER PLANTA PARA ACCEDER A DATOS DEL ARTÍCULO                                            
I0184 ******************************************************************************************    
I0184 *                                                                                             
I0184P GET_FACI        B                                                                            
I0184D GET_FACI        PI                  LIKE(MMCIAS)                                             
I0184D   @DIVI                             LIKE(MMPROP) VALUE                                       
I0184D   @FACI                             LIKE(MMCIAS) VALUE                                       
I0184D   @ITNO                             LIKE(MMITNO) VALUE                                       
I0184 *                                                                                             
I0184C                   IF        ZXMULTIPLA                                                       
I0184 *                                                                                             
I0184 * Si existe registro en ZAQITN en el que la división es propietaria, entonces                 
I0184 * se devuelve la planta propietaria del artículo.                                             
I0184 *                                                                                             
I0184C                   EVAL      MMITNO = @ITNO                                                   
I0184C     KZAQITN00     CHAIN     ZAQITN00                                                         
I0184C                   IF        %FOUND  AND  MMPROP = @DIVI  AND                                 
I0184C                             MMCIAS <> *BLANKS                                                
I0184C                   RETURN    MMCIAS                                                           
I0184C                   ENDIF                                                                      
I0184 *                                                                                             
I0184 * Si la división no es la propietaria, se hace bucle sobre la tabla FACP y                    
I0184 * se devuelve la primera para la que exista MITFAC                                            
I0184 *                                                                                             
I0184C                   MOVEL(P)  MXCONO        M9CONO                                             
I0184C                   EVAL      M9ITNO = @ITNO                                                   
I0184 *                                                                                             
I0184C                   EVAL      T1CTAB = 'FACP'                                                  
I0184C                   EVAL      T1DESC = @DIVI                                                   
I0184C     KGMTABD01     SETLL     GMTABD01                                                         
I0184C     KGMTABD01     READE     GMTABD01                                                         
I0184 *                                                                                             
I0184C                   DOW       NOT %EOF                                                         
I0184 *                                                                                             
I0184C                   EVAL      M9FACI = T1CELE                                                  
I0184C     KMITFAC00     SETLL     MITFAC00                                                         
I0184C                   IF        %EQUAL                                                           
I0184C                   RETURN    M9FACI                                                           
I0184C                   ENDIF                                                                      
I0184 *                                                                                             
I0184C     KGMTABD01     READE     GMTABD01                                                         
I0184C                   ENDDO                                                                      
I0184 *                                                                                             
I0184C                   ENDIF                                                                      
I0184 *                                                                                             
I0184 * Si la división no es multiplanta, o la búsqueda anterior no ha dado frutos,                 
I0184 * devolver la planta entrada                                                                  
I0184 *                                                                                             
I0184C                   RETURN    @FACI                                                            
I0184 *                                                                                             
I0184P                 E                                                                            
