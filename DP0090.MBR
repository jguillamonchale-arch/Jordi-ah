79419 **************************************************************                                
79419 * BUSCAR CLASIFICACION EMPRESA AS400                         *                                
79419 *------------------------------------------------------------*                                
79419c     CS_CLAS_AS    Begsr                                                                      
79419c                   eval      @PCLAS = *blanks                                                 
79419 *                                                                                             
79419 * Miramos nivel de red de la empresa (Si trabaja con FAB/OL)                                  
79419 *                                                                                             
79419c                   eval      zxFABOL = *off                                                   
79419c                   If        %subst(ppampl:46:1) = '1'                                        
79419c                   eval      zxFABOL = *on                                                    
79419c                   endif                                                                      
79419 *                                                                                             
79419 * Buscamos el almacén de Trace y la delegación del almacén de Trace                           
79419 *                                                                                             
