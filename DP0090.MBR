      **************************************************************                                
      * SUBRUTINA PRINCIPAL                                        *                                
      *------º-----------------------------------------------------*                                
     C     PROCESO       BEGSR                                                                      
     C                   EXSR      CS_CIAL                                                          
     C                   EXSR      CS_PROD                                                          
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PRINCIPAL                                        *                                
      *------º-----------------------------------------------------*                                
     C     CS_CIAL       BEGSR                                                                      
     C                   OPEN(E)   MSARTI00                                                         
     C                   EVAL      M5CIAS=@PCIAS                                                    
     C                   EVAL      M5ARTI=@PARTI                                                    
     C                   EVAL      M5VARI=@PVARI                                                    
     C                   EVAL      M5MODE=@PMODE                                                    
     C     KMSARTI00     CHAIN     MSARTI00                                                         
     C                   EVAL      C0CIAS=M5CIAS                                                    
     C                   EVAL      C0PRVR=M5PRVR                                                    
     C     KPUPROV       CHAIN     PUPROV                                                           
     C                   IF        %SUBST(C0AMP2:2:5)='00000'                                       
     C                   EVAL      ZXCIAS=%SUBST(C0AMP2:8:11)                                       
                                                                                                    
     C                   EVAL      Q1CIAS=M5CIAS                                                    
     C                   EVAL      Q1ARVM=@PARTI+@PVARI+@PMODE                                      
     C     KGXEQAR       CHAIN     GXEQAR                                                           
     C                                                                                              
     C                   ENDIF                                                                      
     C                   CLOSE     MSARTI00                                                         
08835                                                                                               
08835C                   CLEAR                   ZXLOGE            3                                
08835C                   IF        %PARMS>7                                                         
08835C                   EVAL      ZXLOGE=@PLOGE                                                    
08835C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PRINCIPAL                                        *                                
      *------º-----------------------------------------------------*                                
     C     CS_PROD       BEGSR                                                                      
     C                   EVAL      EQMCOD='DIVI'                                                    
     C                   EVAL      EQACOD='CIAS'                                                    
     C                   EVAL      EQACIA=0                                                         
     C                   MOVEL     ZXCIAS        ZXAVAL                                             
     C                   EVAL      EQAVAL=ZXAVAL                                                    
     C                   MOVEL     ZXAVAL        EQAVAL                                             
     C     KEQTABL10     CHAIN     EQTABL10                                                         
     C                   MOVEL     EQMVAL        ZXCIA2                                             
     C                   MOVEL     ZXCIA2        Q1CIAS                                             
     C     KGXEQAR03     CHAIN     GXEQAR03                                                         
Q0367C                   IF        %found(GXEQAR03)and Q1FBAJ<>0                                    
Q0367C     KGXEQAR03     READE     GXEQAR03                                                         
Q0367C                   DOW       NOT %EOF(GXEQAR03)                                               
Q0367C                   IF        Q1FBAJ=0                                                         
Q0367C                   LEAVE                                                                      
Q0367C                   ENDIF                                                                      
Q0367C     KGXEQAR03     READE     GXEQAR03                                                         
Q0367C                   ENDDO                                                                      
Q0367C                   ENDIF                                                                      
     C                   MOVEL     ZXCIA2        PPCIAS                                             
     C     PPCIAS        CHAIN     PMLIBL                                                           
     C                   IF        %SUBST(PPBL10:9:1)='V'                                           
     C                   EXSR      CS_CLAS_MVX                                                      
     C                   ELSE                                                                       
     c                   Eval      File_MSARTI00 = %Trim(PPBICC) +                                  
     c                                              '/MSARTI00'                                     
     C                   OPEN(E)   MSARTI00                                                         
     C                   EVAL      M5CIAS=Q1CIAS                                                    
     C                   EVAL      M5ARTI=%SUBST(Q1ARVM:1:15)                                       
     C                   EVAL      M5VARI=%SUBST(Q1ARVM:16:3)                                       
     C                   EVAL      M5MODE=%SUBST(Q1ARVM:19:3)                                       
C1666C     KMSARTI00     CHAIN     MSARTI00                                                         
C1666C*    KMSARTI00     SETLL     MSARTI00                                                         
C1666C*    KMSARTI00     READE     MSARTI00                                                         
C1666C*                  DOW       NOT%EOF(MSARTI00) AND M5BAJA<>'1'                                
C1666C*    KMSARTI00     READE     MSARTI00                                                         
C1666C*                  ENDDO                                                                      
C1666C                   IF        %FOUND                                                           
C1666C*                  IF        NOT %EOF(MSARTI00)                                               
79419C**                 EVAL      @PCLAS=%SUBST(M5AMPL:60:2)                                       
79419C                   exsr      CS_CLAS_AS                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   EVAL      C9CIAS=Q1CIAS                                                    
     C                   EVAL      C9ITEM=Q1ARVM                                                    
     C     KDPMART02     CHAIN     DPMART02                                                         
     C                   IF        %FOUND                                                           
     C                   EVAL      @PENTO=C9ENTO                                                    
     C     C9ENTO        CHAIN     DPMENT                                                           
     C                   EVAL      @PENTD=C0DESC                                                    
                                                                                                    
     C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PRINCIPAL                                        *                                
      *------º-----------------------------------------------------*                                
     C     CS_CLAS_MVX   BEGSR                                                                      
MOVEXC                   MOVEL     PPCIAS        ZXCIAS                                             
MOVEXC                   MOVEL     ZXCIAS        @PEDIVI                                            
MOVEXC                   CALL      'GX0150'                                                         
MOVEXC                   PARM                    @PEDIVI                                            
MOVEXC                   PARM      *blanks       @PEUSER                                            
MOVEXC                   PARM      *BLANKS       @PEVAL                                             
MOVEXC                   EVAL      ZXVAL=@PEVAL                                                     
     C                   OPEN(E)   ZAQBAL00                                                         
     C                   OPEN(E)   AQPEDI00                                                         
     C                   OPEN(E)   MITFAC00                                                         
