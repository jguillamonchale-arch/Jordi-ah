     C                   OPEN(E)   MITBAL10                                                         
     C                   OPEN(E)   CMNDIV00                                                         
MOVEXC                   MOVEL(P)  MXCONO        Z1CONO                                             
MOVEXC                   MOVEL(P)  MXCONO        MBCONO                                             
MOVEXC                   MOVEL(P)  MXCONO        M9CONO                                             
MOVEXC                   MOVEL(P)  MXCONO        CCCONO                                             
I0184C                   MOVEL(P)  MXCONO        MMCONO                                             
I0184C                   MOVEL(P)  MXCONO        CFCONO                                             
MOVEXC                   MOVEL(P)  MXDIVI        Z1DIVI                                             
     C                   MOVEL(P)  MXDIVI        CCDIVI                                             
      *Recuperar planta de la división(CCFACI)                                                      
     C     KCMNDIV00     CHAIN     CMNDIV00                                                         
I0184c**                 EVAL      M9FACI=CCFACI                                                    
     C     KAQPEDI00     CHAIN     AQPEDI00                                                         
I0184c**                 EVAL      MBWHLO=Z1WHLO                                                    
I0184 * Ver si estamos en una división Multiplanta                                                  
I0184C                   EVAL      ZXMULTIPLA = %FOUND(AQPEDI00)                                    
I0184C                                          AND  Z1L101 = '1'                                   
I0184C                   EVAL      M9FACI = GET_FACI(MXDIVI:CCFACI:Q1ARVM)                          
     C                   EVAL      M9ITNO=Q1ARVM                                                    
     C     KMITFAC00     CHAIN     MITFAC00                                                         
79419C*I0184                EVAL      CFFACI=M9FACI                                                 
79419C*I0184  KCFACIL00     CHAIN     CFACIL00                                                      
79419c*I0184                EVAL      MBWHLO=CFWHLO                                                 
79419c                   EVAL      MBWHLO=Z1WHLO                                                    
08835                                                                                               
08835C                   IF        ZXLOGE<>*BLANKS                                                  
08835C                   EVAL      PECIAS=@PCIAS                                                    
08835C                   EVAL      PECTAB='INO2'                                                    
08835C                   EVAL      PECLTA='MAGA'+ZXLOGE                                             
08835 *                                                                                             
08835C                   Eval      File_PMTABD = 'PMTABD  '                                         
