30056 **************************************************************                                
30056 * SUBRUTINA PASAR A HISTORICO LA MODIFICACION                *                                
30056 *------------------------------------------------------------*                                
30056C     CS_COHCON     BEGSR                                                                      
30056 *                                                                                             
30056C                   EVAL      SWCIAS=S5CIAS                                                    
30056C                   EVAL      SWDLGA=S5DLGA                                                    
30056C                   EVAL      SWNPCO=S5NPCO                                                    
30056C                   EVAL      SWTPED=S5TPED                                                    
30056C                   EVAL      SWDATP=S5DATP                                                    
30056C                   EVAL      SWNOPL=S5NOPL                                                    
30056C                   EVAL      SWLINP=S5LINE                                                    
                                                                                                    
30056C                   EVAL      SWDAT1=ZZDATS                                                    
30056C                   IF        SWDAT1=0                                                         
30056C                   EVAL      SWDAT1=*DATE                                                     
30056C                   ENDIF                                                                      
30056C                   TIME                    SWHORA                                             
30056C     *NOKEY        CLEAR     *ALL          RCOHCON                                            
30056C                   DOW       CHAIN=*OFF                                                       
30056C     KCOHCON       CHAIN     COHCON                             81                            
30056C                   IF        CHAIN=*OFF                                                       
30056C                   EVAL      SWHORA=SWHORA+1                                                  
30056C                   ENDIF                                                                      
30056C                   ENDDO                                                                      
                                                                                                    
30056C                   IF        CHAIN=*ON                                                        
30056C                   EVAL      SWFRRE=S5FRRE                                                    
25051C                   EVAL      SWFRR2=S5FRRE                                                    
30056C                   EVAL      SWDT1C=S5DT1C                                                    
30056C                   EVAL      SWDT2C=S5DT2C                                                    
30056C                   EVAL      SWDT3C=S5DT3C                                                    
30056C                   EVAL      SWDT4C=S5DT4C                                                    
30056C                   EVAL      SWCANC=S5CANC                                                    
30056C                   EVAL      SWUNIM=S5UNIM                                                    
30056C                   EVAL      SWPRCC=S5PRCC                                                    
30056C                   EVAL      SWMONC=S5MONC                                                    
30056C                   EVAL      SWCADC=S5CADC                                                    
30056C                   EVAL      SWUNDC=S5UNDC                                                    
30056C                   EVAL      SWJOBP=ZZPANT                                                    
30056C                   EVAL      SWTRAB=ZZUSUA                                                    
30056C                   EVAL      SWCAUS=*BLANKS                                                   
                                                                                                    
30056C                   EVAL      SWPANT=ZZPANT                                                    
30056C                   EVAL      SWUSUA=ZZUSUA                                                    
30056C                   EVAL      SWDAT8=SWDAT1                                                    
                                                                                                    
30056C                   WRITE     RCOHCON                                                          
                                                                                                    
30056C                   ENDIF                                                                      
                                                                                                    
30056C                   ENDSR                                                                      
14066* ================================================================== *                        
14066* SUBRUTINA DE CALCULA DE COSTES ADICIONALES.                        *                        
14066* ================================================================== *                        
14066C     CS_MSACOS     BEGSR                                                                      
14066C                   EVAL      NMCIAS=ZZCIAS                                                    
14066C                   EVAL      NMARTI=S5ARTI                                                    
14066C                   EVAL      NMVARI=S5VARI                                                    
14066C                   EVAL      NMMODE=S5MODE                                                    
14066C                   EVAL      NMTCOJ=*BLANKS                                                   
14066C                   EVAL      NMMAGA=*BLANKS                                                   
14066                                                                                               
14066C                   EVAL      READ1=*OFF                                                       
14066C     KMSACOS       SETLL     MSACOS                                                           
14066C     KMSACOS       READE     MSACOS                                 83                        
14066C                   DOW       READ1=*OFF                                                       
14066*Solo cargar conceptos que estén activos                                                      
14066C                   EVAL      PECIAS=S5CIAS                                                    
14066C                   EVAL      PECTAB='CCOS'                                                    
14066C                   EVAL      PECLTA=NMCLTA                                                    
14066C     KPMTABD       CHAIN     PMTABD                                                           
14066C                   IF        %FOUND(PMTABD) AND PEBAJA<'1'                                    
14066C                   IF        NMCOAD='1'                                                       
14066C                   SELECT                                                                     
14066C                   WHEN      M5TCOS = '0'                                                     
14066C                   EVAL      ZXCOST = ZXCOST + (                                              
14066C                               M5COSU * NMCOSU / 100) * S5CANT * ZXCOCAM3                     
14066C                   WHEN      M5TCOS = '1'                                                     
14066C                   EVAL      ZXCOST = ZXCOST + (                                              
14066C                               M5COSP * NMCOSP / 100) * S5CANT * ZXCOCAM3                     
14066C                   WHEN      M5TCOS = '2'                                                     
14066C                   EVAL      ZXCOST = ZXCOST + (                                              
14066C                               M5COSM * NMCOSM / 100) * S5CANT * ZXCOCAM3                     
14066C                   ENDSL                                                                      
14066C                   ELSE                                                                       
14066C                   SELECT                                                                     
14066C                   WHEN      M5TCOS = '0'                                                     
Q0006C*                  EVAL      ZXCOST = ZXCOST + M5COSU + (NMCOSU * S5CANT)                     
Q0006C                   EVAL      ZXCOST = ZXCOST          + (NMCOSU * S5CANT)                     
14066C                                      * ZXCOCAM3                                              
14066C                   WHEN      M5TCOS = '1'                                                     
Q0006C*                  EVAL      ZXCOST = ZXCOST + M5COSP + (NMCOSP * S5CANT)                     
Q0006C                   EVAL      ZXCOST = ZXCOST          + (NMCOSP * S5CANT)                     
14066C                                      * ZXCOCAM3                                              
14066C                   WHEN      M5TCOS = '2'                                                     
Q0006C*                  EVAL      ZXCOST = ZXCOST + M5COSM + (NMCOSM * S5CANT)                     
Q0006C                   EVAL      ZXCOST = ZXCOST          + (NMCOSM * S5CANT)                     
14066C                                      * ZXCOCAM3                                              
14066C                   ENDSL                                                                      
14066C                   ENDIF                                                                      
14066C                   ENDIF                                                                      
14066C     KMSACOS       READE     MSACOS                                 83                        
14066C                   ENDDO                                                                      
14066C                   ENDSR                                                                      
                                                                                                    
14066 **************************************************************                                
14066 * SUBRUTINA CALCULO COSTES ADICIONALES                         *                              
14066 *------------------------------------------------------------*                                
14066C     CS_COSADI     BEGSR                                                                      
14066C                   EVAL      ZXCOST = 0                                                       
14066C                   EXSR      CS_ZXCOCA3                                                       
14066                                                                                               
14066C                   EVAL      S5CIAS = S0CIAS                                                  
14066C                   EVAL      S5DLGA = S0DLGA                                                  
14066C                   EVAL      S5NPCO = S0NPCO                                                  
14066C                   EVAL      S5TPED = S0TPED                                                  
14066C                   EVAL      S5DATP = S0DATP                                                  
14066C                   EVAL      S5NOPL = S0NOPL                                                  
14066C     KCODEPE       SETLL     CODEPE                                                           
14066C     KCODEPE       READE     CODEPE                                                           
14066C                   DOW       NOT %EOF                                                         
14066                                                                                               
14066C     KMSARTI00     CHAIN     MSARTI00                                                         
14066C                   IF        %FOUND                                                           
14066C                   SELECT                                                                     
14066C                   WHEN      M5TCOS = '0'                                                     
14066C                   EVAL      ZXCOST = ZXCOST +(M5COSU * S5CANT) * ZXCOCAM3                    
14066C                   WHEN      M5TCOS = '1'                                                     
14066C                   EVAL      ZXCOST = ZXCOST +(M5COSP * S5CANT) * ZXCOCAM3                    
14066C                   WHEN      M5TCOS = '2'                                                     
14066C                   EVAL      ZXCOST = ZXCOST +(M5COSM * S5CANT) * ZXCOCAM3                    
14066C                   ENDSL                                                                      
14066                                                                                               
14066C                   EXSR      CS_MSACOS                                                        
14066C                   ENDIF                                                                      
14066C     KCODEPE       READE     CODEPE                                                           
14066C                   ENDDO                                                                      
14066                                                                                               
14066C                   ENDSR                                                                      
                                                                                                    
14066 **************************************************************                                
14066 * SUBRUTINA CLACULO DE COEFICIENTE DE CAMBIO                   *                              
14066 *------------------------------------------------------------*                                
14066C     CS_ZXCOCA3    BEGSR                                                                      
14066C                   EVAL      @PDATA=S5DATP                                                    
14066C                   TIME                    @PHORA                                             
14066C                   IF        @PDATA=*ZEROS                                                    
14066C                   EVAL      @PDATA=ZZDATS                                                    
14066C                   ENDIF                                                                      
14066* Busco el primer cambio existente al comenzar Enero a las 12 horas                           
14066* si se desean cambios en el momento de entrada                                               
14066                                                                                               
14066C                   IF        MCTFHV='1'                                                       
14066C                   EVAL      @PDATA=ZZDATS                                                    
14066C                   ENDIF                                                                      
14066                                                                                               
14066C                   IF        @PDATA=*ZEROS                                                    
14066C                   EVAL      @PDATA=*DATE                                                     
14066C                   ENDIF                                                                      
14066                                                                                               
14066C                   EVAL      ZXCOCAM3=1                                                       
14066C                   IF        ZZMONE <> S0MONE                                                 
14066C                   CALL      'MM2555'                                                         
14066C                   PARM                    @PCIAS                                             
14066C                   PARM      ZZMONE        @PMON1                                             
14066C                   PARM      S0MONE        @PMON2                                             
14066C                   PARM                    @PDATA                                             
14066C                   PARM                    @PHORA                                             
14066C                   PARM      0             @PCMCOCO                                           
14066C                   PARM      0             @PCMCCCO                                           
14066C                   PARM      *BLANKS       @PEERR                                             
14066C                   EVAL      ZXCOCAM3=@PCMCCCO                                                
14066C                   ENDIF                                                                      
14066                                                                                               
14066C                   ENDSR                                                                      
                                                                                                    
04098 **************************************************************                                
04098 * SUBRUTINA CALCULO DIFERENCIAS RENDIMIENTO.                 *                                
04098 **************************************************************                                
04098C     CS_CHKRDTO    BEGSR                                                                      
04098C                   SETOFF                                       1012                          
04098C                   EVAL      WRK48 = (ZZABRD = '1')                                           
04098C                   EVAL      ZXCOST=*ZEROS                                                    
04098C                   EVAL      ZXCOCAMB=1                                                       
04098C                   EXSR      CS_ZXCOCAM                                                       
04098C                   EXSR      CS_CMDCIM                                                        
17069C                   EVAL      PXNUM=*ZEROS                                                     
17069C                   IF        ZXVNET<>0                                                        
04098C                   EVAL      PXNUM=(1-(ZXCOST/ZXVNET))*100                                    
17069C                   ENDIF                                                                      
04098C                   IF        PXNUM < ZXRDMI                                                   
04098C                   EVAL      PXALPH=*BLANKS                                                   
04098C                   CALL      'PRD650'                                                         
04098C                   PARM                    PXNUM                                              
04098C                   PARM                    PXALPH                                             
04098C                   PARM                    PXFLDD                                             
04098C                   PARM      0             PXDCCD                                             
04098C                   PARM                    PXFMD1                                             
04098C                   PARM      'Q'           PXEDTC                                             
04098C                   PARM                    PXNMER                                             
04098C                   PARM                    PXTIPA                                             
04098C                   EVAL      W04RDTOP = %TRIM(PXALPH)                                         
04098C                   EVAL      W04RDTOE = ZZRDMI                                                
04098C                   EVAL      W04NPCO  = S0NPCO                                                
04098C                   EVAL      SUFOPCI=*BLANKS                                                  
04098C                   EVAL      SFLNXC=*OFF                                                      
04098C                   DOW       NOT *IN10 AND NOT *IN12                                          
04098C                   EXFMT     W04                                                              
04098C                   ENDDO                                                                      
04098* Si pulsan F10 y el rendimiento es inferior al definido, bloquearemos el pedido.             
04098C                   IF        NOT *IN12 AND WRK48 = '1'                                        
04098C                   EVAL      ERRGRL = *ON                                                     
04098C                   ENDIF                                                                      
04098C                   ENDIF                                                                      
04098C                   ENDSR                                                                      
                                                                                                    
04098 **************************************************************                                
04098 * SUBRUTINA RECALCULO IMPORTES                               *                                
04098 **************************************************************                                
04098C     CS_RECALC     BEGSR                                                                      
04098C                   MOVE      SDSJNBR       ZXJNBR                                             
04098C                   MOVE      UDATE         ZXDATA                                             
04098C                   TIME                    ZXHORA                                             
04098 *                                                                                             
04098C                   CLEAR                   Z1COMA                                             
04098C     DSLDA         CAT(P)    Z1COMA:0      Z1COMA                                             
04098C                   Z-ADD     86            JOLINE                                             
04098C                   CALL      'PRD935'                                                         
04098C                   PARM                    JOTRAT                                             
04098C                   PARM                    JOLINE                                             
04098C                   PARM                    Z1COMA                                             
04098 *                                                                                             
04098C                   MOVE      @PCIAS        @PECIAS2                                           
04098C                   EVAL      X5CIAS=S0CIAS                                                    
04098C                   EVAL      X5DLGA=S0DLGA                                                    
04098C                   EVAL      X5NPCO=S0NPCO                                                    
04098C                   EVAL      X5DATP=S0DATP                                                    
04098C                   EVAL      X5TPED=S0TPED                                                    
04098C                   EVAL      X5NOPL=S0NOPL                                                    
04098C                   CLEAR                   Z1COMA                                             
04098C     CO2540        CAT       Z1COMA:0      Z1COMA                                             
04098C                   EVAL      JOLINE=88                                                        
04098C                   CALL      'PRD935'                                                         
04098C                   PARM                    JOTRAT                                             
04098C                   PARM                    JOLINE                                             
04098C                   PARM                    Z1COMA                                             
04098                                                                                               
04098C                   EVAL      @PEPRG2='CO2540    '                                             
04098                                                                                               
04098C                   Z-ADD     150           ZXLOGC           15 5                              
04098C                   MOVE      *BLANKS       ZXQCM2          150                                
04098C     ZXQCM2        CAT       'CALL (':0    ZXQCM2                                             
04098C     ZXQCM2        CAT       'PRDGJ8':0    ZXQCM2                                             
04098C     ZXQCM2        CAT       'CL)':0       ZXQCM2                                             
04098C     ZXQCM2        CAT       'PARM(':1     ZXQCM2                                             
04098C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
04098C     ZXQCM2        CAT       JOTRAT:0      ZXQCM2                                             
04098C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
04098C     ZXQCM2        CAT       C(1):1        ZXQCM2                                             
04098C     ZXQCM2        CAT       @PEPRG2:0     ZXQCM2                                             
04098C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
04098C     ZXQCM2        CAT       C(1):1        ZXQCM2                                             
04098C     ZXQCM2        CAT       C(1):1        ZXQCM2                                             
04098C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
04098                                                                                               
