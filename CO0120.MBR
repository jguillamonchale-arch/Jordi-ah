     C     CS_VALRSK     BEGSR                                                                      
     C                   EVAL      S0CIAS=SUFCIAS                                                   
     C                   EVAL      S0DLGA=SUFDLGA                                                   
     C                   EVAL      S0NPCO=SUFNPCO                                                   
     C                   EVAL      S0TPED=SUFTPED                                                   
     C                   EVAL      S0NOPL=SUFNOPL                                                   
     C                   EVAL      S0DATP=SUFDATP                                                   
     C     KCOCAPE       CHAIN(N)  COCAPE                             81                            
     C                   EVAL      PECLTA=S0FPAG                                                    
     C                   EVAL      PECIAS=SUFCIAS                                                   
     C                   EVAL      PECTAB='FPAG'                                                    
     C     KPMTABD       CHAIN     PMTABD                             81                            
     C     KCOCLIN       CHAIN     COCLIN                             81                            
     C                   IF        S0CRIS='1' AND PEBL61='1'                                        
     C                   CALL      'CM2520'                                                         
     C                   PARM      SUFCIAS       @PECIAS                                            
     C                   PARM      S0CUST        @PECUST                                            
     C                   PARM      SUFDLGA       @PEDLGA                                            
     C                   PARM      SUFNPCO       @PENPCO                                            
     C                   PARM      SUFTPED       @PETPED                                            
     C                   PARM      SUFDATP       @PEDATP                                            
     C                   PARM      SUFNOPL       @PENOPL                                            
     C                   PARM      'A'           @PERRO                                             
