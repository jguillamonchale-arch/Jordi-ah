     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='6'                                                       
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      ZXOPT1='S06'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='7'                                                       
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      ZXOPT1='S07'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='8'                                                       
