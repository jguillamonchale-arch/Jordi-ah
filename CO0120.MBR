86909 **************************************************************                                
86909 * SUBRUTINA DE validacion de Bloque Financiero               *                                
86909 * Si Cias tien Parm Dias activado                            *                                
86909 *   (seria para el caso que el pedido en status 10     -----*                                 
86909 *    no tuviese correctamente el S0PHLD como Financiero     *                                 
86909 *------------------------------------------------------------*                                
86909C     CS_VALFIN     BEGSR                                                                      
86909C*                                                                                             
86909C                   DOU       LCKRCD=*OFF                                                      
86909C     KCOCAPE       CHAIN     COCAPE                             8180                          
86909C                   ENDDO                                                                      
86909C*                                                                                             
86909C                   IF        CHAIN=*OFF                                                       
86909C                   IF        S0PHLD<>'3' OR S0PHLD<>'4'                                       
86909C*                                                                                             
86909C                   eval      s0rexc = ' '                                                     
86909C                   eval      s0raut = ' '                                                     
86909C                   eval      s0phld = '3'                                                     
86909C                   IF        S0PHLD='1'                                                       
86909C                   eval      s0phld = '4'                                                     
86909C                   ELSE                                                                       
86909C                   eval      s0phld = '3'                                                     
86909C                   endif                                                                      
86909C*                                                                                             
PGE21C                   EVAL      S0DAT8=*DATE                                                     
PGE21C                   TIME                    S0HORA                                             
PGE21C                   EVAL      S0USUA=SDSUSR                                                    
86909C                   UPDATE    RCOCAPE                                                          
86909 *                                                                                             
86909C     KCOCAPE       SETLL     CODEPE                                                           
86909C     KCOCAPE       READE     CODEPE                                                           
86909C                   DOW       NOT %EOF(CODEPE)                                                 
86909C                   EVAL      S5PHLD=S0PHLD                                                    
PGE21C                   EVAL      S5DAT8=*DATE                                                     
PGE21C                   TIME                    S5HORA                                             
PGE21C                   EVAL      S5USUA=SDSUSR                                                    
86909C                   UPDATE    RCODEPE                                                          
86909C     KCOCAPE       READE     CODEPE                                                           
86909C                   ENDDO                                                                      
86909C*                                                                                             
86909C                   endif                                                                      
86909C                   endif                                                                      
86909C*                                                                                             
86909C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE validacion de INCIDENCIAS                     *                                
      *------------------------------------------------------------*                                
     C     CS_VALINC     BEGSR                                                                      
     C                   CALL      'CO2530'                                                         
     C                   PARM      SUFCIAS       @PECIAS                                            
     C                   PARM      SUFDLGA       @PEDLGA                                            
     C                   PARM      SUFNPCO       @PENPCO                                            
     C                   PARM      SUFTPED       @PETPED                                            
     C                   PARM      SUFDATP       @PEDATP                                            
     C                   PARM      SUFNOPL       @PENOPL                                            
     C                   PARM      *BLANKS       @PERRO                                             
     C                   IF        @PERRO>='1'                                                      
FQ876C                   IF        @PTIPJ='1'                                                       
     C                   EXFMT     W03                                                              
FQ876C                   ENDIF                                                                      
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE SELECCIONA REGISTROS DE SUBARCHIVO           *                                
      *------------------------------------------------------------*                                
     C     CS_SCAN       BEGSR                                                                      
     C                   MOVEA     PSUDES1       SSSDES1                                            
     C                   Z-ADD     1             ZXS1              3 0                              
     C                   Z-ADD     1             ZXS2              3 0                              
     C                   Z-ADD     1             ZXS3              3 0                              
     C                   Z-ADD     1             ZXS4              3 0                              
     C     '*'           LOOKUP    SSSDES1(ZXS1)                          81                        
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      ZXS2=ZXS1+1                                                      
     C                   EVAL      ZXS3=ZXS1+1                                                      
     C     '*'           LOOKUP    SSSDES1(ZXS2)                          81                        
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      ZXS4=ZXS2-1                                                      
     C                   Z-ADD     0             ZXS1              3 0                              
     C     ZXS3          DO        ZXS4          ZXS2                                               
     C                   EVAL      ZXS1=ZXS1+1                                                      
     C                   EVAL      SSSDES2(ZXS1)=SSSDES1(ZXS2)                                      
     C                   ENDDO                                                                      
     C                   EVAL      ZXS1=ZXS4-ZXS3+1                                                 
     C                   MOVEA     SSSDES2       PSUDES1                                            
     C                   IF        PSUDES1<>*BLANKS                                                 
     C                   EXSR      CS_SCANF                                                         
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C     SCANT         ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE SELECCIONA REGISTROS DE SUBARCHIVO           *                                
      *------------------------------------------------------------*                                
     C     CS_SCANF      BEGSR                                                                      
                                                                                                    
     C                   EXSR      CS_RSTFK                                                         
                                                                                                    
     C     KCOCAPE02A    SETGT     COCAPE02                                                         
     C     KCOCAPE020    READE     COCAPE02                               81                        
     C                   DOW       CHAIN=*OFF                                                       
     C     PSUDES1:ZXS1  SCAN      S0DES1                                 81                        
     C                   IF        CHAIN=*ON                                                        
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
     C     KCOCAPE020    READE     COCAPE02                               81                        
     C                   ENDDO                                                                      
                                                                                                    
     C                   EVAL      PSUDES1=S0DES1                                                   
                                                                                                    
     C     SCANFT        ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE LIMPIA COSTES                                *                                
      *------------------------------------------------------------*                                
     C     CS_ZZNPG2     BEGSR                                                                      
     C                   EVAL      S13COST=*ALL'*'                                                  
     C                   EVAL      S13BETE=*ALL'*'                                                  
     C                   EVAL      S13REND=*ALL'*'                                                  
     C                   EVAL      S23COST=*ALL'*'                                                  
     C                   EVAL      S23BETE=*ALL'*'                                                  
     C                   EVAL      S23REND=*ALL'*'                                                  
     C                   EVAL      S33COST=*ALL'*'                                                  
     C                   EVAL      S33BETE=*ALL'*'                                                  
     C                   EVAL      S33REND=*ALL'*'                                                  
     C                   EVAL      S43COST=*ALL'*'                                                  
     C                   EVAL      S43BETE=*ALL'*'                                                  
     C                   EVAL      S43REND=*ALL'*'                                                  
     C                   EVAL      S53COST=*ALL'*'                                                  
     C                   EVAL      S53BETE=*ALL'*'                                                  
     C                   EVAL      S53REND=*ALL'*'                                                  
     C                   EVAL      S63COST=*ALL'*'                                                  
     C                   EVAL      S63BETE=*ALL'*'                                                  
     C                   EVAL      S63REND=*ALL'*'                                                  
     C                   EVAL      S73COST=*ALL'*'                                                  
     C                   EVAL      S73BETE=*ALL'*'                                                  
     C                   EVAL      S73REND=*ALL'*'                                                  
     C                   EVAL      S83COST=*ALL'*'                                                  
     C                   EVAL      S83BETE=*ALL'*'                                                  
     C                   EVAL      S83REND=*ALL'*'                                                  
     C                   EVAL      S93COST=*ALL'*'                                                  
     C                   EVAL      S93BETE=*ALL'*'                                                  
     C                   EVAL      S93REND=*ALL'*'                                                  
     C                   ENDSR                                                                      
      **************************************************************                                
      * Busca nueva situación del SFL.                             *                                
      *------------------------------------------------------------*                                
     C     CS_ROLLDOWN   BEGSR                                                                      
                                                                                                    
     C                   RESET                   ZXLOP00                                            
     C                   RESET                   ZXLIPAG                                            
     C                   EVAL      ZXCOUNT=1                                                        
                                                                                                    
     C                   IF        SFLDROP=*OFF                                                     
     C                   EVAL      ZXLIPAG=ZXLIPAG*2                                                
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        ZXSEMF=*BLANKS                                                   
     C                   EVAL      ZXLIPAG=ZXLIPAG+1                                                
     C                   ENDIF                                                                      
                                                                                                    
     C                   SELECT                                                                     
     C                   WHEN      CCCFMT='1'                                                       
     C                   EXSR      CS_SETGT01                                                       
     C                   WHEN      CCCFMT='2'                                                       
     C                   EXSR      CS_SETGT02                                                       
     C                   WHEN      CCCFMT='3'                                                       
     C                   EXSR      CS_SETGT03                                                       
     C                   WHEN      CCCFMT='4'                                                       
     C                   EXSR      CS_SETGT04                                                       
     C                   WHEN      CCCFMT='5'                                                       
     C                   EXSR      CS_SETGT05                                                       
     C                   WHEN      CCCFMT='6'                                                       
     C                   EXSR      CS_SETGT06                                                       
     C                   WHEN      CCCFMT='7'                                                       
     C                   EXSR      CS_SETGT07                                                       
     C                   WHEN      CCCFMT='8'                                                       
     C                   EXSR      CS_SETGT08                                                       
     C                   WHEN      CCCFMT='9'                                                       
     C                   EXSR      CS_SETGT09                                                       
21031C                   WHEN      CCCFMT='A'                                                       
21031C                   EXSR      CS_SETGT10                                                       
     C                   ENDSL                                                                      
                                                                                                    
     C                   DOW       ZXLOP00 < ZXLIPAG                                                
     C                   SELECT                                                                     
     C                   WHEN      CCCFMT='1'                                                       
     C                   EXSR      CS_REDP01                                                        
     C                   WHEN      CCCFMT='2'                                                       
     C                   EXSR      CS_REDP02                                                        
     C                   WHEN      CCCFMT='3'                                                       
     C                   EXSR      CS_REDP03                                                        
     C                   WHEN      CCCFMT='4'                                                       
     C                   EXSR      CS_REDP04                                                        
     C                   WHEN      CCCFMT='5'                                                       
     C                   EXSR      CS_REDP05                                                        
     C                   WHEN      CCCFMT='6'                                                       
     C                   EXSR      CS_REDP06                                                        
     C                   WHEN      CCCFMT='7'                                                       
     C                   EXSR      CS_REDP07                                                        
     C                   WHEN      CCCFMT='8'                                                       
     C                   EXSR      CS_REDP08                                                        
     C                   WHEN      CCCFMT='9'                                                       
     C                   EXSR      CS_REDP09                                                        
21031C                   WHEN      CCCFMT='A'                                                       
21031C                   EXSR      CS_REDP10                                                        
     C                   ENDSL                                                                      
                                                                                                    
     C                   IF        EOF=*ON                                                          
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
     C                   EXSR      CS_SELSFL                                                        
     C                   IF        ZXSELSFL=1                                                       
     C                   GOTO      TNEXDOWN                                                         
     C                   ENDIF                                                                      
     C                   EVAL      ZXDLGA=S0DLGA                                                    
     C                   EVAL      ZXCUST=S0CUST                                                    
     C                   EVAL      ZXNPCO=S0NPCO                                                    
     C                   EVAL      ZXTPED=S0TPED                                                    
     C                   EVAL      ZXFPED=S0FPED                                                    
     C                   EVAL      ZXDES1=S0DES1                                                    
     C                   EVAL      ZXCLAB=S0CLAB                                                    
     C                   EVAL      ZXFREP=S0FREP                                                    
     C                   EVAL      ZXREFE=S0REFE                                                    
     C                   EVAL      ZXLOP00=ZXLOP00+1                                                
     C     TNEXDOWN      TAG                                                                        
     C                   ENDDO                                                                      
     C                                                                                              
     C                   IF        ZXSEMF=*BLANKS AND                                               
     C                             EOF=*ON        AND                                               
     C                             ZXLOP00=1                                                        
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MSG0114'                                                  
     C                   ENDIF                                                                      
     C                   EVAL      ZXCOMCAR=0                                                       
     C                   EXSR      CS_SAVFK                                                         
     C                   EVAL      ZXSEMF=*BLANKS                                                   
                                                                                                    
     C                   ENDSR                                                                      
