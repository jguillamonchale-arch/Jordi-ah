     C                   EVAL      ZXOPT2='CLR'                                                     
     C                   IF        CCCFMT=' '                                                       
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      ZXOPT1='S01'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='0'                                                       
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      ZXOPT1='S01'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='1'                                                       
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      ZXOPT1='S01'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='2'                                                       
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      ZXOPT1='S02'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='3'                                                       
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      ZXOPT1='S03'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='4'                                                       
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      ZXOPT1='S04'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='5'                                                       
     C                   EXSR      CS_CLRK                                                          
