     C                   EVAL      PPPCMD1='CMD3041'                                                
     C                   ENDIF                                                                      
     C                   EVAL      SUFHED1='HCO1200'                                                
     C                   SELECT                                                                     
     C                   WHEN      ZXNUMVI=1                                                        
     C                   EVAL      SUFHED1='HCO1200'                                                
     C                   WHEN      ZXNUMVI=2                                                        
