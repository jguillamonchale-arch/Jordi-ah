     C                   EVAL      S0TPED=SUFTPED                                                   
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPE       CHAIN     COCAPE                             8180                          
     C                   ENDDO                                                                      
FQ365C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      S0REXC='1'                                                       
FQ365C                   MOVEL     *DATE         S0RCON                                             
07049C                   EVAL      S0PEPE = MCPEPE                                                  
07049C                   EVAL      S0GEXP = MCGEXP                                                  
07049C                   EVAL      S0NPIC = MCNPIC                                                  
07049C                   EVAL      S0LPED = MCLPED                                                  
