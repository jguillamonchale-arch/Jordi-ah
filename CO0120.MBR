FQ284 **************************************************************                                
FQ284 * Rutina Base para Fluidra direct                            *                                
FQ284 **************************************************************                                
FQ284C     FD_BASE       BEGSR                                                                      
FQ284 *                                                                                             
FQ284 * Determinar el tipo de empresa en la que estoy                                               
FQ284 *                                                                                             
FQ284C                   SELECT                                                                     
FQ284 * Comercial                                                                                   
FQ284C                   WHEN      S0PPED<>'99' AND ZZALOL<'1'                                      
FQ284C                   EVAL      @FDORIG=0                                                        
FQ284 * Productiva                                                                                  
FQ284C                   WHEN      S0PPED='99' AND ZZALOL<'1'                                       
FQ284C                   EVAL      @FDORIG=2                                                        
FQ284 * Trace                                                                                       
FQ284C                   WHEN      ZZALOL='1'                                                       
FQ284C                   EVAL      @FDORIG=3                                                        
FQ284 *                                                                                             
FQ284C                   ENDSL                                                                      
FQ284 *                                                                                             
FQ284C                   ENDSR                                                                      
