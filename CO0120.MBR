      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * GUARDO LA CLAU DE POSICIONAMENT DEL PRIMER REGISTRE DESPRES*                                
      * DE LA NETEJA DEL SUBARXIU                                  *                                
      *------------------------------------------------------------*                                
     C     CS_SAVFK      BEGSR                                                                      
     C                   IF        ZXCOMCAR=0                                                       
                                                                                                    
     C                   EVAL      ZXNPCO_1=S0NPCO                                                  
     C                   EVAL      ZXDLGA_1=S0DLGA                                                  
     C                   EVAL      ZXCUST_1=S0CUST                                                  
     C                   EVAL      ZXTPED_1=S0TPED                                                  
     C                   EVAL      ZXFLAN_1=S0FLAN                                                  
     C                   EVAL      ZXFPED_1=S0FPED                                                  
     C                   EVAL      ZXFREP_1=S0FREP                                                  
     C                   EVAL      ZXDES1_1=S0DES1                                                  
     C                   EVAL      ZXCLAB_1=S0CLAB                                                  
     C                   EVAL      ZXREFE_1=S0REFE                                                  
     C                   EVAL      ZXCOMCAR=1                                                       
                                                                                                    
     C                   ENDIF                                                                      
     C     CS_SAVFKT     ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA INICIALITZACIÓ DEL SFL  (2ª PART)                *                                
      *------------------------------------------------------------*                                
     C     CS_SFLIN2     BEGSR                                                                      
     C                   EVAL      ZXNNN00=ZXNRR00                                                  
     C                   EVAL      SUFRCDN=ZXNRR00                                                  
     C                   EVAL      ACCREF=*ON                                                       
     C                   IF        EOF=*ON                                                          
     C                   EVAL      SFLEND=*ON                                                       
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        ZXNRR00=0                                                        
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C                   EVAL      SFLDSP=*OFF                                                      
     C                   ELSE                                                                       
     C                   EVAL      SFLDSP=*ON                                                       
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        ZXCOUNT>ZXNNN00                                                  
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C                   ENDIF                                                                      
     C     SFLIN2T       ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA VALIDACIÓ DELS CMD'S                             *                                
      *------------------------------------------------------------*                                
     C     CS_SFLCMD     BEGSR                                                                      
     C                   IF        VLDCMDKEY=*OFF                                                   
     C                   GOTO      SFLCMDT                                                          
     C                   ENDIF                                                                      
     C                   EVAL      ACCREF=*ON                                                       
     C                   EXSR      CS_SECCMD                                                        
     C     ERRGRL        CABEQ     *ON           SFLCMDT                                            
      * Si han pulsado F20 encenderé el REFRES para realizar dicha                                  
      * función que se encargará de poner la nueva vista                                            
      * F20=TREBALLAR AMB VISTAS.Cambio la vista segun F20.                                         
     C                   IF        INDVIS=*ON                                                       
     C                   EXSR      CS_CMDVIS                                                        
     C                   ENDIF                                                                      
     C                                                                                              
     C                   SELECT                                                                     
      * F03=SORTIR DEL PROGRAMA                                                                     
     C                   WHEN      EXIT=*ON                                                         
     C                   EVAL      ZXOPT1='END'                                                     
      * F04=AJUDA DE PANTALLA                                                                       
     C                   WHEN      HELP=*ON                                                         
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   EXSR      CS_POSCUR                                                        
     C                   EVAL      ACCREF=*OFF                                                      
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEFMT=RECORD                                                    
     C                   EVAL      @PEFLD=FIELD                                                     
                                                                                                    
01   * RENED Recherche des clients (begin)                                                         
02  C                   IF        FIELD='PSUCUS1'                                                  
02  C                   CALL      'CO0650'                                                         
02  C                   PARM                    @PCIAS                                             
02  C                   PARM      *BLANKS       @PCUST1                                            
02  C                   PARM      *BLANKS       @PEERR                                             
03  C                   IF        @PCUST1<>PSUCUS1                                                 
03  C                   EVAL      PSUCUS1=@PCUST1                                                  
03  C                   EVAL      ZXOPT2='CHK'                                                     
03  C                   ENDIF                                                                      
02  C                   ENDIF                                                 F                    
02  C                   IF        FIELD='PSUCUS2'                                                  
02  C                   CALL      'CO0650'                                                         
02  C                   PARM                    @PCIAS                                             
02  C                   PARM      *BLANKS       @PCUST1                                            
02  C                   PARM      *BLANKS       @PEERR                                             
03  C                   IF        @PCUST1<>PSUCUS2                                                 
03  C                   EVAL      PSUCUS2=@PCUST1                                                  
03  C                   EVAL      ZXOPT2='CHK'                                                     
03  C                   ENDIF                                                                      
02  C                   ENDIF                                                 F                    
02  C                   IF        FIELD='PSUCUS8'                                                  
02  C                   CALL      'CO0650'                                                         
02  C                   PARM                    @PCIAS                                             
02  C                   PARM      *BLANKS       @PCUST1                                            
02  C                   PARM      *BLANKS       @PEERR                                             
03  C                   IF        @PCUST1<>PSUCUS8                                                 
03  C                   EVAL      PSUCUS8=@PCUST1                                                  
03  C                   EVAL      ZXOPT2='CHK'                                                     
03  C                   ENDIF                                                                      
02  C                   ENDIF                                                 F                    
02  C                   IF        FIELD='PSUCUS9'                                                  
02  C                   CALL      'CO0650'                                                         
02  C                   PARM                    @PCIAS                                             
02  C                   PARM      *BLANKS       @PCUST1                                            
02  C                   PARM      *BLANKS       @PEERR                                             
03  C                   IF        @PCUST1<>PSUCUS9                                                 
03  C                   EVAL      PSUCUS9=@PCUST1                                                  
03  C                   EVAL      ZXOPT2='CHK'                                                     
03  C                   ENDIF                                                                      
02  C                   ENDIF                                                 F                    
01   * RENED Recherche des clients (end)                                                           
     C                   IF        FIELD='CCCFMT'                                                   
     C                   EVAL      @PEFMT=*BLANKS                                                   
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEFLD='CFMT'                                                    
     C                   ENDIF                                                                      
     C                   IF        FIELD='SUFOPCI'                                                  
     C                   EVAL      @PEFMT=*BLANKS                                                   
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEFLD='OPCI      '                                              
     C                   ENDIF                                                                      
01   * RENED Recherche des clients (begin)                                                         
02  C                   IF        FIELD<>'PSUCUS1' AND FIELD<>'PSUCUS2' AND                        
02  C                             FIELD<>'PSUCUS8' AND FIELD<>'PSUCUS9'                            
01   * RENED Recherche des clients (end)                                                           
     C                   CALL      'MMPROM'                                                         
     C                   PARM      *BLANKS       @PEOPT                                             
     C                   PARM      SDSPGM        @PEPGM                                             
     C                   PARM                    @PEFMT                                             
     C                   PARM                    @PEFLD                                             
     C                   PARM      *BLANKS       @PEERR                                             
      * RENED F4 sur Clients                                                                        
02  C                   ENDIF                                                                      
      ***                                                                                           
      * Si el dato no tiene soporte F4 avisamos                                                     
     C                   IF        @PEERR>'0'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK40=*ON                                                        
     C                   EVAL      MSGER='ADP0304'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           HELPT                                              
      * Si no han realizado ninguna selección no tocamos nada                                       
     C                   IF        @PEERR='A'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           HELPT                                              
     C                   IF        FIELD='CCCFMT'                                                   
     C*                  EVAL      ERRGRL=*ON                                                       
     C                   EVAL      CCCFMT=@PEOPT                                                    
     C                   ENDIF                                                                      
     C                   IF        FIELD='SUFOPCI'                                                  
     C*                  EXSR      CS_POSCUR                                                        
     C                   EVAL      ZXNRR00=SFLPOS1+CSRFILA-9                                        
     C                   IF        SFLDROP=*ON                                                      
     C                   EVAL      ZXNRR00=SFLPOS1+(CSRFILA-9)/2                                    
     C                   ENDIF                                                                      
     C     ZXNRR00       CHAIN     SUFD                               81                            
     C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      SUFOPCI=@PEOPT                                                   
     C                   EVAL      SFLNXC=*ON                                                       
     C                   UPDATE    SUFD                                                             
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     HELPT         TAG                                                                        
     C     ERRGRL        CABEQ     *ON           SFLCMDT                                            
     C                   EXSR      CS_CLRK                                                          
     C                   IF        ZXFMT<>CCCFMT                                                    
     C                   EVAL      ACCREF=*ON                                                       
     C                   EVAL      ZXCOUNT=1                                                        
     C     CCCFMT        CASEQ     ' '           S01CLR                                             
     C     CCCFMT        CASEQ     '0'           S01CLR                                             
     C     CCCFMT        CASEQ     '1'           S01CLR                                             
     C     CCCFMT        CASEQ     '2'           S02CLR                                             
     C     CCCFMT        CASEQ     '3'           S03CLR                                             
     C     CCCFMT        CASEQ     '4'           S04CLR                                             
     C     CCCFMT        CASEQ     '5'           S05CLR                                             
     C     CCCFMT        CASEQ     '6'           S06CLR                                             
     C     CCCFMT        CASEQ     '7'           S07CLR                                             
     C     CCCFMT        CASEQ     '8'           S08CLR                                             
     C     CCCFMT        CASEQ     '9'           S09CLR                                             
21031C     CCCFMT        CASEQ     'A'           S10CLR                                             
     C                   CAS                     S01CLR                                             
     C                   ENDCS                                                                      
     C                   ENDIF                                                                      
      * F05=REFRESCAR PANTALLA                                                                      
     C                   WHEN      REFRES=*ON                                                       
     C                   EXSR      CS_RSTFK                                                         
     C                   EVAL      ZXOPT2='CLR'                                                     
      * F06=CREAR REGISTRE                                                                          
     C                   WHEN      CREATE=*ON                                                       
     C                   EVAL      @PEOPT='1 '                                                      
     C                   CALL      'CO0121'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM                    @PEDLGA                                            
     C                   PARM      @PCUST        @PECUST                                            
FQ937C****************** PARM                    @PENPCO                                            
FQ937C                   PARM      *BLANKS       @PENPCO                                            
     C                   PARM      @PTPE2        @PETPED                                            
FQ937C****************** PARM                    @PEDATP                                            
FQ937C                   PARM      *ZEROS        @PEDATP                                            
FQ937C****************** PARM                    @PENOPL                                            
FQ937C                   PARM      *ZEROS        @PENOPL                                            
     C                   PARM      '1 '          @PEOPT                                             
     C                   PARM      *BLANKS       @PEERR                                             
     C                   EXSR      CS_RSTFK                                                         
     C                   EVAL      ZXOPT2='CLR'                                                     
      * F13=SETUP DEL PROGRAMA                                                                      
     C                   WHEN      SETUP=*ON                                                        
     C                   EVAL      ZXOPT='PA0CLR'                                                   
     C                   EVAL      ZXCOUNT=SFLPOS1                                                  
      * F14=TREBALLAR AMB EL SPOOL                                                                  
     C                   WHEN      WRKSPL=*ON                                                       
     C                   EVAL      ACCREF=*OFF                                                      
     C                   CLEAR                   ZXQCMD                                             
     C                   EVAL                    ZXQCMD='WRKSPLF'                                   
     C                   CALL      'QCMDEXC'                                                        
     C                   PARM                    ZXQCMD                                             
     C                   PARM                    ZXLOGC                                             
      * F16=TREBALLAR AMB TREBALLS SOTMESOS                                                         
     C                   WHEN      WRKSBM=*ON                                                       
     C                   EVAL      ACCREF=*OFF                                                      
     C                   CLEAR                   ZXQCMD                                             
     C                   EVAL                    ZXQCMD='WRKSBMJOB'                                 
     C                   CALL      'QCMDEXC'                                                        
     C                   PARM                    ZXQCMD                                             
     C                   PARM                    ZXLOGC                                             
      * F22=TREBALLAR AMB TRANSCRIPTORS                                                             
     C                   WHEN      WRKWTR=*ON                                                       
     C                   EVAL      ACCREF=*OFF                                                      
     C                   CLEAR                   ZXQCMD                                             
     C                   EVAL                    ZXQCMD='WRKWTR'                                    
     C                   CALL      'QCMDEXC'                                                        
     C                   PARM                    ZXQCMD                                             
     C                   PARM                    ZXLOGC                                             
      * PAGINAR                                                                                     
     C                   WHEN      ROLLUP=*ON                                                       
     C                   EVAL      ACCREF=*OFF                                                      
     C                   EVAL      ZXOPT2='INZ'                                                     
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
      * PAGINAR                                                                                     
     C                   WHEN      ROLLDOWN=*ON                                                     
     C                   EVAL      ZXSEMF=*BLANKS                                                   
     C                   EXSR      CS_RSTFK                                                         
     C                   EXSR      CS_ROLLDOWN                                                      
     C                   EVAL      ACCREF=*OFF                                                      
     C                   EVAL      ZXOPT2='CLR'                                                     
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C                   ENDSL                                                                      
                                                                                                    
     C     SFLCMDT       TAG                                                                        
     C                   IF        ERRGRL=*ON AND ACCREF=*ON                                        
     C                   EVAL      ACCREF=*OFF                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ZXLIPAG=ZXLIPA2                                                  
     C                   IF        SFLDROP=*OFF                                                     
     C                   EVAL      ZXLIPAG=ZXLIPA2*2                                                
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA VALIDACIÓ DEL SFL: FORMAT SFL I OPCIONS          *                                
      *------------------------------------------------------------*                                
     C     CS_SFLCHK     BEGSR                                                                      
     C                   EVAL      ACCREF=*ON                                                       
      * Validación del posicionamiento de cabecera                                                  
     C                   EVAL      PSUDLGA=PSUDLG1                                                  
      *                                                                                             
     C                   IF        CCCFMT='1'                                                       
     C                   EVAL      PSUCUST=PSUCUS1                                                  
     C                   EVAL      PSUTPED=PSUTPE1                                                  
     C                   EVAL      PSUFPED=PSUFPE1                                                  
     C                   EVAL      PSUFREP=*BLANKS                                                  
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='2'                                                       
     C                   EVAL      PSUDES1=PSUDESB                                                  
     C                   EVAL      PSUTPED=PSUTPED                                                  
     C                   EVAL      PSUFPED=PSUFPE2                                                  
     C                   EVAL      PSUFREP=*BLANKS                                                  
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='3'                                                       
     C                   EVAL      PSUCLAB=PSUCLA1                                                  
     C                   EVAL      PSUTPED=PSUTPE3                                                  
     C                   EVAL      PSUFPED=PSUFPE3                                                  
     C                   EVAL      PSUFREP=*BLANKS                                                  
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='4'                                                       
     C                   EVAL      PSUCUST=PSUCUS2                                                  
     C                   EVAL      PSUTPED=PSUTPE4                                                  
     C                   EVAL      PSUFREP=PSUFRE4                                                  
     C                   EVAL      PSUFPED=*BLANKS                                                  
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='5'                                                       
     C                   EVAL      PSUDES1=PSUDES2                                                  
     C                   EVAL      PSUTPED=PSUTPE5                                                  
     C                   EVAL      PSUFREP=PSUFRE5                                                  
     C                   EVAL      PSUFPED=*BLANKS                                                  
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='6'                                                       
     C                   EVAL      PSUCLAB=PSUCLA2                                                  
     C                   EVAL      PSUTPED=PSUTPE6                                                  
     C                   EVAL      PSUFREP=PSUFRE6                                                  
     C                   EVAL      PSUFPED=*BLANKS                                                  
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='7'                                                       
     C                   EVAL      PSUTPED=PSUTPE7                                                  
     C                   EVAL      PSUFPED=*BLANKS                                                  
     C                   ENDIF                                                                      
                                                                                                    
21031C                   IF        CCCFMT='A'                                                       
21031C                   EVAL      PSUTPED=PSUTPEA                                                  
21031C                   EVAL      PSUFPED=*BLANKS                                                  
21031C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='8'                                                       
     C                   EVAL      PSUFREP=PSUFRE8                                                  
     C                   EVAL      PSUCUST=PSUCUS8                                                  
     C                   EVAL      PSUTPED=PSUTPE8                                                  
     C                   EVAL      PSUFPED=*BLANKS                                                  
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='9'                                                       
     C                   EVAL      PSUREFE=PSUREFE                                                  
     C                   EVAL      PSUCUST=PSUCUS9                                                  
     C                   EVAL      PSUTPED=PSUTPE9                                                  
     C                   EVAL      PSUFREP=*BLANKS                                                  
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        (PSUCUST <> *BLANKS OR PSUTPED<>*BLANKS                          
     C                             OR PSUDES1 <> *BLANKS                                            
     C                             OR PSUCLAB <> *BLANKS                                            
     C                             OR PSUREFE <> *BLANKS                                            
     C                             OR PSUFPED <> *BLANKS                                            
     C                             OR PSUFREP <> *BLANKS                                            
     C                             OR PSUNPCO <> *BLANKS)                                           
     C                             OR (PSUDLGA <> *BLANKS AND                                       
     C                                INDPDLG=*OFF)                                                 
     C                   IF        PSUREFE<>*BLANKS                                                 
     C                   EVAL                    @PVAN=*ZEROS                                       
     C                   CALL      'MM2510'                                                         
     C                   PARM                    @PVAN                                              
     C                   PARM      PSUREFE       @PVAA                                              
     C                   PARM      ZZFMFF        @PFMI                                              
     C                   PARM      ZZFMFF        @PFMF                                              
     C                   PARM      ZZFMFS        @PSEP                                              
     C                   PARM      ' '           @PEERR                                             
     C                   IF        @PEERR<>*BLANKS                                                  
     C                   EVAL      ZXFMT=CCCFMT                                                     
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK45=*ON                                                        
     C                   EVAL      MSGER='MSG0065'                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           SFLCHKT                                            
     C                   EVAL      ZXFLAN=@PVAN                                                     
                                                                                                    
     C                   IF        PSUFPED<>*BLANKS                                                 
     C                   EVAL                    @PVAN=*ZEROS                                       
     C                   CALL      'MM2510'                                                         
     C                   PARM                    @PVAN                                              
     C                   PARM      PSUFPED       @PVAA                                              
     C                   PARM      ZZFMFF        @PFMI                                              
     C                   PARM      ZZFMFF        @PFMF                                              
     C                   PARM      ZZFMFS        @PSEP                                              
     C                   PARM      ' '           @PEERR                                             
     C                   IF        @PEERR<>*BLANKS                                                  
     C                   EVAL      ZXFMT=CCCFMT                                                     
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK45=*ON                                                        
     C                   EVAL      MSGER='MSG0065'                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           SFLCHKT                                            
     C                   EVAL      ZXFPED=@PVAN                                                     
                                                                                                    
     C                   IF        PSUFREP<>*BLANKS                                                 
     C                   EVAL                    @PVAN=*ZEROS                                       
     C                   CALL      'MM2510'                                                         
