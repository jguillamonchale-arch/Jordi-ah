FQ876C                   EVAL      SFLDSP=*ON                                                       
FQ876C                   EXSR      CS_CHKOPT                                                        
FQ876C                   IF        ERRGRL=*OFF                                                      
FQ876C                   ENDIF                                                                      
FQ876C                   EVAL      ZXOPT1='END'                                                     
FQ876C     S00CHKT       ENDSR                                                                      
