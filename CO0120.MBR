21031C                   EVAL      SUFDATA=WADATAV3                                                 
21031C                   ENDSL                                                                      
21031                                                                                               
21031C                   EVAL      SUFDAT2=WADAT2                                                   
21031                                                                                               
21031 * busca si tiene observaciones.NIVEL DE CABECERA = 'O'                                        
21031 *                                       DETALLE  = 'I'                                        
21031C                   EVAL      SUFDAT3=*BLANKS                                                  
21031C     KCOOBPE       SETLL     COOBPE                                                           
21031C     KCOOBPE       READE(N)  COOBPE                                 86                        
21031C                   IF        INDBOBS=*OFF                                                     
21031C                   IF        S0LINP=*ZEROS                                                    
21031C                   EVAL      SUFDAT3='O'                                                      
21031C                   ELSE                                                                       
21031C                   EVAL      SUFDAT3='I'                                                      
21031C                   ENDIF                                                                      
21031C                   ENDIF                                                                      
21031C*Marca de impresión                                                                           
21031C                   MOVE      S0MIMP        SUFDAT3                                            
21031C*                                                                                             
                                                                                                    
21031C     S10MFPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE SELECCIONA REGISTROS DE SUBARCHIVO           *                                
      *------------------------------------------------------------*                                
     C     CS_SELSFL     BEGSR                                                                      
     C                   EVAL      ZXSELSFL=0                                                       
     C                   IF        INDPRO1=*ON AND S0CUST<>@PCUST                                   
     C                   EVAL      ZXSELSFL=1                                                       
     C                   GOTO      SELSFLRT                                                         
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        INDPRO2=*ON AND S0TPED<>@PTPED                                   
     C                   EVAL      ZXSELSFL=1                                                       
     C                   GOTO      SELSFLRT                                                         
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        ZXTRAB<>*BLANKS AND S0TRAB<>ZXTRAB                               
     C                   EVAL      ZXSELSFL=1                                                       
     C                   GOTO      SELSFLRT                                                         
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        INDPDLG=*ON                                                      
     C                   IF        ZZDLGA<>S0DLGA                                                   
     C                   EVAL      ZXSELSFL=1                                                       
     C                   GOTO      SELSFLRT                                                         
     C                   ENDIF                                                                      
     C                   ELSE                                                                       
     C*                  IF        ZZDLGA<>*BLANKS                                                  
     C*                  EVAL      VECIAS=S0CIAS                                                    
     C*                  EVAL      VECUST=S0CUST                                                    
     C*                  EVAL      VEDLGA=ZZDLGA                                                    
     C*    KCOCLDL       CHAIN     COCLDL                             81                            
     C*                  IF        CHAIN=*ON                                                        
     C*                  EVAL      ZXSELSFL=1                                                       
     C*                  GOTO      SELSFLRT                                                         
     C*                  ENDIF                                                                      
     C*                  ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
      * SEGUN SELECCION DE RANGO DE LOGISTICAS                                                      
     C                   IF        ZXLOGD<>*BLANKS                                                  
     C                   IF        S0LOGE<ZXLOGD OR S0LOGE>ZXLOGH                                   
     C                   EVAL      ZXSELSFL=1                                                       
     C                   GOTO      SELSFLRT                                                         
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
IT141                                                                                               
IT141C                   IF        ZXAFOT<>*BLANKS                                                  
IT141C                             AND S0ORTP<>ZXAFOT                                               
IT141C                   EVAL      ZXSELSFL=1                                                       
IT141C                   GOTO      SELSFLRT                                                         
IT141C                   ENDIF                                                                      
                                                                                                    
     * Si el usuario es un representante solamente los pedidos en que está                         
     * Se valida solo ZZREPR porque en INPRDLDA se ha validado previamente                         
     * el ZZACLR para rellenar este campo                             ente                         
23024c                   IF        (ZZREPR <> *Zeros)                                               
23024c                   Call      'CO2705'                                                         
23024c                   Parm      *Blanks       @PECust                                            
23024c                   Parm      S0Repr        @PERepr                                            
23024c                   Parm      *Blanks       @PEErr                                             
                                                                                                    
23024c                   If        @PEErr = '1'                                                     
23024c                   Eval      ZXSelSFL = 1                                                     
23024c                   Goto      SelSFLRT                                                         
23024c                   EndIF                                                                      
23024c                   EndIf                                                                      
C0145 * SEGUN SELECCION DE RANGO DE PROCEDENCIA DE PEDIDO                                           
C0145C                   IF        ZXPPDE<>*BLANKS                                                  
C0145C                   IF        S0PPED<ZXPPDE OR S0PPED>ZXPPHA                                   
C0145C                   EVAL      ZXSELSFL=1                                                       
C0145C                   GOTO      SELSFLRT                                                         
C0145C                   ENDIF                                                                      
C0145C                   ENDIF                                                                      
                                                                                                    
     C     SELSFLRT      ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE GUARDA LAS CLAVES DE TODOS TIPOS DE SFL      *                                
      *------------------------------------------------------------*                                
     C     CS_KEYPF      BEGSR                                                                      
     C                   EVAL      SUFDATA=*BLANKS                                                  
     C                   EVAL      SUFDAT2=*BLANKS                                                  
     C                   EVAL      SUFCIAS=S0CIAS                                                   
     C                   EVAL      SUFDLGA=S0DLGA                                                   
     C                   EVAL      SUFNPCO=S0NPCO                                                   
     C                   EVAL      SUFTPED=S0TPED                                                   
     C                   EVAL      SUFDATP=S0DATP                                                   
     C                   EVAL      SUFNOPL=S0nopl                                                   
     C                   EVAL      SUFIDIO=S0IDI1                                                   
     C                   EVAL      SUFCUST=S0CUST                                                   
FQ844 *                                                                                             
FQ844C                   EVAL      SUFDAT4=*BLANKS                                                  
FQ844C                   IF        S0MOST='1'                                                       
FQ844C                   EVAL      SUFDAT4='m'                                                      
FQ844C                   ENDIF                                                                      
FQ844 *                                                                                             
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE CAMBIO DE VISTA ( F20 ).                      *                                
      *------------------------------------------------------------*                                
     C     CS_CMDVIS     BEGSR                                                                      
                                                                                                    
     C                   IF        ZXNUMVI<ZXMAXVI                                                  
     C                   EVAL      ZXNUMVI=ZXNUMVI+1                                                
     C                   ELSE                                                                       
     C                   EVAL      ZXNUMVI=1                                                        
     C                   ENDIF                                                                      
     C                                                                                              
     C                   EVAL      REFRES=*ON                                                       
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * Calcula importes para todas las vistas                     *                                
      *------------------------------------------------------------*                                
     C     CS_CMDCIM     BEGSR                                                                      
                                                                                                    
     C                   EVAL      SYCIAS=S0CIAS                                                    
     C                   EVAL      SYDLGA=S0DLGA                                                    
     C                   EVAL      SYNPCO=S0NPCO                                                    
     C                   EVAL      SYTPED=S0TPED                                                    
     C                   EVAL      SYDATP=S0DATP                                                    
     C                   EVAL      SYNOPL=S0NOPL                                                    
     C                   EVAL      ZXVIVA=0                                                         
     C                   EVAL      ZXVNET=0                                                         
                                                                                                    
     C     KCOCAIM       SETLL     COCAIM                                                           
FQ284C     KCOCAIM       READE(N)  COCAIM                                 84                        
     C                   DOW       READ2=*OFF                                                       
     C                   EVAL      ZXVNET=ZXVNET+SYBIMP                                             
     C                   EVAL      ZXVIVA=ZXVIVA+SYIIV1+SYIIV2                                      
     C                   EXSR      CS_ZXCOCA2                                                       
     C                   EVAL      ZXCOST=ZXCOST+(SYCOST*ZXCOCAM2)                                  
FQ284C     KCOCAIM       READE(N)  COCAIM                                 84                        
     C                   ENDDO                                                                      
                                                                                                    
14066                                                                                               
14066* Si queremos acumular costes adicionales, en lugar de coger el coste del                     
14066* COCAIM, leeremos los artículos del pedido y acumularemos su coste + C.Ad                    
14066C                   IF        MCACOS = '1'                                                     
14066C                   EXSR      CS_COSADI                                                        
14066C                   ENDIF                                                                      
                                                                                                    
      * Los descuentos a utilizar serán los previstos salvo que exista precio co                    
     C                   EVAL      ZXDTO11=S0DTO1                                                   
     C                   EVAL      ZXDTO21=S0DTO2                                                   
     C                   EVAL      ZXDTO31=S0DTO3                                                   
     C                   EVAL      ZXDTO41=S0DTO4                                                   
     C                   IF        S0CAMC<>0                                                        
     C                   EVAL      ZXDTO11=S0DT1C                                                   
     C                   EVAL      ZXDTO21=S0DT1C                                                   
     C                   EVAL      ZXDTO31=S0DT1C                                                   
     C                   EVAL      ZXDTO41=S0DT1C                                                   
     C                   ENDIF                                                                      
      * Trato los dtos sobre pedido                                                                 
     C                   EVAL      XZAUXI=ZXVNET                                                    
      * DTO1                                                                                        
     C                   EVAL      XZAUXI1=XZAUXI*ZXDTO11                                           
     C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
     C                   EVAL      XZAUXI=XZAUXI-XZAUXI1                                            
      * DTO2                                                                                        
     C                   EVAL      XZAUXI1=XZAUXI *ZXDTO21                                          
     C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
     C                   EVAL      XZAUXI =XZAUXI -XZAUXI1                                          
      * DTO3                                                                                        
     C                   EVAL      XZAUXI1=XZAUXI *ZXDTO31                                          
     C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
     C                   EVAL      XZAUXI =XZAUXI -XZAUXI1                                          
      * DTO4                                                                                        
     C                   EVAL      XZAUXI1=XZAUXI *ZXDTO41                                          
     C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
     C                   EVAL      XZAUXI =XZAUXI -XZAUXI1                                          
                                                                                                    
     C                   EVAL(H)   ZXVNET=XZAUXI                                                    
                                                                                                    
     C                   EVAL      XZAUXI=ZXVIVA                                                    
      * DTO1                                                                                        
     C                   EVAL      XZAUXI1=XZAUXI*ZXDTO11                                           
     C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
     C                   EVAL      XZAUXI=XZAUXI-XZAUXI1                                            
      * DTO2                                                                                        
     C                   EVAL      XZAUXI1=XZAUXI *ZXDTO21                                          
     C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
     C                   EVAL      XZAUXI =XZAUXI -XZAUXI1                                          
      * DTO3                                                                                        
     C                   EVAL      XZAUXI1=XZAUXI *ZXDTO31                                          
     C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
     C                   EVAL      XZAUXI =XZAUXI -XZAUXI1                                          
      * DTO4                                                                                        
     C                   EVAL      XZAUXI1=XZAUXI *ZXDTO41                                          
     C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
     C                   EVAL      XZAUXI =XZAUXI -XZAUXI1                                          
                                                                                                    
     C                   EVAL(H)   ZXVIVA=XZAUXI                                                    
      * Decimales de la moneda                                                                      
     C                   EVAL      MBMONE=ZXMONV                                                    
     C     KMSDIV0       CHAIN     MSDIV0                             81                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXVNET*ZXCOCAMB                                            
     C                   EVAL      ZXVTOT=PXNUM                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                                              
     C                   PARM                    PXALPH                                             
     C                   PARM                    PXFLDD                                             
     C                   PARM      MBDECI        PXDCCD                                             
     C                   PARM                    PXFMD1                                             
     C                   PARM                    PXEDTC                                             
     C                   PARM                    PXNMER                                             
     C                   PARM                    PXTIPA                                             
     C                   MOVE      PXALPH        ZXVNETA                                            
                                                                                                    
     C***                EXSR      CS_ZXCOCA2                                                       
     C                   EVAL      PXALPH=*BLANKS                                                   
     C***                EVAL      PXNUM=ZXVIVA*ZXCOCAM2                                            
     C                   EVAL      PXNUM=ZXVIVA*ZXCOCAMB                                            
     C                   EVAL      ZXVTOT=ZXVTOT+PXNUM                                              
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                                              
     C                   PARM                    PXALPH                                             
     C                   PARM                    PXFLDD                                             
     C                   PARM      MBDECI        PXDCCD                                             
     C                   PARM                    PXFMD1                                             
     C                   PARM                    PXEDTC                                             
     C                   PARM                    PXNMER                                             
     C                   PARM                    PXTIPA                                             
     C                   MOVE      PXALPH        ZXVIVAA                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXVTOT                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                                              
     C                   PARM                    PXALPH                                             
     C                   PARM                    PXFLDD                                             
     C                   PARM      MBDECI        PXDCCD                                             
     C                   PARM                    PXFMD1                                             
     C                   PARM                    PXEDTC                                             
     C                   PARM                    PXNMER                                             
     C                   PARM                    PXTIPA                                             
     C                   MOVE      PXALPH        ZXVTOTA                                            
                                                                                                    
     C                   EVAL      PXDCCD=2                                                         
     C                   EVAL      PXEDTC='4'                                                       
     C                   ENDSR                                                                      
      * Búsqueda del cambio para moneda de visualización según SETUP.                               
      **************************************************************                                
      * SUBRUTINA CLACULO DE COEFICIENTE DE CAMBIO                   *                              
      *------------------------------------------------------------*                                
     C     CS_ZXCOCAM    BEGSR                                                                      
     C                   EVAL      @PDATA=S0FPED                                                    
     C                   TIME                    @PHORA                                             
     C                   IF        @PDATA=*ZEROS                                                    
     C                   EVAL      @PDATA=ZZDATS                                                    
     C                   ENDIF                                                                      
      * Busco el primer cambio existente al comenzar Enero a las 12 horas                           
      * si se desean cambios en el momento de entrada                                               
     C                   IF        MCTFHV='1'                                                       
     C                   EVAL      @PDATA=S0FREP                                                    
     C                   IF        S0FRRE>0                                                         
     C                   EVAL      @PDATA=S0FRRE                                                    
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        @PDATA=*ZEROS                                                    
     C                   EVAL      @PDATA=*DATE                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ZXCAMC=S0CAMB                                                    
     C                   EVAL      ZXCMPC=S0CMPR                                                    
     C                   IF        S0CAMC<>0                                                        
     C                   EVAL      ZXCAMC=S0CAMC                                                    
     C                   EVAL      ZXCMPC=S0CMPC                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ZXCOCAMB=1                                                       
     C                   IF        S0MONE<>ZXMONV                                                   
     C****               IF        (ZXCAMC=0) OR (S0MONB<>ZXMONV)                                   
     C                   CALL      'MM2555'                                                         
     C                   PARM                    @PCIAS                                             
     C                   PARM      S0MONE        @PMON1                                             
     C                   PARM      ZXMONV        @PMON2                                             
     C                   PARM                    @PDATA                                             
     C                   PARM                    @PHORA                                             
     C                   PARM      0             @PCMCOCO                                           
     C                   PARM      0             @PCMCCCO                                           
     C                   PARM      *BLANKS       @PEERR                                             
     C                   EVAL      ZXCOCAMB=@PCMCCCO                                                
     C**                 ELSE                                                                       
     C**                 EVAL      ZXCOCAMB=ZXCAMC                                                  
     C**                 IF        (ZXCMPC<>0) AND (S0MONB=ZXMONV)                                  
     C**                 DIV(H)    ZXCMPC        ZXCOCAMB                                           
     C**                 ENDIF                                                                      
     C**                 ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CLACULO DE COEFICIENTE DE CAMBIO                   *                              
      *------------------------------------------------------------*                                
     C     CS_ZXCOCA2    BEGSR                                                                      
     C                   EVAL      @PDATA=S0FPED                                                    
     C                   TIME                    @PHORA                                             
     C                   IF        @PDATA=*ZEROS                                                    
     C                   EVAL      @PDATA=ZZDATS                                                    
     C                   ENDIF                                                                      
      * Busco el primer cambio existente al comenzar Enero a las 12 horas                           
      * si se desean cambios en el momento de entrada                                               
     C                   IF        MCTFHV='1'                                                       
     C                   EVAL      @PDATA=S0FREP                                                    
     C                   IF        S0FRRE>0                                                         
     C                   EVAL      @PDATA=S0FRRE                                                    
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        @PDATA=*ZEROS                                                    
     C                   EVAL      @PDATA=*DATE                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ZXCAMC=S0CAMB                                                    
     C                   EVAL      ZXCMPC=S0CMPR                                                    
     C                   IF        S0CAMC<>0                                                        
     C                   EVAL      ZXCAMC=S0CAMC                                                    
     C                   EVAL      ZXCMPC=S0CMPC                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ZXCOCAM2=1                                                       
     C                   IF        SYCOMO<>S0MONE                                                   
     C                   CALL      'MM2555'                                                         
     C                   PARM                    @PCIAS                                             
     C                   PARM      SYCOMO        @PMON1                                             
     C                   PARM      S0MONE        @PMON2                                             
     C                   PARM                    @PDATA                                             
     C                   PARM                    @PHORA                                             
     C                   PARM      0             @PCMCOCO                                           
     C                   PARM      0             @PCMCCCO                                           
     C                   PARM      *BLANKS       @PEERR                                             
     C                   EVAL      ZXCOCAM2=@PCMCCCO                                                
     C                   ENDIF                                                                      
                                                                                                    
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE GENERA EL PEDIDO DE COMPRAS                  *                                
      *------------------------------------------------------------*                                
     C     CS_SBMGPC     BEGSR                                                                      
      * Campos de PU2660DS                                                                          
     C                   EVAL      X2CIAS=SUFCIAS                                                   
     C                   EVAL      X2DLGA=SUFDLGA                                                   
     C                   EVAL      X2NPCO=SUFNPCO                                                   
     C                   EVAL      X2TPED=SUFTPED                                                   
     C                   EVAL      X2DATP=SUFDATP                                                   
     C                   EVAL      X2NOPL=SUFNOPL                                                   
     C                   EVAL      X2LINE=0                                                         
     C                   EVAL      X2PEPE=@PEPEPE                                                   
     C                   EVAL      X2PRIN=*BLANKS                                                   
     C                   EVAL      X2PR01=*BLANKS                                                   
     C                   EVAL      X2DL01=*BLANKS                                                   
     C                   EVAL      X2NP01=*BLANKS                                                   
     C                   EVAL      X2TP01=*BLANKS                                                   
     C                   EVAL      X2DA01=*ZEROS                                                    
     C                   EVAL      X2NO01=*ZEROS                                                    
     C                   EVAL      X2GDCL=*BLANKS                                                   
      * Si es pedido de entrega directa le coloca la direccion de entrega                           
      * del propio cliente                                                                          
     C**                 IF        S0TPE4='2'                                                       
     C                   IF        (S0TPE4='2') OR (S0EDET='1' AND S0TPE4<>'2')                     
     C                   EVAL      X2GDCL='1'                                                       
     C                   ENDIF                                                                      
      * CAMPOS PARA IDENTIFICAR EL TRABAJO                                                          
     C                   EVAL      ZXJNBR=SDSJOB                                                    
     C                   MOVEL     UDATE         ZXDATA                                             
04060C*                  TIME                    ZXHORA                                             
     C                   EVAL      ZXHORA=ZXHORA+1                                                  
                                                                                                    
     C                   CALL      'MM2559'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM                    @PEDLGA                                            
     C                   PARM      SDSPGM        @PEPROG                                            
     C                   PARM      '         '   @PERCDR                                            
     C                   PARM      'FMTO     '   @PEFIEL                                            
     C                   PARM      '06'          @PEOPCI                                            
     C                   PARM      'LP01206'     @PECCIT                                            
     C                   PARM                    JOTRAT                                             
     C                   PARM                    @PEPRG2                                            
     C                   PARM      '1'           @PEPAR1                                            
     C                   PARM                    @PEPAR2                                            
     C                   PARM      '1'           @PEERR                                             
                                                                                                    
      *                  EVAL      @PEPRG2='PU2660'                                                 
      *  DATOS DE SELECCION                                                                         
     C                   CLEAR                   Z1COMA                                             
     C     DSLDA         CAT       Z1COMA:0      Z1COMA                                             
     C                   EVAL      JOLINE=86                                                        
      *                                                                                             
     C                   CALL      'PRD935'                                                         
     C                   PARM                    JOTRAT                                             
     C                   PARM                    JOLINE                                             
     C                   PARM                    Z1COMA                                             
      *                                                                                             
     C                   CLEAR                   Z1COMA                                             
     C     PU2660        CAT       Z1COMA:0      Z1COMA                                             
     C                   EVAL      JOLINE=88                                                        
     C                   CALL      'PRD935'                                                         
     C                   PARM                    JOTRAT                                             
     C                   PARM                    JOLINE                                             
     C                   PARM                    Z1COMA                                             
     C                                                                                              
      * Sometiendo el trabajo                                                                       
     C                   Z-ADD     100           ZXLOGC           15 5                              
     C                   MOVE      *BLANKS       ZXQCM2                                             
     *                  MOVEL     'SBMJOB'      ZXQCM2                                             
     *    ZXQCM2        CAT       'CMD(':1      ZXQCM2                                             
     C     ZXQCM2        CAT       'CALL (':0    ZXQCM2                                             
     C     ZXQCM2        CAT       'PRDG20':0    ZXQCM2                                             
     C     ZXQCM2        CAT       'CL)':0       ZXQCM2                                             
     C     ZXQCM2        CAT       'PARM(':1     ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       JOTRAT:0      ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):1        ZXQCM2                                             
     C     ZXQCM2        CAT       @PEPRG2:0     ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
     *    ZXQCM2        CAT       ')':0         ZXQCM2                                             
     *    ZXQCM2        CAT       'JOB(':1      ZXQCM2                                             
     *    ZXQCM2        CAT       SDSPGM:0      ZXQCM2                                             
     *    ZXQCM2        CAT       ')':0         ZXQCM2                                             
                                                                                                    
     C                   CALL      'QCMDEXC'                                                        
     C                   PARM                    ZXQCM2                                             
     C                   PARM                    ZXLOGC                                             
     C                                                                                              
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE GENERA EL EXPEDIENTE PARA PACKING LIST       *                                
      *------------------------------------------------------------*                                
     C     CS_SBMGPL     BEGSR                                                                      
      * Campos de CM2506DS                                                                          
     C                   EVAL      X1CIAS=SUFCIAS                                                   
     C                   EVAL      X1DLGA=SUFDLGA                                                   
     C                   EVAL      X1NPCO=SUFNPCO                                                   
     C                   EVAL      X1TPED=SUFTPED                                                   
     C                   EVAL      X1DATP=SUFDATP                                                   
     C                   EVAL      X1NOPL=SUFNOPL                                                   
      * CAMPOS PARA IDENTIFICAR EL TRABAJO                                                          
      * Datos ya identificados antes de llegar aqui                                                 
      *                  EVAL      ZXJNBR=SDSJOB                                                    
      *                  MOVEL     UDATE         ZXDATA                                             
      *                  TIME                    ZXHORA                                             
     C                   EVAL      @PEPRG2='CM2506'                                                 
      *  DATOS DE SELECCION                                                                         
     C                   CLEAR                   Z1COMA                                             
     C     DSLDA         CAT       Z1COMA:0      Z1COMA                                             
     C                   EVAL      JOLINE=86                                                        
      *                                                                                             
     C                   CALL      'PRD935'                                                         
     C                   PARM                    JOTRAT                                             
     C                   PARM                    JOLINE                                             
     C                   PARM                    Z1COMA                                             
      *                                                                                             
     C                   CLEAR                   Z1COMA                                             
     C     CM2506        CAT       Z1COMA:0      Z1COMA                                             
     C                   EVAL      JOLINE=88                                                        
     C                   CALL      'PRD935'                                                         
     C                   PARM                    JOTRAT                                             
     C                   PARM                    JOLINE                                             
     C                   PARM                    Z1COMA                                             
     C                                                                                              
      * Sometiendo el trabajo                                                                       
     C                   Z-ADD     100           ZXLOGC           15 5                              
     C                   MOVE      *BLANKS       ZXQCM2                                             
     C                   MOVEL     'SBMJOB'      ZXQCM2                                             
     C     ZXQCM2        CAT       'CMD(':1      ZXQCM2                                             
     C     ZXQCM2        CAT       'CALL (':0    ZXQCM2                                             
     C     ZXQCM2        CAT       'PRDG20':0    ZXQCM2                                             
     C     ZXQCM2        CAT       'CL)':0       ZXQCM2                                             
     C     ZXQCM2        CAT       'PARM(':1     ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       JOTRAT:0      ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):1        ZXQCM2                                             
     C     ZXQCM2        CAT       @PEPRG2:0     ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
     C     ZXQCM2        CAT       'JOB(':1      ZXQCM2                                             
     C     ZXQCM2        CAT       SDSPGM:0      ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
                                                                                                    
     C                   CALL      'QCMDEXC'                                                        
     C                   PARM                    ZXQCM2                                             
     C                   PARM                    ZXLOGC                                             
     C                                                                                              
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE GRABA LOS DATOS DE PRTF                      *                                
      *------------------------------------------------------------*                                
     C     CS_SBMJOPR    BEGSR                                                                      
     C*  DATOS DE SELECCION                                                                         
     C                   CLEAR                   Z1COMA                                             
     C     DSLDA         CAT       Z1COMA:0      Z1COMA                                             
     C                   EVAL      JOLINE=86                                                        
     C                   CALL      'PRD935'                                                         
     C                   PARM                    JOTRAT                                             
     C                   PARM                    JOLINE                                             
     C                   PARM                    Z1COMA                                             
                                                                                                    
     C                   CLEAR                   Z1COMA                                             
     C     CO1000        CAT       Z1COMA:0      Z1COMA                                             
     C                   EVAL      JOLINE=99                                                        
     C                   CALL      'PRD935'                                                         
     C                   PARM                    JOTRAT                                             
     C                   PARM                    JOLINE                                             
     C                   PARM                    Z1COMA                                             
      * Sometiendo el listado                                                                       
     C                   Z-ADD     100           ZXLOGC           15 5                              
     C                   MOVE      *BLANKS       ZXQCM2                                             
     C                   MOVEL     'SBMJOB'      ZXQCM2                                             
     C     ZXQCM2        CAT       'CMD(':1      ZXQCM2                                             
     C     ZXQCM2        CAT       'CALL (':0    ZXQCM2                                             
     C     ZXQCM2        CAT       'PRDG20':0    ZXQCM2                                             
     C     ZXQCM2        CAT       'CL)':0       ZXQCM2                                             
     C     ZXQCM2        CAT       'PARM(':1     ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       JOTRAT:0      ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):1        ZXQCM2                                             
     C     ZXQCM2        CAT       @PEPRG2:0     ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
     C     ZXQCM2        CAT       'JOB(':1      ZXQCM2                                             
     C     ZXQCM2        CAT       SDSPGM:0      ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
                                                                                                    
     C                   CALL      'QCMDEXC'                                                        
     C                   PARM                    ZXQCM2                                             
     C                   PARM                    ZXLOGC                                             
     C*                                                                                             
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE validacion de riesgo                          *                                
