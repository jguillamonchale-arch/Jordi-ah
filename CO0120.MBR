IN842C                   EVAL      S2CDIR='1'                                                       
IN842C     KCODIPE       CHAIN(N)  CODIPE                                                           
IN842C                   IF        NOT%FOUND(CODIPE) OR                                             
IN842C                             (%FOUND(CODIPE)                                                  
IN842C                              AND %SUBST(S2OB51:6:3)<>S0LOGE)                                 
IN842C                   EXFMT     W03                                                              
IN842C                   EVAL      ERRGRL=*ON                                                       
IN842C                   ENDIF                                                                      
IN842C                   ENDIF                                                                      
IN842C                   ENDIF                                                                      
IN842C                   ENDSR                                                  ESR                
C1543 *------------------------------------------------------------------------*                    
C1543 * Recuperar Categoría de Rotación de un Artículo                         *                    
C1543 *------------------------------------------------------------------------*                    
C1543c     cs_rtvCRot    BEGSR                                                  BSR                
C1543 *                                                                                             
C1543c                   eval      zyCRot = *blank                                                  
C1543c                   eval      zymaga = *blanks                                                 
C1543c                   exsr      cs_rtvTCia                                                       
C1543c                   if        zyTCia <> '1'                                                    
C1543c                   call      'DP0090'                                                         
C1543c                   parm      s5cias        @pecias                                            
C1543c                   parm      s5arti        @pearti                                            
C1543c                   parm      s5vari        @pevari                                            
C1543c                   parm      s5mode        @pemode                                            
C1543c                   parm      *blanks       @peento                                            
C1543c                   parm      *blanks       @peentd                                            
C1543c                   parm      *blanks       @peclas                                            
C1543c                   eval      zyCRot = @peclas                                                 
      *                                                                                             
C1543c                   if        zycrot = *blanks                                                 
C1543c                   eval      m6cias = s5cias                                                  
C1543c                   eval      m6dlga = s5dlga                                                  
C1543c                   eval      m6arti = s5arti                                                  
C1543c                   eval      m6vari = s5vari                                                  
C1543c                   eval      m6mode = s5mode                                                  
C1543c                   eval      m6netl = 2                                                       
C1543c     kmsstst       chain     msstst                                                           
C1543C                   IF        NOT %FOUND OR M6OMIT='1'                                         
C1543C                   eval      M6NETL=1                                                         
C1543c     kmsstst       chain     msstst                                                           
C1543C                   endif                                                                      
C1543c                   if        %found                                                           
C1543C                   EVAL      zycrot=M6CLAS                                                    
C1543c                   else                                                                       
C1543C                   EVAL      zycrot='B '                                                      
C1543c                   endif                                                                      
C1543C                   endif                                                                      
      *                                                                                             
C1543c                   else                                                                       
C1543c                   eval      m0cias = s5cias                                                  
C1543c                   eval      m0loge = s5loge                                                  
C1543c     kmsalma05     chain     msalma05                                                         
C1543c                   if        %found                                                           
C1543c                   eval      zymaga = m0maga                                                  
C1543c                   endif                                                                      
C1543c                   eval      m1cias = s5cias                                                  
C1543c                   eval      m1maga = zymaga                                                  
C1543c                   eval      m1arti = s5arti                                                  
C1543c                   eval      m1vari = s5vari                                                  
C1543c                   eval      m1mode = s5mode                                                  
C1543c     kmsstok       chain     msstok                                                           
C1543c                   if        %found                                                           
C1543c                   eval      zyCRot = m1crot                                                  
C1543c                   endif                                                                      
C1543c                   endif                                                                      
C1543 *                                                                                             
C1543c                   endsr                                                  BSR                
C1543 *------------------------------------------------------------------------*                    
C1543 * Recuperar Tipo de Empresa: Comercial, Productiva, Ccial-Productiva     *                    
C1543 *------------------------------------------------------------------------*                    
C1543c     cs_rtvTCia    BEGSR                                                  BSR                
C1543 *                                                                                             
C1543c                   eval      zyTCia = *blank                                                  
C1543c                   eval      ppampl = *blanks                                                 
C1543c                   move      s5cias        ppcias                                             
C1543c     ppcias        chain     pmlibl                                                           
C1543c                   eval      zyTCia = %subst(ppampl:6:1)                                      
C1543 *                                                                                             
C1543c                   endsr                                                  BSR                
C1543 *------------------------------------------------------------------------*                    
C1543 * Ventana de Confirmación de Anulación                                   *                    
C1543 *------------------------------------------------------------------------*                    
C1543c     cs_confAnul   BEGSR                                                  BSR                
C1543 *                                                                                             
C1543c                   eval      w15SN = '0'                                                      
C1543c                   dow       retro = *off                                                     
C1543c                   exfmt     w15                                                              
C1543c                   select                                                                     
C1543c                   when      help = *on                                                       
C1543C                   CALL      'MMPROM'                                                         
C1543C                   PARM      *blanks       @PEOPT2                                            
C1543C                   PARM      *blanks       @PEPGM                                             
C1543C                   PARM      *blanks       @PEFMT                                             
C1543C                   PARM      'SINO'        @PEFLD                                             
C1543C                   PARM      *BLANKS       @PEERR                                             
C1543C                   IF        @PEERR<'0'                                                       
C1543c                   eval      w15sn = @peopt2                                                  
C1543c                   endif                                                                      
C1543c                   when      retro = *off                                                     
C1543C                   CALL      'MMPROM'                                                         
C1543C                   PARM      *blanks       @PEOPT2                                            
C1543C                   PARM      *blanks       @PEPGM                                             
C1543C                   PARM      *blanks       @PEFMT                                             
C1543C                   PARM      'SINO'        @PEFLD                                             
C1543C                   PARM      'V'           @PEERR                                             
C1543C                   IF        @PEERR>'0'                                                       
C1543C                   EVAL      ERRGRL=*ON                                                       
C1543C                   EVAL      MSGER='ADP0304'                                                  
C1543c                   else                                                                       
C1543c                   eval      retro = *on                                                      
C1543C                   ENDIF                                                                      
C1543c                   when      retro = *on                                                      
C1543c                   eval      @peopt = *blanks                                                 
C1543c                   OTHER                                                                      
C1543c                   eval      retro = *on                                                      
C1543c                   endsl                                                                      
C1543c                   enddo                                                                      
C1543c                   if        w15sn <> '1'                                                     
C1543c                   eval      @peopt = *blanks                                                 
C1543c                   endif                                                                      
C1543c                   eval      retro = *off                                                     
C1543 *                                                                                             
C1543c                   endsr                                                  BSR                
IT141 **************************************************************                                
IT141 * COMMON SUBRUTINE (CS_) :                                  *                                 
IT141 *                                                            *                                
IT141 *------------------------------------------------------------*                                
IT141C     CS_PRTOP6S    BEGSR                                                                      
IT141C                   EVAL      ZXJNBR=SDSJOB                                                    
IT141C                   MOVEL     UDATE         ZXDATA                                             
IT141C                   EVAL      ZXHORA=ZXHORA+1                                                  
IT141C                   MOVE      JOTRAT        @PEJOBT                                            
IT141* SE presentará o no pantalla dependiendo de los parámetros de Setup                          
IT141C                   EVAL      @PEERR='1'                                                       
IT141C                   IF        MCWO06>='1'                                                      
IT141C                   EVAL      @PEERR=*BLANKS                                                   
IT141C                   ENDIF                                                                      
IT141C                                                                                              
IT141C                   CALL      'MM2559'                                                         
IT141C                   PARM                    @PECIAS                                            
IT141C                   PARM                    @PEDLGA                                            
IT141C                   PARM      SDSPGM        @PEPROG                                            
IT141C                   PARM      'AFTS     '   @PERCDR                                            
IT141C                   PARM      'FMTO     '   @PEFIEL                                            
IT141C                   PARM      '01'          @PEOPCI                                            
IT141C                   PARM      'LP01066'     @PECCIT                                            
IT141C                   PARM                    JOTRAT                                             
IT141C                   PARM                    @PEPRG2                                            
IT141C                   PARM      '1'           @PEPAR1                                            
IT141C                   PARM                    @PEPAR2                                            
IT141C                   PARM                    @PEERR                                             
IT141C                                                                                              
IT141* Si se ha hecho F12 no se continúa                                                           
IT141C                   IF        @PEERR='A'                                                       
IT141C                   EVAL      ZXOPT2='DSP'                                                     
IT141C                   EVAL      ERRGRL=*ON                                                       
IT141C                   ENDIF                                                                      
IT141C     ERRGRL        CABEQ     *ON           PRTOP6ST                                           
IT141C                   IF        @PEERR>'0'                                                       
IT141C                   EVAL      ZXOPT2='DSP'                                                     
IT141C                   EVAL      MSGER='MSG0084'                                                  
IT141C                   EVAL      ERRGRL=*ON                                                       
IT141C                   EVAL      WRK40=*ON                                                        
IT141C                   ENDIF                                                                      
IT141C     ERRGRL        CABEQ     *ON           PRTOP6ST                                           
IT141* Campos de CO1000DS                                                                          
IT141C                   EVAL      X0CIAS=SUFCIAS                                                   
IT141C                   EVAL      X0DLGA=SUFDLGA                                                   
IT141C                   EVAL      X0NPCO=SUFNPCO                                                   
IT141C                   EVAL      X0TPED=SUFTPED                                                   
IT141C                   EVAL      X0DATP=SUFDATP                                                   
IT141C                   EVAL      X0NOPL=SUFNOPL                                                   
IT141C                   EVAL      X0IDIO=SUFIDIO                                                   
IT141C                   EVAL      X0OPCI=SUFOPCI                                                   
IT141C*                                                                                             
IT141C                   EXSR      CS_SBMJOPR                                                       
IT141C     PRTOP6ST      ENDSR                                                                      
