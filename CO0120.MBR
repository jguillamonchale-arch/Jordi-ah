      **************************************************************                                
      * SOBRE PROTECCION DE CAMPOS                                 *                                
      *------------------------------------------------------------*                                
     C     CS_PROTECT    BEGSR                                                                      
     C                   IF        @PCUST<>*BLANKS                                                  
     C                   EVAL      INDPRO1=*ON                                                      
     C                   EVAL      PSUCUST=ZXCUST                                                   
     C                   EVAL      PSUCUS1=ZXCUST                                                   
     C                   EVAL      PSUCUS2=ZXCUST                                                   
     C                   EVAL      PSUCUS8=ZXCUST                                                   
     C                   EVAL      PSUCUS9=ZXCUST                                                   
     C     KCOCLIN       CHAIN     COCLIN                             81                            
     C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      PSUDES1=S0DES1                                                   
     C                   EVAL      PSUDESB=S0DES1                                                   
     C                   EVAL      PSUDES2=S0DES1                                                   
     C                   EVAL      PSUCLAB=S0CLAB                                                   
     C                   EVAL      PSUCLA1=S0CLAB                                                   
     C                   EVAL      PSUCLA2=S0CLAB                                                   
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        @PTPED<>*BLANKS                                                  
     C                   EVAL      INDPRO2=*ON                                                      
     C                   EVAL      PSUTPE1=@PTPED                                                   
     C                   EVAL      PSUTPE2=@PTPED                                                   
     C                   EVAL      PSUTPE3=@PTPED                                                   
     C                   EVAL      PSUTPE4=@PTPED                                                   
     C                   EVAL      PSUTPE5=@PTPED                                                   
     C                   EVAL      PSUTPE6=@PTPED                                                   
     C                   EVAL      PSUTPE7=@PTPED                                                   
     C                   EVAL      PSUTPE8=@PTPED                                                   
     C                   EVAL      PSUTPE9=@PTPED                                                   
     C                   EVAL      PSUTPED=@PTPED                                                   
21031C                   EVAL      PSUTPEA=@PTPED                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
FQ876                                                                                               
FQ876 **************************************************************                                
FQ876 * SUBRUTINA CONTROL DEL SFL S00 - REALIZAREMOS               *                                
FQ876 * NO ENSEÑAREMOS EL SUBFICHERO, ÚNICAMENTE ELEGIREMOS        *                                
FQ876 * EL PEDIDO QUE QUEREMOS PARA PODER REALIZAR LA OPCION QUE   *                                
FQ876 * NOS INTERESE                                                                                
FQ876 *------------------------------------------------------------*                                
FQ876C     S00MAIN       BEGSR                                                                      
FQ876C                   DOW       ZXOPT1='S00'                                                     
FQ876C     ZXOPT2        CASEQ     'CLR'         S00CLR                                             
FQ876C     ZXOPT2        CASEQ     'INZ'         S00INZ                                             
FQ876C     ZXOPT2        CASEQ     'CMD'         S00CMD                                             
FQ876C     ZXOPT2        CASEQ     'CHK'         S00CHK                                             
FQ876C                   ENDCS                                                                      
FQ876C                   ENDDO                                                                      
FQ876C                   ENDSR                                                                      
FQ876 **************************************************************                                
FQ876 * SUBRUTINA DE NETEJA DEL SFL                                *                                
FQ876 *------------------------------------------------------------*                                
FQ876C     S00CLR        BEGSR                                                                      
FQ876C                   EVAL      ZXOPT2='INZ'                                                     
FQ876C                   EVAL      CCCFMT='1'                                                       
FQ876C                   MOVEA     ZXZERO10      *IN(90)                                            
FQ876C     S00CLRT       ENDSR                                                                      
FQ876 **************************************************************                                
FQ876 * SUBRUTINA INICIALITZACIÓ I CARREGA DEL SFL                 *                                
FQ876 *------------------------------------------------------------*                                
FQ876C     S00INZ        BEGSR                                                                      
FQ876C                   EVAL      ZXOPT2='CMD'                                                     
FQ876C                   EXSR      CS_SFLIN1                                                        
FQ876C                   EVAL      CHAIN=*OFF                                                       
FQ876 *                                                                                             
FQ876C                   EVAL      S0DLGA=ZXDLGA_IN                                                 
FQ876C                   EVAL      S0NPCO=ZXNPCO_IN                                                 
FQ876C                   EVAL      S0TPED=ZXTPED_IN                                                 
FQ876C                   EVAL      S0DATP=ZXDATP_IN                                                 
FQ876C                   EVAL      S0NOPL=ZXNOPL_IN                                                 
FQ876C     KCOCAPE       CHAIN     COCAPE                                                           
FQ876C                   IF        NOT%FOUND(COCAPE)                                                
FQ876C                   EVAL      ZXOPT1='END'                                                     
FQ876C                   ELSE                                                                       
FQ876C                   EVAL      ZXNRR00=1                                                        
FQ876C                   EVAL      ZXLOP00=1                                                        
FQ876C                   EXSR      CS_KEYPF                                                         
FQ876C                   EVAL      SUFOPCI=ZXOPCI_IN                                                
FQ876C*                  WRITE     SUFD                                                             
FQ876C                   EXSR      CS_SFLIN2                                                        
FQ876C                   ENDIF                                                                      
FQ876C     S00INZT       ENDSR                                                                      
FQ876 **************************************************************                                
FQ876 * SUBRUTINA VALIDACIÓ DELS CMD'S                             *                                
FQ876 *------------------------------------------------------------*                                
FQ876C     S00CMD        BEGSR                                                                      
FQ876C                   EVAL      ZXOPT2='CHK'                                                     
FQ876C                   CLEAR                   CO0120                                             
FQ876C                   EVAL      MCNAUT='1'                                                       
FQ876C                   EVAL      MCNPIC='0'                                                       
FQ876C                   EVAL      MCLAOR='0'                                                       
FQ876C                   EVAL      MCLPED='0'                                                       
FQ876C     S00CMDT       ENDSR                                                                      
FQ876 **************************************************************                                
