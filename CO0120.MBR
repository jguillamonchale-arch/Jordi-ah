IN944 ***************************************************************                               
IN944 * VALIDAMOS LA DELEGACIÓN /ALMACEN / LOGÍSTICA                                                
IN944 ***************************************************************                               
IN944C     CS_VALIDA_DLGABEGSR                                                                      
IN944C                   EVAL      ZXDLGA_ORG=@PDLGA                                                
IN944C                   IF        ZXLOGE_ORG=*BLANKS                                               
IN944C                   EVAL      ZXLOGE_ORG=P7LOGS                                                
IN944C                   ENDIF                                                                      
IN944 * miramos si delegación corresponde con logística informada                                   
IN944C                   EVAL      M0LOGE=ZXLOGE_ORG                                                
IN944C                   EVAL      M0CIAS=@PCIAS                                                    
IN944C     KMSALMA05     CHAIN     MSALMA05                                                         
IN944C                   IF        %FOUND                                                           
IN944C                   EVAL      ZXMAGA_ORG=M0MAGA                                                
IN944C                   IF        ZXDLGA_ORG<>M0DLGA                                               
IN944C                   EVAL      ZXDLGA_ORG=M0DLGA                                                
IN944C                   ENDIF                                                                      
IN944C                   EVAL      THDLGA=ZXDLGA_ORG                                                
IN944C                   ENDIF                                                                      
IN944C                   ENDSR                                                                      
IN944 ***********************************************************                                   
IN944 *  CALCULO PLAZO  TODO EL PEDIDO                          *                                   
IN944 ***********************************************************                                   
IN944C     CS_CALC_PLZST2BEGSR                                                                      
IN944 * calculamos plazos por línea                                                                 
IN944C                   EVAL      S5CIAS=SUFCIAS                                                   
IN944C                   EVAL      S5DLGA=SUFDLGA                                                   
IN944C                   EVAL      S5NPCO=SUFNPCO                                                   
IN944C                   EVAL      S5TPED=SUFTPED                                                   
IN944C                   EVAL      S5DATP=SUFDATP                                                   
IN944C                   EVAL      S5NOPL=SUFNOPL                                                   
IN944C     KCODEPE       SETLL     CODEPE                                                           
IN944C     KCODEPE       READE     CODEPE                                                           
IN944C                   DOW       NOT %EOF                                                         
IN944C                   EVAL      ZXLOGE_ORG=S5LOGE                                                
IN944C                   EXSR      CS_CALC_PLZSTD                                                   
IN944C     KCODEPE       READE     CODEPE                                                           
IN944C                   ENDDO                                                                      
IN944 * calculamos coenvio                                                                          
IN944C                   IF        THTACT<='0' AND S0COEN>='1'                                      
NAP45C                             AND S0COEN<>'3'                                                  
IN944C                   EXSR      CS_FRRRCOE                                                       
IN944C                   ENDIF                                                                      
IN944 * calculamos agrupación semanal (excepción coenvios totales)                                  
IN944C                   IF        THTARS='1' AND                                                   
NAP45* IN944                      (S0COEN<='0' OR S0COEN='2') AND                                  
NAP45C                             (S0COEN<='0' OR S0COEN='2' OR S0COEN='3') AND                    
IN944C                             ((THWEEK>='1' AND S0TPE4<>'2') OR                                
IN944C                             (THWEEK='2'))                                                    
IN944C                   EXSR      CS_FSEMANAL                                                      
IN944C                   ENDIF                                                                      
IN944 *                                                                                             
IN944C                   EXSR      CS_MAXCAB_FRRE                                                   
IN944C                   ENDSR                                                                      
IN944 ***********************************************************                                   
IN944 *  CALCULO PLAZO  1 LINEA                                                                     
IN944 ***********************************************************                                   
IN944C     CS_CALC_PLZSTDBEGSR                                                                      
IN944C                   EVAL      M5CIAS=S5CIAS                                                    
IN944C                   EVAL      M5ARTI=S5ARTI                                                    
IN944C                   EVAL      M5VARI=S5VARI                                                    
IN944C                   EVAL      M5MODE=S5MODE                                                    
IN944C                   EXSR      CS_ARTSRV                                                        
IN944C                   IF        NOT ARTSRV                                                       
IN949C                   IF        S5FREP<*DATE                                                     
IN949C                   EVAL      S5FREP=*DATE                                                     
IN949C                   ENDIF                                                                      
IN944C                   EVAL      @PEFRRE=S5FREP                                                   
IN944C                   EXSR      CS_VALIDA_DLGA                                                   
IN944C     KCOPPEC       CHAIN     COPPEC                             81                            
IN944C                   IF        CHAIN=*OFF AND THACTI<'1'                                        
IN944C                   IF        S5TCOJ='4'                                                       
IN944C                   EXSR      CS_PLZCNJ                                                        
IN944C                   ELSE                                                                       
IN944C                   CALL      'CO2610'                                                         
IN944C                   PARM                    @PCIAS                                             
IN944C                   PARM      S5DLGA        @PEDLGA                                            
IN944C                   PARM      S5ARTI        @PEARTI                                            
IN944C                   PARM      S5VARI        @PEVARI                                            
IN944C                   PARM      S5MODE        @PEMODE                                            
IN944C                   PARM      *BLANKS       @PETCOJ                                            
IN944C                   PARM                    @PEFRRE                                            
IN944C                   PARM      *ZEROS        @PEFDDS                                            
IN944C                   PARM      S5CANT        @PECANT                                            
IN944C                   PARM      S5UNIM        @PEUNIM                                            
IN944C                   PARM      S5LOGE        @PELOGE                                            
IN944C                   PARM      *BLANKS       @PETPLA                                            
IN944C                   PARM      '*'           @PERRO                                             
IN944C                   PARM      S5NPCO        @FDNPCO                                            
IN944C                   PARM      S5TPED        @FDTPED                                            
IN944C                   PARM      S5DATP        @FDDATP                                            
IN944C                   PARM      S5NOPL        @FDNOPL                                            
IN944C                   PARM      S5LINE        @FDLINE                                            
IN944C                   ENDIF                                                                      
IN944C                   EVAL      S5TPLA = @PETPLA                                                 
IN944C                   IF        THTACT<='0'                                                      
IN944C                   IF        S5FRRE<>@PEFRRE                                                  
IN944C                   EXSR      CS_COHCON                                                        
IN944C                   ENDIF                                                                      
IN944C                   EVAL      S5FRRE = @PEFRRE                                                 
IN944C                   EVAL      S5DISP = %EDITC(@PEFDDS:'X')                                     
IN944C                   IF        S5FRRE <> 0                                                      
IN944C                   EVAL      S5FRRR=S5FRRE                                                    
IN944C                   ENDIF                                                                      
IN944C                   ENDIF                                                                      
IN944C                   ENDIF                                                                      
PGE21C                   EVAL      S5DAT8=*DATE                                                     
PGE21C                   TIME                    S5HORA                                             
PGE21C                   EVAL      S5USUA=SDSUSR                                                    
IN944C                   UPDATE    RCODEPE                                                          
IN944C                   ELSE                                                                       
IN944C                   UNLOCK    CODEPE                                                           
IN944C                   ENDIF                                                                      
IN944C                   ENDSR                                                                      
IN944 **************************************************************************                    
IN944 * SUBRUTINA PARA COMPROBAR FECHAS DE COENVÍO                             *                    
IN944 *------------------------------------------------------------------------*                    
IN944C     CS_MAXCAB_FRREBEGSR                                                  BSR                
IN944C                                                                                              
IN944C                   EVAL      ZXLOGE_ORG=S0LOGE                                                
IN944C                   EXSR      CS_VALIDA_DLGA                                                   
IN944C     KCOPPEC       CHAIN     COPPEC                             81                            
IN948 *                  IF        %FOUND(COPPEC) AND THTACT<='0' AND THRFPE='1'                    
IN948 *                            AND THTARS='1'                                                   
IN948C                   IF        S0C420<>'X'                                                      
IN944C                   CLEAR                   ZGFMAX                                             
IN944C     KCOCAPE       SETLL     CODEPE20                                                         
IN944C     KCOCAPE       READE(N)  CODEPE20                                                         
IN944C                   DOW       NOT %EOF(CODEPE20)                           D0                 
IN944C                   EVAL      M5CIAS=C_S5CIAS                              ·0                 
IN944C                   EVAL      M5ARTI=C_S5ARTI                              ·0                 
IN944C                   EVAL      M5VARI=C_S5VARI                              ·0                 
IN944C                   EVAL      M5MODE=C_S5MODE                              ·0                 
IN944C                   EXSR      CS_ARTSRV                                    ·0                 
IN944C                   IF        NOT ARTSRV AND C_S5FRRE>ZGFMAX                I1                
IN944C                   EVAL      ZGFMAX=C_S5FRRE                               ·1                
IN944C                   ENDIF                                                   E1                
IN944C     KCOCAPE       READE(N)  CODEPE20                                     ·0                 
IN944C                   ENDDO                                                  E0                 
IN944C     KCOCAPE       CHAIN     COCAPE                                                           
IN944C                   IF        %FOUND(COCAPE)                               I0                 
IN960C                             AND S0C420<>'X'                                                  
IN944C     KCOCAPE       CHAIN     COCAPE                                                           
IN944C                   EVAL      S0FRRE=ZGFMAX                                ·0                 
Q0003C*                  IF        ZXFMAX=0                                                         
Q0003C                   IF        ZGFMAX=0                                                         
IN960C                   EVAL      S0FRRR=S0FREP                                ·0                 
IN960C                   ELSE                                                                       
IN944C                   EVAL      S0FRRR=ZGFMAX                                ·0                 
IN960C                   ENDIF                                                                      
PGE21C                   EVAL      S0DAT8=*DATE                                                     
PGE21C                   TIME                    S0HORA                                             
PGE21C                   EVAL      S0USUA=SDSUSR                                                    
IN944C                   UPDATE    RCOCAPE                                      ·0                 
IN944C                   ENDIF                                                  E0                 
IN944C                   ENDIF                                                  E0                 
IN944C                   ENDSR                                                  ESR                
IN842 **************************************************************************                    
IN842 * INCIDENCIA DIRECCIONES                                                 *                    
