     C     S01INZ        BEGSR                                                                      
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   EXSR      CS_SFLIN1                                                        
                                                                                                    
     C                   DOW       ZXLOP00 < ZXLIPAG                                                
     C                   EXSR      CS_READ01                                                        
     C                   IF        EOF=*ON                                                          
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        ZXHST='0' OR ZXHST=' '                                           
     C                   IF        S0FPED<ZZDATS                                                    
     C                   GOTO      TNEXRE01                                                         
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   EXSR      CS_SELSFL                                                        
     C                   IF        ZXSELSFL=1                                                       
     C                   GOTO      TNEXRE01                                                         
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ZXNRR00=ZXNRR00 + 1                                              
     C                   EVAL      ZXLOP00=ZXLOP00 + 1                                              
     C                   EXSR      CS_MOVFP                                                         
     C                   EXSR      CS_SAVFK                                                         
     C                   EVAL      *IN33=*OFF                                                       
     C                   IF        S0TPE4='2'                                                       
     C                   EVAL      *IN33=*ON                                                        
     C                   ENDIF                                                                      
