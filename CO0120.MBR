IT141                                                                                               
      * RECUPERACIÓ DE LA LDA DE COMPRES                                                            
     C     *DTAARA       DEFINE    PURLDA        DSLDA                                              
FQ876C*                  IN        DSLDA                                                            
FQ876C*                  EVAL      ZEAMPL=ZZAMPL                                                    
                                                                                                    
     C     *ENTRY        PLIST                                                                      
     C                   PARM                    @PCUST                                             
     C                   PARM                    @PTPE2                                             
     C                   PARM                    @PERRO                                             
FQ876 *                                                                                             
FQ876C                   PARM                    @PDLGA_IN                                          
FQ876C                   PARM                    @PNPCO_IN                                          
FQ876C                   PARM                    @PTPED_IN                                          
FQ876C                   PARM                    @PDATP_IN                                          
FQ876C                   PARM                    @PNOPL_IN                                          
FQ876C                   PARM                    @POPCI_IN                                          
FQ876C                   PARM                    @PERRO_IN                                          
FQ876 *                                                                                             
      *                                                                                             
FQ876                                                                                               
FQ876C                   IF        %PARMS=10                                                        
FQ876C                   EVAL      ZXDLGA_IN=@PDLGA_IN                                              
FQ876C                   EVAL      ZXNPCO_IN=@PNPCO_IN                                              
FQ876C                   EVAL      ZXTPED_IN=@PTPED_IN                                              
FQ876C                   EVAL      ZXDATP_IN=@PDATP_IN                                              
FQ876C                   EVAL      ZXNOPL_IN=@PNOPL_IN                                              
FQ876C                   EVAL      ZXOPCI_IN=@POPCI_IN                                              
FQ876C                   EVAL      ZXERRO_IN=@PERRO_IN                                              
FQ876C     ZXDLGA_IN     CHAIN     PMEMPR00                                                         
FQ876 * ANTES DE NADA RECUPERO EL TIPO DE TRABAJO (INTERACTIVO O BATCH)                             
FQ876C* SI EL TRABAJO ES BATCH TRANSFORMO TODO LO MANUAL EN AUTOMATICO                              
FQ876C* '0' SIGNIFICA BATCH                                                                         
FQ876C* '1' SIGNIFICA INTERACTIVO                                                                   
FQ876C                   CALL      'RTVTIJ'                                                         
FQ876C                   PARM      *BLANKS       @PTIPJ                                             
FQ876C                   IF        @PTIPJ>='1'                                                      
FQ876C                   OPEN      CO0120FM                                                         
FQ876C                   ELSE                                                                       
FQ876C                   EVAL      @PCIAS=P7CIAS                                                    
FQ876C                   EVAL      @PDLGA=ZXDLGA_IN                                                 
FQ876C                   CALL      'PRDGJ4CL'                                                       
FQ876C                   CALL      'INPRDLDA'                                                       
FQ876C                   PARM                    @PCIAS                                             
FQ876C                   PARM                    @PDLGA                                             
FQ876C                   PARM      SDSUSR        @PEUSER          10                                
FQ876C                   PARM                    @PEIMPR          10                                
FQ876C                   ENDIF                                                                      
FQ876C                   ELSE                                                                       
FQ876C                   OPEN      CO0120FM                                                         
FQ876C                   EVAL      ZXDLGA_IN=*BLANKS                                                
FQ876C                   EVAL      ZXNPCO_IN=*BLANKS                                                
FQ876C                   EVAL      ZXTPED_IN=*BLANKS                                                
FQ876C                   EVAL      ZXDATP_IN=*ZEROS                                                 
FQ876C                   EVAL      ZXNOPL_IN=*ZEROS                                                 
FQ876C                   EVAL      ZXOPCI_IN=*BLANKS                                                
FQ876C                   EVAL      ZXERRO_IN=*BLANKS                                                
FQ876C                   EVAL      @PTIPJ='1'                                                       
FQ876C                   ENDIF                                                                      
FQ876C                   IN        DSLDA                                                            
FQ876C                   EVAL      ZEAMPL=ZZAMPL                                                    
                                                                                                    
     C                   EVAL      Z1ASTE='*'                                                       
     C                   EVAL      Z1AST2='*'                                                       
     C                   EVAL      Z1AST3='*'                                                       
     C                   EVAL      PXFMD1=ZZFMD1                                                    
     C                   EVAL      PXDCCD=2                                                         
     C* CAPÇALERES D'OPCIONS DEL SFL  (CODIS D'ARXIU DE MISSATGES)                                  
     C                   EVAL      SUFOPC2=*BLANKS                                                  
     C                   IF        ZZNPGM=' '                                                       
     C                   EVAL      SUFOPC1='OCO0120'                                                
30056C*                  EVAL      SUFOPC2='OCO012B'                                                
     C                   EVAL      SUFOPC2='OCO012C'                                                
     C                   ELSE                                                                       
     C                   EVAL      SUFOPC1='OCB0120'                                                
     C                   ENDIF                                                                      
     C* TITOLS DE PANTALLES (CODIS D'ARXIU DE MISSATGES)                                            
     C                   IF        ZZNPGM=' '                                                       
     C                   EVAL      CCCCTIT='TCO0120'                                                
     C                   ELSE                                                                       
     C                   EVAL      CCCCTIT='TCU0120'                                                
     C                   ENDIF                                                                      
     C* ACTIVEM EL SFLDSPCTL                                                                        
     C                   EVAL      SFLCTL=*ON                                                       
      * ACTUALITZACIÓ DELS CAMPS DEL PMSETP I ALTRES CAMPS AMB VALORS COMUNS                        
04098C                   EVAL      ZXAMPL=ZZAMPL                                                    
     C                   EVAL      MICIAS=ZZCIAS                                                    
     C                   EVAL      MECIAS=ZZCIAS                                                    
     C                   EVAL      @PCIAS=ZZCIAS                                                    
     C                   EVAL      @PEDLGA=ZZDLGA                                                   
     C                   EVAL      @PECIAS=ZZCIAS                                                   
     C                   EVAL      @PEDLGA=ZZDLGA                                                   
     C                   EVAL      S0CIAS=ZZCIAS                                                    
     C                   EVAL      S0DLGA=ZZDLGA                                                    
     C                   EVAL      PSUDLG1=ZZDLGA                                                   
     C                   EVAL      PSUDLGA=ZZDLGA                                                   
     C                   EVAL      S0CUST=@PCUST                                                    
     C                   EVAL      @PTPED=@PTPE2                                                    
     C                   EVAL      S0TPED=@PTPED                                                    
     C                   EVAL      PICIAS=ZZCIAS                                                    
     C                   EVAL      PIPROG=SDSPGM                                                    
     C                   EVAL      PIUSU1=ZZUSUA                                                    
     C                   EVAL      ZXDLGA=ZZDLGA                                                    
     C                   EVAL      ZXCUST=@PCUST                                                    
     C                   EVAL      MBCIAS=ZZCIAS                                                    
     C                   EVAL      S2CIAS=ZZCIAS                                                    
     C                   EVAL      S2DLGA=ZZDLGA                                                    
  CSMC                   EVAL      THCIAS=@PCIAS                                                    
  CSMC                   EVAL      THDLGA=@PDLGA                                                    
     C                   EVAL      N3CIAS=ZZCIAS                                                    
     C                   EVAL      ZXCOCAMB=1                                                       
C1543C                   EVAL      MMCIAS=ZZCIAS                                                    
                                                                                                    
     C                   IF        ZZPPCC='2'                                                       
     C                   EVAL      ZXDLGA=*BLANKS                                                   
     C                   EVAL      S0DLGA=*BLANKS                                                   
     C                   EVAL      PSUDLGA=*BLANKS                                                  
     C                   ENDIF                                                                      
     C                   EVAL      S0DES1=*BLANKS                                                   
     C                   EVAL      S0CLAB=*BLANKS                                                   
     C* Puesto que en cada pedido se puede poner una clave o descripción                            
     C* distinta o modificada se decide tomar los datos del fichero de                              
     C* proveedores para tener los valores de posicionamiento                                       
     C     KCOCLIN       CHAIN     COCLIN                             81                            
     C                   EVAL      ZXDES1=S0DES1                                                    
     C                   EVAL      ZXCLAB=S0CLAB                                                    
     C                   EVAL      ZXTPED=@PTPED                                                    
     C                   EVAL      ZXFLAN=0                                                         
     C                   EVAL      ZXFPED=0                                                         
     C                   EVAL      ZXFREP=0                                                         
                                                                                                    
      *************************************************                                             
     C* Protección de campos según parámetros llegados                                              
     C                   EXSR      CS_PROTECT                                                       
      *************************************************                                             
      * RECUPEREM DEL FITXER DE SETUP EL FORMAT QUE EM DE MOSTRAR PER OMISIÓ                        
     C     KMSSETP       CHAIN (N) PMSETP                             81                            
     C                   CLEAR                   CO0120                                             
     C     PIDATR        CAT       CO0120:0      CO0120                                             
     C                   EVAL      ZXNAUT=MCNAUT                                                    
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      MCTFHC='1'                                                       
     C                   EVAL      MCPEPE=ZZPEPE                                                    
      *                  EVAL      MCPRPL=*BLANKS                                                   
     C                   EVAL      MCGEXP='1'                                                       
      ** PARAMETROS ESPECIALES SI SE TRABAJA PEDIDO VENTAS-PEDIDO COMPRAS                           
     C                   IF        ZZPEPE='1'                                                       
     C                   EVAL      MCNAUT='1'                                                       
     C                   EVAL      MCNPIC='1'                                                       
     C                   EVAL      MCLAOR='0'                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                  EVAL      ZXPRPL=MCPRPL                                                    
     C                   EVAL      ZXLOGD=MCLOGD                                                    
     C                   EVAL      ZXLOGH=MCLOGH                                                    
C0145C                   EVAL      ZXPPDE=MCPPDE                                                    
C0145C                   EVAL      ZXPPHA=MCPPHA                                                    
     C                   EVAL      ZXGEXP=MCGEXP                                                    
     C                   EVAL      ZXNPIC=MCNPIC                                                    
     C                   EVAL      ZXPEPE=MCPEPE                                                    
     C                   EVAL      ZXHST=MCTFHC                                                     
     C                   EVAL      ZXFMT=MCS120                                                     
     C                   EVAL      ZXDROP=MCSDRP                                                    
     C                   EVAL      ZXTRAB=MCTRAB                                                    
     C                   IF        ZXDROP=' ' OR ZXDROP>'1'                                         
     C                   EVAL      ZXDROP='0'                                                       
     C                   ENDIF                                                                      
IT141C                   EVAL      ZXAFOT=MCAFOT                                                    
                                                                                                    
     C* RECUPEREM ELS VALORS DE L'AREA DE PARÀMETRES DE PROGRAMA                                    
     C                   IF        CHAIN=*OFF                                                       
     C                   SELECT                                                                     
     C                   WHEN      MCS120=' ' OR MCS120='0'                                         
     C                   EVAL      ZXOPT='S01CLR'                                                   
     C                   WHEN      MCS120='1'                                                       
     C                   EVAL      ZXOPT='S01CLR'                                                   
     C                   WHEN      MCS120='2'                                                       
     C                   EVAL      ZXOPT='S02CLR'                                                   
     C                   WHEN      MCS120='3'                                                       
     C                   EVAL      ZXOPT='S03CLR'                                                   
     C                   WHEN      MCS120='4'                                                       
     C                   EVAL      ZXOPT='S04CLR'                                                   
     C                   WHEN      MCS120='5'                                                       
     C                   EVAL      ZXOPT='S05CLR'                                                   
     C                   WHEN      MCS120='6'                                                       
     C                   EVAL      ZXOPT='S06CLR'                                                   
     C                   WHEN      MCS120='7'                                                       
     C                   EVAL      ZXOPT='S07CLR'                                                   
     C                   WHEN      MCS120='8'                                                       
     C                   EVAL      ZXOPT='S08CLR'                                                   
     C                   WHEN      MCS120='9'                                                       
     C                   EVAL      ZXOPT='S09CLR'                                                   
21031C                   WHEN      MCS120='A'                                                       
21031C                   EVAL      ZXOPT='S10CLR'                                                   
     C                   ENDSL                                                                      
     C                   EVAL      PA0SV01=MCVIST                                                   
     C                   ENDIF                                                                      
                                                                                                    
      * ZXMAXVI = Número máximo de vistas en el programa.                                           
      * ( Tendría que ser el mismo que vistas existan en PMPROM )                                   
     C                   EVAL      ZXMAXVI=3                                                        
     C* Recupero el número de vista inicial del SETUP                                               
     C                   IF        PA0SV01>='1' AND PA0SV01 <='3'                                   
     C                   MOVE      PA0SV01       ZXNUMVI                                            
     C                   ELSE                                                                       
     C                   EVAL      ZXNUMVI=1                                                        
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      ERRGRL=*ON                                                       
      * PROTECCIÓN DE LA DELEGACIÓN SEGUN DATOS RECUPERADOS DE LA PURLDA                            
     C                   EVAL      INDPDLG=*ON                                                      
     C                   IF        ZZPPCC>='2'                                                      
     C                   EVAL      INDPDLG=*OFF                                                     
     C                   ENDIF                                                                      
      *                                                                                             
04060C                   TIME                    ZXHORA                                             
      *                                                                                             
CR106 *                                                                le                           
CR106C                   EVAL      PECIAS=ZZCIAS                                                    
CR106C                   EVAL      PECTAB='PORT'                                                    
CR106C                   EVAL      PECLTA='ARTICULO'                                                
CR106C     KPMTABD       CHAIN     PMTABD                                                           
CR106C                   IF        %FOUND                                                           
CR106C                   EVAL      ZXART_PORTES=PEDESC                                              
CR106C                   ELSE                                                                       
CR106C                   EVAL      ZXART_PORTES=*BLANKS                                             
CR106C                   ENDIF                                                                      
FQ876C                   IF        ZXOPCI_IN>*BLANKS                                                
FQ876C                   EVAL      ZXOPT='S00CLR'                                                   
FQ876C                   ENDIF                                                                      
FQ844C                   EVAL      P7CIAS=ZZCIAS                                                    
FQ844C                   EVAL      P7DLGA=ZZDLGA                                                    
FQ844C     KPMEMPR       CHAIN     PMEMPR                                                           
CR785c*                                                                                             
CR785 * Parámetros Riesgo                                                                           
86909C                   eval      zxdnsr = 0                                                       
CR785C                   EVAL      PRCIAS=@PCIAS                                                    
CR785C                   EVAL      PRDLGA=@PDLGA                                                    
CR785C     KCOPRIS       CHAIN     COPRIS                                                           
CR785C                   IF        Not %FOUND(COPRIS)                                               
CR785C                   EVAL      PRDLGA=*BLANKS                                                   
CR785C     KCOPRIS       CHAIN     COPRIS                                                           
CR785C                   ENDIF                                                                      
86909 *                                                                                             
86909C                   if        prdnsr <> *blanks                                                
86909C                   eval      zxdnsr = %int(prdnsr)                                            
86909C                   move      *date         zxdats                                             
86909C                   eval      zxdatf = zxdats + %days(zxdnsr)                                  
86909C                   move      zxdatf        zxdatflp                                           
86909C                   endif                                                                      
