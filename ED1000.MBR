C1632C                   EVAL      THDLGA=@PDLGA                                                    
C1632C     KCOPPEC       CHAIN     COPPEC                                                           
C1632C                   ELSE                                                                       
C1632C                   EVAL      THSIMU='0'                                                       
C1632C                   ENDIF                                                                      
     C* CAPÇALERES D'OPCIONS DEL SFL  (CODIS D'ARXIU DE MISSATGES)                                  
     C                   EVAL      SUFOPC1='OED1000'                                                
     C***                EVAL      SUFOPC2=*BLANKS                                                  
     C* TITOLS DE PANTALLES (CODIS D'ARXIU DE MISSATGES)                                            
     C                   EVAL      CCCCTIT='TED1000'                                                
     C* ACTIVEM EL SFLDSPCTL                                                                        
     C                   EVAL      SFLCTL=*ON                                                       
C1632C                   IF        THSIMU='1' OR THSIMU='2'                                         
C1632C                   EVAL      SUFOPC1='OED1001'                                                
C1632C                   EVAL      CCCCTIT='TED1001'                                                
C1632C                   ENDIF                                                                      
