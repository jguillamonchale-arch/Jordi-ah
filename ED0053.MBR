FH009C                   EVAL      P2ARTRE=T3RTRE                                                   
C1369C                   EVAL      P2ALVIR=T3LVIR                                                   
C1636C                   EVAL      P2AVFYB=T3VFYB                                                   
CR533C                   EVAL      P2AFDSC=T3FDSC                                                   
C2608C                   EVAL      P2APPPP=T3PPPP                                                   
