FGI25 //----------------------------------------------------------------------------------------    
      //----------------------------------------------------------------------------------------    
      //GetExcept: Recuperem excepcions article/proveïdor (segons parms rebuts)                    
         dcl-proc GetExcept;                                                                        
         dcl-pi *n ind;               //valor de retorn                                             
           pcias like(@pcias) value;                                                                
           ptreg like(t4treg) value;                                                                
           pdlga like(@pdlga) value;                                                                
           pprvr like(t4prvr) value;                                                                
           parvt like(t4arvt) value;                                                                
           pfamt like(t4famt) value;                                                                
           pprio like(t4prio) value;                                                                
           pdsArt likeds(dsArt) ;                                                                   
         end-pi;                                                                                    
         dcl-s itemp like(s5line) inz;                                                              
                                                                                                    
           //Mateix codi per article i proveïdor, depenent dels parms                               
             chain (pcias:ptreg:pdlga:pprvr:parvt:pfamt:pprio) edpar2;                              
             if %found(edpar2);                    // Si existeix excepció sempre tindrem un        
               chain (@pcias:t4maga) msalma;       // codi de magatzem NO virtual                   
               if %found(msalma);                                                                   
                 //Guardem aquest magatzem per calcular el Ncoe                                     
                 itemp=  %lookup(m0logs:TAuxExc);                                                   
                 if itemp = 0; // no el teniem                                                      
                   iAuxExc += 1;                                                                    
                   TAuxExc(iAuxExc) = m0logs;                                                       
                   itemp = iAuxExc;                                                                 
                 endif;                                                                             
                 pDsArt.znMag = kMaxMag + itemp; // Assigno un valor per utilitzar-lo més endeva    
                 pDsArt.zLogFinal = m0logs;                                                         
E7249            //pDsArt.zLogVirtual = Call1411(t4maga:*blanks);                                   
E7249            pDsArt.zLogVirtual = Call1411(t4maga:*blanks:s0dlga);                              
                 pDsArt.zExcpt = *on;                                                               
                 if (m0tal1 = k8 or m0tal1 = k7);                                                   
                   pDsArt.zTpe4 = k2;                                                               
                 else;                                                                              
                   pDsArt.zTpe4 = *blanks;                                                          
                 endif;                                                                             
                 iExcpt += 1     ;  // acumulem línies assignades per Except arti/prov              
E7139          //Txurr_Save('GetExcpt' :*on:Simon_tx);                                              
E7139          //Txurr_Save('Dlga:'+pdlga+' Prv:'+pprvr+' Art:'+ %trim(parvt) +                     
E7139          //           ' ->'+%char(iExcpt)  :*off:Simon_tx);                                   
E7269            if parvt<>*blanks;                                                                 
E7139            Txurr_Save(' ' + %subst(Getmsg(kmsg0028):1:10) + ' Art:' +                         
E7139              %trim(parvt)+  ' -> '+  %trim(Getmsg(kmsg0029)) +': '+ m0logs                    
E7139              :*off:Simon_tx);                                                                 
E7269            else;                                                                              
E7269            Txurr_Save(' ' + %subst(Getmsg(kmsg0028):1:10) + ' Prv:' +                         
E7269              %trim(pprvr)+  ' -> '+  %trim(Getmsg(kmsg0029)) +': '+ m0logs                    
E7269              :*off:Simon_tx);                                                                 
E7269            endif;                                                                             
                 return *on;                                                                        
               endif;                                                                               
             endif;                                                                                 
             return *off;                                                                           
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //GuardaArtS5: guardem dades específiques de línia de comanda                                
         dcl-proc GuardaArtS5;                                                                      
         dcl-pi *n;                                                                                 
           pDsArt likeds(dsArt);// row de Tart                                                      
         end-pi;                                                                                    
                                                                                                    
             pDsArt.zLine = s5line;          //    linea tractada                                   
             pDsArt.zloge     = s5loge;      // logística actual                                    
             pDsArt.zFrep     = s5frep;      // data prevista                                       
             pDsArt.zNcoe     = atoi(%subst(s5ampl:1:2));     // número coenvio                     
             pDsArt.zTdi1     = s5tdi1 ;     // adreça d'entrega... a nivell línia??                
             pDsArt.zImpLin   = cs_importe();// Import calculat de la línia                         
             pDsArt.zCant     = s5cant;      // qty                                                 
             pDsArt.zUnim     = s5unim;      // unitat                                              
             pDsArt.zUni2     = m5unim;                                                             
             pDsArt.zCan2     = pDsArt.zCant;                                                       
             // Separem operatives en funció del tipus de procés                                    
             select;                                                                                
             when gPROC = kPROCSimulacio or                                                         
                  gPROC = kPROCConfirmacio or                                                       
                  gPROC = kPROCForcedHeader;                                                        
             //pDsArt.zProb = ChkObsoleto();                                                        
                pDsArt.zTcoj =                                                                      
                      ChkConjunto(m5cias:m5arti:m5vari:m5mode:m5prvr); // Conjunt                   
               if s5unim <> m5unim;                                                                 
                 pDsArt.zCan2 =                                                                     
                          ChgUnitats(pDsArt.zCant:pDsArt.zUnim:pDsArt.zUni2:                        
                            pDsArt.zArti:pDsArt.zVari:pDsArt.zMode);                                
               endif;                                                                               
             when gPROC = kPROCAddLin;                                                              
               if  s5line = @pline;                                                                 
               //pDsArt.zProb = ChkObsoleto();                                                      
                 pDsArt.zTcoj =                                                                     
                      ChkConjunto(m5cias:m5arti:m5vari:m5mode:m5prvr); // Conjunt                   
                 if s5unim <> m5unim;                                                               
                   pDsArt.zCan2 =                                                                   
                          ChgUnitats(pDsArt.zCant:pDsArt.zUnim:pDsArt.zUni2:                        
                            pDsArt.zArti:pDsArt.zVari:pDsArt.zMode);                                
                                                                                                    
                 endif;                                                                             
               else;                                                                                
                 pDsArt.zLogFinal = s5loge ;     // logística final assignada                       
               endif;                                                                               
             when gPROC = kPROCForcedLin ;                                                          
               if s5line<> @pline; // no és la línia que han afegit                                 
                 pDsArt.zLogFinal = s5loge ;     // logística final assignada                       
               else;                                                                                
               //pDsArt.zProb = ChkObsoleto();                                                      
                 pDsArt.zTcoj =                                                                     
                        ChkConjunto(m5cias:m5arti:m5vari:m5mode:m5prvr); // Conjunt                 
                 if s5unim <> m5unim;                                                               
                   pDsArt.zCan2 =                                                                   
                          ChgUnitats(pDsArt.zCant:pDsArt.zUnim:pDsArt.zUni2:                        
                            pDsArt.zArti:pDsArt.zVari:pDsArt.zMode);                                
                 endif;                                                                             
               endif;                                                                               
             endsl;                                                                                 
             if  pDsArt.zProb <> *blanks;                                                           
               bTenimObso = *on;                                                                    
             endif;                                                                                 
                                                                                                    
             exsr CS_PESOSVOL;                                                                      
                                                                                                    
             return;                                                                                
                                                                                                    
                                                                                                    
C3758C     CS_PESOSVOL   BEGSR                                                                      
C3758                                                                                               
C3758C                   CALL      'MM2686'                                                         
C3758C                   PARM                    @PCIAS                                             
C3758C                   PARM      S5ARTI        @PEARTI                                            
C3758C                   PARM      S5VARI        @PEVARI                                            
C3758C                   PARM      S5MODE        @PEMODE                                            
C3758C                   PARM      S5TCOJ        @PETCOJ                                            
C3758C                   PARM      S5CANT        @PECAST                                            
C3758C                   PARM      S5UNIM        @PEUNST                                            
C3758C                   PARM      0             @PEPBRE                                            
C3758C                   PARM      zZUPES        @PEUPES                                            
C3758C                   PARM      0             @PEVOLB                                            
C3758C                   PARM      ZZUVOL        @PEUVOL                                            
C3758C                   PARM      ZZUMED        @PEUMED                                            
C3758C                   PARM      0             @PENBUL                                            
C3758C                   PARM      *BLANK        @PETPAL                                            
C3758C                   PARM      *BLANK        @PETCT1                                            
C3758C                   PARM      *BLANK        @PEVTC1                                            
C3758C                   PARM      *BLANK        @PEERR                                             
C3758                                                                                               
C3758C                   IF        @PEERR=*blanks                                                   
           Tart(iLarti).zPesLin = @PEPBRE;                                                          
           Tart(iLarti).zVolLin = @PEVOLB;                                                          
C3758C                   ELSE                                                                       
           Tart(iLarti).zPesLin = *zero  ;                                                          
           Tart(iLarti).zVolLin = *zero  ;                                                          
C3758C                   ENDIF                                                                      
C3758C                   ENDSR                                                                      
                                                                                                    
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //GuardaArticle: guardem les dades necessaries en Tart                                       
      // Cridem aquest codi amb una lectura del MSARTI feta                                         
      // El contador de posició de la taula corresponent (Tart o Tcom) es gestiona fora             
         dcl-proc GuardaArticle;                                                                    
         dcl-pi *n;                                                                                 
           pDsArt likeds(dsArt);// row de Tart                                                      
         end-pi;                                                                                    
                                                                                                    
           //iLarti += iLarti;                                                                      
             clear pDsArt;                                                                          
             pDsArt.zArti = m5arti;          // -                                                   
             pDsArt.zVari = m5vari;          // +  Arti, Vari, Mode                                 
             pDsArt.zMode = m5mode;          // -                                                   
             pDsArt.zPrvr = m5prvr ;         // proveïdor de l'article                              
             pDsArt.zSiol = m5siol ;         // article propi                                       
             pDsArt.zNoED = %subst(m5ampl:63:1);                                                    
             pDsArt.zLogFinal = *blanks;     // logística final assignada                           
             pDsArt.zForzado  = *off;        // línia forçada                                       
             pDsArt.zExcpt    = *off;        // logística x excepció                                
             pDsArt.zProb     = *blanks;     // art obsolet                                         
             pDsArt.zProb     = ChkObsoleto();                                                      
             pDsArt.zCost     = GetCost();                                                          
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      // GetCost: Passem el valor de cost per articles obsolets???                                 
         dcl-proc GetCost;                                                                          
         dcl-pi *n like(m5cosu);                                                                    
         end-pi;                                                                                    
         dcl-s xRetorn like(m5cosu);                                                                
                                                                                                    
           select;                                                                                  
           when m5tcos = k0;                                                                        
             xRetorn = m5cosu;                                                                      
           when m5tcos = k1;                                                                        
             xRetorn = m5cosp;                                                                      
           when m5tcos = k2;                                                                        
             xRetorn = m5cosm;                                                                      
           other;                                                                                   
             xRetorn = m5cosu;                                                                      
           endsl;                                                                                   
           return xRetorn;                                                                          
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      // ChkObsoleto : validem si és obsoleto                                                      
         dcl-proc ChkObsoleto;                                                                      
         dcl-pi *n char(2);                                                                         
         end-pi;                                                                                    
         dcl-s xRetorn char(2) inz(*blanks);                                                        
                                                                                                    
           if gChkObso ;  // Obsolets                                                               
             select;                                                                                
             when %subst(m5ampl:49:2) = kOB;                                                        
               xRetorn = kOB;                                                                       
             when %subst(m5ampl:49:2) = kOC;                                                        
               xRetorn = kOC;                                                                       
             endsl;                                                                                 
           endif;                                                                                   
           return xRetorn;                                                                          
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      // ChgUnitats : canvi unitats                                                                
         dcl-proc ChgUnitats;                                                                       
         dcl-pi *n like(s5cant);  // Retorn: qty convertida                                         
           p_cant like(s5cant) const;  // qty                                                       
           p_unim like(s5unim) const;  // uni origen                                                
           p_uni2 like(s5unim) const;  // uni destí                                                 
           p_arti like(s5arti) const;  // arti                                                      
           p_vari like(s5vari) const;  //     vari                                                  
           p_mode like(s5mode) const;  //         mode                                              
         end-pi;                                                                                    
                                                                                                    
         dcl-s xRetorn like(s5cant) inz;                                                            
                                                                                                    
           chain (@pcias:p_arti:p_vari:p_mode:p_unim) pmunal;                                       
           if not %found;                                                                           
             chain (@pcias:p_arti:*blanks:*blanks:p_unim) pmunal;                                   
           endif;                                                                                   
           if %found;                                                                               
             if p6tcof<> k1;                                                                        
               xRetorn = p_cant * p6cofa;                                                           
             else;                                                                                  
               if p6cofa <> 0;                                                                      
                 xRetorn = p_cant / p6cofa;                                                         
               endif;                                                                               
             endif;                                                                                 
             //Ajuste y decimales                                                                   
             xzauxi = xRetorn;                                                                      
             xzdeci= 0 ;    //zxdes0;                                                               
             xzajud= 0 ;    //zxaju0;                                                               
             /copy *libl/qsrdsrc,srd001                                                             
             xRetorn = xzauxi;                                                                      
           else;                                                                                    
             xRetorn = p_cant;                                                                      
           endif;                                                                                   
           return xRetorn;                                                                          
         end-proc;                                                                                  
                                                                                                    
