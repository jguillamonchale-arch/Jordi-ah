IT228 //----------------------------------------------------------------------------------------    
          dcl-pi *n;                                                                                
             @pcias like(s5cias);    //                                                             
             @pdlga like(s5dlga);    //  Clau de la comanda a processar                             
             @pnpco like(s5npco);    //                                                             
             @ptped like(s5tped);    //                                                             
             @pdatp like(s5datp);    //                                                             
             @pnopl like(s5nopl);    //                                                             
             @ppline like(s5line) ;  // número de línia Add-lin o Forced lin ED                     
          end-pi;                                                                                   
      //----------------------------------------------------------------------------------------    
      // Tipus de procés                                                                            
      //           1 ---> Simulació                                                                 
      //           2 ---> Confirmació                                                               
      //           3 ---> Add Lin                                                                   
      //           4 ---> Forced Lin                                                                
      //           5 ---> Forced Header                                                             
      //                                                                                            
      //****************************************************************************************    
      // Main Program                                                                              
      //****************************************************************************************    
      //                                                                                            
      //Generamos el/los ficheros de trabajo deseados en QTEMP                                     
      //Això és per 'conservar' la informació de decisions.                                        
      //En el nostre cas és un mal de cap: No serveixen pel càlcul i s'ha de veure com dimonis     
      // els omplim                                                                                
                                                                                                    
        utipgm('DO0050W':'DO005001':*blanks:*blanks:*blanks:*blanks:                                
                *blanks:*blanks:*blanks:*blanks:*blanks:*blanks:                                    
                *blanks:*blanks);                                                                   
                                                                                                    
        utipgm('DO0051W':'DO0051W1':*blanks:*blanks:*blanks:*blanks:                                
                *blanks:*blanks:*blanks:*blanks:*blanks:*blanks:                                    
                *blanks:*blanks);                                                                   
                                                                                                    
        utipgm('DO0052W':*blanks   :*blanks:*blanks:*blanks:*blanks:                                
                *blanks:*blanks:*blanks:*blanks:*blanks:*blanks:                                    
                *blanks:*blanks);                                                                   
                                                                                                    
        utipgm('DO0053W':*blanks   :*blanks:*blanks:*blanks:*blanks:                                
                *blanks:*blanks:*blanks:*blanks:*blanks:*blanks:                                    
                *blanks:*blanks);                                                                   
                                                                                                    
      //Abrir Ficheros QTEMP                                                                       
        OpenFiles();                                                                                
                                                                                                    
      //Carrega dades per defecte, parms generals                                                  
        if LoadDefault();                                                                           
                                                                                                    
      //Carrega les línies de la comanda, mira excepcions arti - prov, art.serveis, B, etc         
      // Si el procés es AddLin guardem les log. de les línies per emprar-les al carregar magatz    
          LoadArti();                                                                               
                                                                                                    
      //Carrega els magatzems                                                                      
      // Tots, Tots + ME, els de les logístiques emprades, mag amb mtal1=8                          
          if iLPEND > *zero;                                                                        
            LoadMaga();                                                                             
          endif;                                                                                    
                                                                                                    
      //Validacions articles - magatzems - stocks - dates ...                                      
      // Omplim els diferents nivells del cub                                                       
      // Els conjunts també es calculen                                                             
          if iLPEND > *zero;                                                                        
            ValidaTot();                                                                            
          endif;                                                                                    
                                                                                                    
      //Preprocés per especials (ArtiB/Obso)                                                       
E7139 //       if iLPEND > *zero and (gChkArtiB or bTenimObso);                                     
E7139     if iLPEND > *zero and (gChkArtiB or bTenimObso or gChkSS); //Phase3                       
E7374       // Guardem línies pendents actualment per calcular si s'han assignat                    
E7374       iLAux = iLPEND;                                                                         
            ProcessaME(); //Donem sortida a tot el que no conti com punt d'Expedició                
E7374       iArtB = iLAux - iLPEND ;                                                                
          endif;                                                                                    
                                                                                                    
        //Procés fins que estigui tot assignat o no poguem fer-ho                                  
          Dow iLPEND > *zero;                                                                       
          //Hem superat els punts d'expedició?                                                     
           select;                                                                                  
            when iLPEND > *zero and gMaxPE = iPE ; //Arribat al límit                               
            // Tot el que queda s'ha de baixar nivell de validació i intentar assignar-ho           
            // als magatzems que ja hem empleat... per ordre de prioritat, no d'assignació          
            AssignaMagResidual(); //No queden PE disponibles i tenim pendents                       
           when iLPEND > *zero and gMaxPE > iPE ; //Tenim línies pendents d'assignar                
            // Assignem per quantitat de línies que compleixen totes les condicions                 
            // Quan cap magatzem compleix totes les condicions i queden línies pendents hem         
            // de baixar nivell de validació per intentar assignar                                  
            // Es a dir: sortirem de processa amb alguna assignació i un PE disponible menys.       
             Processa(1);                                                                           
           other; // Quins other podem tenir?                                                       
            //                                                                                      
             leave;                                                                                 
           endsl;                                                                                   
         enddo;                                                                                     
        else;  // Errors en LoadDefault                                                             
        // S'han produit errors en Default. Ens assegurem que ED0050W no quedin marques que altr    
        //  programes (ED0060, etc) facin de les seves i ens remenin la comanda                     
           exec sql                                                                                 
             update ed0050w set t2forz='0', t2entd='0'                                              
               where t2line <> 0 ;                                                                  
E7223      if @pline > 0 and gPROC=kPROCForcedLin;                                                  
E7223        exec sql                                                                               
E7223          update codepe set s5tpe4=' '                                                         
E7223           where s5line= :@pline and s5cias= :@pcias and s5dlga= :@pdlga                       
E7223            and s5npco= :@pnpco and s5tped= :@ptped and s5datp= :@pdatp                        
E7223            and s5nopl= :@pnopl;                                                               
E7223      endif;                                                                                   
        endif;  // end LoadDefault                                                                  
                                                                                                    
      //Moure resultats a fitxer                                                                   
        // En aquest punt tenim la informació de les logístiques assignades en la taula d'articl    
        //  que, de fet, són línies de comanda.                                                     
        //   Passem les dades als fitxers:                                                          
        //     Primer les línies i després, si tenim logístiques ED, actualitzar capçalera.         
        // Previament mostrem el resúm de les assignacions i donem opció a cancelar-ho              
        // O mostem informació dels possibles errors/incidencies                                    
          Simon_show();     //Simon                                                                 
                                                                                                    
        if MostraResultat();                                                                        
          UpdateSO();                                                                               
E7139     SaveHst(); //Generem registre en fitxer històric DOOMHT                                   
        endif;                                                                                      
                                                                                                    
      //Tanquem fitxers                                                                            
        CloseFiles();                                                                               
                                                                                                    
      //And that's all folks!                                                                      
        *inlr = *on;                                                                                
                                                                                                    
      //////////////////////////////////////////////////////////////////////////////////////////    
      // Subrutines                                                                                
      //----------------------------------------------------------------------------------------    
        begsr *inzsr;                                                                               
                                                                                                    
     C     *DTAARA       DEFINE    PURLDA        DSLDA                                              
     C                   IN        DSLDA                                                            
     C     KPMUNAL       KLIST                                                                      
     C                   KFLD                    @pCIAS                                             
     C                   KFLD                    P6ARTI                                             
     C                   KFLD                    P6VARI                                             
     C                   KFLD                    P6MODE                                             
     C                   KFLD                    P6UNIM                                             
                                                                                                    
          // Establim valors sql                                                                    
          //exec sql SET OPTION COMMIT = *NONE,                                                     
                    //   CLOSQLCSR = *ENDMOD ;                                                      
                                                                                                    
          @pforce = *blanks;                                                                        
          @pline  = *zeros;                                                                         
          //Informem les vars amb els parms opcionals, si s'escau                                   
          //if %addr(@ppforce) <> *null;                                                            
          //  @pforce = @ppforce;       esbrinem si és forçada per la pila de programes CO0176      
          //endif;                                                                      CO0181      
          if %addr(@ppline)<> *null;                                                                
            @pline = @ppline;                                                                       
          endif;                                                                                    
          // Determinem quin procés executem                                                        
          gPROC = ChkProc();                                                                        
          // Determinem batch/online                                                                
          gJobType = qJobType();                                                                    
          // Si estem en Batch no mirem debug                                                       
          if gJobType = kI; // and gJobType<> kI;  //mod    per no executar-ho                      
            // Debug??                                                                              
            cString = kSS;                                                                          
            pstr    =  getenv(cString);                                                             
            if pstr    = *null ;                                                                    
              bSimon = *off;                                                                        
            else;                                                                                   
              cstr = %str(pstr);                                                                    
              if %len(%trim(cstr)) > 1; // = kDBG ;                                                 
                bSimon = *on;                                                                       
              endif;                                                                                
            endif;                                                                                  
          endif;                                                                                    
          // Carreguem la taula de nivells de validació per emprar                                  
          TLevel(1) = kFinal;                                                                       
          TLevel(2) = kFinalP1;                                                                     
          TLevel(3) = kFinalP2;                                                                     
        endsr;                                                                                      
                                                                                                    
                                                                                                    
      //////////////////////////////////////////////////////////////////////////////////////////    
      // Procediments Interns                                                                      
      //----------------------------------------------------------------------------------------    
                                                                                                    
      //ChkPROC: Determinem quin procés executem                                                   
         dcl-proc ChkPROC;                                                                          
         dcl-pi *n like(s5line) end-pi;                                                             
          dcl-s xRetorn like(s5line) inz;                                                           
          dcl-s xChar char(1) inz;                                                                  
                                                                                                    
          // cerquem els programes de forçat en la pila de programes                                
                                                                                                    
          exec sql                                                                                  
            SELECT 'A' INTO :xChar                                                                  
              FROM TABLE(QSYS2.STACK_INFO('*')) A                                                   
              WHERE PROGRAM_NAME IN ('CO0181', 'CO0176')                                            
              FETCH FIRST 1 ROW ONLY;                                                               
          if sqlcode = 0;  //Trobat: procés forçat                                                  
            @pforce = k1;                                                                           
          else;                                                                                     
            @pforce = k0;                                                                           
          endif;                                                                                    
                                                                                                    
          select;                                                                                   
          when @pline > 0 and @pforce = k1 ;                                                        
            xRetorn = kPROCForcedLin;                                                               
          when @pline = 0 and @pforce = k1 ;                                                        
            xRetorn = kPROCForcedHeader;                                                            
          when @pline > 0 and @pforce <>k1 ;                                                        
          //xRetorn = kPROCAddlin;                                                                  
            xRetorn = kPROCForcedLin;    // co180 i co181 com forced                                
          when @pline = 0 and @pforce <>k1 ;                                                        
            // Aquí podem tenir simulació o confirmació                                             
            // cerquem el programa de simulació en la pila de programes                             
            exec sql                                                                                
              SELECT 'A' INTO :xChar                                                                
               FROM TABLE(QSYS2.STACK_INFO('*')) A                                                  
                WHERE PROGRAM_NAME = 'ED1000'                                                       
                FETCH FIRST 1 ROW ONLY;                                                             
            if sqlcode = 0;                                                                         
              xRetorn = kPROCSimulacio;                                                             
            else;                                                                                   
              xRetorn = kPROCConfirmacio;                                                           
            endif;                                                                                  
          endsl;                                                                                    
          return xRetorn;                                                                           
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //OpenFiles: Obrim fitxers de treball                                                        
         dcl-proc OpenFiles;                                                                        
         dcl-pi *n end-pi;                                                                          
        //open ED0050W;                                                                             
          open DO0050W;                                                                             
          open DO0051W;                                                                             
          open DO0052W;                                                                             
          open DO0053W;                                                                             
          //open DO005001;                                                                          
          open GXSTO0;                                                                              
FGI25     open zaqbal00;                                                                            
FGI25     open mitbal00;                                                                            
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //CloseFiles: Pos eso                                                                        
         dcl-proc CloseFiles;                                                                       
         dcl-pi *n end-pi;                                                                          
        //close ED0050W;                                                                            
FGI25   //close DO0050W;                                                                            
FGI25   //close DO0051W;                                                                            
FGI25   //close DO0052W;                                                                            
FGI25   //close DO0053W;                                                                            
          //close DO005001;                                                                         
FGI25   //close GXSTO0;                                                                             
FGI25     close *all;                                                                               
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //LoadDefault: recuperem paràmetres generals de procés                                       
         dcl-proc LoadDefault;                                                                      
         dcl-pi *n ind;                                                                             
         end-pi;                                                                                    
         dcl-s xRetorn ind inz(*off);                                                               
                                                                                                    
E7139      ctSiED    = GetMsg(kmsg0001);                                                            
E7139      ctNoED    = GetMsg(kmsg0002);                                                            
           gERROR = kNOError  ; // valor x defecte                                                  
           chain (@pcias:@pdlga) edparm;                                                            
           if not %found(edparm) or T3baja = k1 ;                                                   
             // megda                                                                               
             return *off;                                                                           
           endif;                                                                                   
                                                                                                    
