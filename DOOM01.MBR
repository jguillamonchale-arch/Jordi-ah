           LoadMagaObso(); //sense parms: sempre                                                    
         endif;                                                                                     
E7139    //Txurr_Save('LoadMaga':*on:Simon_tx);                                                     
E7139    Txurr_Save(GetMsg(kmsg0030):*on:Simon_tx); // Load Warehouses                              
                                                                                                    
         // Si estem en AddLin sols carreguem els que tinguem en les logístiques emprades           
         // Si estem en Forçatlin sols carreguem els tipus m0tal1=8 de les logístiques emprades     
         // Cerquem la llista d'opcions començant per la més restrictiva                            
                                                                                                    
         // Cerquem opcions x client  TREG = G i dlga                                               
         if LoadMagaDet(@PDLGA:kG :s0cust);                                                         
E7269      Txurr_Save('-Load-'+@PDLGA+'-Cust:'+%trim(s0cust):*off:Simon_tx);                        
           exsr infoDBG;                                                                            
           exsr ChkMagaDFLT;                                                                        
           return;                                                                                  
         endif;                                                                                     
                                                                                                    
         // Cerquem opcions x client  TREG = G i dlga *                                             
         if LoadMagaDet('*':kG :s0cust);                                                            
E7269      Txurr_Save('-Load-  *  '  +'-Cust:'+%trim(s0cust):*off:Simon_tx);                        
           exsr infoDBG;                                                                            
           exsr ChkMagaDFLT;                                                                        
           return;                                                                                  
         endif;                                                                                     
                                                                                                    
         // Cerquem opcions x proc.ped TREG = H i dlga                                              
         if LoadMagaDet(@PDLGA:kH :s0pped);                                                         
E7269      Txurr_Save('-Load-'+@PDLGA+'-PPed:'+%trim(s0pped):*off:Simon_tx);                        
           exsr infoDBG;                                                                            
           exsr ChkMagaDFLT;                                                                        
           return;                                                                                  
         endif;                                                                                     
                                                                                                    
         // Cerquem opcions x proc.ped TREG = H i dlga *                                            
         if LoadMagaDet('*':kH :s0pped);                                                            
E7269      Txurr_Save('-Load-  *  '  +'-PPed:'+%trim(s0pped):*off:Simon_tx);                        
           exsr infoDBG;                                                                            
           exsr ChkMagaDFLT;                                                                        
           return;                                                                                  
         endif;                                                                                     
                                                                                                    
         // Si NO ho trobem cerquem per dlga  TREG = 0                                              
         if LoadMagaDet(@PDLGA:k0 :'     ');                                                        
E7269      Txurr_Save('-Load-'+@PDLGA+'------':*off:Simon_tx);                                      
           exsr infoDBG;                                                                            
           exsr ChkMagaDFLT;                                                                        
           return;                                                                                  
         endif;                                                                                     
                                                                                                    
         // Si NO ho trobem cerquem per dlga = *  TREG = 0                                          
         if LoadMagaDet('*':k0 :'     ');                                                           
E7269      Txurr_Save('-Load-  *  ------':*off:Simon_tx);                                           
           exsr infoDBG;                                                                            
           exsr ChkMagaDFLT;                                                                        
           return;                                                                                  
         endif;                                                                                     
         return;                                                                                    
                                                                                                    
         begsr ChkMagaDFLT;                                                                         
         // Mirem si tenim un maga DFLT. En cas contrari forcem com DFLT el maga de Header          
         if  gDFTmaga = *blanks ;    //NO TENIM MAGA DFLT.                                          
E7139      //Txurr_Save('NO MAGA Default!':*on:Simon_tx);                                           
           iAux = iLmag; //guardem valor                                                            
           if gPROC = kPROCAddLin ;                                                                 
             Tlog(iLlog + 1) = s0loge ; //<-per enganyar a carregamagatzem i el processi            
             bAux = *off;                                                                           
           else;                                                                                    
             bAux = *on;               //<-per enganyar a carregamagatzem i el processi             
           endif;                                                                                   
           clear REDPAR2;                                                                           
           CarregaMagatzem(@pcias:gHDRmaga: bAux);                                                  
           // Com estic forçant que em carregui un magatzem és possible que NO hagi informat        
           // les variables globals                                                                 
           gDFTmaga = Tmag(iLmag).zMaga;  // magatzem i logística per defecte                       
           gDFTloge = Tmag(iLmag).zLoge;    // magatzem i logística per defecte                     
           gDFTpos  = iLmag ;    // posició, en Tmag, del magatzem per defecte                      
           gDFTlogV = Tmag(iLmag).zLogVirtual;  // log virtual x dft                                
           // Per evitar càlculs innecessaris aquest magatzem NO el tindrem en compte               
           // Solament s'utilitzarà per posar el que NO s'hagi pogut colocar en les altres opcio    
           if iLmag > iAux;                                                                         
             iLmag -= 1;                                                                            
           endif;                                                                                   
                                                                                                    
         endif;                                                                                     
         endsr;                                                                                     
                                                                                                    
                                                                                                    
         begsr infoDBG;                                                                             
E7139     Txurr_Save(%trim(GetMsg(kmsg0036)) +' ' + %editc(iLmag - iLmagME:'X')                     
E7139      :*off:Simon_tx);                                                                         
         endsr;                                                                                     
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //LoadMagaObso: Carreguem magatzems especials per Obsolets, ArtiB                            
         dcl-proc LoadMagaObso;                                                                     
         dcl-pi *n end-pi;                                                                          
         dcl-s iCnt like(s5line) inz(*zero);                                                        
                                                                                                    
         //Carreguem tots els registres de MSDDOM per cia/dlga                                      
         // Nota: limitat a deixar 20 elements per resta de Punts d'Expedició                       
                                                                                                    
         open msddom11;                                                                             
         setll (@pcias:@pdlga) msddom11;                                                            
         reade (@pcias:@pdlga) msddom11;                                                            
         dow not %eof(msddom11);                                                                    
           // Hem de guardar info separada per Obsolets i ArtiB                                     
           if xapr01 >k0; //SOLS mirem un camp prioritat. Actualment en tots 4 tenen el mateix v    
                                                                                                    
             chain (xacias:xadlg2) pmempr;                                                          
             if %found(pmempr);                                                                     
               if iLmag  < (kMaxMag - 10);                                                          
                 if CarregaMagatzem(xacias:p7maga:*on);                                             
                   // Dades específiques d'aquestos magatzems                                       
                   Tmag(iLmag).zMagEsp = *on;                                                       
                   if gChkObso;                                                                     
                     Tmag(iLmag).zairOB = xair01;                                                   
                     Tmag(iLmag).zairOC = xair02;                                                   
                     Tmag(iLmag).zaoeOB = xaoe01;                                                   
                     Tmag(iLmag).zaoeOC = xaoe02;                                                   
                   endif;                                                                           
                   if gChkArtiB;                                                                    
                     Tmag(iLmag).zairAB = xair04;                                                   
                     Tmag(iLmag).zaoeAB = xaoe04;                                                   
                   endif;                                                                           
E7139              if gChkSS;                                                                       
E7139                Tmag(iLmag).zairSS = xair03;                                                   
E7139                Tmag(iLmag).zaoeSS = xaoe03;                                                   
E7139                Tmag(iLmag).zpsMax = (atoi(%subst(xaampl:1:5)) + 1)/100;                       
E7139              endif;                                                                           
                 endif;                                                                             
               else;                                                                                
                 return; // Reservem 10 posicion pels PE de cia/dlga                                
               endif;                                                                               
             endif;                                                                                 
           endif;                                                                                   
           reade (@pcias:@pdlga) msddom11;                                                          
         enddo;                                                                                     
         // Guardem la darrera posició emprada                                                      
         iLmagME = iLmag;                                                                           
         close msddom11;                                                                            
                                                                                                    
E7139    //Txurr_Save('LoadMagaObso':*on:Simon_tx);                                                 
E7139    //Txurr_Save('MagME ' + %editc(iLmagME:'X'):*off:Simon_tx);                                
E7139    Txurr_Save(%trim(GetMsg(kmsg0031))+' '+ %editc(iLmagME:'X')                                
E7139              :*off:Simon_tx);//Special Warehouse loaded                                       
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //LoadMagaDet: Recuperem magatzems... aquí sí, finalment!                                    
      // tres parms: Dlga, treg, client (si s'escau)                                                
         dcl-proc LoadMagaDet;                                                                      
         dcl-pi *n ind;               //valor de retorn                                             
           pdlga like(t4dlga) value;      //parm rebut : dlga                                       
           ptreg like(t4treg) value;      //parm rebut : treg                                       
           pPrvr like(t4prvr) value;      //parm client/proc.ped.                                   
         end-pi;                                                                                    
         dcl-s xRetorn ind inz(*off);                                                               
         dcl-s iMag  like(s5line); // position Magatzems, var local                                 
         dcl-s CArvt like(t4arvt);                                                                  
         dcl-s CFamt like(t4famt);                                                                  
         dcl-s CPrvr like(t4prvr);      //parm client/proc.ped.                                     
         dcl-s BKiLmag  like(s5line);    //BackUp iLmag                                             
                                                                                                    
         //Monta clau en funció del tipus d'accés                                                   
         exsr MontaClau;                                                                            
                                                                                                    
         // Guardem el valor actual iLmag per saber si hem carregat magatzems                       
         BKiLmag  = iLmag ;                                                                         
         //                                                                                         
         setll (@pcias:ptreg:pdlga:CPrvr:CArvt:CFamt) edpar2;                                       
         reade (@pcias:ptreg:pdlga:CPrvr:CArvt:CFamt) edpar2;                                       
         dow not %eof(edpar2);                                                                      
           // Hem trobat registre en edpar2, per tant podem considerar que tenim dades, tot i qu    
           // ara hem de validar que les tinguem amb T4PRIO>0                                       
           if t4prio > 0;                                                                           
             exsr RtvEdpar4;                                                                        
             CarregaMagatzem(@pcias:t4maga:*off);                                                   
           endif;                                                                                   
           reade (@pcias:ptreg:pdlga:CPrvr:CArvt:CFamt) edpar2;                                     
         enddo;                                                                                     
                                                                                                    
         if iLmag > BKiLmag; //hem afegit magatzems                                                 
           xRetorn = *on;                                                                           
         else;                                                                                      
           xRetorn = *off;                                                                          
         endif;                                                                                     
                                                                                                    
         return xRetorn;                                                                            
                                                                                                    
         // sbr's de la procedure                                                                   
         //.....................................................................................    
         // Intentem recuperar dades del Edpar4                                                     
         // En aquest fitxer, en teoria, sols tindrem dades dels magatzems m0tal1=8                 
         // Tot i que hi accedim abans de llegir MSALMA, i saber si és un Tal1=8, en procés norm    
         // carreguem entre 20-24 magatzems (obsolets i parametritzats).                            
         //                                                                                         
         begsr RtvEdpar4;                                                                           
           chain (t4cia1:t4treg:t4dlga:t4prvr:t4arvt:t4famt:t4prio:1:                               
                 t4cia2:t4maga) edpar4;                                                             
           if %found(edpar4);                                                                       
             T4OIMP=T6OIMP ;   //Omitir import min.                                                 
             T4OCAP=T6OCAP ;   //Omitir capacidad                                                   
             T4CSTO=T6CSTO ;   //No hi ha informació. Tots els registres a *blanks                  
             T4DFTO=T6DFTO ;                                                                        
             T4COEN=T6COEN ;                                                                        
             T4OPES=T6OPEB ;   //zOpes                                                              
             T4OPEN=T6OPEN ;   // No utilitzat                                                      
             T4OUNI=T6OUNI ;   //zOuni                                                              
           endif;                                                                                   
                                                                                                    
         endsr;                                                                                     
         //.....................................................................................    
         begsr MontaClau;                                                                           
         select;                                                                                    
         when ptreg = kG ; // Customer                                                              
           CFamt = *blanks;                                                                         
           CPrvr = pPrvr;                                                                           
           CArvt = *blanks;                                                                         
         when ptreg = kH ; // Proc.Ped                                                              
           CFamt = pPrvr;                                                                           
           CPrvr = *blanks;                                                                         
           CArvt = *blanks;                                                                         
         when ptreg = k0 ; // Deleg                                                                 
           CFamt = *blanks;                                                                         
           CPrvr = *blanks;                                                                         
           CArvt = *blanks;                                                                         
         endsl;                                                                                     
         endsr;                                                                                     
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //CalculaData: calculem data horitzó                                                         
         dcl-proc CalculaData;                                                                      
         dcl-pi *n like(@pedat1);    // retorn                                                      
           pDays like(T5horz);       // parm rebut                                                  
         end-pi;                                                                                    
         dcl-s idat1 like(@pedat1);  // integer data 1                                              
         dcl-s idat2 like(@pedat1);  // integer data 2                                              
         dcl-s cerr  like(@perro);   // char    error                                               
         dcl-s idies like(@pedays);  // integer dies                                                
         idies = pDays;                                                                             
         idat1 = %dec(%date() : *iso);                                                              
         pCO2611(idat1:idies:idat2:cerr);                                                           
         if cerr <> *blanks;                                                                        
           idat2 = *zero;                                                                           
         endif;                                                                                     
         return idat2;                                                                              
                                                                                                    
         end-proc;                                                                                  
      //----------------------------------------------------------------------------------------    
      //CarregaMagatzem: passem les dades a la taula Tmag                                          
      // Podem venir per càrrega normal (EDPAR2) o per ME (MSDDOM11)                                
      // Si venim per ME no fem preguntes de camps EDPAR2                                           
         dcl-proc CarregaMagatzem;                                                                  
         dcl-pi *n ind;              //retorn                                                       
           picias like(t4cia1);       //parm integer cia                                            
           pcmaga like(T4maga);       //parm char  maga                                             
           pbME   ind const;          //parm BOOLEAN venim de carregar Magatzems Obsolest/ArtiB     
         end-pi;                                                                                    
         dcl-s xRetorn ind inz(*off);                                                               
                                                                                                    
           chain (picias:pcmaga) msalma;                                                            
           // Guardarem el magatzem si (el trobem, evidentment)                                     
           //   Procés de simulació o confirmació : ho carreguem TOT                                
           //   Procés Forçat (Lin o Header): sols els M0TAL1 = 8 (magatzems OL)                    
           //   Procés Afegir Lin : sols els de les logístiques de les altres línies de la coman    
           //   Magatzems Especials (ArtiB/Obso): per Addlin ha d'existir en les logístiques de     
           //      altres línies. Per la resta si arribem aquí es carreguen tots                    
           if %found(msalma) and m0baja <> k1 and                            //registre actiu       
             (( gPROC = kPROCSimulacio ) or (gPROC = kPROCConfirmacio) or    //simulació o confi    
              ( gPROC = kPROCForcedLin    and m0tal1=k8 )              or    //forced lin + OL      
              ( gPROC = kPROCForcedHeader and m0tal1=k8 )              or    //forced Head + OL     
              ( gPROC = kPROCAddLin and %lookup(m0loge:Tlog)> 0)       or  //addlin + log de lin    
              ( gPROC <>kPROCAddLin and pbME ));     //ME: obso/artiB                               
             chain (picias:pcmaga) edpar3;                                                          
             if %found(edpar3) and t5baja <> k1;                           // registre actiu        
               iLmag += 1;                                                                          
               xRetorn = *on;                                                                       
               Tmag(iLmag).zMaga = pcmaga;      // codi magatzem                                    
               Tmag(iLmag).zLoge = m0loge;     // logística magatzem                                
               Tmag(iLmag).zPrvr = m0prvr;     // proveïdor magatzem                                
               Tmag(iLmag).zTal1 = m0tal1;     // tipus magatzem                                    
               if (m0tal1 = k8 or m0tal1 = k7);                                                     
E7249            //Tmag(iLmag).zLogVirtual = Call1411(pcmaga:*blanks);                              
E7249            Tmag(iLmag).zLogVirtual = Call1411(pcmaga:*blanks:s0dlga);                         
E7249            Tmag(iLmag).zWHLO = Call1411(pcmaga:k2:*blanks); // Codi maga en M3                
               else;                                                                                
                 Tmag(iLmag).zLogVirtual = *blanks;                                                 
               endif;                                                                               
               if pbME;                                                                             
                 Tmag(iLmag).zOctI = *on ;   // Omit ctl import                                     
                 Tmag(iLmag).zOctC = *on ;   // Omit ctl capacitat                                  
                 Tmag(iLmag).zOctL = *off;   // Omit ctl lines                                      
                 Tmag(iLmag).zOctS = *off;   // Omit ctl Stock                                      
                 Tmag(iLmag).zOmag = *off;   // Omit maga ?????                                     
                 Tmag(iLmag).zOuni = *zero;                                                         
                 Tmag(iLmag).zOpes = *zero;                                                         
                 Tmag(iLmag).zAmasi= *zero       ;                                                  
               else;                                                                                
                 // Maga x Def: podem tenir, com a França, maga dflt en OL                          
                 // Per tant guardarem com DFLT                                                     
                 //     el marcat com DFLT si NO es ol                                              
                 //     el primer maga NO ol, si encara no tenim valor                              
               //if (t4dfto   = k1      and Tmag(iLmag).zTal1 <> k8) or                             
               //   (gDFTmaga = *blanks and Tmag(iLmag).zTal1 <> k8);                               
                 if (t4dfto   = k1 or gDFTmaga = *blanks) and                                       
                    (Tmag(iLmag).zTal1 <> k8 and Tmag(iLmag).zTal1 <> k7);                          
E7139              //Txurr_Save('MagaDefault:'+pcmaga:*off:Simon_tx);                               
E7139              Txurr_Save(%trim(GetMsg(kmsg0032))+': '+pcmaga                                   
E7139               :*off:Simon_tx);                                                                
                   gDFTmaga = pcmaga;     // magatzem i logística per defecte                       
                   gDFTloge = m0loge;    // magatzem i logística per defecte                        
                   gDFTpos  = iLmag ;    // posició, en Tmag, del magatzem per defecte              
                   gDFTlogV = Tmag(iLmag).zLogVirtual;  // log virtual x dft                        
                 endif;                                                                             
                 // Omit Import min                                                                 
                 Tmag(iLmag).zOctI = CheckChar(t4oimp);                                             
                 // Omit ctl capacitat                                                              
                 Tmag(iLmag).zOctC = CheckChar(t4ocap);                                             
                 // Omit Ctl Lin                                                                    
                 Tmag(iLmag).zOctL = CheckChar(t4clin);                                             
                 // Omit Control stock                                                              
                 Tmag(iLmag).zOctS = CheckChar(t4cstk);                                             
                 // Omit Maga??????                                                                 
                 Tmag(iLmag).zOmag = CheckChar(t4omag);                                             
                 Tmag(iLmag).zOuni = atoi(t4ouni);                                                  
                 Tmag(iLmag).zOpes = atoi(t4opes);                                                  
                 Tmag(iLmag).zAmasi= T5masi     ;                                                   
               endif;                                                                               
               // Comanda Sin Cargo. Prioritzem per sobre d'altres parms.                           
               if gSC and s0tped = kSC;                                                             
                 Tmag(iLmag).zOctI = *on;                                                           
               endif;                                                                               
               Tmag(iLmag).zImpo = t5impo; // Valor Imp mínim                                       
               if t5impo = 0;                                                                       
                 Tmag(iLmag).zOctI = *on;  // Si NO tenim Imp mínim Omitim ctl import               
               endif;                                                                               
               Tmag(iLmag).zDisp = t5disp;                                                          
               Tmag(iLmag).zMLin = T5MLIN;                                                          
               Tmag(iLmag).zMLia = T5MLIA;                                                          
               Tmag(iLmag).zMLiz = T5MLIA;   // var per anar incrementant les línies                
               if T5capa = 0;                                                                       
                 Tmag(iLmag).zCapa = 100;                                                           
               else;                                                                                
                 Tmag(iLmag).zCapa = T5capa;                                                        
               endif;                                                                               
               Tmag(iLmag).zPeso = T5peso;                                                          
               Tmag(iLmag).zVolu = T5Volu;                                                          
               Tmag(iLmag).zhorz = T5horz;                                                          
               Tmag(iLmag).zFhor = CalculaData(T5horz);                                             
               Tmag(iLmag).zPmin = T5pmin;                                                          
               Tmag(iLmag).zNlin  = 0 ;                                                             
               Tmag(iLmag).zAssigRonda = 0;                                                         
               //Si estem forçant Lin també el guardo com maga assignat                             
               //D'aquesta forma si arribem al procés AssignaMagResidual farà el darrer intent      
               if gPROC = kPROCForcedLin;                                                           
                 iLAmag +=1;                                                                        
                 TAmag(iLAmag) = iLmag;                                                             
               endif;                                                                               
             endif;                                                                                 
           endif;                                                                                   
                                                                                                    
           return xRetorn;                                                                          
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //CheckChar: Conversió de char a boolean                                                     
      //   Passem el valor '1' a *on   i la resta a *off                                            
         dcl-proc CheckChar;                                                                        
         dcl-pi *n ind;      // retorn bool                                                         
           pcX like(t4oimp); // parm char                                                           
         end-pi;                                                                                    
         // Vars pròpies                                                                            
         dcl-s xRetorn ind inz(*off);                                                               
                                                                                                    
           if pcX = k1;                                                                             
             xRetorn = *on;                                                                         
           endif;                                                                                   
                                                                                                    
           return xRetorn;                                                                          
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //LoadArti: Carreguem Articles (línies de comanda)                                           
      //          Validacions especifiques, dades addicionals.                                     
      //           Guardem logístiques emprades en procés AddLin                                    
                                                                                                    
         dcl-proc LoadArti;                                                                         
         dcl-pi *n end-pi;                                                                          
         // Vars pròpies                                                                            
         dcl-s bOk ind;                                                                             
         dcl-s iAux like(s5line);                                                                   
         dcl-s cloge like(s5loge) inz;                                                              
         dcl-s cmaga like(m0maga) inz;                                                              
         dcl-s iSer like(s5line) inz;                                                               
         dcl-s iOut like(s5line) inz;                                                               
         dcl-s iIn  like(s5line) inz;                                                               
           //clear Tart;                                                                            
           // Lectura codepe                                                                        
E7139      Txurr_Save(GetMsg(kmsg0027) :*on :Simon_tx);   // 'Load Items'                           
           setll (@pcias:@pdlga:@pnpco:@ptped:@pdatp:@pnopl) codepe;                                
           bOk =*on;                                                                                
           dow not %eof(codepe);                                                                    
             reade(n) (@pcias:@pdlga:@pnpco:@ptped:@pdatp:@pnopl) codepe;                           
             if %eof(codepe);                                                                       
               leave;                                                                               
             endif;                                                                                 
             // Contador registres llegits                                                          
             iIn += 1;                                                                              
                                                                                                    
             // En aquest punt tindrem operatives variades depenent del gPROC                       
             //  gPROC = kPROCSimulacio        carreguem tot, validem tot                           
             //  gPROC = kPROCConfirmacio      carreguem tot, validem tot                           
             //  gPROC = kPROCForcedLin              SOLS carreguem la lin específica i la valid    
             //  gPROC = kPROCForcedHeader      carreguem tot, validem tot                          
             //  gPROC = kPROCAddLin           carreguem tot i, la lin especifica, la validem       
             //                            En aquest cas també gestionem la carrega de magatzems    
             //                          ja que les logístiques disponibles per la nova línia se    
             //                        les emprades en les línies existents de la comanda.          
             //  En TOTS els casos ignorem els articles de servei                                   
                                                                                                    
             // Procés ForcedLin: sols carreguem la lin demanada.                                   
             if gPROC = kPROCForcedLin and S5line <> @pline;                                        
               //ignorem línia                                                                      
               iOut +=1;                                                                            
               iter;                                                                                
             endif;                                                                                 
                                                                                                    
             //Dades addicionals                                                                    
             chain (s5arti:s5vari:s5mode) msarti;                                                   
                                                                                                    
             //Validacions específiques                                                             
             // Article de servei                                                                   
             pectab  = 'TIPG';                                                                      
             peclta = m5tipg;                                                                       
             chain (s5cias:pectab:peclta) pmtabd;                                                   
             if %found(pmtabd) and %trim(pebl61)=k1 ;                                               
               //article de servei: l'ignorem                                                       
               iSer += 1;                                                                           
               iter;                                                                                
             endif;                                                                                 
                                                                                                    
             // Línies tancades o amb quantitats servides:                                          
             //    Sols es poden tenir en compte per processos AddLin o ForceLin                    
             if s5stul = k5  or s5capp> 0;                                                          
               if gPROC = kPROCSimulacio or                                                         
                  gPROC = kPROCConfirmacio or                                                       
                  gPROC = kPROCForcedHeader;                                                        
                  //ignorem línia                                                                   
                   iOut +=1;                                                                        
                   iter;                                                                            
               endif;                                                                               
             endif;                                                                                 
                                                                                                    
             // Separem operatives en funció del tipus de procés                                    
             select;                                                                                
             when gPROC = kPROCSimulacio or                                                         
                  gPROC = kPROCConfirmacio or                                                       
                  gPROC = kPROCForcedHeader;                                                        
               iLarti += 1;                                                                         
               //clear Tart(iLarti) ;                                                               
               GuardaArticle(Tart(iLarti));                                                         
               GuardaArtS5(Tart(iLarti));    //Guardem dades específiques de línia comanda          
               exsr CercaExcept;                                                                    
             when gPROC = kPROCForcedLin;                                                           
               iLarti += 1;                                                                         
               GuardaArticle(Tart(iLarti));                                                         
               GuardaArtS5(Tart(iLarti));   //Guardem dades específiques de línia comanda           
               if s5line = @pline;                                                                  
                 exsr CercaExcept;  // Excepcions sempre                                            
               endif;                                                                               
             when gPROC = kPROCAddLin;                                                              
               if  s5line <> @pline; //Guardem logístiques de les línies                            
                 exsr SaveLogLin;   // existents menys l'afegida                                    
               endif;                                                                               
               iLarti += 1;                                                                         
               GuardaArticle(Tart(iLarti));                                                         
               GuardaArtS5(Tart(iLarti));   //Guardem dades específiques de línia comanda           
               if s5line = @pline;                                                                  
                 exsr CercaExcept;                                                                  
               endif;                                                                               
             endsl;                                                                                 
           enddo;                                                                                   
                                                                                                    
E7139      //Txurr_Save('LoadArti':*on:Simon_tx);                                                   
E7139      //Txurr_Save('In    ' + %editc(iIn:'X'):*off:Simon_tx);                                  
E7139      //Txurr_Save('Out   ' + %editc(iOut:'X'):*off:Simon_tx);                                 
E7139      //Txurr_Save('Serv: ' + %editc(iSer:'X'):*off:Simon_tx);                                 
E7139      //Txurr_Save('iLart ' + %editc(iLarti:'X'):*off:Simon_tx);                               
E7139                                                                                               
E7139      Txurr_Save(' '+%subst(GetMsg(kmsg0033):1:12) + %editc(iIn:'X')                           
E7139           :*off:Simon_tx);    //  Leidos                                                      
E7139      Txurr_Save(' '+%subst(GetMsg(kmsg0034):1:12) + %editc(iOut:'X')                          
E7139           :*off:Simon_tx);   //  Descartados                                                  
E7139      Txurr_Save(' '+%subst(GetMsg(kmsg0035):1:12) + %editc(iSer:'X')                          
E7139           :*off:Simon_tx);   //  Servicio                                                     
E7139      Txurr_Save(' '+%subst(GetMsg(kmsg0036):1:12) + %editc(iLarti:'X')                        
E7139           :*off:Simon_tx); //  Cargados                                                       
E7139      Txurr_Save(' '+%subst(GetMsg(kmsg0028):1:12) + %editc(iExcpt :'X')                       
E7139           :*off:Simon_tx);//  Excepcion                                                       
E7139      Txurr_Save(' '+%subst(GetMsg(kmsg0037):1:12) + %editc(iLPEND:'X')                        
E7139           :*off:Simon_tx);  //  Pendientes                                                    
E7139                                                                                               
           return;                                                                                  
         //.....................................................................................    
         begsr SaveLogLin;                                                                          
           // Si la línia és ED podem tenir una logística virtual                                   
           cmaga = *blanks;                                                                         
           if s5tpe4= k2;                                                                           
             cmaga = s5loge;                                                                        
E7249        //cloge = Call1411(cmaga:k1);                                                          
E7249        cloge = Call1411(cmaga:k1:s0dlga);                                                     
             if cloge <> *blanks; //1411 retorna, en aquest cas, el magatzem                        
               chain (@pcias:cloge) msalma;  //cerquem la logística                                 
               if %found(msalma);                                                                   
                 cloge = m0loge;                                                                    
               endif;                                                                               
             endif;                                                                                 
           endif;                                                                                   
           if cloge = *blanks;                                                                      
             cloge = s5loge;                                                                        
           endif;                                                                                   
           if %lookup(cloge:Tlog)  = 0; //not found                                                 
             iLlog += 1;                                                                            
             Tlog(iLlog) = cloge;                                                                   
             TNcoe(iLlog) = atoi(%subst(s5ampl:1:2));                                               
           endif;                                                                                   
         endsr;                                                                                     
         //.....................................................................................    
                                                                                                    
         begsr CercaExcept;                                                                         
             // 2022/07/21.- Primer afegit                                                          
             // S'ha d'accedir al proveïdor de la fitxa de l'article per veure si tenim un nou      
             //  paràmetre:                                                                         
             //          - logística siempre ED                                                     
             // En cas d'estar informat ho tractem com una excepció                                 
             chain (@pcias:Tart(iLarti).zPrvr) puprov;                                              
             if %found(puprov) and c0baja<>k1;                                                      
               Tart(iLarti).zLogVirtual = %subst(c0amp2:70:3);                                      
               if Tart(iLarti).zLogVirtual <> *blanks;                                              
                 Tart(iLarti).zLogFinal = Tart(iLarti).zLogVirtual;                                 
                 Tart(iLarti).zExcpt = *on;                                                         
                 iExcpt += 1     ;  // acumulem línies assignades per Except arti/prov              
               endif;                                                                               
             endif;                                                                                 
                                                                                                    
             // Restriccions d'article, de proveïdor                                                
             // Aquests assignen directament la logística de sortida                                
             if Tart(iLarti).zLogFinal = *blanks; //si no ho tenim assignat                         
               t4arvt = s5arti + s5vari + s5mode;                                                   
               t4prio = 1;                                                                          
               //Nivell article + dlga                                                              
               if GetExcept(@pcias:kC :@pdlga:*blanks:t4arvt:                                       
                   *blanks:t4prio:Tart(iLarti)) = *off;                                             
                                                                                                    
                 //Nivell article + *                                                               
                 if GetExcept(@pcias:kC :'*':*blanks:t4arvt:                                        
                     *blanks:t4prio:Tart(iLarti)) = *off;                                           
                                                                                                    
                   // Nivell prov + dlga                                                            
                   if GetExcept(@pcias:kB:@pdlga:m5prvr:*blanks:*blanks:                            
                       t4prio:Tart(iLarti)) = *off;                                                 
                                                                                                    
                     // Nivell prov + *                                                             
FGI25          //    GetExcept(@pcias:kB:'*':m5prvr:*blanks:*blanks:                                
FGI25          //      t4prio:Tart(iLarti));                                                        
FGI25                if GetExcept(@pcias:kB:'*':m5prvr:*blanks:*blanks:                             
FGI25                    t4prio:Tart(iLarti)) = *off;                                               
FGI25 // Nova excepció                                                                              
FGI25                  if GetExceptMTOS(@pcias:@pdlga:Tart(iLarti))=*off;                           
FGI25   //               GetExceptMTOS(@pcias:'*':Tart(iLarti));                                    
FGI25                  endif; //nivel MTOS + dlga                                                   
FGI25                endif; //nivel Prov + *                                                        
                   endif; //nivell prov + dlga                                                      
                 endif; //nivell article + *                                                        
               endif; //nivell article + dlga                                                       
             endif;  //si no ho tenim assignat                                                      
             // Si NO hem assignat excepció                                                         
             if Tart(iLarti).zLogFinal = *blanks;                                                   
               iLPEND += 1;                                                                         
               Tpend(iLPEND) = iLarti; //Guardo els elements pendents d'assignar                    
             endif;                                                                                 
         endsr;                                                                                     
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
FGI25 //----------------------------------------------------------------------------------------    
FGI25 //GetExceptMTOS: Cerca d'excepcions MTO/MTS i validació en maga origen                       
FGI25    dcl-proc GetExceptMTOS;                                                                    
FGI25    dcl-pi *n ind;               //valor de retorn                                             
FGI25      pcias like(@pcias) value;                                                                
FGI25      pdlga like(@pdlga) value;                                                                
FGI25      pdsArt likeds(dsArt) ;                                                                   
