      //----------------------------------------------------------------------------------------    
      //ChkConjunto : retorna si és conjunt o no                                                   
         dcl-proc ChkConjunto;                                                                      
         dcl-pi *n like(NDTCOJ);                                                                    
           xcias like(s5cias);                                                                      
           xarti like(s5arti);                                                                      
           xvari like(s5vari);                                                                      
           xmode like(s5mode);                                                                      
           xprvr like(m5prvr);                                                                      
         end-pi;                                                                                    
         // Vars pròpies                                                                            
         dcl-s iA like(s5line);                                                                     
         dcl-s x3arvm like(c3arvm);                                                                 
         dcl-s xRetorn like(NDTCOJ) inz;                                                            
                                                                                                    
           open mscojc;                                                                             
           //open puprcj;  //19/08/2022.- OL2-186                                                   
           //Miramos si es Conjunto de Venta                                                        
           chain (xcias:xarti:xvari:xmode:k4 ) mscojc;                                              
           if %found(mscojc) and ndbaja<k1 ;                                                        
             //19/08/2022.- OL2-186: eliminem tot aquest blok                                       
             ////miramos si es Conjunto de Compra;                                                  
             //chain (xcias:xarti:xvari:xmode:k1 ) mscojc;                                          
             //if %found(mscojc) and ndbaja<k1 ;                                                    
             //  //Si es Conjunto de Ventas y de Compra  validem contra PUPRCJ                      
             //  x3arvm = xarti + xvari + xmode;                                                    
             //  chain (xcias:x3arvm:k1:xprvr) puprcj;                                              
             //  if %found(puprcj);                                                                 
             //    xRetorn = k4;                                                                    
             //  else;                                                                              
             //    xRetorn = *blanks;                                                               
             //  endif;                                                                             
             //else;                                                                                
             //  //Si es Conjunto de Ventas y No de Compra Si lo tratamos                           
             //  xRetorn = k4 ;                                                                     
             //endif;                                                                               
             //19/08/2022.- OL2-186: Add                                                            
             xRetorn = k4 ;                                                                         
             //19/08/2022.- OL2-186: END                                                            
           else;                                                                                    
             //Si No es Conjunto de Venta , Pues no es Conjunto y punto                             
             xRetorn = *blanks;                                                                     
           endif;                                                                                   
           close mscojc;                                                                            
           //close puprcj; //19/08/2022.- OL2-186                                                   
                                                                                                    
           return xRetorn;                                                                          
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //qJobType: tipus de job, interact o batch                                                   
         dcl-proc qJobType;                                                                         
         dcl-pi *n char(1) end-pi;                                                                  
         dcl-pr QUSRJOBI extpgm ;                                                                   
          *n char(32766) options(*varsize) ;                                                        
          *n int(10:0) const ;                                                                      
          *n char(8) const ;                                                                        
          *n char(26) const ;                                                                       
          *n char(16) const ;                                                                       
         end-pr;                                                                                    
         dcl-ds Returned len(86) ;                                                                  
          JobType char(1) pos(61) ;                                                                 
         end-ds;                                                                                    
                                                                                                    
         QUSRJOBI(Returned:%size(Returned):'JOBI0100':'*':'') ;                                     
         return JobType ;                                                                           
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ValidaTot : Validacions referents a Maga-Arti                                              
         dcl-proc ValidaTot;                                                                        
         dcl-pi *n end-pi;                                                                          
         dcl-s iA like(s5line);                                                                     
         dcl-s iM like(s5line);                                                                     
                                                                                                    
         //dbg                                                                                      
E7139   // Txurr_Save('ValidaTot':*on:Simon_tx);                                                    
E7139   // Txurr_Save('Start:' + %char(%timestamp):*off:Simon_tx);                                  
E7139     Txurr_Save(GetMsg(kmsg0038):*on:Simon_tx);                                                
                                                                                                    
                                                                                                    
          open pmcaor01;                                                                            
          open pmcaor08;                                                                            
          open pmdeor05;                                                                            
FGI25   //E7249     open mitbal00;                                                                  
E7249     open utcom0  ;                                                                            
          // Realitzem les validacions de cada 'pis' del cub                                        
          // Bucle Articles (línies de comanda)                                                     
          //  Bucle Magatzems                                                                       
          //    Per cada Article/Magatzem es realitzem totes les validacions                        
          // Si l'article és un conjunt va per un altre banda, similar, i es passen les dades       
          //  sumaritzades (AND) dels componets a l'article pare                                    
          for iA = 1 to iLarti; // per tots els articles carregats                                  
            if Tart(iA).zTcoj = k4;                                                                 
              ComputeConjunt(iA); //Calcula opcions per cada component                              
                                  //i agrupa al row pare                                            
            else;                                                                                   
            for iM = 1 to iLmag; // per tots els magatzems carregats                                
                                                                                                    
             if Tart(iA).zTcoj<> k4;   // No kit                                                    
              // 1er.- Existencia de l'article                                                      
              CArt(iA).CMag(iM).CVal(kExist) =                                                      
                ValExist(Tart(iA):iM:CArt(iA).CMag(iM).CVal(kExist):                                
                                   CArt(iA).CMag(iM).CVal(kM1PROP));                                
              // 2on.- Disponible                                                                   
              CArt(iA).CMag(iM).CVal(kDispo) =                                                      
                ValDisp(Tart(iA):iM:CArt(iA).CMag(iM).CVal(kDispo));                                
              // 3er.- Data horitzó                                                                 
              CArt(iA).CMag(iM).CVal(kFrep) =                                                       
                ValFhor(Tart(iA):iM:CArt(iA).CMag(iM).CVal(kFrep) );                                
              // 4rt.- Pesos Volumns Unitats                                                        
              CArt(iA).CMag(iM).CVal(kPesVol) =                                                     
                ValPesVol(Tart(iA):iM:CArt(iA).CMag(iM).CVal(kPesVol));                             
              // 5é .- Proveïdor                                                                    
              CArt(iA).CMag(iM).CVal(kProv) =                                                       
                ValProv(Tart(iA):iM:CArt(iA).CMag(iM).CVal(kProv));                                 
              // Si el prov no passa ja no farem la crida al ED51                                   
              if CArt(iA).CMag(iM).CVal(kProv) = 0;                                                 
                 CArt(iA).CMag(iM).CVal(kED51) = CArt(iA).CMag(iM).CVal(kProv);                     
              endif;                                                                                
              // 6é .- Número línies assignades                                                     
              CArt(iA).CMag(iM).CVal(kNLin) =                                                       
                ValNlin(Tart(iA):iM:CArt(iA).CMag(iM).CVal(kNLin):                                  
                                    CArt(iA).CMag(iM).CVal(kDispo));                                
             endif;                                                                                 
              // 7é .- Possible FD (ED0051) // per tots els articles, kits inclosos                 
              CArt(iA).CMag(iM).CVal(kED51) =                                                       
                ValED51(Tart(iA):iM:CArt(iA).CMag(iM).CVal(kED51):                                  
                                   CArt(iA).CMag(iM).CVal(kM1PROP):                                 
                                   CArt(iA).CMag(iM).CVal(kxInci));                                 
              // 8é .- Acumula Validacions per Art/Mag: si aquesta combinacio Art/Mag supera tot    
              //                       les validacions.                                             
               ValidaGrpArtMag(iA:iM);                                                              
                                                                                                    
              // Sols per ME (magatzems especials: ArtiB/Obso)                                      
E7139         //       if gChkArtiB or bTenimObso;                                                  
E7139         if gChkArtiB or bTenimObso or gChkSS; //Phase3 add gChkSS                             
                // 9é .- Valida si NO conta PE pel ME                                               
                CArt(iA).CMag(iM).CVal(kNoPE) =                                                     
E7728          // ValidaNoPE(Tart(iA):iM:CArt(iA).CMag(iM).CVal(kFinal));                           
E7728     // Per ArtiB,Obso,SS sols validem contra Disponible                                       
E7728             ValidaNoPE(Tart(iA):iM:CArt(iA).CMag(iM).CVal(kDispo));                           
                //10é .- Valida Final ME                                                            
                CArt(iA).CMag(iM).CVal(kFinalME) =                                                  
                  ValidaFinalME(CArt(iA).CMag(iM).CVal(kFinal):                                     
                                CArt(iA).CMag(iM).CVal(kNoPE));                                     
              else;                                                                                 
                CArt(iA).CMag(iM).CVal(kNoPE) = 0;                                                  
                CArt(iA).CMag(iM).CVal(kFinalME) = 0;                                               
              endif;                                                                                
                                                                                                    
             endfor; // bucle Magatzems                                                             
            endif; // Conjunts                                                                      
          endfor; // Bucle articles                                                                 
                                                                                                    
          close pmcaor01;                                                                           
          close pmcaor08;                                                                           
          close pmdeor05;                                                                           
FGI25   //E7249     close mitbal00;                                                                 
E7249     close utcom0  ;                                                                           
          // En aquest punt ja tenim tot el cub informant excepte la fila iLarti + 1                
          // Aquí sumaritzem, a nivell magatzem, quantes línies compleixen les condicions i, en     
          // pis kFinal, quantes línies compleixen TOTES les condicions                             
          // Pels ME (magatzems especials) tenim 2 línies addicionals                               
          ValidaFinal();                                                                            
         //dbg                                                                                      
E7139   // Txurr_Save('End  :' + %char(%timestamp):*off:Simon_tx);                                  
E7139   // Txurr_Save('>' + %char(ilmag) + ' X ' + %char(iLarti+1) + ' X ' +                        
E7139   //        %char(kFinalME) + ' = ':*off:Simon_tx);                                           
E7139   // Txurr_Save('>' + %char(iLmag * (iLarti+1) * kFinalME)+                                   
E7139   //                   ' Validacions':*off:Simon_tx);                                         
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ChkValorsActuals                                                                           
      //   Aquest és un pas repetitiu en totes les validacions i permet centralitzar accions        
      //  pels processos AddLin i ForcedLin                                                         
         dcl-proc ChkValorsActuals;                                                                 
         dcl-pi *n like(s5line);                                                                    
          pDsArt likeds(dsArt);                                                                     
          pM like(s5line);                                                                          
          pActual like(s5line);                                                                     
         end-pi;                                                                                    
         dcl-s xRetorn like(s5line) inz(*zero);                                                     
                                                                                                    
          select;                                                                                   
          when ( gPROC = kPROCForcedLin ) or ( gPROC = kPROCAddLin ); // Per AddLin / ForcedLin     
            if pDsArt.zLine <> @pline;                     //No és Lin afectada                     
             if Tmag(pM).zLoge = pDsArt.zLogFinal  or         //i té la log d'aquest maga           
              (Tmag(pM).zLogVirtual = pDsArt.zLogVirtual and Tmag(pM).ztal1=k8);                    
               return 1;                                                                            
             else;                                                                                  
               return 0;                                                                            
             endif;                                                                                 
            endif;   // si és la línea afectada realitza les validacions corresponents              
          when pDsArt.zLogFinal <> *blanks;  // Si ja el tenim assignat (per except) forcem a 0     
            return 0;                                                                               
          endsl;                                                                                    
          return pActual;                                                                           
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ValExist: Valida existencia                                                                
      //                                                                                            
         dcl-proc ValExist;                                                                         
         dcl-pi *n like(s5line);                                                                    
          pDsArt likeds(dsArt);                                                                     
          //iA like(s5line);                                                                        
          pM like(s5line);                                                                          
          pActual like(s5line);                                                                     
          piPROP like(s5line); //Valor de l'element del pis kM1PROP                                 
         end-pi;                                                                                    
         dcl-s xRetorn like(s5line) inz(*zero);                                                     
         dcl-s xAuxPrvr like(m0prvr) inz;                                                           
                                                                                                    
          // Comprovacions independents del tipus de validació;                                     
          xRetorn = ChkValorsActuals(pDsArt:pM:pActual);                                            
          if xRetorn <> 999; // Ja hem decidit o ja teniem valor                                    
            return xRetorn;                                                                         
          endif;                                                                                    
                                                                                                    
          chain (@pcias:Tmag(pM).zMaga:pDsArt.zArti                                                 
                  :pDsArt.zVari:pDsArt.zMode)msstok;                                                
                                                                                                    
          select;                                                                                   
          when Tmag(pM).ztal1 = k8;      // Sols per magatzems tal1=8.                              
            select;                                                                                 
            when pDsArt.zNoed = k1; // article NO accepta ED                                        
              xRetorn = 0;                                                                          
            when %found(msstok);                                                                    
              piPROP = atoi(M1PROP); //Propietat article en aquest maga                             
              xRetorn = 1;                                                                          
            other;                                                                                  
              xRetorn = 0;                                                                          
            endsl;                                                                                  
E7249       if xRetorn = 1;                                                                         
E7249       // Accedim al MITBAL per verificar l'estat d'aquest article a M3.                       
E7249       // Ja tenim el CONO en gCONO i WHLO en Tmag(x).zWHLO. Sols ens falta ITNO.              
E7249         if Tmag(pM).zPrvr <> *blanks;                                                         
E7249           xAuxPrvr= Tmag(pM).zPrvr;                                                           
E7249         else;                                                                                 
E7249           xAuxPrvr= pDsArt.zPrvr;                                                             
E7249         endif;                                                                                
E7249         xRetorn = GetStsM3(Tmag(pM).zWHLO:xAuxPrvr:                                           
E7249                    pDsArt.zArti+pDsArt.zVari+pDsArt.zMode:xRetorn);                           
E7249         if xRetorn = 0;                                                                       
E7249           Txurr_Save(cRRd+'M3 status!'+cNGr+'Art:'+ pDsArt.zArti +                            
E7249            ' Whse:'+Tmag(pM).zMaga:*off:Simon_tx);                                            
E7249         endif;                                                                                
E7249       endif;                                                                                  
          other;                                                                                    
            xRetorn = 1;                                                                            
          endsl;                                                                                    
          return xRetorn;                                                                           
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ValDisp: Valida disponible                                                                 
         dcl-proc ValDisp;                                                                          
         dcl-pr pMM1412 extpgm('MM1412');                                                           
          *n like(s5cias);                                                                          
          *n like(s5arti);                                                                          
          *n like(s5vari);                                                                          
          *n like(s5mode);                                                                          
          *n like(@Stok);                                                                           
          *n like(m0baja);                                                                          
          *n like(m0maga);                                                                          
         end-pr;                                                                                    
         dcl-pi *n like(s5line);   // Retorn: 0 o 1                                                 
          pDsArt likeds(dsArt);   // input: ds Article                                              
          piM like(s5line);        // input: posició Taula Magatzems                                
          piActual like(s5line);   // input: valor actual d'aquesta validació                       
         end-pi;                                                                                    
         dcl-s xRetorn like(s5line);                                                                
         dcl-s xDispo like(m1sact) inz(*zero);                                                      
E7139    // Passem la var a global         dcl-s p_Stock like(@Stok) inz;                           
         dcl-s p_Serv like(m0baja) inz;                                                             
E7219     p_Stock=*zero;                                                                            
          // Comprovacions independents del tipus de validació;                                     
          xRetorn = ChkValorsActuals(pDsArt:piM:piActual);                                          
          if xRetorn <> 999; // Ja hem decidit o ja teniem valor                                    
            return xRetorn;                                                                         
          endif;                                                                                    
          //chain (@pcias:Tmag(piM).zMaga:pDsArt.zArti:pDsArt.zVari//Hem fet la lectura en ValEx    
          //      :pDsArt.zMode)msstok;                                                             
          if not %found(msstok);                                                                    
            m1crot = *blanks;                                                                       
          endif;                                                                                    
                                                                                                    
          select;                                                                                   
          // Si tenim Omit ctl stock (els ME sempre ho tenen desactivat)                            
            when Tmag(piM).zOctS;                                                                   
              return 1;                                                                             
E7728     // Si  CtlSobreStock                                                                      
E7728       when gChkSS    and Tmag(piM).zMagEsp;                                                   
E7728         xRetorn = xRetorn; // Check Sobre Stock i Maga Esp: continuem validacions             
          // Validacions per si és un ME (magatzem especial per ArtiB/Obso)                         
            when gChkObso  and Tmag(piM).zMagEsp and pDsArt.zProb <> *blanks; //Valida Obso         
              xRetorn = xRetorn; //Chkobso, MagaObso i article OBSO.. continuem validacions         
            when gChkArtiB and Tmag(piM).zMagEsp; //Valida ArtiB                                    
              if m1crot <> kB;   //Validem la rotació                                               
                return  0;     //ChkArtiB, MagaObso i article NO B                                  
              endif;                                                                                
            when gChkObso  and Tmag(piM).zMagEsp and pDsArt.zProb =  *blanks; //Valida Obso         
              return  0 ; // ChkObso, MagaObso i article NO obso, No ArtiB(hauriem entrat en les    
                           // condicions anteriors.                                                 
          endsl;                                                                                    
          // En aquest punt hem de realitzar els cálculs per validar que                            
          //    Tenim stk per satisfer la línia                                                     
          //    Si està parametritzat, no superem l'estoc mínim (msstok.m1smin)                     
                                                                                                    
          // Càlculs diferents per tipus de magatzem                                                
          select;                                                                                   
          when      Tmag(piM).zTAL1=k8;                                                             
            pMM1412(@pcias:pDsArt.zArti:pDsArt.zVari:                                               
                 pDsArt.zMode:p_Stock:p_Serv:Tmag(piM).zMaga);                                      
          when      Tmag(piM).zTAL1=k7;                                                             
            g1cias = @pcias;                                                                        
            g1maga = Tmag(piM).zMaga;                                                               
            g1arti = pDsArt.zArti ;                                                                 
            g1vari = pDsArt.zVari ;                                                                 
            g1mode = pDsArt.zMode ;                                                                 
            g1cali = kA;                                                                            
                                                                                                    
            chain (g1cias:g1maga:g1arti:g1vari:g1mode:g1cali) gxsto0;                               
                                                                                                    
            //  G1CIAS+G1MAGA gr G1ARTI gr G1VARI gr G1MODE gr  G1CALI gr                           
            //  G1CIAO z3.0 G1MAGO gr G1ARTO grG1VARO gr G1MODO gr G1CALO gr                        
            //                                                                                      
            //                                                                                      
            if %found(gxsto0);                                                                      
              p_Stock = g1sact;                                                                     
            else;                                                                                   
              return 0;    //tal1=7 i no trobem registre                                            
            endif;                                                                                  
          other;                                                                                    
          //m1cias=@pcias;                                                                          
          chain (@pcias:pDsArt.zArti:pDsArt.zVari:pDsArt.zMode:                                     
                  Tmag(piM).zMaga:kA)mssto01;                                                       
            if %found(mssto01) and m1sact> 0 ;                                                      
                                                                                                    
     C                   EVAL      ZXSTDD = 0                                                       
     C                   EVAL      ZXSTKA = 0                                                       
     C                   EVAL      ZXCANS0 = 0                                                      
     C                   EVAL      ZXCANE0 = 0                                                      
     C                   EVAL      ZXDEPO0 = 0                                                      
      * Solo tratamos si el almacén tiene stock                                                     
     C                   EVAL      ZXSTKA=M1SACT                                                    
     C                   EVAL      ZXCANT=1                                                         
      * Busqueda cantidades de stock pdte servir,fabricar,deposito...                               
     C                   EXSR      CS_CANSTOK                                                       
      * Stock disponible                                                                            
     C                   EVAL      ZXSTDD=ZXSTKA-ZXCANS0-ZXCANE0                                    
     C                   IF        ZXDEPO0>0                                                        
     C                   EVAL      ZXSTDD=ZXSTDD-ZXDEPO0                                            
     C                   ENDIF                                                                      
      *                                                                                             
                         p_Stock = zxstdd;                                                          
     C                   ENDIF                                                                      
     C                   ENDSL                                                                      
      *                                                                                             
                                                                                                    
          // Independentment del tal1 del magatzem                                                  
          // p_Stock -> disponible calculat                                                         
          //                                                                                        
          select;                                                                                   
          when p_Stock < pDsArt.zCan2;  //No tenim ni per servir la línia                           
            xRetorn = 0;                                                                            
E7323     when Tmag(piM).zMagEsp;      //Magatzem especial i tenim stock                            
E7323       xRetorn = 1;               //No validem %                                               
          when (p_Stock * Tmag(piM).zDisp/100)< pDsArt.zCan2 and                                    
                          Tmag(piM).zDisp>0;                                                        
            xRetorn = 0;                                                                            
          //when (p_Stock - pDsArt.zCan2) <(pDsArt.zCant * Tmag(piM).zPmin) and                     
          //                Tmag(piM).zPmin>0;                                                      
          //  xRetorn = 0;                                                                          
          when p_Stock - pDsArt.zCan2     < m1smin * Tmag(piM).zPmin / 100  and                     
               m1smin * Tmag(piM).zPmin / 100 <> 0 ;                                                
            xRetorn = 0;                                                                            
          other;                                                                                    
            xRetorn = 1;                                                                            
          endsl;                                                                                    
                                                                                                    
          return xRetorn;                                                                           
          //---------------------                                                                   
      **********************************************************************                        
      *  Busqueda cantidades de stock pdte servir,fabricar,deposito...                              
      **********************************************************************                        
     C     CS_CANSTOK    BEGSR                                                                      
                                                                                                    
     C                   EVAL      @PEDATD=*DATE                                                    
     C                   EVAL      @PEDATH=*DATE                                                    
     C                   MOVE      @PEDATD       ZXDATD                                             
     C                   MOVE      @PEDATH       ZXDATH                                             
     C                   SUBDUR    1000  :*D     ZXDATD                                             
     C                   ADDDUR    1000  :*D     ZXDATH                                             
     C                   MOVE      ZXDATD        @PEDATD                                            
     C                   MOVE      ZXDATH        @PEDATH                                            
                                                                                                    
      * Pendiente de servir                                                                         
           @perro = '1';                                                                            
           @pecant = *zero;                                                                         
           @pecan1=*zero;                                                                           
           pCO2770(@pcias:@pdlga:pDsArt.zArti:pDsArt.zVari:pDsArt.zMode:@petcoj:                    
              @pedatd:@pedath:@pecant:@pecan1:Tmag(piM).zLoge:@pomfde:@perro);                      
     C                   EVAL      ZXCANS0 = @PECANT * ZXCANT                                       
                                                                                                    
      * Pendiente de traspasos depositos                                                            
     C                   EVAL      @PETISE=' '                                                      
                                                                                                    
           @perro = *blanks;                                                                        
           @pecant= 0;                                                                              
           @pecan1 = 0;                                                                             
           pMM2604(@pcias:zzdlga :@pearti:@pevari:@pemode:@petcoj:@pedatd:                          
                   @pedath:@pecant:@pecan1:m1maga:@petise:@perro);                                  
                                                                                                    
     C                   EVAL      ZXDEPO0 = @PECANT * ZXCANT                                       
                                                                                                    
      * Esto solo para empresas que utilizan nuestra produccion                                     
     C                   EVAL      @PECAN1=0                                                        
     C                   EVAL      @PECAN2=0                                                        
b01  C                   IF        ZZTCIA='1' OR ZZTCIA='2'                                         
     C                   EVAL      @PEDATD=*DATE                                                    
     C                   EVAL      @PEDATH=*DATE                                                    
     C                   MOVE      @PEDATD       ZXDATD                                             
     C                   MOVE      @PEDATH       ZXDATH                                             
     C                   SUBDUR    1000  :*D     ZXDATD                                             
     C                   ADDDUR    1000  :*D     ZXDATH                                             
     C                   MOVE      ZXDATD        @PEDATD                                            
     C                   MOVE      ZXDATH        @PEDATH                                            
      * Solo realizaré la búsqued en artículos susceptibles de ser utilizados en                    
      * es decir, que sean estructuras o componentes.                                               
           chain (@pcias:pDsArt.zArti:pDsArt.zVari:pDsArt.zMode) pmcaor01;                          
     C**** KMSARTI00     CHAIN     PMCAOR01                           81                            
b02  C                   IF        not %found(pmcaor01)                                             
           chain (@pcias:pDsArt.zArti:pDsArt.zVari:pDsArt.zMode) pmcaor08;                          
     C**** KMSARTI00     CHAIN     PMCAOR08                           81                            
e02  C                   ENDIF                                                                      
                                                                                                    
      * Búsqueda de las necesidades a tener en cuenta en OF's                                       
     C                   EVAL      @PECAN1=0                                                        
     C                   EVAL      @PECAN2=0                                                        
           chain (@pcias:pDsArt.zArti:pDsArt.zVari:pDsArt.zMode) pmdeor05;                          
     C**** KMSARTI00     CHAIN     PMDEOR05                           81                            
b02  C                   IF        %found(pmdeor05)                                                 
      * Si MÑSNCC>='1', entonces (DOLL) se desea que se presente el                                 
      * material asignado                                                                           
     C                   EVAL      @PERRO=*BLANKS                                                   
                                                                                                    
     C                   CALL      'MM2602'                                                         
     C                   PARM                    @pCIAS                                             
     C                   PARM                    @PEARTI                                            
     C                   PARM                    @PEVARI                                            
     C                   PARM                    @PEMODE                                            
     C                   PARM                    @PEDATD                                            
     C                   PARM                    @PEDATH                                            
     C                   PARM      0             @PECAN1                                            
     C                   PARM      0             @PECAN2                                            
     C                   PARM                    M1MAGA                                             
     C                   PARM                    M5MAGD                                             
     C                   PARM                    @PERRO                                             
e02  C                   ENDIF                                                                      
e01  C                   ENDIF                                                                      
     C                   EVAL      ZXCANE0 = @PECAN2 * ZXCANT                                       
                                                                                                    
     C                   ENDSR                                                                      
          //---------------------                                                                   
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ValFhor: Data horitzó                                                                      
         dcl-proc ValFhor;                                                                          
         dcl-pi *n like(s5line);                                                                    
          pDsArt likeds(dsArt);                                                                     
          piM like(s5line);                                                                         
          piActual like(s5line);                                                                    
         end-pi;                                                                                    
         dcl-s xRetorn like(s5line);                                                                
                                                                                                    
          // Comprovacions independents del tipus de validació;                                     
          xRetorn = ChkValorsActuals(pDsArt:piM:piActual);                                          
          if xRetorn <> 999; // Ja hem decidit o ja teniem valor                                    
            return xRetorn;                                                                         
          endif;                                                                                    
                                                                                                    
          // Depenem del tal1 del magatzem                                                          
          select;                                                                                   
          when TMag(piM).zTal1 = k8;  // Magatzem Operador Logístic                                 
            xRetorn = 1 ;                                                                           
          when Tmag(piM).zMaga = gDFTmaga; // Magatzem per defecte                                  
            xRetorn = 1 ;                                                                           
          other;                                                                                    
            if TMag(piM).zFhor < pDsArt.zFrep;                                                      
              xRetorn = 0  ;                                                                        
            else;                                                                                   
              xRetorn = 1  ;                                                                        
            endif;                                                                                  
          endsl;                                                                                    
          return xRetorn;                                                                           
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ValPesVol: Validem Pesos Volumns Unitats                                                   
         dcl-proc ValPesVol;                                                                        
         dcl-pi *n like(s5line);                                                                    
          pDsArt likeds(dsArt);                                                                     
          piM like(s5line);                                                                         
          piActual like(s5line);                                                                    
         end-pi;                                                                                    
         dcl-s xRetorn like(s5line) inz(*zero);                                                     
                                                                                                    
          // Comprovacions independents del tipus de validació;                                     
          xRetorn = ChkValorsActuals(pDsArt:piM:piActual);                                          
          if xRetorn <> 999; // Ja hem decidit o ja teniem valor                                    
            return xRetorn;                                                                         
          endif;                                                                                    
                                                                                                    
          xRetorn = 1; // Per defecte                                                               
                                                                                                    
          // Pes                                                                                    
          if Tmag(piM).zOpes > pDsArt.zPesLin and Tmag(piM).zOpes > *zero;                          
              xRetorn = 0;                                                                          
          endif;                                                                                    
                                                                                                    
          // Unitats                                                                                
          if Tmag(piM).zOuni > pDsArt.zCan2 and Tmag(piM).zOuni > *zero;                            
            xRetorn = 0;                                                                            
          endif;                                                                                    
                                                                                                    
          //No tenim res per volum??                                                                
                                                                                                    
          return xRetorn;                                                                           
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ValProv : Valida proveïdor                                                                 
         dcl-proc ValProv;                                                                          
         dcl-pi *n like(s5line);                                                                    
          pDsArt likeds(dsArt);                                                                     
          piM like(s5line);                                                                         
          piActual like(s5line);                                                                    
         end-pi;                                                                                    
         dcl-s cPrvr   like(C0prvr) inz;                                                            
         dcl-s iCias   like(c3cias) inz;                                                            
         dcl-s xRetorn like(s5line) inz(*zero);                                                     
         dcl-s iCnt like(s5line) inz;                                                               
                                                                                                    
          // Comprovacions independents del tipus de validació;                                     
          xRetorn = ChkValorsActuals(pDsArt:piM:piActual);                                          
          if xRetorn <> 999; // Ja hem decidit o ja teniem valor                                    
            return xRetorn;                                                                         
          endif;                                                                                    
                                                                                                    
          if Tmag(piM).zPrvr <> *blanks and                                                         
            (Tmag(piM).ztal1 = k8 or Tmag(piM).ztal1=k7);                                           
            cPrvr = Tmag(piM).zPrvr;                                                                
          else;                                                                                     
            cPrvr = pDsArt.zPrvr;                                                                   
          endif;                                                                                    
          iCias = @pcias;                                                                           
          chain (iCias:cPrvr) puprov ;                                                              
          if %found(puprov) ;                                                                       
E7223       //if  %subst(c0amp2:1:1)= k1;                                                           
E7223       if  %subst(c0amp2:1:1)= k1 or %subst(c0amp2:1:1)= k2;                                   
              xRetorn = 1;                                                                          
            else;                                                                                   
              return 0; //no accepta ED, no val la pena mirar res més                               
            endif;                                                                                  
             //  (%subst(c0amp2:1:1)=*blanks or %subst(c0amp2:1:1)=k0);                             
            //if pDsArt.zNoED <> k2;  Ja hem mirat si l'article accepta ED en ValExist              
            //  xRetorn = 0;                                                                        
            //else;                                                                                 
            //  xRetorn = 1;                                                                        
            //endif;                                                                                
          else;                                                                                     
            //Comprobar si el Proveïdor és extern                                                   
            chain (iCias:cPrvr) gxeqpr;                                                             
            if %found(gxeqpr) and q1pgrp=k1;                                                        
              xRetorn = 1;                                                                          
            else;                                                                                   
              xRetorn = 0;                                                                          
            endif;                                                                                  
          endif;                                                                                    
                                                                                                    
          return xRetorn;                                                                           
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //MostraResultat: Montem el resúm de la info a mostrar                                       
         dcl-proc MostraResultat;                                                                   
         dcl-pi *n ind;               //valor de retorn                                             
         end-pi;                                                                                    
         dcl-s xRetorn ind inz(*off);                                                               
E7139    //dcl-s ctsiED char(50);     les passem a global                                           
E7139    //dcl-s ctnoED char(50);     les passem a global                                           
         dcl-s ixX like(s5line);                                                                    
         dcl-s iyY like(s5line);                                                                    
         dcl-s ixI like(s5line);                                                                    
         dcl-s sAux char(1);                                                                        
                                                                                                    
             clear @ptitulo ;                                                                       
             clear txurru;                                                                          
             clear tjob;                                                                            
             //Montem txurru per passar al MSGBOX                                                   
             // 1er. Titol                                                                          
             @ptitulo = cRWh + %trim(GetMsg(kmsg0000)) + CNGr;                                      
                                                                                                    
             // 2on. Guardem textes 'Accepta FD' i 'No Accepta FD' ja que es poden emprar           
             //      varies vegades.                                                                
E7139        //ctSiED    = GetMsg(kmsg0001);                                                        
E7139        //ctNoED    = GetMsg(kmsg0002);                                                        
                                                                                                    
             select;                                                                                
             when gERROR = kErrorTransFP  ; //Error validacions x deft                              
               exsr MontaHeader;                                                                    
               Txurr_Save(GetMsg(kmsg0018)                  :*off:txurru);                          
                                                                                                    
             when gERROR = kErrorClient  ; //Error client no ed i NO simulació                      
               exsr MontaHeader;                                                                    
               Txurr_Save(GetMsg(kmsg0011):*off:txurru);                                            
                                                                                                    
             when gERROR = kErrorPedCompl  ; //Error Pedido Completo NO es pot assignar. queda l    
               exsr MontaHeader;                                                                    
               Txurr_Save(GetMsg(kmsg0020):*off:txurru);                                            
               Txurr_Save(GetMsg(kmsg0021):*off:txurru);                                            
                                                                                                    
             when gERROR = kErrorNotPossible;//Error No s'ha pogut assignar una/totes les línies    
               exsr MontaHeader;                                                                    
               exsr MontaErrorNotPossible;                                                          
               //Txurr_Save('kErrorNotPossible: not be assigned':*off:txurru);                      
               //Txurr_Save(cURd + '.Muesga..............' + cNGr  :*off:txurru);                   
                                                                                                    
             when gPROC = kPROCForcedLin;   //                                                      
               exsr MontaForced;                                                                    
             when gERROR = kNOError  ; //Tot correcte, procés normal                                
               exsr MontaHeader;                                                                    
               exsr MontaNOError;                                                                   
                                                                                                    
             endsl; // <- gERROR                                                                    
                                                                                                    
             //Mostrem finestra                                                                     
             @plongitud = %len(txurru);                                                             
             select;                                                                                
             when gPROC = kPROCSimulacio;                                                           
               @pfuncion = k0;        //  k2;  // F10 confirmar, F12 cancelar                       
             when gERROR <> kNOError ;                                                              
               @pfuncion = k0;                                                                      
             when gPROC = kPROCForcedLin;                                                           
               @pfuncion = k0;        //  k2;  // F10 confirmar, F12 cancelar                       
             when gPROC = kPROCForcedHeader;                                                        
               @pfuncion = k2;        //  k2;  // F10 confirmar, F12 cancelar                       
             when gPROC = kPROCAddLin;                                                              
               @pfuncion = k0;        //  k2;  // F10 confirmar, F12 cancelar                       
             other;                                                                                 
               @pfuncion = k0;                                                                      
             endsl;                                                                                 
                                                                                                    
             if gERROR <> kNOError                                                                  
               or gPROC = kPROCForcedLin                                                            
               or gPROC = kPROCForcedHeader                                                         
               or gPROC = kPROCAddLin;                                                              
E7225         if gJobType = kI; // and gJobType<> kI;  //mod    per no executar-ho                  
               pMSGBOX(@pTitulo:%addr(txurru)+2:@pLongitud:@pFuncion:                               
                     @pRetorno:*on);                                                                
E7225         endif;                                                                                
             endif;                                                                                 
                                                                                                    
             select;                                                                                
             when gPROC = kPROCSimulacio;                                                           
               xRetorn = *on;                                                                       
             when gERROR= kErrorPedCompl  ; //tenim error 3, hem d'actualitzar la capçalera per     
               xRetorn = *on;                                                                       
             when gERROR = kErrorNotPossible;//Error No s'ha pogut assignar una/totes les línies    
               xRetorn = *on;                                                                       
             when gERROR <> kNOError ; // qualsevol altre error no actualitzem                      
               xRetorn = *off;                                                                      
             when gPROC = kPROCConfirmacio;                                                         
               xRetorn = *on;                                                                       
             when gPROC = kPROCForcedLin;                                                           
               xRetorn = *on;                                                                       
             when gPROC = kPROCForcedHeader and @pRetorno <> k2; //NO han acceptat                  
               DesmarcaHeader();                                                                    
               xRetorn = *off;                                                                      
             //  xRetorn = *on;                                                                     
             when gPROC = kPROCAddLin;                                                              
               xRetorn = *on;                                                                       
             when @pfuncion = k2 and @pRetorno = k2; // Si hem demanat confirmació i han accepta    
               xRetorn = *on;                                                                       
             other;                                                                                 
               xRetorn = *off;                                                                      
             endsl;                                                                                 
E7377        if gPROC = kPROCConfirmacio and xRetorn = *off;                                        
E7377          SaveHst(); //Generem registre en fitxer històric DOOMHT                              
E7377        endif;                                                                                 
                                                                                                    
             return xRetorn;                                                                        
                                                                                                    
             //.................................................................................    
             begsr MontaErrorNotPossible;                                                           
                                                                                                    
               Txurr_Save(GetMsg(kmsg0017)           :*off:txurru);                                 
               Txurr_Save(*blanks                    :*off:txurru);                                 
                                                                                                    
               for ixX = 1 to iLArti;  //Busquem tots els articles assignats a Default              
                 iyY += 1;                                                                          
                                                                                                    
               //if Tart(ixX).znMag = gDFTpos;  // logística x defecte                              
               //                                                                                   
               //  for iyY = (iLmagME + 1) to iLmag; //Busquem els magatzems OL                     
               //                                                                                   
               //    if Tmag(iyY).zTal1 = k8;                                                       
               //      // Revisem quins valors tenim a 0                                            
               //      if cArt(ixX).cMag(iyY).cVar(kExist) = *zero;                                 
               //                                                                                   
               //                                                                                   
               //    endif;                                                                         
               //  endfor;                                                                          
               //endif;                                                                             
                                                                                                    
               endfor;                                                                              
               Txurr_Save(%trim(GetMsg(kmsg0009)) +' '+gDFTloge+':'+                                
                      %char(iyY) :*off:txurru);                                                     
             endsr;                                                                                 
             //.................................................................................    
             begsr MontaForced ;                                                                    
               Txurr_Save(GetMsg(kmsg0009)+ ':'      :*off:txurru);                                 
               if gPROC = kProcForcedLin;                                                           
                 Txurr_Save(' -> ' + tart(1).zLogFinal :*on:txurru);                                
               else;                                                                                
                 exsr MontaLogAssign;                                                               
               endif;                                                                               
               Txurr_Save(GetMsg(kmsg0010)           :*off:txurru);                                 
             endsr;                                                                                 
             //.................................................................................    
             begsr MontaLogAssign;                                                                  
               // Recorrem Magatzems Assignats i montem la info:                                    
               //                                                                                   
               for ixX = 1 to iLAmag;                                                               
                 clear tjob;                                                                        
                 if (Tmag(TAmag(ixX)).ztal1=k8 or Tmag(TAmag(ixX)).ztal1=k7);                       
                 //tjob = cRGr+ Tmag(TAmag(ixX)).zMaga + ' ' +                                      
                 //            %char(Tmag(TAmag(ixX)).zNlin) + cNGr;                                
                   tjob = cRGr+ Tmag(TAmag(ixX)).zMaga + cNGr;                                      
                 else;                                                                              
                 //tjob = ' ' +Tmag(TAmag(ixX)).zMaga + ' ' +                                       
                 //                 %char(Tmag(TAmag(ixX)).zNlin);                                  
                   tjob = ' ' +Tmag(TAmag(ixX)).zMaga + ' ' ;                                       
                 endif;                                                                             
               //Txurr_Save(tjob  :*off:txurru);                                                    
                 Txurr_Save(%char(Tmag(TAmag(ixX)).zNlin) + ' ' +                                   
                      %trim(GetMsg(kmsg0003)) + ' ' + %trim(tjob)                                   
                                  :*off:txurru);                                                    
               endfor;                                                                              
             endsr;                                                                                 
             //.................................................................................    
             begsr MontaNOError;                                                                    
               exsr MontaLogAssign;                                                                 
                                                                                                    
               // 5é.  Recorrem Arti cercant Excepcions i montem la info:                           
               //     número de línies -> assignades per Excepció                                   
               for ixX = 1 to iLarti;                                                               
                 if Tart(ixX).zExcpt;                                                               
                   ixI += 1;                                                                        
                 endif;                                                                             
               endfor;                                                                              
               if ixI > *zero;                                                                      
                 Txurr_Save(%char(ixI) +' '+ %trim(GetMsg(kmsg0019))   :                            
                            *off:txurru);                                                           
               endif;                                                                               
               // linea en blank                                                                    
               Txurr_Save(*blanks                                :*off:txurru);                     
                                                                                                    
               // 6é.  Literal de conformitat:                                                      
               //      Està d'accord amb el resultat? Premi F-10                                    
               //      En cas contrari premi F-12 i la comanda NO serà modificada                   
               Txurr_Save(GetMsg(kmsg0004)                       :*off:txurru);                     
               Txurr_Save(GetMsg(kmsg0005)                       :*off:txurru);                     
             endsr;                                                                                 
             //.................................................................................    
             begsr MontaHeader;                                                                     
               //     Client    : accepta o no                                                      
               if gEDClient;                                                                        
                 tjob = cNWh + %trim(ctSiED) + cNGr;                                                
               else;                                                                                
                 tjob = cRRd + %trim(ctNoED) + cNGr;                                                
               endif;                                                                               
               Txurr_Save(%subst(GetMsg(kmsg0014):1:8) + ' ' + s0cust + ' ' +                       
                  %subst(s0des1:1:30-(%len(%trim(tjob))))+ %trim(tjob):*off:                        
                           txurru);                                                                 
               clear tjob;                                                                          
               //     Fpag      : accepta o no                                                      
               if gEDFPag;                                                                          
                 tjob = cNWh + %trim(ctSiED) + cNGr;                                                
               else;                                                                                
                 tjob = cRRd + %trim(ctNoED) + cNGr;                                                
               endif;                                                                               
               Txurr_Save(%subst(GetMsg(kmsg0016):1:10)+'    '+s0fpag+'    '+                       
                  %subst(cFormaPago:1:30-(%len(%trim(tjob))))+ %trim(tjob):*off:                    
                           txurru);                                                                 
               clear tjob;                                                                          
               //     Transport : accepta o no                                                      
               if gEDTrans;                                                                         
                 tjob = cNWh + %trim(ctSiED) + cNGr;                                                
               else;                                                                                
                 tjob = cRRd + %trim(ctNoED) + cNGr;                                                
               endif;                                                                               
               Txurr_Save(%subst(GetMsg(kmsg0015):1:13)+' '+s0ttta+'   '+                           
                  %subst(n1des1:1:30-(%len(%trim(tjob))))+ %trim(tjob):*off:                        
                           txurru);                                                                 
               clear tjob;                                                                          
                                                                                                    
E7377 // Si s'han produit errors en LoadDefault NO tenim informació per l'históric                  
E7377          if %len(Simon_tx) < 50;                                                              
E7377            Simon_tx = txurru;                                                                 
E7377          endif;                                                                               
               // Add 1 lin en blank                                                                
               Txurr_Save(*blanks:*off:txurru);                                                     
             endsr;                                                                                 
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //UpdateSO: Actualitza la comanda                                                            
      //  Passem la logística assignada i calculem el valor per s5ncoe                              
      //  O, en cas de PedidoCompleto i no poder assignar, no toquem les línies i sols bloquejem    
      //   la capçalera                                                                             
      //                                                                                            
         dcl-proc UpdateSO;                                                                         
         dcl-pi *n end-pi;                                                                          
         dcl-s xRetorn ind inz(*off);                                                               
         dcl-s iA like(s5line);                                                                     
                                                                                                    
         // 24/11/2022.- Parlat amb Toni: no lck header i deixar les línies amb resultat del càl    
         // Error de pedido completo gERROR = k3                                                    
         //if gERROR= kErrorPedCompl ;                                                              
         //  chain (@pcias:@pdlga:@pnpco:@ptped:@pdatp:@pnopl) cocape;                              
         //  s0phld = k1;  //Pedido retenido                                                        
         //  s0rhld = k1;  //RETENER RESERVAS AUT                                                   
         //  update rcocape;                                                                        
         //  return; //sortim i no toquem res més                                                   
         //endif;                                                                                   
         // Per si de cas netejem el fitxer Do0052w                                                 
         exsr Clear0052w;                                                                           
E7139    chain (@Pcias:@Pdlga) pmempr;                                                              
                                                                                                    
         For iA = 1 to iLarti;                                                                      
                                                                                                    
           select;                                                                                  
           when ( gPROC = kPROCSimulacio ) or (gPROC = kPROCConfirmacio) ; //simulació o confirm    
             Tart(iA).zLogFinal = GetVirtual(iA);                                                   
             Tart(iA).zNNcoe = GetCoenvio(iA);                                                      
             UpdateCodepe(iA);                                                                      
           when ( gPROC = kPROCForcedLin ) ;                  //forced lin:Sols mod 1 lin           
             if Tart(iA).zLine = @pline;                                                            
               Tart(iA).zLogFinal = GetVirtual(iA);                                                 
               Tart(iA).zNNcoe = Tart(iA).zNcoe; // Deixem el valor que tenia                       
               UpdateCodepe(iA);                                                                    
             endif;                                                                                 
           when ( gPROC = kPROCForcedHeader )  ;               //forced Head                        
             Tart(iA).zLogFinal = GetVirtual(iA);                                                   
             Tart(iA).zNNcoe = GetCoenvio(iA);                                                      
             UpdateCodepe(iA);                                                                      
           when ( gPROC = kPROCAddLin );                      //Addlin: Sols mod 1 lin              
             if Tart(iA).zLine = @pline;                                                            
               Tart(iA).zLogFinal = GetVirtual(iA);                                                 
               Tart(iA).zNNcoe = Tart(iA).zNcoe; // Deixem el valor que tenia                       
               UpdateCodepe(iA);                                                                    
             endif;                                                                                 
           endsl;                                                                                   
         endfor;                                                                                    
         //Mirem si actualitzem capçalera                                                           
         if s0tpe4 <> k2 and gTPE4 or gS0COEN <> %subst(s0ampl:1:1);                                
           chain (@pcias:@pdlga:@pnpco:@ptped:@pdatp:@pnopl) cocape;                                
           if gS0COEN <> %subst(s0ampl:1:1);                                                        
             %subst(s0ampl:1:1) = gS0COEN;                                                          
           endif;                                                                                   
           if s0tpe4 <> k2;                                                                         
             s0tpe4 = k2;                                                                           
           endif;                                                                                   
           update rcocape;                                                                          
         endif;                                                                                     
                                                                                                    
         return;                                                                                    
         //.....................................................................................    
         begsr Clear0052w;                                                                          
                                                                                                    
           exec sql                                                                                 
             delete from do0052w where d2cias>0;                                                    
                                                                                                    
         endsr;                                                                                     
         //.....................................................................................    
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //UpdateCodepe                                                                               
      //                                                                                            
      // Passem les dades al fitxer (sols una vegada)                                               
         dcl-proc UpdateCodepe;                                                                     
         dcl-pi *n ;                                                                                
           iA like(s5line);       //parm: posició on estem de Tart                                  
         end-pi;                                                                                    
                                                                                                    
         dcl-s xRetorn like(s5loge);                                                                
         dcl-s xA like(s5line);                                                                     
         dcl-s iLine like(s5line) inz;                                                              
         dcl-s xInci char(3) inz;                                                                   
                                                                                                    
         // Lectura amb lck del codepe                                                              
         chain                                                                                      
           (@pcias:@pdlga:@pnpco:@ptped:@pdatp:@pnopl:Tart(iA).zLine) codepe;                       
         // Movem els camps LOGE, NCOE, TPE4                                                        
         if Tart(iA).zLogFinal <> s5loge;                                                           
           s5loge = Tart(iA).zLogFinal ;                                                            
         endif;                                                                                     
         if Tart(iA).ztpe4 <> s5tpe4;                                                               
           s5tpe4 = Tart(iA).ztpe4;                                                                 
         endif;                                                                                     
         s5ncoe = %subst(%editc(Tart(iA).zNNcoe:'X'):2:2);                                          
E7377    if gs0coen=k3;                                                                             
E7377      s5ncoi='00';                                                                             
E7377      s5ncof='00';                                                                             
E7377    endif;                                                                                     
                                                                                                    
         // Update                                                                                  
         update rcodepe;                                                                            
                                                                                                    
         // Si la logística assignada NO es d'un magatzem m0tal1=8 hem de desmarcar el              
         // corresponent registre en ED0050W per evitar que, algun pgm simpatic com ED0060,         
         // ens ho torni a canviar.                                                                 
         iLine = Tart(iA).zLine;                                                                    
         if Tart(iA).ztpe4 <> k2;                                                                   
           exec sql                                                                                 
             update ed0050w set t2forz='0', t2entd='0'                                              
               where t2line = :iLine ;   // :Tart(iA).zLine;                                        
         else;                                                                                      
           if Tart(iA).znMag > *zero and Tart(iA).znMag < (iLmag + 1);                              
             //xInci = %char(CArt(iA).CMag(Tart(iA).znMag).CVal(kxInci));                           
             xInci = %editc(CArt(iA).CMag(Tart(iA).znMag).CVal(kxInci):'X');                        
           else;                                                                                    
             xInci = *blanks;                                                                       
           endif;                                                                                   
           exec sql                                                                                 
             update ed0050w set t2forz='0', t2entd='1', t2inci=:xInci                               
               where t2line = :iLine ;   // :Tart(iA).zLine;                                        
         endif;                                                                                     
                                                                                                    
         // Gravem el registre en DO0052W per tal que ED1000W mostri la informació correcte         
         clear RDO0052W;                                                                            
         select;                                                                                    
         when Tart(iA).zExcpt = *on;                                   //Excepció Article/Proveï    
           d2treg = kz;                                                                             
           d2va23 = 1;                                                                              
         when Tart(iA).zProb = kob and Tmag(Tart(iA).znMag).zMagEsp;   //Obsolets OB                
           d2treg = kz;                                                                             
           d2va05 = 1;                                                                              
         when Tart(iA).zProb = koc and Tmag(Tart(iA).znMag).zMagEsp;   //Obsolets OC                
           d2treg = kz;                                                                             
           d2va21 = 1;                                                                              
         when Tmag(Tart(iA).znMag).zMagEsp;                            //Articles B                 
           d2treg = kz;                                                                             
           d2va14 = 1;                                                                              
         when Tart(iA).znMag = iLmagME + 1; //Primera opció de magatzems                            
           d2treg = k0;                                                                             
           d2va23 = 1;                                                                              
         when Tart(iA).znMag = gDFTpos; // Magatzem per defecte                                     
           d2treg = k0;                                                                             
           d2va23 = 2;                                                                              
         when Tart(iA).znMag > iLmagME + 1; //Següent opció de magatzems                            
           d2treg = k0;                                                                             
           d2va23 = 3;                                                                              
         other;                                                                                     
           d2treg = kz;                                                                             
           d2va23 = 1;                                                                              
         endsl;                                                                                     
         // Movem la info de la clau                                                                
         d2cias = @pcias;                                                                           
         d2dlga = @pdlga;                                                                           
         d2npco = @pnpco;                                                                           
         d2tped = @ptped;                                                                           
         d2datp = @pdatp;                                                                           
         d2nopl = @pnopl;                                                                           
         d2line = Tart(iA).zLine;                                                                   
                                                                                                    
         write RDO0052W;                                                                            
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //GetVirtual                                                                                 
      //                                                                                            
      // Decidim si apliquem virtual o ho deixem tal qual                                           
         dcl-proc GetVirtual;                                                                       
         dcl-pi *n like(s5loge);  //Valor de retorn: logística                                      
           zA like(s5line);       //parm: posició on estem de Tart                                  
         end-pi;                                                                                    
                                                                                                    
         dcl-s xRetorn like(s5loge);                                                                
         dcl-s iM like(s5line);                                                                     
                                                                                                    
         xRetorn = Tart(zA).zLogFinal;         //Retornem el mateix valor per defecte               
                                                                                                    
         //if Tart(zA).zSiol <> k2 and Tart(zA).zTpe4 = k2;                                         
         select;                                                                                    
         when Tart(zA).zExcpt = *on; //assignat x excepció                                          
           if Tart(zA).zLogVirtual <> *blanks;     //Si tenim informat log virtual                  
             xRetorn = Tart(zA).zLogVirtual;       //El retornem                                    
           endif;                                                                                   
         when %trim(Tart(zA).zTpe4)= k2 and                                                         
           (cArt(zA).cMag(Tart(zA).znMag).cVal(kM1PROP) <> 1 and                                    
            cArt(zA).cMag(Tart(zA).znMag).cVal(kM1PROP) <> 2);                                      
           if Tart(zA).zLogVirtual <> *blanks;     //Si tenim informat log virtual                  
             xRetorn = Tart(zA).zLogVirtual;       //El retornem                                    
           endif;                                                                                   
         endsl;                                                                                     
                                                                                                    
         return xRetorn;                                                                            
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //Call1411                                                                                   
      //                                                                                            
      // Cerquem la logística virtual , sempre serà un tal1=8                                       
      // Cridem aquest codi sempre que el magatzem sigui tal1=8 durant la càrrega de magatzems      
      // Encara que NO sabem si aquest Mag serà emprat li cerquem el virtual. Si aquest Mag és      
      // emprat ja tindrem el valor i ens estalviem fer la crida a cada línia de comanda.           
      //                                                                                            
         dcl-proc Call1411;                                                                         
         dcl-pi *n like(s5loge);                                                                    
           zMag like (m0maga);                                                                      
           ztipo char(1) const;                                                                     
E7249      zDLGA like(s0dlga) const;                                                                
         end-pi;                                                                                    
                                                                                                    
         dcl-s cresp  like(@peresp);                                                                
         dcl-s xRetorn like(s5loge);                                                                
         dcl-s iM like(s5line);                                                                     
                                                                                                    
E7249    //pMM1411(s0cias:zMag:ztipo:s0dlga:cresp);                                                 
E7249    pMM1411(s0cias:zMag:ztipo:zDLGA:cresp);                                                    
         if cresp <> *blanks;                                                                       
           xRetorn = cresp;                                                                         
         endif;                                                                                     
         return xRetorn;                                                                            
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //GetCoenvio                                                                                 
      //                                                                                            
         dcl-proc GetCoenvio;                                                                       
         dcl-pi *n like(s5line);                                                                    
           //zCoe like(s5line);  // valor coenvio                                                   
           iA   like(s5line); //element de Tart                                                     
         end-pi;                                                                                    
                                                                                                    
         dcl-s xRetorn like(s5line);                                                                
                                                                                                    
                                                                                                    
         select;                                                                                    
         when gS0COEN = k0; // Coenvio 0: totes les línies amb el mateix valor = 00                 
           xRetorn = *zero;                                                                         
         when gS0COEN = k1; // Coenvio 1: totes les línies amb el mateix valor = 01                 
           xRetorn = 1;                                                                             
         when gS0COEN = k2; // Coenvio 2: línies agrupades per lógística                            
           //xRetorn = 1;    //   zCoe;                                                             
           xRetorn = SaveAmag(Tart(iA).znMag);                                                      
           //MUESGATION                                                                             
         when gS0COEN = k3; // Coenvio 3: totes les línies amb el mateix valor = 00                 
           xRetorn = *zero;                                                                         
         endsl;                                                                                     
                                                                                                    
         if Tart(iA).zSiol <> k2 and Tart(iA).zTpe4 = k2;                                           
           if %subst(P7AMP2:10:1) = k1;                                                             
             xRetorn = CS_EXCEPM3(iA:xRetorn);                                                      
           endif;                                                                                   
         endif;                                                                                     
                                                                                                    
         return xRetorn;                                                                            
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //CS_EXCEPM3: cerca excepció M3                                                              
         dcl-proc CS_EXCEPM3;                                                                       
         dcl-pi *n like(s5line);                                                                    
          iA like(s5line);  //posició de Tart                                                       
          iActual like(s5line);  //valor actual                                                     
         end-pi;                                                                                    
         dcl-s xRetorn like(s5line) inz;                                                            
                                                                                                    
         xRetorn = iActual;                                                                         
                                                                                                    
         if Tart(iA).zExcpt;   // assignat per excepció                                             
           return xRetorn;                                                                          
         endif;                                                                                     
                                                                                                    
         if Tmag(Tart(iA).znMag).zPrvr <> *blanks;                                                  
           C3prvr = Tmag(Tart(iA).znMag).zPrvr ;                                                    
         else;                                                                                      
           C3prvr = Tart(iA).zPrvr ;                                                                
         endif;                                                                                     
         C3arvm = Tart(iA).zArti + Tart(iA).zVari + Tart(iA).zMode;                                 
         chain (@pcias:C3prvr:C3arvm) puprp0;                                                       
         if %found(puprp0);                                                                         
           @PEdprvr = C3prvr;                                                                       
           if C3ARVP<>*BLANKS;                                                                      
             @PEdARVP = C3ARVP;                                                                     
           else;                                                                                    
             @PEdARVP = C3arvm;                                                                     
           endif;                                                                                   
         else;                                                                                      
           @PEdARVP = C3arvm;                                                                       
IT228      @PEdPRVR = Tart(iA).zPrvr ;                                                              
         endif;                                                                                     
         if Tmag(Tart(iA).znMag).zLogVirtual <> *blanks;                                            
           @PEdAlm1= Tmag(Tart(iA).znMag).zLogVirtual ;                                             
         else;                                                                                      
           @PEdAlm1= Tmag(Tart(iA).znMag).zLoge ;                                                   
         endif;                                                                                     
IT228 *                                                                                    Z        
IT228C                   CALL      'ED2530'                                                Z        
IT228C                   PARM                    @pCIAS                                    Z        
IT228C                   PARM                    @pedprvr                                  Z        
IT228C                   PARM                    @PEdARVP                                  Z        
IT228C                   PARM                    @PEdALM1                                  Z        
IT228C                   PARM                    @PEdALM2                                  Z        
IT228C                   PARM                    @PEINFO                                   Z        
IT228 *                                                                                    Z        
IT228C                   IF        @PEINFO='A' OR @PEINFO='P'                   1          Z        
            xRetorn = 0;                                                                            
IT228 *                                                                         I          Z        
IT228C                   ENDIF                                                  1          Z        
IT228 *                                                                                             
                                                                                                    
            return xRetorn;                                                                         
                                                                                                    
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //GetMsg: Agafem el texte                                                                    
         dcl-proc GetMsg;                                                                           
         dcl-pi *n like(@ptitulo);                                                                  
          xmsgID like(p_msgID) value;                                                               
         end-pi;                                                                                    
         // Variables pel RTVMSGTXT                                                                 
         dcl-s   p_library char(10) inz('*LIBL     ');                                              
         dcl-s   p_msgf char(10)    inz('ASGMSG    ');                                              
         dcl-s   p_msgID char(10) ;                                                                 
         dcl-s   p_msgdata char(500) inz;                                                           
         dcl-s   p_msgTEXT like(string_t);                                                          
         dcl-s   string_t varchar(2048) template;                                                   
                                                                                                    
         dcl-s xRetorn like(@ptitulo) inz;                                                          
         //RtvMsgTxt: Recupera texte de missage file                                               
         dcl-pr pRtvMsgTxt     extpgm('RTVMSGTXT');                                                 
           *n like(p_library);                                                                      
           *n like(p_msgF);                                                                         
           *n like(p_msgID);                                                                        
           *n like(p_msgData);                                                                      
           *n like(string_t);                                                                       
         end-pr;                                                                                    
                                                                                                    
             p_msgID = xmsgID;                                                                      
             pRtvMsgTxt(p_library:p_msgf:p_msgID:p_msgdata:p_msgTEXT);                              
             xRetorn  = %trim(p_msgTEXT);                                                           
                                                                                                    
             return xRetorn;                                                                        
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ValNlin: número de línies                                                                  
         dcl-proc ValNlin;                                                                          
         dcl-pi *n like(s5line);                                                                    
          pDsArt likeds(dsArt);        // Fitxa article                                             
          piM like(s5line);            // Número (posició) del magatzem                             
          piActual like(s5line);       // Valor actual d'aquesta validació                          
          piDispo  like(s5line);       // Valor validació disponible                                
         end-pi;                                                                                    
         dcl-s xRetorn like(s5line) inz(*zero);                                                     
                                                                                                    
          // Comprovacions independents del tipus de validació;                                     
          xRetorn = ChkValorsActuals(pDsArt:piM:piActual);                                          
          if xRetorn <> 999; // Ja hem decidit o ja teniem valor                                    
            return xRetorn;                                                                         
          endif;                                                                                    
                                                                                                    
          // Sols per magatzems locals, tal1 < 8                                                    
          select;                                                                                   
          when Tmag(piM).zOctL; //Omit ctl línies activat                                           
            xRetorn = 1;                                                                            
          when TMag(piM).ztal1 < k7 and piDispo = 1; // maga Locals i que tinguin estoc             
            if TMag(piM).zMLiz < TMag(piM).zMlin; // lin.Max < lin actuals + les calculades         
              TMag(piM).zMliz += 1;                                                                 
              xRetorn = 1;                                                                          
            else;                                                                                   
              xRetorn = 0;                                                                          
            endif;                                                                                  
          when TMag(piM).ztal1 < k7 and piDispo<> 1; // maga Locals i que NO tinguin estoc          
            xRetorn = 0;                                                                            
          other;                                                                                    
            xRetorn = 1;                                                                            
          endsl;                                                                                    
          return xRetorn;                                                                           
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ValED51: Pot ser ED? sols per m0tal1 = 8                                                   
         dcl-proc ValED51;                                                                          
         dcl-pi *n like(s5line);                                                                    
          pDsArt likeds(dsArt);                                                                     
          piM like(s5line);                                                                         
          piActual like(s5line);                                                                    
          piM1prop like(s5line);                                                                    
          pixInci  like(s5line);                                                                    
         end-pi;                                                                                    
         dcl-pr pED0051 extpgm('ED0051');                                                           
            *n like(s0cias) const;                                                                  
            *n like(s0dlga) const;                                                                  
            *n like(s0npco) const;                                                                  
            *n like(s0tped) const;                                                                  
            *n like(s0datp) const;                                                                  
            *n like(s0nopl) const;                                                                  
            *n like(s5line) const;                                                                  
            *n like(xdarv1) const;                                                                  
            *n like(xdcom2) const;                                                                  
            *n like(s0cust) const;                                                                  
            *n like(s5tdi1) const;                                                                  
            *n char(3) const;                                                                       
            *n like(xlogi) const;                                                                   
            *n like(xorig) const;                                                                   
            *n like(xInte) const;                                                                   
            *n like(xPerro);                                                                        
            *n like(xInci);                                                                         
            *n like(xLoge);                                                                         
         end-pr;                                                                                    
         dcl-s xdarv1 like(@fdarv1) inz;                                                            
         dcl-s xdcom2 like(@fdarv1) inz;                                                            
         dcl-s xLogi  like(@plogi) inz;                                                             
         dcl-s xOrig like(@porig) inz;                                                              
         dcl-s xInte like(@pinte) inz(1);                                                           
         dcl-s xPerro like(@perro) inz;                                                             
         dcl-s xInci  like(@pinci) inz;                                                             
         dcl-s xLoge  like(s0loge) inz;                                                             
         dcl-s xLine  like(s5line) inz;                                                             
         dcl-s xRetorn like(s5line) inz(*zero);                                                     
                                                                                                    
          // Comprovacions independents del tipus de validació;                                     
          xRetorn = ChkValorsActuals(pDsArt:piM:piActual);                                          
          if xRetorn <> 999; // Ja hem decidit o ja teniem valor                                    
            return xRetorn;                                                                         
          endif;                                                                                    
                                                                                                    
          // Sols per magatzems logístics, tal1 = 7 o 8                                             
          select;                                                                                   
          when TMag(piM).ztal1 = k7 or TMag(piM).ztal1 = k8;                                        
            // Cridem al ED0051 per validar-ho                                                      
            // Si tenim proveïdor del magatzem l'utilitzem. En cas contrari el de l'article         
            if Tmag(piM).zPrvr <> *blanks;                                                          
              if piM1prop = 1 or piM1prop = 2;                                                      
                xLoge = Tmag(piM).zLoge;                                                            
              else;                                                                                 
                xLoge = Tmag(piM).zLogVirtual;                                                      
              endif;                                                                                
            else;                                                                                   
              xLoge = *blanks;                                                                      
            endif;                                                                                  
            if pDsArt.zNoed = k1; //muesga, article NO accepta ED                                   
              xRetorn = 0;                                                                          
            else;                                                                                   
              pED0051(@pcias:@pdlga:@pnpco:@ptped:@pdatp:@pnopl:                                    
                    pDsArt.zLine:xdarv1:xdcom2:s0cust:pDsArt.zTdi1:                                 
                     '403':xLogi:xOrig:xInte:xPerro:xInci:xLoge);                                   
              if xInci = k003 or xInci = k005 or xInci = k019 or xInci=k060;                        
                xRetorn = 0;                                                                        
              else;                                                                                 
                xRetorn = 1;                                                                        
              endif;                                                                                
              pixInci = atoi(xInci);                                                                
          //  if xPerro <> *blanks;                                                                 
          //    if pDsArt.zLine <> 0;                                                               
          //      xLine = pDsArt.zLine;                                                             
          //      exec sql                                                                          
          //        update ed0050w set t2inci=:xInci                                                
          //        where t2line = :xLine;                                                          
          //    endif;                                                                              
          //  endif;                                                                                
            endif;                                                                                  
          other;                                                                                    
            xRetorn = 1;                                                                            
          endsl;                                                                                    
          return xRetorn;                                                                           
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ValidaNoPE: Valida si NO conta punt entrega. Sols ME (magatzems especials: ArtiB/Obso)     
         dcl-proc ValidaNoPE;                                                                       
         dcl-pi *n like(s5line);                                                                    
          pDsArt likeds(dsArt);                                                                     
          iM like(s5line);                                                                          
          xAnterior like(s5line); //Valor del row kFinal                                            
         end-pi;                                                                                    
         dcl-s xRetorn like(s5line) inz(*zero);                                                     
                                                                                                    
          // Si les validacions anterior són 0 posem 0                                              
          if xAnterior = 0;                                                                         
            return 0;                                                                               
          endif;                                                                                    
          // Si ja el tenim assignat (per except) forcem a 0                                        
          if pDsArt.zLogFinal <> *blanks;                                                           
            return 0;                                                                               
          endif;                                                                                    
                                                                                                    
E7139     xRetorn = 0; //Phase3 add                                                                 
          // Sols per ME (magatzems especial)                                                       
          select;                                                                                   
          when pDsArt.zProb = kOB;                                                                  
            if Tmag(iM).zaoeOB = k1;    // No conta punt                                            
              if (pDsArt.zCost * pDsArt.zCan2) > Tmag(iM).zairOB ;  //Control cost                  
                xRetorn = 1;                                                                        
              endif;                                                                                
            else;                                                                                   
              xRetorn = 0;                                                                          
            endif;                                                                                  
          when pDsArt.zProb = kOC;                                                                  
            if Tmag(iM).zaoeOC = k1;  //No conta punt                                               
              if (pDsArt.zCost * pDsArt.zCan2) > Tmag(iM).zairOC ;  //Control cost                  
                xRetorn = 1;                                                                        
              endif;                                                                                
            else;                                                                                   
              xRetorn = 0;                                                                          
            endif;                                                                                  
          other;                                                                                    
            if Tmag(iM).zaoeAB = k1;                                                                
              if (pDsArt.zCost * pDsArt.zCan2) > Tmag(iM).zairAB ;  //Control cost                  
                xRetorn = 1;                                                                        
              endif;                                                                                
E7139         //  else;                                                                             
E7139         //   xRetorn = 0;                                                                     
            endif;                                                                                  
E7139       if Tmag(iM).zaoeSS = k1;                                                                
E7139                                                                                               
E7139         //chain (cia:maga:arti:vari:mode) msstok; //Hem fet la lectura en ValExist            
E7139         if %found(msstok);                                                                    
E7139         // Nota: p_Stock es calcula en ValDisp i és variable global                           
E7139           if (Tmag(iM).zpsMax * m1smax) > (p_Stock - pDsArt.zCan2)                            
E7139              or m1smax = 0;                                                                   
E7139            xRetorn = 0;                                                                       
E7139           else;                                                                               
E7139             if (pDsArt.zCost * pDsArt.zCan2) > Tmag(iM).zairSS ; // SS                        
E7139               xRetorn = 1;                                                                    
E7139             endif;  //zairSS                                                                  
E7139           endif;  // m1smax                                                                   
E7139         endif;  // %found                                                                     
E7139       endif;  // zaoeSS                                                                       
          endsl;                                                                                    
                                                                                                    
          return xRetorn;                                                                           
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ValidaFinalME: Validació final per magatzems especials                                     
         dcl-proc ValidaFinalME;                                                                    
         dcl-pi *n like(s5line);                                                                    
          xValid like(s5line);                                                                      
          xAnterior like(s5line);                                                                   
         end-pi;                                                                                    
         dcl-s xRetorn like(s5line) inz(*zero);                                                     
                                                                                                    
          select;                                                                                   
          when xValid =  1 and xAnterior = 1;                                                       
            xRetorn = 1;                                                                            
          when xValid <> 1 and xAnterior = 1;                                                       
            xRetorn = 0;                                                                            
          when xValid =  1 and xAnterior <> 1;                                                      
            xRetorn = 0;                                                                            
          when xValid <> 1 and xAnterior <> 1;                                                      
            xRetorn = 0;                                                                            
          endsl;                                                                                    
          // Sip, ho sé: innecessari. M'agrada deixar-ho clar i lligat.                             
                                                                                                    
          return xRetorn;                                                                           
         end-proc;                                                                                  
      //----------------------------------------------------------------------------------------    
      //ValidaGrpArtMag: Acumula Validacions per Arti/Maga                                         
         dcl-proc ValidaGrpArtMag;                                                                  
         dcl-pi *n;                                                                                 
          piA like(s5line);  //posició Tart                                                         
          piM like(s5line);  //posició Tmag                                                         
         end-pi;                                                                                    
         dcl-s iI like(s5line) inz;                                                                 
         //dcl-s xA like(s5line) inz;                                                               
         //dcl-s xM like(s5line) inz;                                                               
         dcl-s iacumula like(s5line) inz;                                                           
                                                                                                    
          // Si ja tenim valor NO importa, el MODIFIQUEM sempre.                                    
          // Per TOTS els magatzems, logístics o no, per ArtiB/Obso                                 
          // Acumulem validacions parcials                                                          
          // Parcial 1 : Existencia, Disponibilitat, ED51 i Nlin                                    
          if cArt(piA).cMag(piM).cVal(kExist) = 1   and                                             
             cArt(piA).cMag(piM).cVal(kED51)  = 1   and                                             
             cArt(piA).cMag(piM).cVal(kDispo) = 1   and                                             
             cArt(piA).cMag(piM).cVal(knlin) = 1;                                                   
            Cart(piA).CMag(piM).CVal(kFinalP1) = 1;                                                 
          else;                                                                                     
            Cart(piA).CMag(piM).CVal(kFinalP1) = 0;                                                 
          endif;                                                                                    
          // Parcial 2 : Existencia, ED51 i Nlin                                                    
          if cArt(piA).cMag(piM).cVal(kExist) = 1   and                                             
             cArt(piA).cMag(piM).cVal(kED51)  = 1   and                                             
             cArt(piA).cMag(piM).cVal(knlin) = 1;                                                   
            Cart(piA).CMag(piM).CVal(kFinalP2) = 1;                                                 
          else;                                                                                     
            Cart(piA).CMag(piM).CVal(kFinalP2) = 0;                                                 
          endif;                                                                                    
                                                                                                    
          // kFinal ha d'esser sempre el darrer pis de les validacions                              
          for iI = 1 to kFinal-1;                                                                   
            iacumula +=  Cart(piA).CMag(piM).CVal(iI) ;                                             
          endfor;                                                                                   
                                                                                                    
          if iacumula = (kFinal-1); // Totes les validacions tenen 1                                
            Cart(piA).CMag(piM).CVal(kFinal) = 1;                                                   
          else;                                                                                     
            Cart(piA).CMag(piM).CVal(kFinal) = 0;                                                   
          endif;                                                                                    
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ValidaFinal: Acumula Validacions a nivell Maga                                             
         dcl-proc ValidaFinal;                                                                      
         dcl-pi *n end-pi;                                                                          
         dcl-s iM like(s5line) inz; // Posició Mag                                                  
         dcl-s iV like(s5line) inz; // Posició Pis (Valida)                                         
         dcl-s iA like(s5line) inz; // Posició Pis (Valida)                                         
         dcl-s iacumula like(s5line) inz;                                                           
                                                                                                    
          // Si ja tenim valor NO importa, el MODIFIQUEM sempre.                                    
                                                                                                    
          // Per TOTS els magatzems, logístics o no, per ArtiB/Obso                                 
          // kFinalME ha d'esser sempre el darrer pis de les validacions                            
          //  Després venen els pisos d'acumulats que omplim aquí                                   
          for iM = 1 to iLmag;                                                                      
            for iV = 1 to kFinalME;                                                                 
              iacumula = *zero;                                                                     
              for iA = 1 to iLarti;                                                                 
                iacumula +=  Cart(iA).CMag(iM).CVal(iV) ;                                           
              endfor;                                                                               
              // Assignem el valor en la darrera fila: iLarti + 1                                   
              Cart(iLarti + 1).CMag(iM).Cval(iV) = iacumula;                                        
            endfor;                                                                                 
          endfor;                                                                                   
                                                                                                    
          // Tindrem, el la posició iLarti + 1, el sumatori de línies que compleixen la condició    
          // I en el pis kFinal, el darrer de condicions/validacions, el sumatori de les línies     
          //  que compleixen TOTES les condicions.                                                  
          // I en el pis kFinalME els que compleixen TOTES les condicions i no conta Punt expedi    
          //  pels magatzems especials (ME): ArtiB/Obso                                             
          // I en el pis kFinalP1 i kFinalP2 els que copleixen les condicions parcials de cada c    
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ComputeConjunt: Càlcul de cada component del conjunt                                       
      // Crearem un cub sols pels components del conjunt.                                           
      // Els magatzems són els mateixos que ja hem carregat. Sols queda carregar els                
      //  articles en una taula nova.                                                               
      // I realitzar TOTES les validacions (que són les mateixes) i després passar els resultats    
      //  al cub principal                                                                          
      //                                                                                            
         dcl-proc ComputeConjunt;                                                                   
         dcl-pi *n;                                                                                 
          piA like(s5line); // Article Conjunt: element de Tart.                                    
         end-pi;                                                                                    
E7139 //       dcl-c kMaxCom const(20); // màxim components : passem a var global                   
         dcl-s iC like(s5line) inz;                                                                 
         dcl-s iM like(s5line) inz;                                                                 
         dcl-s iV like(s5line) inz;                                                                 
         dcl-s iLCom like(s5line) inz(*zero);                                                       
         dcl-s iacumula like(s5line) inz;                                                           
         dcl-s iProp   like(s5line) inz;                                                            
         dcl-s bkPROC  like(s5line) inz; // Var per guardar el PROC real                            
olfgi    dcl-s oExcpt like(s5line) inz(*zero); // per guardar el Total de Lin x Except              
olfgi    dcl-s wExcpt  like(s5line) inz(*zero);                                                     
olfgi    dcl-s wLogFinal like(s5loge) inz(*blanks);                                                 
olfgi    dcl-s wLogVirtual like(s5loge) inz(*blanks);                                               
       //Dimensió Components                                                                       
       //  Dimensió Magatzems                                                                      
       //    Dimensió Validacions                                                                  
       dcl-ds xCom qualified dim(kMaxCom); // Aquest cub és molt més petit                          
         dcl-ds xMag dim(kMaxMag); //                                                               
           xVal like(s5line) inz(999) dim(kMaxVal);                                                 
         end-ds;                                                                                    
       end-ds;                                                                                      
       //   xCom(x).xMag(y).xVal(z)  = ....                                                        
olfgi  // Guardem el número de línies assignades x excepció ja que el procés de components pot      
olfgi  // modificar aquest valor i perdem la realitat                                               
olfgi    oExcpt = iExcpt;                                                                           
                                                                                                    
       // 1er: carregar components en TCom                                                          
         iLCom = LoadCom(piA);                                                                      
olfgi  // Retornem el valor de línies assignades x excepció                                         
olfgi    iExcpt = oExcpt;                                                                           
                                                                                                    
       // 2on: realitzar les validacions                                                            
       // Per tal que les validacions siguin correctes i ja que són les mateixes que s'utilitzem    
       // pels articles, les enganyem modificant el valor de gPROC                                  
       // ja que per AddLin o ForcedLin no funciona per components                                  
                                                                                                    
          bkPROC = gPROC; // guardem valor actual                                                   
          gPROC =  kPROCsimulacio;  //modifiquem el valor. Confirmació també serviria               
                                                                                                    
          // Realitzem les validacions de cada 'pis' del cub                                        
          for iC = 1 to iLCom; // per tots els components carregats                                 
             for iM = 1 to iLmag; // per tots els magatzems carregats                               
                                                                                                    
              // 1er.- Existencia de l'article                                                      
              xCom(iC).xMag(iM).xVal(kExist) =                                                      
                ValExist(TCom(iC):iM:xCom(iC).xMag(iM).xVal(kExist):                                
                         xCom(iC).xMag(iM).xVal(kM1PROP));  //Element per guardar Propietat         
              // 2on.- Disponible                                                                   
              xCom(iC).xMag(iM).xVal(kDispo) =                                                      
                ValDisp(TCom(iC):iM:xCom(iC).xMag(iM).xVal(kDispo));                                
              // 3er.- Data horitzó                                                                 
              xCom(iC).xMag(iM).xVal(kFrep) =                                                       
                ValFhor(TCom(iC):iM:xCom(iC).xMag(iM).xVal(kFrep) );                                
              // 4rt.- Pesos, Volumns...                                                            
              xCom(iC).xMag(iM).xVal(kPesVol) =                                                     
                ValPesVol(TCom(iC):iM:xCom(iC).xMag(iM).xVal(kPesVol));                             
              // 5é .- Proveïdor                                                                    
              xCom(iC).xMag(iM).xVal(kProv) =                                                       
                ValProv(TCom(iC):iM:xCom(iC).xMag(iM).xVal(kProv));                                 
              // Si el prov no passa ja no farem la crida al ED51                                   
              if xCom(iC).xMag(iM).xVal(kProv) = 0;                                                 
                 xCom(iC).xMag(iM).xVal(kED51) = xCom(iC).xMag(iM).xVal(kProv);                     
              endif;                                                                                
              // 6é .- Número línies assignades                                                     
              xCom(iC).xMag(iM).xVal(kNLin) =                                                       
                ValNlin(TCom(iC):iM:xCom(iC).xMag(iM).xVal(kNLin):                                  
                                    xCom(iC).xMag(iM).xVal(kDispo));                                
              // 7é .- Possible FD (ED0051)                                                         
              xCom(iC).xMag(iM).xVal(kED51) =                                                       
              //ValED51(TCom(iC):iM:xCom(iC).xMag(iM).xVal(kED51):                                  
                ValED51(TArt(piA):iM:xCom(iC).xMag(iM).xVal(kED51):                                 
                         xCom(iC).xMag(iM).xVal(kM1PROP):      //Element per guardar Propietat      
                         xCom(iC).xMag(iM).xVal(kxInci));    //Element per guardar xInci del ED0    
              // 8é .- Acumula Validacions per Art/Mag: si aquesta combinacio Art/Mag supera tot    
              //                       les validacions.                                             
               exsr ValidaGrpArtMagCom;                                                             
              // Sols per ME (magatzems especials: ArtiB/Obso)                                      
            //if gChkArtiB or bTenimObsoCom; //Tenim component obsolet                              
                // 9é .- Valida si NO conta PE pel ME                                               
                xCom(iC).xMag(iM).xVal(kNoPE) =                                                     
                  ValidaNoPE(TCom(iC):iM:xCom(iC).xMag(iM).xVal(kFinal));                           
                //10é .- Valida Final ME                                                            
                xCom(iC).xMag(iM).xVal(kFinalME) =                                                  
                  ValidaFinalME(xCom(iC).xMag(iM).xVal(kFinal):                                     
                                xCom(iC).xMag(iM).xVal(kNoPE) );                                    
            //endif;                                                                                
                                                                                                    
             endfor; // bucle Magatzems                                                             
          endfor; // Bucle articles                                                                 
                                                                                                    
          gPROC = bkPROC; // restaurem el valor de Procés                                           
                                                                                                    
       // 3er: passar valors a cub principal                                                        
          exsr MouConjunt;                                                                          
                                                                                                    
          return;                                                                                   
                                                                                                    
                                                                                                    
          // sbr propies                                                                            
                                                                                                    
          // Passem la info final al cub principal                                                  
          // Per tal que un article conjunt sigui valid (1) tots els seus components han de ser     
          //  valids pel mateix magatzem/validació                                                  
                                                                                                    
          begsr MouConjunt;                                                                         
                                                                                                    
            for iM = 1 to iLmag;                                                                    
              for iV = 1 to kFinalME;                                                               
                iacumula = *zero;                                                                   
                for iC = 1 to iLCom;                                                                
                  iacumula += xCom(iC).xMag(iM).xVal(iV);                                           
                endfor;                                                                             
                if iacumula = iLCom; //Si tots els components per aquest maga han passat aquesta    
                                    // validació tindrem el mateix valor que el número de compon    
                                   // Per tant l'article conjunt passa aquesta validació per aqu    
                                  // magatzem.                                                      
                  CArt(piA).CMag(iM).CVal(iV) = 1;                                                  
                else;                                                                               
                  CArt(piA).CMag(iM).CVal(iV) = 0;                                                  
                endif;                                                                              
              endfor;                                                                               
              // per m1prop                                                                         
              if Tmag(iM).ztal1 = k8 or Tmag(iM).ztal1 = k7;                                        
                iProp = 2;                                                                          
                for iC = 1 to iLCom;                                                                
                  if xCom(iC).xMag(iM).xVal(kM1PROP) <> 1 and                                       
                     xCom(iC).xMag(iM).xVal(kM1PROP) <> 2;                                          
                     iProp = *zero;                                                                 
                  endif;                                                                            
                endfor;                                                                             
                CArt(piA).CMag(iM).CVal(kM1PROP) = iProp;                                           
              endif;                                                                                
            endfor;                                                                                 
olfgi       // Darrera volta: si tots els componets s'han assignat per excepció                     
olfgi       for iC = 1 to iLCom;                                                                    
olfgi         if TCom(iC).zExcpt ;                                                                  
olfgi           if wLogFinal = *blanks or wLogFinal=Tcom(iC).zLogFinal;                             
olfgi             wExcpt +=1;                                                                       
olfgi             wLogFinal = TCom(iC).zLogFinal;                                                   
olfgi             wLogVirtual= TCom(iC).zLogVirtual;                                                
olfgi           endif;                                                                              
olfgi         endif;                                                                                
olfgi       endfor;                                                                                 
olfgi       // Si tots els components s'han assignat a la mateixa logística x excepció el kit       
olfgi       //   l'hem d'assignar a aquesta logística                                               
olfgi       if wExcpt = iLCom; //total línies assignades x excepció = total components              
olfgi         Tart(piA).zExcpt=*on;                                                                 
olfgi         Tart(piA).zLogFinal= wLogFinal;                                                       
olfgi         Tart(piA).zLogVirtual=wLogVirtual;                                                    
olfgi         iExcpt +=1;                                                                           
olfgi       endif;                                                                                  
            //Per xInci                                                                             
            //iInci = *zeros;                                                                       
            //for iM = 1 to iLmag;                                                                  
            //  if Tmag(iM).ztal1=k8 or Tmag(iM).ztal1=k7;                                          
            //    for iC = 1 to iLCom;                                                              
            //      if xCom(iC).xMag(iM).xVal(kxInci) <> 999 and                                    
            //         xCom(iC).xMag(iM).xVal(kxInci) <> *zero;                                     
            //        iInci = xCom(iC).xMag(iM).xVal(kxInci);                                       
            //      endif;                                                                          
            //    endfor;                                                                           
            //    CArt(piA).CMag(iM).CVal(kxInci) = iInci;                                          
            //    iInci = *zeros;                                                                   
            //  endif;                                                                              
            //endfor;                                                                               
          endsr;                                                                                    
                                                                                                    
          // 'Acumulem' validacions                                                                 
          begsr ValidaGrpArtMagCom;                                                                 
            // Per TOTS els magatzems, logístics o no, per ArtiB/Obso                               
            // kFinal ha d'esser sempre el darrer pis de les validacions                            
            // Acumulem validacions parcials                                                        
            // Parcial 1 : Existencia, Disponibilitat, ED51 i Nlin                                  
            if xCom(iC).xMag(iM).xVal(kExist) = 1   and                                             
               xCom(iC).xMag(iM).xVal(kED51)  = 1   and                                             
               xCom(iC).xMag(iM).xVal(kDispo) = 1   and                                             
               xCom(iC).xMag(iM).xVal(knlin) = 1;                                                   
              xCom(iC).xMag(iM).xVal(kFinalP1) = 1;                                                 
            else;                                                                                   
              xCom(iC).xMag(iM).xVal(kFinalP1) = 0;                                                 
            endif;                                                                                  
            // Parcial 2 : Existencia, ED51 i Nlin                                                  
            if xCom(iC).xMag(iM).xVal(kExist) = 1   and                                             
               xCom(iC).xMag(iM).xVal(kED51)  = 1   and                                             
               xCom(iC).xMag(iM).xVal(knlin) = 1;                                                   
              xCom(iC).xMag(iM).xVal(kFinalP2) = 1;                                                 
            else;                                                                                   
              xCom(iC).xMag(iM).xVal(kFinalP2) = 0;                                                 
            endif;                                                                                  
            //Obsolets i Conjunt no lliguen, com l'aigua i l'oli                                    
            xCom(iC).xMag(iM).xVal(kFinalME) = 0;                                                   
            xCom(iC).xMag(iM).xVal(kNoPE) = 0;                                                      
            // Acumulem per final                                                                   
            iacumula = *zero;                                                                       
            for iV = 1 to kFinal-1;                                                                 
              iacumula +=  xCom(iC).xMag(iM).xVal(iV) ;                                             
            endfor;                                                                                 
                                                                                                    
            if iacumula = (kFinal-1); // Totes les validacions tenen 1                              
              xCom(iC).xMag(iM).xVal(kFinal) = 1;                                                   
            else;                                                                                   
              xCom(iC).xMag(iM).xVal(kFinal) = 0;                                                   
            endif;                                                                                  
                                                                                                    
          endsr;                                                                                    
                                                                                                    
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //LoadCom: carrega taula components                                                          
      //                                                                                            
         dcl-proc LoadCom;                                                                          
         dcl-pi *n like(s5line);  // Retorn número de components carregats                          
          piA like(s5line); // Article Conjunt: element de Tart.                                    
         end-pi;                                                                                    
         dcl-s iI like(s5line) inz(*zero);                                                          
         // Vars pròpies                                                                            
         dcl-s bOk ind;                                                                             
                                                                                                    
           open mscojd;                                                                             
           // Lectura MSCOJD                                                                        
           setll (@pcias:Tart(piA).zArti:                                                           
                 Tart(piA).zVari:Tart(piA).zMode:k4) mscojd;                                        
           reade (@pcias:Tart(piA).zArti:                                                           
                 Tart(piA).zVari:Tart(piA).zMode:k4) mscojd;                                        
           bOk =*on;                                                                                
           dow not %eof(mscojd);                                                                    
             if ndbaja <> k1;                                                                       
                                                                                                    
               //Dades addicionals                                                                  
               chain (ndcomp:ndvar2:ndmod2) msarti;                                                 
                                                                                                    
               // En aquest punt sempre carreguem dades                                             
               iI += 1;                                                                             
               GuardaArticle(TCom(iI));                                                             
               TCom(iI).zCant = Tart(piA).zCant * ndcant;                                           
               TCom(iI).zCan2 = Tart(piA).zCan2 * ndcant;                                           
             //TCom(iI).zProb = ChkObsoleto();                                                      
               exsr CercaExcept;                                                                    
             //if TCom(iI).zProb <> *blanks;                                                        
             //  bTenimObsoCom = *on;                                                               
             //endif;                                                                               
             endif;                                                                                 
             reade (@pcias:Tart(piA).zArti:                                                         
                 Tart(piA).zVari:Tart(piA).zMode:k4) mscojd;                                        
           enddo;                                                                                   
           close mscojd;                                                                            
           return iI;                                                                               
                                                                                                    
         begsr CercaExcept;                                                                         
             // Restriccions d'article, de proveïdor                                                
             if TCom(iI).zLogFinal = *blanks; //si no ho tenim assignat                             
               t4arvt = Tcom(iI).zArti + TCom(iI).zVari + TCom(iI).zMode ;                          
               t4prio = 1;                                                                          
               //Nivell article                                                                     
               if GetExcept(@pcias:kC :@pdlga:*blanks:t4arvt:*blanks:t4prio:                        
                 TCom(iI))= *off;                                                                   
                 // Nivell prov                                                                     
                 GetExcept(@pcias:kB:@pdlga:m5prvr:*blanks:*blanks:t4prio:                          
                   TCom(iI));                                                                       
               endif;                                                                               
             endif;                                                                                 
         endsr;                                                                                     
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ProcessaME: processa magatzems especials                                                   
      // Donem sortida a totes les línies de ME que NO carreguin punt expedició                     
      // No ens preocupem de controlar PE, donem sortida a TOT el que es pugui                      
         dcl-proc ProcessaME;                                                                       
         dcl-pi *n end-pi;                                                                          
         dcl-s iM like(s5line) inz;                                                                 
                                                                                                    
E7139    // Txurr_Save('ProcessaME':*on:Simon_tx);                                                  
E7139    // Txurr_Save('->iLPEND:'+ %char(iLPEND):*off:Simon_tx);                                   
E7139    Txurr_Save(GetMsg(kmsg0040):*on:Simon_tx); // 'Special Warehouses Process'                 
                                                                                                    
         iM = FindMax(iLarti+1:kFinalME:1:iLmagME); // Cerquem ME                                   
         dow iM <> 0;                                                                               
          if ValidaMaga(iM:kFinalME); // Validem imports per magatzem (sumatori línies)             
E7139       //Txurr_Save('->Assign:'+ %char(iM):*off:Simon_tx);                                     
E7139       Txurr_Save(cRWh+'>'+cNGr+                                                               
E7139           %editc(CArt(iLarti+1).CMag(iM).CVal(kFinalME):'X') +                                
E7139           %trim(GetMsg(kmsg0042))+ ' '+                                                       
E7139           %trim(GetMsg(kmsg0029))+ ': ' + Tmag(iM).zMaga :*off:Simon_tx);                     
            AssignaMag(iM:kFinalME);        // Assignem les línies al magatzem                      
          else;                                                                                     
            RessetMag(iM:kFinalME); // Inicialitzem el pis d'aquest maga per no utilitzar-l'ho      
          endif;                                                                                    
          iM = FindMax(iLarti+1:kFinalME:1:iLmagME); // Cerquem següent ME                          
         enddo;                                                                                     
                                                                                                    
E7139    //Txurr_Save('<-iLPEND:'+ %char(iLPEND):*off:Simon_tx);                                    
E7139    Txurr_Save(%trim(GetMsg(kmsg0037))+':'+ %char(iLPEND):*off:Simon_tx);                      
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //Processa: processa magatzems                                                               
      // Donem sortida a totes les línies per un PE                                                 
      // Sortirem del bucle quan:                                                                   
      //       - Hem assignat línies a un PE                                                        
      //       - NO hem pogut assignar res de res                                                   
      // Si NO hem pogut assignar ens cridem a nosaltres mateixos reduïnt criteris                  
      // Si SI hem pogut assignar sortim                                                            
      //                                                                                            
      // Els criteris de validació els tenim en la taula TLevel. Aquesta taula sols té el valor     
      //  del pis que agafem com referent de validació.                                             
      // Per exemple, tenim en TLevel els valors 08, 09 i 10 que corresponent a kFinal,kFinalP1     
      // (Nota:sols tenim 3 nivells de validació, per tant mai ens cridarem amb un valor superio    
      //                                                                                            
      // En el bucle principal valida si queden PE utilitzables i, en cas afirmatiu, ens tornarà    
      //  cridar.                                                                                   
      //                                                                                            
         dcl-proc Processa;                                                                         
         dcl-pi *n ;                                                                                
          piLevel like(s5line) value; //Nivell de validació                                         
         end-pi;                                                                                    
         dcl-s iM like(s5line) inz;                                                                 
         dcl-s bOk ind inz(*off);                                                                   
                                                                                                    
E7139    //Txurr_Save('Processa':*on:Simon_tx);                                                     
E7139    //Txurr_Save('->iLPEND:'+ %char(iLPEND)+'-> Level:'+%char(piLevel):*off:                   
E7139    //         Simon_tx);                                                                      
E7139                                                                                               
E7139    Txurr_Save(%trim(GetMsg(kmsg0041))+' L->'+%editc(piLevel:'X')                              
E7139     :*on:Simon_tx); // 'Main Process'                                                         
E7139                                                                                               
         iM = FindMax(iLarti+1:TLevel(piLevel):iLmagME + 1:iLmag); // Cerquem Magatzem              
         dow iM <> 0;                                                                               
           // s0coen <> 1 O (s0coen=1 Y podem subministrar TOTES les línies)                        
           if gS0COEN <>k1 OR (gS0COEN=k1 AND                                                       
              CArt(iLarti+1).CMag(iM).CVal(TLevel(piLevel)) = iLPEND);                              
             if ValidaMaga(iM:TLevel(piLevel)); // Validem imports per magatzem (sumatori línies    
E7139          //Txurr_Save('->Assign:'+ %char(iM):*off:Simon_tx);                                  
E7139          Txurr_Save(cRWh+'>'+cNGr+                                                            
E7139           %editc(CArt(iLarti+1).CMag(iM).CVal(TLevel(piLevel)):'X') +                         
E7139           %trim(GetMsg(kmsg0042))+ ' '+                                                       
E7139           %trim(GetMsg(kmsg0029))+ ': ' + Tmag(iM).zMaga :*off:Simon_tx);                     
               AssignaMag(iM:TLevel(piLevel));  // Assignem les línies al magatzem                  
               bOk = *on;                                                                           
               leave;                                                                               
             else;                                                                                  
               RessetMag(iM:TLevel(piLevel));//Inicialitzem el pis d'aquest maga                    
             endif;                                                                                 
           else; // coen=1 Y no podem subnimistrar TOTES les línies                                 
             RessetMag(iM:TLevel(piLevel));//Inicialitzem el pis d'aquest maga                      
           endif;                                                                                   
          iM = FindMax(iLarti+1:TLevel(piLevel):iLmagME+1:iLmag); // Cerquem següent                
         enddo;                                                                                     
         if bOk = *off;                                                                             
           if piLevel < %elem(TLevel);//No hem assignat i queden criteris menys restrit             
             piLevel +=1; // Incrementem el valor per passar al seguent criteri                     
             Processa(piLevel); // Crida recursiva                                                  
           else;                                                                                    
             // Hem realitzat TOTS els nivells de validació i NO hem pogut assignar res             
             // Ho passem a residual que ho passarà al magatzem per defecte                         
E7139        //Txurr_Save('->ToResidual' :*off:Simon_tx);                                           
             AssignaMagResidual();                                                                  
           endif;                                                                                   
         endif;                                                                                     
                                                                                                    
E7139    //Txurr_Save('<-iLPEND:'+ %char(iLPEND)+'-> Level:'+%char(piLevel):*off:                   
E7139    //        Simon_tx);                                                                       
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //AssignaMagResidual: '...repartiendo las migajas...'                                        
      //                                                                                            
         dcl-proc AssignaMagResidual;                                                               
         dcl-pi *n end-pi;                                                                          
         dcl-s iM   like(s5line) inz;                                                               
         dcl-s iA   like(s5line) inz;                                                               
         dcl-s iBkpnd like(s5line) inz;                                                             
         dcl-s xRetorn like(s5line) inz;                                                            
         dcl-s bDft ind inz(*off);                                                                  
         dcl-s iDft like(s5line) inz;                                                               
         dcl-s iNcoe like(s5line) inz;                                                              
                                                                                                    
        //Bucle per articles pendents                                                               
        // Cercar existencia en totes les logístiques , per prioritat de logística                  
        //   Si NO es possible ho passem a default de la dlga.                                      
        // En aquest punt podem tenir o NO PE disponible.                                           
        // Per tant podem tenim un problema si hem passat línies a DFLT i no teniem PE disponibl    
        //                                                                                          
                                                                                                    
E7139      //Txurr_Save('AssignaMagResidual':*on:Simon_tx);                                         
E7139      //Txurr_Save('->iLPEND:'+ %char(iLPEND):*off:Simon_tx);                                  
E7139      Txurr_Save(GetMsg(kmsg0043):*on :Simon_tx);                                              
           iBkPND = ilPEND;                                                                         
           For iA = 1 to iLPEND;                                                                    
E7317        //iM = GetNext(0);                                                                     
E7317        iM = GetNext(iLmagME);                                                                 
             //For iM = (iLmagME + 1) to iLmag;                                                     
             dow iM>0;                                                                              
              //Validem: Existencia solament. Ja ho hem intentat amb més condicions.                
              if CArt(Tpend(iA)).CMag(iM).CVal(KExist) = 1;                                         
                 //Guardo logística si no l'em emprat abans                                         
                 iNcoe = SaveAmag(iM);                                                              
               //Adjudicat!!                                                                        
                 Adjudicat(Tpend(iA):iM);                                                           
               //Tart(Tpend(iA)).zNNcoe = iNcoe;                                                    
               //iNcoe = Tart(Tpend(iA)).zNNcoe;                                                    
                 iBkPND -= 1;                                                                       
                 leave;                                                                             
              endif;                                                                                
             //endfor;                                                                              
              iM = GetNext(iM);                                                                     
             enddo;                                                                                 
                                                                                                    
             // Si NO l'hem pogut assignar el passem a default                                      
             if Tart(Tpend(iA)).zLogFinal = *blanks;      // No s'ha pogut assignar                 
               bDft = *on;                                                                          
               iDft += 1;                                                                           
               Tart(Tpend(iA)).zLogFinal = gDFTloge;                                                
               Tart(Tpend(iA)).zLogVirtual = gDFTLogV    ;                                          
             //Tart(Tpend(iA)).zNNcoe = gDFTpos ; //                                                
               Tart(Tpend(iA)).znMag = gDFTpos;                                                     
               Tmag(gDFTpos).zNlin += 1;                                                            
               iBkPND -= 1;                                                                         
               select;                                                                              
               when gPROC = kPROCSimulacio or gPROC = kPROCConfirmacio ; //procés Normal            
               when gPROC = kPROCForcedLin or gPROC = kPROCAddLin      ;    //procés Forçat  or     
                 gERROR = kErrorNotPossible ;                              // addlin                
               when gPROC = kPROCForcedHeader ;               // Forçat capçalera                   
            //   Tart(Tpend(iA)).zLogFinal = Tart(Tpend(iA)).zLoge;  //deixem la logística que t    
                 gERROR = kErrorNotPossible ;                              // addlin                
               endsl;                                                                               
             endif;                                                                                 
           endfor;                                                                                  
                                                                                                    
           // En aquest punt ho hem de tenir tot assignat                                           
           // iBkPND ha d'estar a 0                                                                 
           ilPEND = iBkPND;                                                                         
                                                                                                    
           // Si hem arribat aquí amb 'Pedido Completo' hem de bloquejar header i NO tocar          
           // les línies                                                                            
           if bDft and %subst(s0ampl:63:1) = k1;                                                    
             gERROR = kErrorPedCompl  ;                                                             
           endif;                                                                                   
                                                                                                    
           // Si ens ha saltat un error no fem res mes                                              
           if gERROR <> kNoError and gERROR<> kErrorPedCompl;                                       
             return;                                                                                
           endif;                                                                                   
                                                                                                    
           // Podem tenir el 'problema' de que el magatzem x defecte ens hagi incrementat els PE    
           //                                                                                       
           select;                                                                                  
           when bDft and gDFTused;                                                                  
             // cap problema: hem passat a dft i ja el teniem utilitzat                             
      //     RepassaNcoe(gDFTpos);                                                                  
           when bDft and not(gDFTused) and (gMaxPE = iPE);                                          
             // Problemo: hem emprat el magatzem x dft i no el teniem. Hem incrementat un PE        
             // Hem d'agafar tot el que estigues assignat al darrer maga emprat i passar-ho a df    
             ReassignaMag(TAmag(iLAmag):gDFTpos); // PosMag a desassignar - PosMag a assignar       
      //     RepassaNcoe(gDFTpos);                                                                  
           when not(bDft) and gDFTused;                                                             
             // cap problema: no hem passat a dft tot i que ja el teniem utilitzat                  
           when not(bDft) and not(gDFTused);                                                        
             // cap problema: no hem passat a dft i no el teniem.                                   
           endsl;                                                                                   
                                                                                                    
           return;                                                                                  
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //RepassaNcoe: repassem Ncoe per deixar-ho uniforme                                          
      //                                                                                            
      // dcl-proc RepassaNcoe; ///(gDFTpos                                                          
      // dcl-pi *n;                                                                                 
      //  piM like(s5line) value;  //pos maga origen                                                
      //  //piNcoe like(s5line) value;  //nCoe assignat                                             
      // end-pi;                                                                                    
      // dcl-s iNcoe like(s5line) inz;                                                              
      // dcl-s iA   like(s5line) inz;                                                               
      //                                                                                            
      //   Txurr_Save('RepassaNcoe':*on:Simon_tx);                                                  
      //   //1er.- Cercar valor en TAmag                                                            
      //   iNcoe = SaveAmag(piM);                                                                   
      //   //Cercar TOTS els articles que estiguin assignats en aquest magatzem i canviar-li        
      //   For iA = 1 to iLarti;                                                                    
      //     if Tart(iA).znMag = piM ;                                                              
      //       Tart(iA).zNNcoe = iNcoe;                                                             
      //     endif;                                                                                 
      //   endfor;                                                                                  
      //                                                                                            
      //   return;                                                                                  
      //                                                                                            
      // end-proc;                                                                                  
      //                                                                                            
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ReassignaMag: Passem les assignacions d'un magatzem a un altre                             
      //   El número de coenvio ho gestiona RepassaNcoe                                             
         dcl-proc ReassignaMag;                                                                     
         dcl-pi *n;                                                                                 
          piO like(s5line)     ;  //pos maga origen                                                 
          piD like(s5line) value;  //pos maga destí                                                 
         end-pi;                                                                                    
         dcl-s iA   like(s5line) inz;                                                               
         dcl-s iaux like(s5line) inz;                                                               
                                                                                                    
E7139    //Txurr_Save('ReassignaMag':*on:Simon_tx);                                                 
E7139    //Txurr_Save('Ori:'+ %char(piO) + ' Des:' + %char(piD):*off:                               
E7139    //          Simon_tx);                                                                     
E7139      Txurr_Save(GetMsg(kmsg0044):*on : Simon_tx);                                             
E7139      Txurr_Save(' From:'+ Tmag(piO).zMaga + ' To:' + Tmag(piD).zMaga :                        
E7139          *off:Simon_tx);                                                                      
           //Cercar TOTS els articles que estiguin assignats en aquest magatzem i canviar-li        
           For iA = 1 to iLarti;                                                                    
             if Tart(iA).znMag = piO ;                                                              
               Adjudicat(iA:piD);                                                                   
               Tmag(piD).znLin += 1;                                                                
             endif;                                                                                 
           endfor;                                                                                  
                                                                                                    
           Tmag(piO).znLin = 0; // Inicialitzem linies assignades a maga ori                        
           //piO = piD;           // modifiquem TAmag amb el valor de del maga destí                
           // Hem d'eliminar la posició origen                                                      
           for iaux = pio to ilamag;                                                                
             Tamag(iaux) = Tamag(iaux+1);                                                           
           endfor;                                                                                  
           Tamag(ilamag) = *zero;                                                                   
           ilamag -= 1;                                                                             
                                                                                                    
           return;                                                                                  
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //GetNext: recupera el següent valor en TAmag                                                
      //                                                                                            
         dcl-proc GetNext;                                                                          
         dcl-pi *n like(s5line);                                                                    
          piA like(s5line) value;  //valor de comparació                                            
         end-pi;                                                                                    
         dcl-s ix   like(s5line) inz;                                                               
         dcl-s xRetorn like(s5line) inz(999);                                                       
         dcl-s iAux like(s5line) inz;                                                               
                                                                                                    
           For ix = 1 to iLAmag;                                                                    
             if TAmag(ix) > piA and TAmag(ix) < xRetorn;                                            
               xRetorn = TAmag(ix);                                                                 
               iAux = ix;                                                                           
             endif;                                                                                 
           endfor;                                                                                  
           if xRetorn = 999;                                                                        
             xRetorn = *zero;                                                                       
           endif;                                                                                   
                                                                                                    
           return xRetorn;                                                                          
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //FindMax: Cerca el valor més alt en el row/pis donats                                       
      //                                                                                            
         dcl-proc FindMax;                                                                          
         dcl-pi *n like(s5line);                                                                    
          piA like(s5line) value;  //col article                                                    
          piV like(s5line) value;    // pis validació                                               
          piStr  like(s5line) value;   // fila inicial warehouse                                    
          piEnd  like(s5line) value;     // fila final           warehouse                          
         end-pi;                                                                                    
         dcl-s iM   like(s5line) inz;                                                               
         dcl-s iSave like(s5line) inz;                                                              
         dcl-s xRetorn like(s5line) inz;                                                            
                                                                                                    
         for iM = piStr to piEnd;                                                                   
          if CArt(piA).CMag(iM).CVal(piV) > iSave;                                                  
            iSave = CArt(piA).CMag(iM).CVal(piV);                                                   
            xRetorn = iM;                                                                           
          endif;                                                                                    
         endfor;                                                                                    
         return xRetorn;                                                                            
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //ValidaMaga: validem sumatori imports d'articles per maga (i també número de línies)        
      //            i tot el que sigui validacions agrupades de les línies sobre un maga           
      //                                                                                            
      // Rebem les coordenades Maga - Validació                                                     
      // En Maga - Validació - iLarti + 1 tindrém el TOTAL d'elements valids                        
      //                                                                                            
      // Si el magatzem ja s'ha utilitzat, ja li hem assignat línies, NO hem de fer les validaci    
      //  ja les hem passat abans                                                                   
      //                                                                                            
         dcl-proc ValidaMaga;                                                                       
         dcl-pi *n ind;                                                                             
          piM like(s5line) value;                                                                   
          piV like(s5line) value; //pis Validació. Sempre serà kFinal o kFinalME                    
         end-pi;                                                                                    
         dcl-s iA   like(s5line) inz;                                                               
         dcl-s iCnt like(s5line) inz;                                                               
         dcl-s iSave like(s5line) inz;                                                              
         dcl-s iImportTotal like(t5impo) inz;                                                       
         dcl-s xRetorn ind inz(*off);                                                               
                                                                                                    
E7139    //Txurr_Save('ValidaMaga':*oN:Simon_tx);                                                   
                                                                                                    
         // Mirem si ja hem assignat aquest maga                                                    
         if %lookup(piM:TAmag) > 0;  // Ja l'hem utilitzat, no necessitem validar-l'ho              
E7139      //Txurr_Save('-ValidaMaga:'+%char(piM)+'->PreviouslyUsed':                               
E7139      //        *off:Simon_tx);                                                                
           return *on;                                                                              
         endif;                                                                                     
                                                                                                    
         // Si NO tenim PEnED disponible i NO és un maga tal1=8                                     
         if (Tmag(piM).zTal1<>k8 and Tmag(piM).zTal1<>k7) and iPEnED=gMaxPEnED;                     
           return *off;                                                                             
         endif;                                                                                     
                                                                                                    
         if not Tmag(piM).zOctI ; //Omit control import mínim                                       
           //1er.- Sumaritzar imports de les línies vàlides per aquest magatzem                     
           for iA = 1 to iLarti;                                                                    
             if iCnt = CArt(iLarti + 1).CMag(piM).CVal(piV); //Ja els hem trobat tots,              
               leave;     // Sortim del bucle                                                       
             endif;                                                                                 
             if CArt(iA).CMag(piM).CVal(piV) = 1;                                                   
               iCnt += 1;                                                                           
               iImportTotal += Tart(iA).zImpLin;                                                    
             endif;                                                                                 
           endfor;                                                                                  
                                                                                                    
           if iImportTotal < Tmag(piM).zImpo     //Import comanda inferior a mínim                  
             and Tmag(piM).zImpo > 0;            // i tenim un valor mínim superior a 0             
E7139        //Txurr_Save('*ImpMinim* Suma:' + %char(iImportTotal) + ',Parm:'+                      
E7139        //  %char(Tmag(piM).zImpo) + ',Maga:'+%char(piM):*off:Simon_tx);                       
E7139        Txurr_Save(CRRd+'* '+ %trim(GetMsg(kmsg0045))+CRWh+                                    
E7139        Tmag(piM).zMaga +CNGr+%editc(Tmag(piM).zImpo:'X')+                                     
E7139        CRWh+%editc(iCnt:'X')+CNGr+%trim(GetMsg(kmsg0042))+                                    
E7139        %editc(iImportTotal:'X'):*off:Simon_tx);                                               
             return *off;                                                                           
           endif;                                                                                   
         endif; //Omit control import mínim                                                         
                                                                                                    
         // En aquest punt hem passat el control d'import                                           
         // Càlcul % línies sobre el total de la comanda                                            
         //    iLarti = 100%                                                                        
         //    iCnt o CArt(iLarti + 1).CMag(zM).CVal(zV) _=> x , línies que es poden assignar       
         // i ON tenim el % a superar???                         a aquest maga (iM)                 
         // Utilitzarem el valor t5capa, guardat en Tmag(iM).zCapa                                  
                                                                                                    
         if not Tmag(piM).zOctC; //NO Omit ctl capacitat                                            
           if (CArt(iLarti + 1).CMag(piM).CVal(piV) >                                               
                  Tmag(piM).zMLin * Tmag(piM).zCapa /100)  and                                      
                  Tmag(piM).zMLin>0 and Tmag(piM).zCapa >0;                                         
E7139        //Txurr_Save('*Capacit.* Lins:' +                                                      
E7139        //   %char(CArt(iLarti + 1).CMag(piM).CVal(piV)) + ',Parm:'+                           
E7139        //  %char(Tmag(piM).zCapa) + ',Maga:'+%char(piM):*off:Simon_tx);                       
E7139        Txurr_Save(CRRd+'* '+ %trim(GetMsg(kmsg0046))+CRWh+                                    
E7139        Tmag(piM).zMaga +CNGr+%editc(Tmag(piM).zMLin:'X')+' '+                                 
E7139        %editc(Tmag(piM).zCapa:'X')+'  '+                                                      
E7139        CRWh+%editc(CArt(iLarti + 1).CMag(piM).CVal(piV) :'X')+                                
E7139               CNGr+%trim(GetMsg(kmsg0042)):*off:Simon_tx);                                    
             return *off;                                                                           
           endif;                                                                                   
         endif;    // Omit ctl capacitat                                                            
                                                                                                    
         // Altres validacions....                                                                  
         //    Total línies que compleixen validació per aquest magatzem                            
         //           CArt(iLarti + 1).CMag(piM).CVal(piV)                                          
         //    Total línies que s'han carregat    iLarti                                            
         //    Total línies assignades via Excepció  iExcpt                                         
         //    % mínim per assignar la comanda a un magatzem   zAmasi                               
                                                                                                    
E7374        // if  CArt(iLarti + 1).CMag(piM).CVal(piV) * 100 / (iLarti - iExcpt) <                
E7374        //          Tmag(piM).zAmasi;                                                          
E7139        //Txurr_Save('*Amasi  .* Lins:' +                                                      
E7139        //   %char(CArt(iLarti + 1).CMag(piM).CVal(piV)) + ',Parm:'+                           
E7139        //  %char(Tmag(piM).zAmasi) + ',Maga:'+%char(piM):*off:Simon_tx);                      
HDC74        //E7374      if  CArt(iLarti + 1).CMag(piM).CVal(piV) * 100 /                          
HDC74    if  (iLarti - iExcpt - iArtB  >*zero) and                                                  
HDC74        CArt(iLarti + 1).CMag(piM).CVal(piV) * 100 /                                           
E7374          (iLarti - iExcpt - iArtB ) < Tmag(piM).zAmasi;                                       
E7139        Txurr_Save(CRRd+'* '+ %trim(GetMsg(kmsg0047))+CRWh+                                    
E7139        Tmag(piM).zMaga +CNGr+%editc(Tmag(piM).zAmasi:'X')+' '+                                
E7139        CRWh+%editc(CArt(iLarti + 1).CMag(piM).CVal(piV) :'X')+                                
E7139               CNGr+%trim(GetMsg(kmsg0042)):*off:Simon_tx);                                    
             return *off;                                                                           
         endif;                                                                                     
                                                                                                    
         return *on;                                                                                
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //AssignaMag: Assignem les línies al magatzem                                                
      //                                                                                            
      // Rebem les coordenades Maga - Validació                                                     
      // En Maga - Validació - iLarti + 1 tindrém el TOTAL d'elements valids                        
      //                                                                                            
         dcl-proc AssignaMag;                                                                       
         dcl-pi *n ;                                                                                
          piM like(s5line) value;                                                                   
          piV like(s5line) value;                                                                   
         end-pi;                                                                                    
         dcl-s iArt like(s5line) inz;                                                               
         dcl-s iCnt like(s5line) inz;                                                               
         dcl-s iM   like(s5line) inz;                                                               
         dcl-s iP   like(s5line) inz;                                                               
         dcl-s iV2  like(s5line) inz;                                                               
         dcl-s iValor like(s5line) inz;                                                             
         dcl-s bContaPE ind inz(*off);  // Indicador per incrementar, o no, els PE                  
         dcl-s bMagUpd  ind inz(*off);  // Indicador d'actualització en mag                         
         dcl-s iNcoe like(s5line);                                                                  
E7269    dcl-s iValorANTiLAmag like(s5line); // Valor anterior de iLAmag                            
                                                                                                    
         //Hem de validar si aquesta assignació conta com PE                                        
         // En el pis kNoPE indiquem, per ME (magatzems especials per ArtiB i Obso) si aquest       
         // no conta com punt d'expedició. I en cas afirmatiu posem un 1. I en cas negatiu posem    
         //     Es a dir: el valor 1 NO incrementa PE.                                              
         //               el valor 0 SI incrementa PE.                                              
         // I pels arti-maga que no siguin PE, obsolets, ArtiB...?                                  
         //               el valor per defecte, 999, SI incrementen PE.                             
         // Usea, sols es lliura d'incrementar PE si tenim 1                                        
         //                                                                                         
                                                                                                    
         // Guardem valor actual per comparacions                                                   
         // Nota: aquest valor serà del pis kFinal, el més provable. I el valor d'aquest pis        
         //  es va modificant a mida que assignem items al magatzems.                               
         iValor = Cart(iLarti+1).CMag(piM).CVal(piV);                                               
                                                                                                    
         //Guardem Magatzem assignat, si no l'hem utilitzat abans                                   
         //Ens retorna la posició en TAmag on tenim aquest magatzem. Utilitzem aquest valor per     
E7269    iValorANTiLAmag = iLAmag; // Guardem el valor actual per determinar si aquest maga         
E7269                             // l'hem utilitzat abans o no.                                    
         iNcoe = SaveAmag(piM);                                                                     
         //iLAmag += 1;         //Comptador magatzems assignats                                     
         //TAmag(iLAmag) = piM;  //Magatzems utilitzats                                             
                                                                                                    
         //Si és el magatzem per defecte activem l'indicador                                        
         if piM = gDFTpos;                                                                          
           gDFTused = *on;                                                                          
         endif;                                                                                     
                                                                                                    
         //Si maga tal1<>8 incrementem contador                                                     
         if (Tmag(piM).zTal1 <> k7 and Tmag(piM).zTal1 <> k8);                                      
           iPEnED +=1;                                                                              
         endif;                                                                                     
                                                                                                    
         // Bucle per tots els articles disponibles en aquest magatzem                              
         For iArt = 1 to iLarti;                                                                    
           if CArt(iArt).CMag(piM).CVal(piV) = 1;                                                   
             iCnt += 1;                           //contador línies processades                     
             iLPEND -= 1;                         //contador línies pendents                        
             //Adjudicat!!                                                                          
             Adjudicat(iArt:piM);                                                                   
             if CArt(iArt).CMag(piM).CVal(kNoPE) <> 1;  //Si hem d'incrementar PE                   
               bContaPE = *on;                         //Si hem d'incrementar PE                    
             endif;                                    //Si hem d'incrementar PE                    
             // Guardem per NNcoe                                                                   
             Tart(iArt).zNNcoe = iNcoe;                                                             
             // Aquest article ja està assignat. Ara toca desmarcar-l'ho dels altres magatzems      
             For iM = 1 to iLmag;                                                                   
               DesmarcaArtMag(iArt:iM:kFinalME:bMagUpd);                                            
               //Validacions Parcials: desmarquem en totes les validacions.                         
               For iV2 = 1 to %elem(TLevel);                                                        
                 DesmarcaArtMag(iArt:iM:TLevel(iV2):bMagUpd);                                       
               endfor;                                                                              
               //Corregim núm lin maga, si cal                                                      
               if bMagUpd and Tmag(iM).zMliZ > *zero;                                               
                  Tmag(iM).zMliZ -= 1;                                                              
               endif;                                                                               
               bMagUpd = *off;                                                                      
             endfor;                                                                                
           else;                                                                                    
             //Actualitzo taula pendents, si s'escau                                                
             if Tart(iArt).zLogFinal = *blanks;                                                     
               iP += 1;                                                                             
               Tpend(iP) = iArt ;                                                                   
             endif;                                                                                 
           endif;                                                                                   
                                                                                                    
         endfor;                                                                                    
         // En aquest punt ilPEND = iP                                                              
         ilPEND = iP;                                                                               
         iRonda += 1; // Comptador de rondes                                                        
         Tmag(piM).zAssigRonda = iRonda;                                                            
E7269    //if bContaPE;                                                                             
E7269    // Incrementem el comptador de Punts Expedició emprats si aquest magatzem ens increment    
E7269    //  punt (bContaPE) i si NO l'hem utilitzat abans                                          
E7269    if bContaPE and (iValorANTiLAmag < iLAmag);                                                
           iPE += 1;    // Comptador de Punts Expedició emprats                                     
         endif;                                                                                     
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //SaveAmag:   Guardem la posició del magatzem assignat, si NO l'hem empleat abans            
      //                                                                                            
         dcl-proc SaveAmag;                                                                         
         dcl-pi *n like(s5line);                                                                    
          piM like(s5line) value;  // Element de Tmag                                               
         end-pi;                                                                                    
         dcl-s xRetorn like(s5line);                                                                
         // Cerquem el valor en TAmag                                                               
         xRetorn = %lookup(piM:TAmag) ;                                                             
         if xRetorn = 0 ;  // Not found                                                             
           iLAmag += 1;  // incrementem contador de darrera posició                                 
           TAmag(iLAmag) = piM;  // guardem posició magatzem assignat                               
           xRetorn = iLAmag;                                                                        
         endif;                                                                                     
         return xRetorn;                                                                            
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //DesmarcaArtMag                                                                             
      //                                                                                            
         dcl-proc DesmarcaArtMag;                                                                   
         dcl-pi *n ;                                                                                
          piA like(s5line) value;  // Element de Tart                                               
          piM like(s5line) value;  // Element de Tmag                                               
          piV like(s5line) value;  // pis de validació                                              
          pbUpd ind;                                                                                
         end-pi;                                                                                    
                                                                                                    
         dcl-s bUpd ind inz(*off);                                                                  
                                                                                                    
           if CArt(piA).CMag(piM).CVal(piV) = 1;                                                    
             //Validacions Finals per ME                                                            
             CArt(piA).CMag(piM).CVal(piV) = 0;                                                     
             CArt(iLarti + 1).CMag(piM).CVal(piV) -= 1;                                             
             bUpd = *on;                                                                            
           endif;                                                                                   
           pbUpd = pbUpd  or bUpd;                                                                  
         return;                                                                                    
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //Adjudicat: Movem camps assignació Article / Magatzem                                       
      //                                                                                            
      //  Els comptadors d'articles pendents (iLPEND), magatzems emprats (iLAmag), taules           
      //   de pendents (Tpend) o maga assignats (TAmag) es mantenen fora                            
      //  Aquí sols movem info entre Tmag i Tarti                                                   
      //                                                                                            
         dcl-proc Adjudicat;                                                                        
         dcl-pi *n ;                                                                                
          piA like(s5line) value;  // Element de Tart                                               
          piM like(s5line) value;  // Element de Tmag                                               
         end-pi;                                                                                    
                                                                                                    
             Tart(piA).zLogFinal = Tmag(piM).zLoge;        //guardem logística en línia Adjudica    
             Tart(piA).zLogVirtual = Tmag(piM).zLogVirtual;  //guardem logística virtualAdjudica    
             Tart(piA).znMag = piM ; //Posició del magatzem assignat                    Adjudica    
             if Tmag(piM).ztal1= k8 or Tmag(piM).ztal1= k7;//                            Adjudic    
               Tart(piA).zTpe4 = k2;                    // informem s5tpe4 = 2         Adjudicat    
               gTPE4 = *on;                             // Sip, tenim TPE4=2            Adjudica    
             else;                                     //                               Adjudica    
               Tart(piA).zTpe4 = *blanks;              // tpe4 a blanks                Adjudicat    
             endif;                                  //                               Adjudicat     
             Tmag(piM).zNlin += 1  ; // Línies assignades a aquest magatzem           Adjudicat     
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //RessetMag: Resetejem aquest Magatzem per tal que no ens torni a sortir                     
      //                                                                                            
      // Això ho fem per magatzems que no superen les validacions finals (ValidaMaga)               
      //                                                                                            
         dcl-proc RessetMag;                                                                        
         dcl-pi *n ;                                                                                
          piM like(s5line) value;  //Parm Integer Magatzem                                          
          piV like(s5line) value;  //Parm Integer Validacions                                       
         end-pi;                                                                                    
         dcl-s iA   like(s5line) inz;                                                               
         dcl-s iCnt like(s5line) inz;                                                               
                                                                                                    
        for iA = 1 to iLarti;                                                                       
          if iCnt = CArt(iLarti + 1).CMag(piM).CVal(piV);   // Ja hem processat totes les línies    
            leave;                                                                                  
          endif;                                                                                    
          if CArt(iA).CMag(piM).CVal(piV) = 1    ;                                                  
            iCnt  += 1;                                                                             
            CArt(iA).CMag(piM).CVal(piV) = 0 ;      // inicializem valor per arti/maga/Validació    
          endif;                                                                                    
        endfor;                                                                                     
        CArt(iLArti + 1).CMag(piM).CVal(piV) = 0;   // inicialitzem acumulat d'aquesta validació    
        return        ;                                                                             
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //Txurr_Save:                                                                                
      //                                                                                            
         dcl-proc Txurr_Save;                                                                       
         dcl-pi *n;                                                                                 
           pTxt char(50) value;                                                                     
           pBol ind value;                                                                          
E7139      ptxurru like(DODATA);  //varchar(5000);                                                  
         end-pi;                                                                                    
                                                                                                    
         if pBol;                                                                                   
           pTxt = cRWh + %trim(pTxt) +cNGr ;                                                        
         endif;                                                                                     
E7139    //if %len(ptxurru) < 5000;                                                                 
E7139    if %len(ptxurru) < %len(ptxurru: *MAX);                                                    
           ptxurru = ptxurru + pTxt;                                                                
         endif;                                                                                     
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //Simon_show:                                                                                
      //                                                                                            
         dcl-proc Simon_show;                                                                       
         dcl-pi *n end-pi;                                                                          
                                                                                                    
        if bSimon;          //Simon                                                                 
                                                                                                    
         @pTitulo = kSS;                                                                            
         @pFuncion = k0;                                                                            
         @pLongitud = %len(Simon_tx);                                                               
         pMSGBOX(@pTitulo:%addr(Simon_tx)+2:@pLongitud:@pFuncion:@pRetorno:*on);                    
                                                                                                    
        endif;                                                                                      
                                                                                                    
         end-proc;                                                                                  
                                                                                                    
                                                                                                    
      //----------------------------------------------------------------------------------------    
      //cs_importe: càlcul import línia                                                            
      // Calculo Importe línea pedido                                                               
      //                                                                                            
         dcl-proc CS_IMPORTE;                                                                       
         dcl-pi *n like(zxbimp) end-pi;                                                             
                                                                                                    
                                                                                                    
     C                   EVAL      ZXMONE2 = S5MONE                                                 
      * Tipo de IVA                                                                                 
     C                   EVAL      PECIAS=S5CIAS                                                    
     C                   EVAL      PECTAB='TIV2'                                                    
     C                   EVAL      PECLTA=*BLANKS                                                   
     C                   EVAL      PECLTA=S0TIV3                                                    
           chain (@pcias:pectab:peclta) pmtabd;                                                     
     C**** KPMTABD       CHAIN     PMTABD                                                           
     C                   IF        %FOUND(PMTABD)                                                   
     C                   EVAL      ZXTIVC=PEBL61                                                    
     C                   EVAL      ZXPABI=%subst(pebl65:1:1)                                        
     C                   ELSE                                                                       
     C                   EVAL      ZXPABI=*BLANKS                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      XZAUXI=*ZEROS                                                    
     C                   EVAL      XZAUXI1=*ZEROS                                                   
     C                   EVAL      MBCIAS=S5CIAS                                                    
     C                   EVAL      MBMONE=ZXMONE2                                                   
     * Ecotaxe                                                                                     
     C                   EVAL      XZTAXE=0                                                         
     C                   IF        S5ECOP<>*BLANKS                                                  
     C                   CALL      'MN0398'                                                         
     C                   PARM                    @PCIAS                                             
     C                   PARM      S5ECOP        @PEECOP                                            
     C                   PARM      S5DATP        @PEFLCD                                            
     C                   PARM      0             @PETAXE                                            
     C                   EVAL      XZTAXE=@PETAXE                                                   
     C                   ENDIF                                                                      
      * Buscamos en Ajuste decimal                                                                  
                                                                                                    
     C**** KMSDIV0       CHAIN     MSDIV0                                                           
           chain (@pcias:mbmone) msdiv0;                                                            
     C                   IF        %FOUND(MSDIV0)                                                   
     C                   EVAL      XZDECI=MBDECI                                                    
     C                   EVAL      XZAJUD=MBAJUD                                                    
     C                   ENDIF                                                                      
      * Buscamos en PMUNAL UNIDADES ALTERNATIVAS                                                    
     C                   EVAL      XZCOFU=1                                                         
     C                   IF        S5UNIM<>S5UNDP                                                   
     C                   EVAL      XZCIAS=@PCIAS                                                    
     C                   EVAL      XZARTI=S5ARTI                                                    
     C                   EVAL      XZVARI=S5VARI                                                    
     C                   EVAL      XZMODE=S5MODE                                                    
     C                   EVAL      ZXCA10=S5CANT                                                    
     C                   EVAL      ZXCA11=S5CANT                                                    
     C                   EVAL      ZXUN10=S5UNIM                                                    
     C                   EVAL      ZXUN11=S5UNDP                                                    
     C* CAMBIO de unidades                                                                          
     C/COPY *LIBL/QSRDSRC,SRD021                                                                    
     C                   ENDIF                                                                      
      * Buscamos en CAMBIO MONEDA CABECERA DEL PEDIDO                                               
     C                   IF        ZXMONE2<>S5MONE                                                  
     C                   CALL      'MM2555'                                                         
     C                   PARM      S5CIAS        @PCIAS                                             
     C                   PARM      S5MONE        @PMON1                                             
     C                   PARM      ZXMONE2       @PMON2                                             
     C                   PARM      S5DATP        @PDATA                                             
     C                   PARM      S5NOPL        @PHORA                                             
     C                   PARM      0             @PCMCOCO                                           
     C                   PARM      0             @PCMCCCO                                           
     C                   PARM      *BLANKS       @PEERR                                             
     C                   EVAL      ZXCOCAMB=@PCMCCCO                                                
     C                   ELSE                                                                       
     C                   EVAL      ZXCOCAMB=1                                                       
     C                   ENDIF                                                                      
                                                                                                    
      * Buscamos en % de IVA                                                                        
     C                   EVAL      MVCIAS=S5CIAS                                                    
     C                   EVAL      MVTIVA=S5TIVA                                                    
     C                   EVAL      MVPABI=ZXPABI                                                    
     C                   EVAL      MVFLCD=@PDATP                                                    
           setgt (@pcias:mvtiva:mvpabi) msivas;                                                     
           readpe (@pcias:mvtiva:mvpabi:mvflcd) msivas;                                             
     C**** KMSIVAS       SETGT     MSIVAS                                                           
     C**** KMSIVAS0      READPE    MSIVAS                                 83                        
     C                   SELECT                                                                     
     C                   WHEN      ZXTIVC=' '                                                       
     C                   EVAL      MVPIV2=*ZEROS                                                    
     C                   WHEN      ZXTIVC='0'                                                       
     C                   EVAL      MVPIV1=*ZEROS                                                    
     C                   EVAL      MVPIV2=*ZEROS                                                    
     C                   ENDSL                                                                      
      * Calculamos el precio de nueva linea o modificada                                            
     C                   EVAL      XZCANT=S5CANT                                                    
     C                   EVAL      XZPREC=S5PREC                                                    
     C                   EVAL      XZCADP=S5CADP                                                    
     C                   EVAL      XZDTO1=S5DTO1                                                    
     C                   EVAL      XZDTO2=S5DTO2                                                    
     C                   EVAL      XZDTO3=S5DTO3                                                    
     C                   EVAL      XZDTO4=S5DTO4                                                    
b01  C                   IF        XZDTO4=*ZEROS                                                    
     C                   EVAL      XZDTO4=@PDTOE                                                    
e01  C                   ENDIF                                                                      
ECOP C/COPY *LIBL/QSRDSRC,SRD022ECO                                                                 
ECOP C* AJUSTE Y DECIMALES                                                                          
ECOP C/COPY *LIBL/QSRDSRC,SRD001                                                                    
ECOP C                   Z-ADD     XZAUXI        ZXBIMPECO                                          
05052* Evitar error división por 0                                                                 
05052C                   IF        XZCADP = 0                                                       
05052C                   EVAL      XZCADP = 1                                                       
05052C                   ENDIF                                                                      
05052C                   IF        XZCADP = 0                                                       
05052C                   EVAL      XZCADP = 1                                                       
05052C                   ENDIF                                                                      
     C/COPY *LIBL/QSRDSRC,SRD022                                                                    
                                                                                                    
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
     C                   Z-ADD     XZAUXI        ZXBIMP                                             
ECOP C                   ADD       ZXBIMPECO     ZXBIMP                                             
      * Calculamos el IVA                                                                           
     C                   EVAL      XZAUXI=ZXBIMP*MVPIV1                                             
     C     XZAUXI        DIV(H)    100           XZAUXI                                             
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
     C                   Z-ADD     XZAUXI        ZXIIV1                                             
      * Calculamos el Recargo de equivalencia                                                       
     C                   EVAL      XZAUXI=ZXBIMP*MVPIV2                                             
     C     XZAUXI        DIV(H)    100           XZAUXI                                             
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
     C                   Z-ADD     XZAUXI        ZXIIV2                                             
                                                                                                    
      * Omitimos BASE o IVA segun tipo de IVA                                                       
                                                                                                    
b01  C                   IF        MVOMTB>='1'                                                      
     C                   EVAL      ZXBIMP=ZXBIMP-ZXBIMP                                             
e01  C                   ENDIF                                                                      
b01  C                   IF        MVOMTI>='1'                                                      
     C                   EVAL      ZXIIV1=ZXIIV1-ZXIIV1                                             
     C                   EVAL      ZXIIV2=ZXIIV2-ZXIIV2                                             
e01  C                   ENDIF                                                                      
       return zxbimp;                                                                               
                                                                                                    
         end-proc;                                                                                  
      //----------------------------------------------------------------------------------------    
      //DesmarcaHeader                                                                             
      // treiem FD de la capçalera                                                                  
      //                                                                                            
         dcl-proc DesmarcaHeader;                                                                   
         dcl-pi *n  end-pi;                                                                         
                                                                                                    
           exec sql                                                                                 
             update cocape set s0tpe4=' '                                                           
             where s0cias = :@pcias and s0dlga = :@pdlga and s0npco = :@pnpco                       
               and s0tped = :@ptped and s0datp = :@pdatp and s0nopl = :@pnopl;                      
                                                                                                    
         end-proc;                                                                                  
E7139 //----------------------------------------------------------------------------------------    
E7139 //SaveHst: Guardem dades en Històric càlcul Doom                                             
E7139 //                                                                                            
E7139    dcl-proc SaveHst;                                                                          
E7139    dcl-pi *n  end-pi;                                                                         
E7139                                                                                               
E7139      select;                                                                                  
E7139      when  gProc = kPROCsimulacio    ;                                                        
E7139        return;  // no fem res                                                                 
E7139      when  Simon_tx=''               ;                                                        
E7139        return;  // no fem res                                                                 
E7139      endsl;                                                                                   
E7139                                                                                               
E7139      Open doomht;                                                                             
E7139      clear rdoomht;                                                                           
E7139      docias= @pcias;        //-+                                                              
E7139      dodlga= @pdlga;        // |                                                              
E7139      donpco= @pnpco;        // +--- Clau comanda                                              
E7139      dotped= @ptped;        // |                                                              
E7139      dodatp= @pdatp;        // |                                                              
E7139      donopl= @pnopl;        //-+                                                              
E7139      dousua= Pgm.sdsUser;       //----- Usuari que realitza el procés                         
E7139      doproc= %char(gPROC);        //----- Tipus de procés                                     
E7139      dotmsp= %timestamp;    //----- Timestamp                                                 
E7139      %nullind(dodata) = *off;                                                                 
E7139      dodata = Simon_tx;  //----- Dades del càlcul                                             
E7139      write rdoomht;                                                                           
E7139      close doomht;                                                                            
E7139      return;                                                                                  
E7139                                                                                               
E7139    end-proc;                                                                                  
E7249 //----------------------------------------------------------------------------------------    
E7249 //GetCono: Recupera el cono perdido en la AP7                                                
E7249 //                                                                                            
E7249    dcl-proc GetCono;                                                                          
E7249    dcl-pi *n like(MBCONO);                                                                    
E7249    end-pi;                                                                                    
E7249    dcl-s xReturn like(MBCONO) inz;                                                            
E7249      open svuser;                                                                             
E7249      chain (Pgm.sdsUser) svuser;                                                              
E7249      if %found(svuser) and %subst(k4amp4:1:3)<>*blanks;                                       
E7249        xReturn=atoi(%subst(k4amp4:1:3));                                                      
E7249      else;                                                                                    
E7249        xReturn=100;                                                                           
E7249      endif;                                                                                   
E7249      close svuser;                                                                            
E7249      return xReturn;                                                                          
E7249                                                                                               
E7249    end-proc;                                                                                  
E7249 //----------------------------------------------------------------------------------------    
E7249 //GetStsM3:Recupera status de l'article / maga en M3                                         
E7249 //                                                                                            
E7249    dcl-proc GetStsM3;                                                                         
E7249    dcl-pi *n like(s5line);                                                                    
E7249      pWHLO like(MBWHLO) const;                                                                
E7249      pPRVR like(M0PRVR) const;                                                                
E7249      pARVM like(C3ARVM) const;                                                                
E7249      pRetorn like(s5line) const;                                                              
E7249    end-pi;                                                                                    
E7249    dcl-s xRetorn like(s5line) inz;                                                            
E7249      // 1er.- Verificar que aquest proveïdor el tenim en M3                                   
E7249      // Cerquem la Cia d'aquest proveïdor en UTCOM                                            
E7249      chain (s0cias:'5':pPrvr:*blanks) utcom0;                                                 
E7249      if %found(utcom0) and u0baja <> k0;                                                      
E7253        if %trim(U0CIA1)='018'; // TXAPU per IBERSPA: no s'ha de validar                       
E7253          return pRetorn;      // ja que està en Legacy                                        
E7253        endif;                                                                                 
E7249        //Mirem que l'empresa estigui en M3                                                    
E7249        chain (U0CIA1) pmlibl;                                                                 
E7249        if %found(pmlibl) and %subst(ppbl10:9:1)=kV ;                                          
E7249          xRetorn=xRetorn;                                                                     
E7249        else;                                                                                  
E7249          return pRetorn; //No està en M3 o no tenim reg en pmlibl                             
E7249        endif;                                                                                 
E7246      else;                                                                                    
E7249       return  pRetorn; // no tenim UTCOM per aquest proveïdor                                 
E7249      endif;                                                                                   
E7249      // En aquest punt el proveïdor està en M3                                                
E7249      // 2on.-Cerquem el ITNO d'aquest proveïdor                                               
E7249      chain (s0cias:pPrvr:pArvm) puprp0;                                                       
E7249      if %found(puprp0) and c3arvp <> *blanks;                                                 
E7249        mbitno= c3arvp;                                                                        
E7249      else;                                                                                    
E7249        mbitno= pArvm;                                                                         
E7249      endif;                                                                                   
E7249      //3er.- Finalment accedim al mitbal per validar                                          
E7249      chain (gCONO:pWHLO:mbitno) mitbal00;                                                     
E7249      if %found(mitbal00) and mbstat>=k20 and mbstat<k80;                                      
E7249        xRetorn=1;                                                                             
E7249      else;                                                                                    
E7249        xRetorn=0;                                                                             
E7249      endif;                                                                                   
E7249                                                                                               
E7249      return xRetorn;                                                                          
E7249                                                                                               
E7249    end-proc;                                                                                  
