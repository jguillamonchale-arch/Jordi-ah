       /////////////////////////////////////////////////////////////////////////////////////////    
       // Variables - Constants - Taules                                                           
       //---------------------------------------------------------------------------------------    
       //                                                                                           
       //Definició del cub de decisions/validacions.                                               
       // 3 dimensions:                                                                             
       //                                                                                           
       //                        /\                                                                 
       //                       /  \   Articles (linies de comanda                                  
       //           Magatzems  /    \                                                               
       //                     /      \                                                              
       //                    |\      /|                                                             
       //         Validacions| \    / |                                                             
       //                    |  \  /  |                                                             
       //                     \  \/   /                                                             
       //                      \  |  /                                                              
       //                       \ | /                                                               
       //                        \|/                                                                
       //                                                                                           
       //      Per pisos (nivells de validació)                                                     
       //                                                                                           
       //                Articles                                      Primer pis:Valida existei    
       //                                                                        article en maga    
       //                | A1 | A2 | A2 | ... | iLarti + 1                                          
       //                +----+----+----+-----+----------                                           
       //   Magatzem 1   |  1 |  1 | 0  |  0  |  2                                                  
       //             ---+----+----+----+-----+----------                                           
       //   Magatzem 2   |  1 |  1 | 1  |  1  |  4                                                  
       //             ---+----+----+----+-----+----------                                           
       //   Magatzem 3   |  0 |  1 | 1  |  1  |  3                                                  
       //             ---+----+----+----+-----+----------                                           
       //             ....                                                                          
       //                                                                                           
       //                Articles                                      Segón pis:Valida estock      
       //                                                                   disponible en maga      
       //                | A1 | A2 | A2 | ... | iLarti + 1                                          
       //                +----+----+----+-----+----------                                           
       //   Magatzem 1   |  1 |  0 | 0  |  0  |  1                                                  
       //             ---+----+----+----+-----+----------                                           
       //   Magatzem 2   |  1 |  1 | 0  |  1  |  3                                                  
       //             ---+----+----+----+-----+----------                                           
       //   Magatzem 3   |  0 |  1 | 1  |  1  |  3                                                  
       //             ---+----+----+----+-----+----------                                           
       //             ....                                                                          
       //       Tercer, quart, cinqué.... altres validacions.                                       
       //             ....                                                                          
       //                                                                                           
       //                Articles                                    Darrer pis: 'sumatori' lógi    
       //                                                                de les validacions         
       //                | A1 | A2 | A2 | ... | iLarti + 1                                          
       //                +----+----+----+-----+----------            Nota: tenim 3 pisos de Fina    
       //   Magatzem 1   |  1 |  0 | 0  |  0  |  3                                                  
       //             ---+----+----+----+-----+----------               1.- Totes les condicions    
       //   Magatzem 2   |  1 |  1 | 0  |  1  |  7                      2.- 4 condicions (fixes)    
       //             ---+----+----+----+-----+----------               3.- 3 condicions (fixes)    
       //   Magatzem 3   |  0 |  1 | 1  |  1  |  6                                                  
       //             ---+----+----+----+-----+----------            I tenim els pisos per ME       
       //             ....                                                                          
       //                                                                                           
       //   En aquest punt les decicions són independents del coenviament (S0COEN)                  
       //                                                                                           
       //                                                                                           
       //---------------------------------------------------------------------------------------    
       //Bucle mentre tinguem linies pendents d'assignar (iLPEND)                                   
       // Si queden punts d'expedició disponibles                                                   
       //   Es prioritza pel pis kFinal (totes les validacions) qui pugui servir més línies.        
       //     Si cap magatzem pot servir-ne es prioritza pel pis kFinalP1 (menys restrictiu)        
       //       Si cap magatzem pot servir-ne es prioritza pel pis kFinalP2 (menys restrictiu)      
       //         Si cap magatzem pot servir-ne es tracta com residual                              
       //                                                                                           
       // Si NO queden punts d'expedició disponibles                                                
       //   Es tracta com residual                                                                  
       //                                                                                           
       //---------------------------------------------------------------------------------------    
       //                                                                                           
       //   S'ha de tenir en compte si tenim especials (artiB o Obso) i si tenim magatzems que N    
       //      contin com PE.                                                                       
       //      En aquest cas s'ha d'assignar TOT el que es pugui a aquestos magatzems               
       //   En cas contrari, encara que tinguem especials (artiB o Obso), l'assignació es farà      
       //      per més conjunt, més agrupat.                                                        
       //                                                                                           
       //Dimensió Articles                                                                         
       //  Dimensió Magatzems                                                                      
       //    Dimensió Validacions                                                                  
       dcl-ds CArt qualified dim(kMaxArt); //                                                       
         dcl-ds CMag dim(kMaxMag); //                                                               
           CVal like(s5line) inz(999) dim(kMaxVal);                                                 
         end-ds;                                                                                    
       end-ds;                                                                                      
       //                                                                                           
       //   CArt(x).CMag(y).CVal(z)  = ....                                                        
       //                                                                                           
                                                                                                    
       //---------------------------------------------------------------------------------------    
       //                                                                                           
       //Taula Articles. Una per línia. Informació específica                                      
       //                                                                                           
       //  Tota la informació necessaria per realitzar les validacions                              
       //                                                                                           
       dcl-ds dsArt Template;                                                                       
           zArti     like(s5arti) inz;                                                              
           zVari     like(s5vari) inz;                                                              
           zMode     like(s5mode) inz;                                                              
           zTcoj     like(NDTCOJ) inz;  //Conjunt                                                   
           zLine     like(s5line) inz;  //Número de línia                                           
           zLoge     like(s5loge) inz;  //Logística actual                                          
           zNcoe     like(s5line) inz;  // Número de coenvio                                        
           zNNcoe    like(s5line) inz;  // New Número de coenvio                                    
           zPrvr     like(m0prvr) inz;  //ProveÏdor article                                         
           zFrep     like(s5frep) inz;  //data prevista                                             
           zCant     like(s5cant) inz;  // Qty comanda                                              
           zUnim     like(s5unim) inz;  // Unitat Comanda                                           
           zCan2     like(s5cant) inz;  // Qty cambiada a unitat article (m5unim)                   
           zUni2     like(m5unim) inz;  // Unitat Article                                           
           zSiol     like(m5siol) inz;  // Article Propi                                            
           zTpe4     like(s5tpe4) inz;  // FD o no FD? That's the question!                         
           zNoED     char(1) inz(*blanks);                                                          
           zProb     char(2) inz(*blanks);    // Obsolet                                            
           zImpLin   like(d2imed) inz(*zero);  //Import línia    computed                           
           zVolLin   like(xVolpes) inz(*zero);  //Volumen línia   computed                          
           zTdi1     like(s5tdi1) inz;  // adreça d'endrega?? a nivell de línia?                    
           zPesLin   like(xVolpes) inz(*zero);  //Pes línia       computed                          
           zVUnLin   like(d2volu) inz(*blanks); // Unitat volum                                     
           zCost     like(m5cosp) inz;   // Cost per càlcul Especialillos                           
           zForzado  ind inz(*off); //Indicador de línia forçada                                    
           zExcpt    ind inz(*off); //Indicador de logística per except (arti/prov)                 
           zLogFinal like(s5loge) inz;  //Logística assignada                                       
           zLogVirtual like(s5loge) inz;  //Logística virtual de la logística assignada             
           znMAG     like(s5line) inz;   //Posició del magatzem assignat                            
           //// zServ     like(@PERRO);  //Article de servei. No és necessari                       
           // i dades d'excepció, paràmetres, etc...                                                
       end-ds;                                                                                      
       dcl-ds Tart likeds(dsArt) dim(kMaxArt) ; //qualified implicit amb Likeds                     
       //                                                                                           
       //  Tart(x).zArti = ....                                                                    
       //                                                                                           
       //Taula Components                                                                          
       dcl-ds TCom likeds(dsArt) dim(kMaxCom) ; //qualified implicit amb Likeds                     
       //   TCom(x).zArti  = ....                                                                  
                                                                                                    
       //Taula Magatzems emprats. Per processar residual                                           
       dcl-s TAMag like(s5line) dim(kMaxMag) inz; //Número de línia                                 
       //Taula Auxiliar per les assignacions via Excepcions                                        
       dcl-s TauxExc like(m0maga) dim(kMaxMag) inz;                                                 
       //Var Auxiliar per les assignacions via Excepcions                                          
       dcl-s iAuxExc like(s5line) inz;                                                              
       //Taula de Nivells de validació, criteris de validació, muesgues de validació... que sé     
       dcl-s TLevel like(s5line) dim(03) inz; // Pis criteri de validació a emprar                  
       //Taula Pendents. Aquí tindrem la informació de les línies que estan pendents d'assignar    
       dcl-s Tpend like(s5line) dim(kMaxArt) inz; //Número de línia                                 
       //  Inicialment tindrem la mateixa informació... o no.                                       
       //    Els articles amb excepcions ja no formaran part d'aquesta taula                        
       //                                                                                           
       //   Element  1  2  3  4  5  6                                                               
       //   valor    1  2  3  4  5  6 ...                                                           
       //                                                                                           
       //          Despés d'assignar línies a un magatzem, tindriem (per exemple)                   
       //                                                                                           
       //   Element  1  2  3  4  5  6                                                               
       //   valor    3  5  6  4  5  6 ...                                                           
       //                                                                                           
       //          Es a dir, sols queden els elements 3, 5 i 6 pendents d'assignar                  
       //      Tart(3) -> Tart(Tpend(1)).zVal                                                       
       //                                                                                           
       //   Però tenim els elements 4, 5, 6 informats!!                                             
       //   Sip, el darrer element que s'ha d'utilitzar està indicat per la variable iLPEND         
       //                                                                                           
       //      For i = 1 to iLPEND            // Ex. Bucle per tots els pendents                    
       //         Tart(Tpend(i)).zVal  .....                                                        
                                                                                                    
       //Taula Magatzems. Informació específica                                                    
       dcl-ds Tmag dim(kMaxMag) qualified;                                                          
           zMaga     like(m0maga);     //codi magatzem                                              
           zLoge     like(m0loge);     //logística del magatzem                                     
           zPrvr     like(m0prvr);     //Proveïdor del magatzem                                     
           ztal1     like(m0tal1);     //Tipus de magatzem                                          
           zImpo     like(T5impo);     // Import mínim                                              
           zDisp     like(T5DISP);     // %disponibilitat                                           
           zMLin     like(T5MLIN);     // num max línies                                            
           zMLia     like(T5MLIA);     // num línies actuals                                        
           zMLiZ     like(T5MLIA);     // calculat: num línies actuals descomptant assignació       
           zOctL     ind inz(*off);    // Omit Control línies    t4clin                             
           zOctS     ind inz(*off);    // Omit Control Stock     t4cstk                             
           zOctC     ind inz(*off);    // Omit Control Capacitat       t4ocap                       
           zOmag     ind inz(*off);    // Omit Magatzem ???? <--- MUESGA     t4omag                 
           zOctI     ind inz(*off);    // Omit Control Import Mínim          t4oimp                 
           zCapa     like(T5capa);     // capacitat màxima                                          
           zPeso     like(T5peso);     // pes màxim                                                 
           zVolu     like(T5Volu);     // volum màxim                                               
           zhorz     like(T5horz);     // dias horitzó                                              
           zFhor     like(@pedat1);    // data calculada                                            
           zPmin     like(T5pmin);     // % sobre mínimo                                            
           zAmasi    like(t5masi);     // % línies sobre total per poder triar aquest magatzem      
           zMagEsp   ind inz(*off);    // indicador de magaEsp                                      
           zOuni     like(xVolPes);    // t4ouni                                                    
           zOpes     like(xVolPes);    // t4opes                                                    
           zairOB    like(xair01);     // obsolets B                                                
           zairOC    like(xair01);     // obsolets C                                                
           zairAB    like(xair01);     // Articles B                                                
E7139      zairSS    like(xair03);     // SS Phase3                                                 
           zaoeOB    like(xaoe01);     // obsolets B  Si 1 NO conta punt expedició                  
           zaoeOC    like(xaoe01);     // obsolets C  Si 1 NO conta punt expedició                  
           zaoeAB    like(xaoe01);     // Articles B  Si 1 NO conta punt expedició                  
E7139      zaoeSS    like(xaoe03);     // SS Phase3  Si 1 NO conta punt expedició                   
E7139      zpsMax    packed(5:2) inz;  // SS Phase3  %proteger SMax                                 
           zNlin     like(s5line);     // número de línies que compleixen condició                  
           zAssigRonda  like(s5line);   //Magatzem assignat en n ronda (1a, 2a, ...)                
           zLogVirtual like(m0loge) inz;   //logística virtual del magatzem                         
E7249      zWHLO like(MBWHLO) inz; // Codi magatzem en M3. Sols per maga TAL1=8                     
           // i dades d'excepció, paràmetres, etc...                                                
       end-ds;                                                                                      
