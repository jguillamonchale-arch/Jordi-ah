FGI25                                                                                               
FGI25                  pDsArt.znMag = kMaxMag + itemp; // Assigno un valor per utilitzar-lo desp    
FGI25                  pDsArt.zLogFinal = m0logs;                                                   
FGI25                  pDsArt.zLogVirtual = Call1411(t4maga:*blanks:s0dlga);                        
FGI25                  pDsArt.zExcpt = *on;                                                         
FGI25                  if (m0tal1 = k8 or m0tal1 = k7);                                             
FGI25                    pDsArt.zTpe4 = k2;                                                         
FGI25                  else;                                                                        
FGI25                    pDsArt.zTpe4 = *blanks;                                                    
FGI25                  endif;                                                                       
