       //Alfanumeric To Integer                                                                    
       dcl-pr atoi int(10)  extproc('atoi');                                                        
          str      pointer  options(*string) value;                                                 
       end-pr;                                                                                      
                                                                                                    
       //Recupera variables d'entorn                                                               
       dcl-pr getenv pointer extproc('getenv');                                                     
         *n pointer value options(*string:*trim)  ;                                                 
       end-pr;                                                                                      
                                                                                                    
       //Tool per virtuals i d'altres                                                              
       dcl-pr pMM1411 extpgm('MM1411');                                                             
           @cias  like(s5cias) const;                                                               
           @maga  like(m0maga) const;                                                               
           @tipo  char(1) const;                                                                    
           @dlga  like(s0dlga) const;                                                               
           @resp  like(@peresp);                                                                    
       end-pr;                                                                                      
                                                                                                    
       //MsgBox: tool per mostrar info                                                             
       dcl-pr pMSGBOX        extpgm('MSGBOX');                                                      
         *n like(@pTitulo) const ;                        // Title                                  
         *n pointer const;                                // Pointer to message                     
         *n like(@pLongitud) const;                       // Length of message                      
         *n like(@pFuncion) const;                        // Function keys                          
         *n like(@pRetorno);                              // Return Value                           
         *n ind const;                                    // Optional: Text adjust                  
       end-pr;                                                                                      
                                                                                                    
       //Suma dies laborables a una data                                                           
       dcl-pr pCO2611 extpgm('CO2611');                                                             
