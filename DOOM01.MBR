FGI25                //OK, tenim excepció. Hem de validar-ho contra el MITBAL                       
FGI25                chain (gCONO:mqwhlo:mqitno) mitbal00;                                          
FGI25                if %found(mitbal00) and mbpuit=3;                                              
FGI25                  chain (pcias:t4maga) msalma;                                                 
20907                  if pDsArt.zNoed = k1 ; // Article NO accepta ED                              
