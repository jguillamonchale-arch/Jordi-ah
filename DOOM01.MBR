      //LoadMaga: Recuperem magatzems pel càlcul                                                   
         dcl-proc LoadMaga;                                                                         
         dcl-pi *n end-pi;                                                                          
         dcl-s bAux ind inz(*off);                                                                  
         dcl-s iAux like(s5line) inz;                                                               
                                                                                                    
                                                                                                    
         clear Tmag;                                                                                
         // Si tenim gChkArtiB o bTenimObso carreguem primer els magatzems de MSDDOM.               
         //   gChkArtiB i gChkObso són paràmetres a nivell empresa/dlga                             
         //                                                                                         
E7139    //       if bTenimObso or gChkArtiB; // Si tenim obsolets o Validar ArtiB                  
