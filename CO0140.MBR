     C     KCOCLIN       CHAIN(N)  COCLIN                             81                            
                                                                                                    
     C                   EVAL      ZXCUST=S0CUST                                                    
      * Obtenemos tiva del clientes                                                                 
      * Ahora con cabmio de criterio obtenemos el tipo de IVA del Pedido                            
     C                   EVAL      PECTAB='TIV2'                                                    
     C                   EVAL      PECLTA=*BLANKS                                                   
     C*                  EVAL      PECLTA=CL_S0TIVA                                                 
     C                   EVAL      PECLTA=S0TIV3                                                    
     C     KPMTABD       CHAIN     PMTABD                             81                            
     C                   EVAL      ZXTIVC=PEBL61                                                    
     C                   EVAL      ZXBL65I=PEBL65                                                   
                                                                                                    
     C                   IF        ZZE046='4'                                                       
     C                   EVAL      INDFRA=*ON                                                       
     C                   ENDIF                                                                      
     C                   IF        ZZPPPV>='1'                                                      
     C                   EVAL      INDPRO1=*ON                                                      
     C                   ENDIF                                                                      
                                                                                                    
      * Posicionamiento en situar en                                                                
     C                   EVAL      ERRGRL=*ON                                                       
      * GASTOS ADICIONALES                                                                          
     C                   IF        INDFRA=*ON AND @PGACL='1'                                        
     C                   EXSR      CS_GADIC                                                         
     C                   ENDIF                                                                      
      * Si es para envío automático                                                                 
     C                   IF        ZZEPP7>='1'                                                      
     C                   EVAL      U0CIAS=@PCIAS                                                    
     C                   EVAL      U0TENV='3'                                                       
     C                   EVAL      U0CLP0=S0CUST                                                    
      * El registro no debe ser baja ni puede estar desactivado y                                   
      * debe permitir traspaso automatico de pedidos                                                
     C     KUTCOM0       CHAIN     UTCOM0                             81                            
     C                   IF        CHAIN=*OFF AND U0BAJA<='0' AND                                   
     C                             U0ACTI<='0' AND U0EPP1>='1'                                      
     C                   EVAL      ZXUTCOMU=1                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      ************ GRABACION EN TRXXXX *****************************                                
      * Vamos a simplificar la situación de cara a temas relacionados                               
      * con el O.L. En principio, si @PACTU<='0'=> grabación normal por                             
      * opción RC manual=> grabara tanto cumpla condiciones de OL en local                          
      * como condiciones de O.L virtual                                                             
      * Las condiciones de O.L. local la marcarán ZZALOL y NRMAOR o NRMADE                          
      * = ZZMATR                                                                                    
     C                   EVAL      ZXOLLOCAL=*BLANKS                                                
     C                   IF        (ZZALOL>='1')                                                    
     C                   EVAL      ZXOLLOCAL='1'                                                    
     C                   ENDIF                                                                      
