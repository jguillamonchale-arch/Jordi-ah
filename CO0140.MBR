CR653C*C0031             EVAL      MSGER='ERR3017'                                                  
CR653C*C0031             EVAL      WRK34=*ON                                                        
CR653C*C0031             EVAL      WRK35=*ON                                                        
CR653C*C0031             EVAL      WRK39=*ON                                                        
CR653C*C0031             EVAL      WRK43=*ON                                                        
CR653C*C0031             ENDIF                                                                      
C0031C     ERRGRL        CABEQ     *ON           TSUCCHK                                            
