     C                   ENDIF                                                                      
     C                   SELECT                                                                     
     C                   WHEN      ZXNUMVI=1                                                        
     C                   EVAL      SUFDATA=W2DATAV1                                                 
     C                   WHEN      ZXNUMVI=2                                                        
     C                   EVAL      SUFDATA=W2DATAV2                                                 
     C                   WHEN      ZXNUMVI=3                                                        
     C                   EVAL      SUFDATA=W2DATAV3                                                 
23014C                   WHEN      ZXNUMVI=4                                                        
23014C                   EVAL      SUFDATA=W2DATAV4                                                 
FQ944C                   WHEN      ZXNUMVI=5                                                        
FQ944C                   EVAL      SUFDATA=W2DATAV5                                                 
     C                   ENDSL                                                                      
C0031C                   IF        S0COEN>='1'                                                      
FQ937C                   IF        S5NCOE>'00'                                                      
C0031C                   MOVEL     'C'           S022NCOE                                           
