23014C                   EVAL      S24MARC='*'                                                      
23014C                   ENDIF                                                                      
FQ944 *                                                                                             
FQ944C                   WHEN      ZXNUMVI=5                                                        
FQ944C                   EVAL      S25ARTI=S5ARTI                                                   
FQ944C                   EVAL      S25VARI=S5VARI                                                   
FQ944C                   EVAL      S25MODE=S5MODE                                                   
FQ944C                   EVAL      S25STUL=S5STUL                                                   
FQ944 * FECHA PEDIDO                                                                                
FQ944C                   EVAL      @PVAN=*ZEROS                                                     
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM      S5DATP        @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S25DATP=@PVAA                                                    
FQ944 * FECHA PETICIÓN ENTREGA CLIENTE                                                              
FQ944C                   EVAL      @PVAN=*ZEROS                                                     
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM      S5FREP        @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S25FREP=@PVAA                                                    
