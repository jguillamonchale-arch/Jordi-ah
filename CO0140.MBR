     C                   IF        S5PHLD>='1'                                                      
     C                   EVAL      S022PHLD='H'                                                     
     C                   ENDIF                                                                      
     C                   EVAL      S022RHLD=*BLANKS                                                 
     C                   IF        S5RHLD>='1'                                                      
     C                   EVAL      S022RHLD='M'                                                     
     C                   ENDIF                                                                      
     C***                EVAL      S022PPRG=S5PPRG                                                  
     C                   EVAL      S022TPPR=S5TPPR                                                  
C1663C                   EVAL      S022TPRM=S5TPRM                                                  
     C***                IF        S5PNUM<>0                                                        
     C***                MOVE      S5PNUM        S022PNUM                                           
     C***                ENDIF                                                                      
                                                                                                    
     C                   EXSR      CS_KEYPF                                                         
                                                                                                    
      *** En el caso de que se desee que el usuario no visualice costes                             
     C                   IF        ZZNPG2>='1'                                                      
