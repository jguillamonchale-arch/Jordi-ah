     C                   ENDIF                                                                      
     C                   IF        SUCMONE=*BLANKS                                                  
     C                   EVAL      SUCMONE=S0MONE                                                   
     C                   ENDIF                                                                      
     C                   EVAL      P6DECI=0                                                         
     C                   EVAL      P6AJUD=0                                                         
     C                   EVAL      P6ARTI=SUCARTI                                                   
     C                   EVAL      P6VARI=SUCVARI                                                   
     C                   EVAL      P6MODE=SUCMODE                                                   
     C                   EVAL      P6UNIM=SUCUNIM                                                   
     C     KPMUNAL       CHAIN     PMUNAL                             81                            
     C                   IF        *IN81=*ON                                                        
     C                   EVAL      P6VARI=*BLANKS                                                   
     C                   EVAL      P6MODE=*BLANKS                                                   
     C     KPMUNAL       CHAIN     PMUNAL                             81                            
     C                   ENDIF                                                                      
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK47=*ON                                                        
     C                   EVAL      MSGER='MSG0055'                                                  
     C                   ENDIF                                                                      
     C                   EVAL      PXDCCD=P6DECI                                                    
