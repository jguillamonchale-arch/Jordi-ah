04111C                   ENDIF                                                                      
04111*                                                                                             
04111C     W13INZT       ENDSR                                                                      
04111**************************************************************                                
04111* SUBRUTINA VISUALITZACIÓ DE W13                             *                                
04111*------------------------------------------------------------*                                
04111C     W13DSP        BEGSR                                                                      
04111*                                                                                             
04111C                   EVAL      ZXOPT2='CMD'                                                     
04111C                   EXFMT     W13                                                              
04111C                   EVAL      ERRGRL=*OFF                                                      
04111C                   EVAL      MSGER=*BLANKS                                                    
04111C                   SETOFF                                       58                            
04111C                   EVAL      CSRFILA=0                                                        
04111C                   EVAL      CSRCOLU=0                                                        
04111*                                                                                             
04111C     W13DSPT       ENDSR                                                                      
04111**************************************************************                                
04111* SUBRUTINA VALIDACIÓ DE CMD'S                               *                                
04111*------------------------------------------------------------*                                
04111C     W13CMD        BEGSR                                                                      
04111*                                                                                             
04111C                   EVAL      ZXOPT2='CHK'                                                     
04111*                                                                                             
04111C                   SELECT                                                                     
04111* F04=AJUDA ASSOCIADA A CAMP                                                                  
04111C                   WHEN      HELP=*ON                                                         
04111C                   EVAL      ZXOPT2='DSP'                                                     
04111C                   EXSR      W13F4                                                            
04111C                   EVAL      HELP=*OFF                                                        
04111C                   ENDSL                                                                      
04111*                                                                                             
04111C     W13CMDT       ENDSR                                                                      
04111**************************************************************                                
04111* SUBRUTINA VALIDACIÓ DE PANTALLA W13                        *                                
04111*------------------------------------------------------------*                                
04111C     W13CHK        BEGSR                                                                      
04111*                                                                                             
04111C                   EVAL      ZXOPT2='UPD'                                                     
04111*                                                                                             
04111C                   EVAL      @PEOPT=*BLANKS                                                   
04111C                   EVAL      @PEOPT=W13ETOD                                                   
04111C                   CALL      'MMPROM'                                                         
04111C                   PARM                    @PEOPT                                             
04111C                   PARM      *BLANKS       @PEPGM                                             
04111C                   PARM      *BLANKS       @PEFMT                                             
04111C                   PARM      'SINO      '  @PEFLD                                             
04111C                   PARM      'V'           @PEERR                                             
04111*                                                                                             
04111C                   IF        @PEERR>'0'                                                       
04111C                   EVAL      ERRGRL=*ON                                                       
04111C                   EVAL      MSGER='ASG1003'                                                  
04111C                   EVAL      WRK58=*ON                                                        
04111C                   ENDIF                                                                      
04111C     ERRGRL        CABEQ     *ON           W13CHKT                                            
04111*                                                                                             
04111C     W13CHKT       TAG                                                                        
04111C                   IF        ERRGRL=*ON                                                       
04111C                   EVAL      ZXOPT2='DSP'                                                     
04111C                   ENDIF                                                                      
04111*                                                                                             
04111C                   ENDSR                                                                      
04111**************************************************************                                
04111* ACTUALITZA EL CAMP A LA COMANDA                            *                                
04111*------------------------------------------------------------*                                
04111C     W13UPD        BEGSR                                                                      
04111*                                                                                             
04111C                   EVAL      ZXOPT1='END'                                                     
04111*                                                                                             
04111C     KCOCAPE       CHAIN     COCAPE                             81                            
04111C                   IF        CHAIN=*OFF                                                       
04111C                   EVAL      S0ETOD=W13ETOD                                                   
PGE21C                   EVAL      S0DAT8=*DATE                                                     
PGE21C                   TIME                    S0HORA                                             
PGE21C                   EVAL      S0USUA=SDSUSR                                                    
04111C                   UPDATE    RCOCAPE                                                          
04111C                   ENDIF                                                                      
04111*                                                                                             
04111C                   ENDSR                                                                      
04111**************************************************************                                
04111* SUBRUTINA DE AYUDA EN CAMPOS DEL   FMT P2A                 *                                
04111*------------------------------------------------------------*                                
04111C     W13F4         BEGSR                                                                      
04111*                                                                                             
04111* No se permite acceso a consulta si estamos en opcion de visualizar                          
04111C                   IF        INDDSP=*ON                                                       
04111C                   EVAL      ERRGRL=*ON                                                       
04111C                   ENDIF                                                                      
04111C     ERRGRL        CABEQ     *ON           W13F4T                                             
04111*                                                                                             
04111* F4 PARA VALORES QUE UNICAMENTE SE ACCEDE POR PROMPT SEGUN REFERENCIA                        
04111* DEL DICCIONARIO                                                                             
04111C                   IF        FIELD='W13ETOD'                                                  
04111C                   EVAL      @PEOPT=*BLANKS                                                   
04111C                   EVAL      @PEFLD='SINO   '                                                 
04111C                   CALL      'MMPROM'                                     Query-Aut-F4   X    
04111C                   PARM                    @PEOPT                         PARM Qry-F4         
04111C                   PARM      *BLANKS       @PEPGM                         PARM Qry-F4         
04111C                   PARM      *BLANKS       @PEFMT                         PARM Qry-F4         
04111C                   PARM                    @PEFLD                         PARM Qry-F4         
04111C                   PARM      *BLANKS       @PEERR                         PARM Qry-F4         
04111*                                                                                             
04111C                   IF        @PEERR>'0'                                                       
04111C                   EVAL      ERRGRL=*ON                                                       
04111C                   EVAL      MSGER='ADP0304'                                                  
04111C                   ENDIF                                                                      
04111C     ERRGRL        CABEQ     *ON           W13F4T                                             
04111*                                                                                             
04111* Si no han realizado ninguna selección no tocamos nada                                       
04111C                   IF        @PEERR='A'                                                       
04111C                   EVAL      ERRGRL=*ON                                                       
04111C                   ENDIF                                                                      
04111C     ERRGRL        CABEQ     *ON           W13F4T                                             
04111C                   EVAL      W13ETOD=@PEOPT                                                   
04111C                   GOTO      W13F4T                                                           
04111C                   ENDIF                                                                      
04111*                                                                                             
04111* SI NO TIENE F4 SOPORTADO DOY ERROR                                                          
04111C                   EVAL      ERRGRL=*ON                                                       
04111C                   EVAL      MSGER='ADP0304'                                                  
04111C     ERRGRL        CABEQ     *ON           W13F4T                                             
04111*                                                                                             
04111C     W13F4T        ENDSR                                                                      
IN948 **************************************************************************                    
IN948 * SUBRUTINA PARA COMPROBAR FECHAS DE COENVÍO                             *                    
IN948 *------------------------------------------------------------------------*                    
IN948C     CS_MAXCAB_FRREBEGSR                                                  BSR                
IN948C                   EVAL      ZXLOGE_ORG=S0LOGE                                                
IN948C                   EXSR      CS_VALIDA_DLGA                                                   
IN948C     KCOPPEC       CHAIN     COPPEC                             81                            
IN948 *                  IF        %FOUND(COPPEC) AND THTACT<='0' AND THRFPE='1'                    
IN948 *                            AND THTARS='1'                                                   
IN948C                   IF        S0C420<>'X'                                                      
IN948C                   CLEAR                   ZGFMAX                                             
IN944C     KCOCAPE       SETLL     CODEPE20                                                         
IN948C     KCOCAPE       READE(N)  CODEPE20                                                         
IN948C                   DOW       NOT %EOF(CODEPE20)                           D0                 
IN948C                   EVAL      M5CIAS=C_S5CIAS                              ·0                 
IN948C                   EVAL      M5ARTI=C_S5ARTI                              ·0                 
IN948C                   EVAL      M5VARI=C_S5VARI                              ·0                 
IN948C                   EVAL      M5MODE=C_S5MODE                              ·0                 
IN948C                   EXSR      CS_ARTSRV                                    ·0                 
IN948C                   IF        NOT ARTSRV AND C_S5FRRE>ZGFMAX                I1                
IN948C                   EVAL      ZGFMAX=C_S5FRRE                               ·1                
IN948C                   ENDIF                                                   E1                
IN948C     KCOCAPE       READE(N)  CODEPE20                                     ·0                 
IN948C                   ENDDO                                                  E0                 
IN948C     KCOCAPE       CHAIN     COCAPE                                                           
IN948C                   IF        %FOUND(COCAPE)                               I0                 
IN960C                             AND S0C420<>'X'                                                  
IN948C     KCOCAPE       CHAIN     COCAPE                                                           
IN948C                   EVAL      S0FRRE=ZGFMAX                                ·0                 
IN960C                   IF        ZGFMAX=0                                                         
IN960C                   EVAL      S0FRRR=S0FREP                                ·0                 
IN960C                   ELSE                                                                       
IN948C                   EVAL      S0FRRR=ZGFMAX                                ·0                 
IN960C                   ENDIF                                                                      
PGE21C                   EVAL      S0DAT8=*DATE                                                     
PGE21C                   TIME                    S0HORA                                             
PGE21C                   EVAL      S0USUA=SDSUSR                                                    
IN948C                   UPDATE    RCOCAPE                                      ·0                 
IN948C                   ENDIF                                                  E0                 
IN948C                   ENDIF                                                  E0                 
IN948C                   ENDSR                                                  ESR                
C1663 **************************************************************                                
C1663 * SUBRUTINA PARA BUSCAR SI HAY PROMOCIN Y CANTIDAD RESTO                                      
C1663 *-------------------------------------------------------------                                
C1663C     CS_BUSPROM    BEGSR                                                                      
C1663                                                                                               
C1663C                   EVAL      ZXAMUL  =*BLANKS                                                 
C1663C                   IF        ZXTPRM_OUT='1' OR ZXTPRM_OUT='3'                                 
C1663C                                        OR ZXTPRM_OUT='5'                                     
C1663C                   EVAL      ZXAMUL  ='1'                                                     
C1663C                   ENDIF                                                                      
C1663 *                                                                                             
C1663C                   IF        ZXTPRM_OUT='6' OR ZXTPRM_OUT='7'                                 
C1663C                                        OR ZXTPRM_OUT='8'                                     
C1663C                   EVAL      ZXAMUL  ='2'                                                     
C1663C                   ENDIF                                                                      
C1663 *                                                                                             
C1663C                   EVAL      SXCUST=S0CUST                                                    
C1663C****               EVAL      SXPRMO=@PEPRMO                                                   
C1663C                   EVAL      SXARVM=ZXARVMX                                                   
C1663C                   EVAL      SXTCOJ=SUCTCOJ                                                   
C1663 *                                                                                             
C1663 * promocion CLIENTE                                                                           
C1663C                   IF        ZXTPRM_OUT<'2'                                                   
C1663C     KCOPRMD_S     SETLL     COPRMD02                                                         
C1663C     KCOPRMD_S     READE     COPRMD02                                                         
C1663C                   DOW       NOT %EOF(coprmd02)                                               
C1663C                   IF        S0FPED>=SXFDES AND                                               
C1663C                             S0FPED<=SXFHAS AND                                               
C1663C                             ZXCANT>=SXCDES AND                                               
C1663C                             (ZXAMUL =SXAMUL OR                                               
C1663C                             (ZXAMUL  ='0' AND SXAMUL=' '))                                   
C1663C                   IF        ZXCANT<=SXCHAS                                                   
C1663C                   EVAL      ZXREST=0                                                         
C1663C                   LEAVE                                                                      
C1663C                   ELSE                                                                       
C1663C                   EVAL      ZXREST=ZXCANT-SXCHAS                                             
C1663C                   ENDIF                                                                      
C1663C                   ENDIF                                                                      
C1663C     KCOPRMD_S     READE     COPRMD02                                                         
C1663C                   ENDDO                                                                      
C1663C                   ENDIF                                                                      
C1663 *                                                                                             
C1663C                   IF        ZXTPRM_OUT='6'                                                   
C1663C     KCOPRMD_S     SETLL     COPRMD02                                                         
C1663C     KCOPRMD_S     READE     COPRMD02                                                         
C1663C                   DOW       NOT %EOF(coprmd02)                                               
C1663C                   IF        S0FPED>=SXFDES AND                                               
C1663C                             S0FPED<=SXFHAS AND                                               
C1663C                             ZXCANT>=SXCDES AND                                               
C1663C                             (SXAMUL ='2' )                                                   
C1663C                   IF        ZXCANT<=SXCHAS                                                   
C1663C                   EVAL      ZXREST=0                                                         
C1663C                   LEAVE                                                                      
C1663C                   ELSE                                                                       
C1663C                   EVAL      ZXREST=ZXCANT-SXCHAS                                             
C1663C                   ENDIF                                                                      
C1663C                   ENDIF                                                                      
C1663C     KCOPRMD_S     READE     COPRMD02                                                         
C1663C                   ENDDO                                                                      
C1663C                   ENDIF                                                                      
C1663 *                                                                                             
C1663 * promocion GRUPO                                                                             
C1663 *                                                                                             
C1663C                   IF        ZXTPRM_OUT='2' OR ZXTPRM_OUT='3'                                 
C1663C                   IF        CL_S0GRP2<>*BLANKS                                               
C1663C                   EVAL      PECTAB='GCOM      '                                              
C1663C                   EVAL      PECLTA=CL_S0GRP2                                                 
C1663C                   CLEAR                   PEDESC                                             
C1663C     KPMTABD       CHAIN     PMTABD                                                           
C1663C                   MOVEL     PEDESC        SXCUST                                             
C1663C     KCOPRMD_S     SETLL     COPRMD02                                                         
C1663C     KCOPRMD_S     READE     COPRMD02                                                         
C1663C                   DOW       NOT %EOF(coprmd02)                                               
C1663C                   IF        S0FPED>=SXFDES AND                                               
C1663C                             S0FPED<=SXFHAS AND                                               
C1663C                             ZXCANT>=SXCDES AND                                               
C1663C                             (ZXAMUL  =SXAMUL OR                                              
C1663C                             (ZXAMUL  ='0' AND SXAMUL=' '))                                   
C1663C                   IF        ZXCANT<=SXCHAS                                                   
C1663C                   EVAL      ZXREST=0                                                         
C1663C                   LEAVE                                                                      
C1663C                   ELSE                                                                       
C1663C                   EVAL      ZXREST=ZXCANT-SXCHAS                                             
C1663C                   ENDIF                                                                      
C1663C                   ENDIF                                                                      
C1663C     KCOPRMD_S     READE     COPRMD02                                                         
C1663C                   ENDDO                                                                      
C1663C                   ENDIF                                                                      
C1663C                   ENDIF                                                                      
C1663 *                                                                                             
C1663C                   IF        ZXTPRM_OUT='7'                                                   
C1663C                   IF        CL_S0GRP2<>*BLANKS                                               
C1663C                   EVAL      PECTAB='GCOM      '                                              
C1663C                   EVAL      PECLTA=CL_S0GRP2                                                 
C1663C                   CLEAR                   PEDESC                                             
C1663C     KPMTABD       CHAIN     PMTABD                                                           
C1663C                   MOVEL     PEDESC        SXCUST                                             
C1663C     KCOPRMD_S     SETLL     COPRMD02                                                         
C1663C     KCOPRMD_S     READE     COPRMD02                                                         
C1663C                   DOW       NOT %EOF(coprmd02)                                               
C1663C                   IF        S0FPED>=SXFDES AND                                               
C1663C                             S0FPED<=SXFHAS AND                                               
C1663C                             ZXCANT>=SXCDES AND                                               
C1663C                             (SXAMUL='2')                                                     
C1663C                   IF        ZXCANT<=SXCHAS                                                   
C1663C                   EVAL      ZXREST=0                                                         
C1663C                   LEAVE                                                                      
C1663C                   ELSE                                                                       
C1663C                   EVAL      ZXREST=ZXCANT-SXCHAS                                             
C1663C                   ENDIF                                                                      
C1663C                   ENDIF                                                                      
C1663C     KCOPRMD_S     READE     COPRMD02                                                         
C1663C                   ENDDO                                                                      
C1663C                   ENDIF                                                                      
C1663C                   ENDIF                                                                      
C1663 *                                                                                             
C1663 * promocion ARTICULO                                                                          
C1663 *                                                                                             
C1663C                   IF        ZXTPRM_OUT='4' OR ZXTPRM_OUT='5'                                 
C1663C                   CLEAR                   SXCUST                                             
C1663C     KCOPRMD_S     SETLL     COPRMD02                                                         
C1663C     KCOPRMD_S     READE     COPRMD02                                                         
C1663C                   DOW       NOT %EOF(coprmd02)                                               
C1663C                   IF        S0FPED>=SXFDES AND                                               
C1663C                             S0FPED<=SXFHAS AND                                               
C1663C                             ZXCANT>=SXCDES AND                                               
C1663C                             (ZXAMUL  =SXAMUL OR                                              
C1663C                             (ZXAMUL  ='0' AND SXAMUL=' '))                                   
C1663C                   IF        ZXCANT<=SXCHAS                                                   
C1663C                   EVAL      ZXREST=0                                                         
C1663C                   LEAVE                                                                      
C1663C                   ELSE                                                                       
C1663C                   EVAL      ZXREST=ZXCANT-SXCHAS                                             
C1663C                   ENDIF                                                                      
C1663C                   ENDIF                                                                      
C1663C     KCOPRMD_S     READE     COPRMD02                                                         
C1663C                   ENDDO                                                                      
C1663C                   ENDIF                                                                      
C1663                                                                                               
C1663C                   IF        ZXTPRM_OUT='8'                                                   
C1663C                   CLEAR                   SXCUST                                             
C1663C     KCOPRMD_S     SETLL     COPRMD02                                                         
C1663C     KCOPRMD_S     READE     COPRMD02                                                         
C1663C                   DOW       NOT %EOF(coprmd02)                                               
C1663C                   IF        S0FPED>=SXFDES AND                                               
C1663C                             S0FPED<=SXFHAS AND                                               
C1663C                             ZXCANT>=SXCDES AND                                               
C1663C                             (SXAMUL='2')                                                     
C1663C                   IF        ZXCANT<=SXCHAS                                                   
C1663C                   EVAL      ZXREST=0                                                         
C1663C                   LEAVE                                                                      
C1663C                   ELSE                                                                       
C1663C                   EVAL      ZXREST=ZXCANT-SXCHAS                                             
C1663C                   ENDIF                                                                      
C1663C                   ENDIF                                                                      
C1663C     KCOPRMD_S     READE     COPRMD02                                                         
C1663C                   ENDDO                                                                      
C1663C                   ENDIF                                                                      
C1663 *                                                                                             
C1663C***                IF        SXCDES<>0                                                        
C1663C***  ZXCANT        DIV       SXCDES        ZXMODU                                             
C1663C***                MVR                     ZXREST                                             
C1663C***                ENDIF                                                                      
C1663 *                                                                                             
C1663C                   IF        ZXREST<>0                                                        
C1663 * 1º, cantidad promoción - GRATUITAS con recalculo de precio                                  
C1663C                   CLEAR                   ZXCALC                                             
C1663C                   EVAL      @PECALC=*BLANKS                                                  
C1663C                   EVAL      ZXPRMO='5'                                                       
C1663C                   EVAL      @PECALC=ZXCALC                                                   
C1663C                   EVAL      @PECDEX=%char(SXCDES)                                            
C1663 * Obtenemos precio para cantidad resto de la promocion                                        
C1663 *                                                                                             
C1663C                   CALL      'CO2600'                                                         
C1663C                   PARM                    @PCIAS                                             
C1663C                   PARM      S0CUST        @PECUST                                            
C1663C                   PARM      ZXARVMX       @PEARVM                                            
C1663C                   PARM      SUCTCOJ       @PETCOJ                                            
C1663C                   PARM      S0FPED        @PEFPED                                            
C1663C                   PARM      ZXREST        @PECANT                                            
C1663C                   PARM      SUCUNIM       @PEUNIM                                            
C1663C                   PARM      ZXMONE2       @PEMONP                                            
C1663C                   PARM      S0MONB        @PEMONB                                            
C1663C                   PARM                    @PEZXCO                                            
C1663C                   PARM      S0CLTR        @PECLTR                                            
C1663C                   PARM      0             @PEPREC                                            
C1663C                   PARM      0             @PEDTO1                                            
C1663C                   PARM      0             @PEDTO2                                            
C1663C                   PARM      0             @PEDTO3                                            
C1663C                   PARM      0             @PEDTO4                                            
C1663C                   PARM      *BLANKS       @PEMONE                                            
C1663C                   PARM      0             @PECADP                                            
C1663C                   PARM      *BLANKS       @PEUNDP                                            
C1663C                   PARM      SUCTCST       @PETCST                                            
C1663C                   PARM      *BLANKS       @PETPPR                                            
C1663C                   PARM      *BLANKS       @PEPRMO                                            
C1663C                   PARM      0             @PEPCM1                                            
C1663C                   PARM      0             @PEPCM2                                            
C1663C                   PARM      0             @PEPCM3                                            
C1663C                   PARM      *BLANKS       @PEERR                                             
C1663C                   PARM      ZXTDI1        @PETDI1                                            
C1663C                   PARM                    @PECALC                                            
C1663C                   PARM                    @PECDEX                                            
C1663 *                                                                                             
C1663 ** SI FALTA PRECIO - MOSTRAR VENTANA CON DATOS PROMOC Y CANT                                  
C1663C                   IF        @PEERR>='1'                                                      
C1663C                   EVAL      PXDCCD=MBDECI                                                    
C1663C                   MOVE      MBAJUD        PXTIPA                                             
C1663C                   EVAL      PXALPH=*BLANKS                                                   
C1663C                   EVAL      PXNUM=SXPREC                                                     
C1663C                   CALL      'PRD650'                                                         
C1663C                   PARM                    PXNUM                                              
C1663C                   PARM      *BLANKS       PXALPH                                             
C1663C                   PARM                    PXFLDD                                             
C1663C                   PARM      2             PXDCCD                                             
C1663C                   PARM                    PXFMD1                                             
C1663C                   PARM                    PXEDTC                                             
C1663C                   PARM                    PXNMER                                             
C1663C                   PARM                    PXTIPA                                             
C1663C                   MOVE      PXALPH        SUCPREC                                            
C1663C                   EVAL      PXALPH=*BLANKS                                                   
C1663C                   EVAL      PXNUM=ZXCANT-ZXREST                                              
C1663C                   CALL      'PRD650'                                                         
C1663C                   PARM                    PXNUM                                              
C1663C                   PARM                    PXALPH                                             
C1663C                   PARM                    PXFLDD                                             
C1663C                   PARM                    PXDCCD                                             
C1663C                   PARM                    PXFMD1                                             
C1663C                   PARM                    PXEDTC                                             
C1663C                   PARM                    PXNMER                                             
C1663C                   PARM                    PXTIPA                                             
C1663C                   EVAL      W27PROM=%TRIM(SUCPREC)+' '+SUCMONE+                              
C1663C                             ' para '+%TRIM(PXALPH)+' '+SUCUNIM                               
C1663C                   EVAL      PXALPH=*BLANKS                                                   
C1663C                   EVAL      PXNUM=ZXREST                                                     
C1663C                   CALL      'PRD650'                                                         
C1663C                   PARM                    PXNUM                                              
C1663C                   PARM                    PXALPH                                             
C1663C                   PARM                    PXFLDD                                             
C1663C                   PARM                    PXDCCD                                             
C1663C                   PARM                    PXFMD1                                             
C1663C                   PARM                    PXEDTC                                             
C1663C                   PARM                    PXNMER                                             
C1663C                   PARM                    PXTIPA                                             
C1663C                   EVAL      W27REST=%TRIM(PXALPH)+' '+SUCUNIM                                
C1663C                   ENDIF                                                                      
C1663C                   ENDIF                                                                      
C1663C                   ENDSR                                                                      
C1663                                                                                               
C1663 **************************************************************                                
C1663 * BUSCAMOS SI ARTÍCULO TIENE PROMOCIONES ACTIVAS             *                                
C1663 **************************************************************                                
C1663C     CS_PROMOS     BEGSR                                                                      
C1663                                                                                               
C1663C*                  IF        S5PRMO=*BLANKS                                                   
C1663C                   EVAL      @PEFDES=S0DATP                                                   
C1663C                   EVAL      @PELINE=S5LINE                                                   
C1663C                   EVAL      @PECIAS=S5CIAS                                                   
C1663C                   EVAL      @PEDATP=S5DATP                                                   
C1663C                   EVAL      @PENOPL=S5NOPL                                                   
C1663 * verifico si + 1 cjto                                                                        
C1663C                   CLOSE     CODEPE                                                           
C1663C                   CALL      'CU0055'                             55                          
C1663C                   PARM                    @PECIAS           3 0                              
C1663C                   PARM      S5CUST        @PECUST                                            
C1663C                   PARM      S5DLGA        @PEDLGA                                            
C1663C                   PARM      S5NPCO        @PENPCO                                            
C1663C                   PARM      S5TPED        @PETPED                                            
C1663C                   PARM                    @PEDATP                                            
C1663C                   PARM                    @PENOPL                                            
C1663C                   PARM      S5LINE        @PELINE                                            
C1663C                   PARM      S5ARTI        @PEARTI                                            
C1663C                   PARM      S5VARI        @PEVARI                                            
C1663C                   PARM      S5MODE        @PEMODE                                            
C1663C                   PARM      S5TCOJ        @PETCOJ                                            
C1663C                   PARM      S0FPED        @PEFDES                                            
C1663C                   PARM      S5PRMO        @PEPRMO                                            
C1663C                   PARM      S5TPRM        @PETPRM                                            
C1663C                   PARM                    @PELINA                                            
C1663C                   PARM                    @PELINR                                            
C1663C                   PARM      '1V'          @PEOPT                                             
C1663C                   PARM      *BLANKS       @PEERR                                             
C1663C                   IF        @PEERR>*BLANKS OR                                                
C1663C                             @PEPRMO>*BLANKS                                                  
C1663C                   IF        @PEERR>*BLANKS                                                   
C1663C                   EVAL      @PEOPT='1 '                                                      
C1663C                   ELSE                                                                       
C1663C                   EVAL      @PEOPT='1O'                                                      
C1663C                   ENDIF                                                                      
C1663 *                                                                                             
C1663 *                                                                                             
C1663C                   CALL      'CU0055'                             55                          
