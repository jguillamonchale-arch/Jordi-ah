     C                   EVAL      ZXTTF1=S3TTF1                                                    
     C                   EVAL      ZXTTF2=S3TTF2                                                    
     C                   ELSE                                                                       
     C                   GOTO      TVALTTF1                                                         
     C                   ENDIF                                                                      
                                                                                                    
     C                   ELSE                                                                       
                                                                                                    
     C                   IF        M5TTF2>='1'                                                      
     C                   EVAL      ZXTTF1=M5TTF1                                                    
     C                   EVAL      ZXTTF2=M5TTF2                                                    
     C                   ELSE                                                                       
