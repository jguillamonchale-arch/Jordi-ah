10A12C                   EXSR      CS_RECPLZCOE                                                     
C0031C                   EVAL      C_S5LINE=0                                                       
C0031 *                                                                                             
C0031C                   EVAL      W09SINO='0'                                                      
C0031C                   EVAL      ZGFRAL=S5FRRR                                                    
FQ937C                   EVAL      ZGFORI=S5FRRR                                                    
C0031 *                                                                                             
IN947C*    KCODEPE200    SETLL     CODEPE20                                                         
IN947C*    KCODEPE20     READE     CODEPE20                                                         
IN947C*                  DOW       NOT %EOF(CODEPE20)                                               
IN947C*                  EVAL      M5ARTI=C_S5ARTI                                                  
IN947C*                  EVAL      M5VARI=C_S5VARI                                                  
IN947C*                  EVAL      M5MODE=C_S5MODE                                                  
IN947C*                  EXSR      CS_ARTSRV                                                        
IN947C*                  IF        NOT ARTSRV                                                       
IN947C*                                                                                             
IN947C*                  IF        (S0COEN='2' AND S5NCOE=C_S5NCOE) OR                              
IN947C*                            S0COEN='1'                                                       
IN947C*                  IF        C_S5FRRR>ZGFRAL                                                  
IN947C*                  EVAL      ZGFRCO=C_S5FRRR                                                  
IN947C*                  EVAL      S5FRRR=C_S5FRRR                                                  
IN947C*                  IF        S5FRRE<>0                                                        
IN947C*                  EVAL      S5FRRE=C_S5FRRR                                                  
IN947C*                  ELSE                                                                       
IN947C* FQ944 ********** EVAL      S5FREP=C_S5FRRR                                                  
IN947C*                  ENDIF                                                                      
IN947C*                  EVAL      W09SINO='1'                                                      
IN947C*                  EVAL      ZGFRAL=C_S5FRRR                                                  
IN947C*                  LEAVE                                                                      
IN947C*                  ENDIF                                                                      
IN947C*                                                                                             
IN947C*                  IF        C_S5FRRR<ZGFRAL                                                  
IN947C*                  EVAL      ZGFRCO=C_S5FRRR                                                  
IN947C*                  EVAL      C_S5FRRR=ZGFRAL                                                  
IN947C*                  IF        C_S5FRRE<>0                                                      
IN947C*                  EVAL      C_S5FRRE=C_S5FRRR                                                
IN947C*                  ELSE                                                                       
IN947C* FQ944 ********** EVAL      C_S5FREP=C_S5FRRR                                                
IN947C*                  ENDIF                                                                      
IN947C*                  EVAL      W09SINO='1'                                                      
IN947C*                  UPDATE    RCODEPE20                                                        
IN947C*                  ENDIF                                                                      
IN947C*                  ENDIF                                                                      
IN947C*                                                                                             
IN947C*                  ENDIF                                                                      
IN947C*    KCODEPE20     READE     CODEPE20                                                         
IN947C*                  ENDDO                                                                      
      * Buscar la fecha FRRR más desfavorable del coenvío                                           
