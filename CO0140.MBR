CUK04C                   EVAL      ZXHayStk = '1'                                                   
CUK04C                   IF        SUCTCOJ <> '4'                                                   
CUK04C                   EVAL      S5ARTI=SUCARTI                                                   
CUK04C                   EVAL      S5VARI=SUCVARI                                                   
CUK04C                   EVAL      S5MODE=SUCMODE                                                   
CUK04* comprobar si el artículo debe validar stock                                                 
CUK04C                   IF        M5CSTT > '0'                                                     
CUK04C                   EXSR      CS_CALESTO                                                       
CUK04C                   EVAL      ZXHayStk = (ZXSDIS >= ZXCANT)                                    
CUK04C                   ENDIF                                                                      
CUK04C                   ELSE                                                                       
CUK04* comprobamos componentes del conjunto                                                        
CUK04C                   EVAL      NDARTI = SUCARTI                                                 
CUK04C                   EVAL      NDVARI = SUCVARI                                                 
CUK04C                   EVAL      NDMODE = SUCMODE                                                 
CUK04C                   EVAL      NDTCOJ = SUCTCOJ                                                 
CUK04C     KMSCOJC       SETLL     MSCOJD                                                           
CUK04C     KMSCOJC       READE     MSCOJD                                                           
CUK04C                   DOW       NOT %EOF                                                         
CUK04C                   IF        NDBAJA<>'1'                                                      
CUK04C                   EVAL      M5ARTI = NDCOMP                                                  
CUK04C                   EVAL      M5VARI = NDVAR2                                                  
CUK04C                   EVAL      M5MODE = NDMOD2                                                  
CUK04C     KMSARTI00     CHAIN     MSARTI00                                                         
CUK04C                   IF        NOT %FOUND                                                       
CUK04C                   EVAL      ZXHayStk = '0'                                                   
CUK04C                   LEAVE                                                                      
CUK04C                   ENDIF                                                                      
CUK04* comprobar si el artículo debe validar stock                                                 
CUK04C                   IF        M5CSTT > '0'                                                     
MMK04C                   EVAL      S5ARTI = NDCOMP                                                  
CUK04C                   EVAL      S5VARI = NDVAR2                                                  
CUK04C                   EVAL      S5MODE = NDMOD2                                                  
CUK04C                   EXSR      CS_CALESTO                                                       
CUK04C                   EVAL      ZXHayStk = (ZXSDIS >= ZXCANT)                                    
CUK04C                   ENDIF                                                                      
CUK04C                   IF        NOT ZXHayStk                                                     
CUK04C                   LEAVE                                                                      
CUK04C                   ENDIF                                                                      
CUK04C                   ENDIF                                                                      
CUK04C     KMSCOJC       READE     MSCOJD                                                           
CUK04C                   ENDDO                                                                      
CUK04C                   ENDIF                                                                      
CUK04C                   ENDSR                                                                      
                                                                                                    
CUK04**************************************************************                                
CUK04* Tratar falta de stock en artículo individual               *                                
CUK04**************************************************************                                
CUK04C     CS_NoStkItem  BEGSR                                                                      
CUK04C                   EVAL      PXALPH = ' '                                                     
CUK04C                   EVAL      PXNUM = ZXCANT                                                   
CUK04C                   EVAL      PXDCCD= @RtvDecUn(SUCARTI:SUCVARI:SUCMODE:                       
CUK04C                                               SUCUNIM)                                       
CUK04C                   EVAL      PXEDTC= '2'                                                      
CUK04C                   EXSR      CS_Edita                                                         
CUK04C                   MOVE      PXALPH        W11CANT                                            
CUK04C                   EVAL      PXALPH = ' '                                                     
CUK04C                   EVAL      PXNUM = ZXSDIS                                                   
CUK04C                   EXSR      CS_Edita                                                         
CUK04C                   MOVE      PXALPH        W11STOK                                            
CUK04C                   IF        W11STOK = ' '                                                    
CUK04C                   MOVE      '0'           W11STOK                                            
CUK04C                   ENDIF                                                                      
CUK04C                   EXFMT     W11                                                              
CUK04C                   IF        *IN10                                                            
CUK04* Desactivamos indicador para no volver a mostrar la ventana en este artículo                 
CUK04C                   EVAL      ZXARTIX = SUCARTI                                                
CUK04C                   EVAL      ZXVARIX = SUCVARI                                                
CUK04C                   EVAL      ZXMODEX = SUCMODE                                                
CUK04C                   EVAL      ZXARVMX2 = ' '                                                   
CUK04C                   CALL      'MM0960'                                                         
CUK04C                   PARM      ZXARVMX       @PEARVM                                            
CUK04C                   PARM                    @PESUBS                                            
CUK04C                   PARM      ' '           @PEDESC                                            
CUK04C                   PARM      MILGCA        @PELOGE                                            
CUK04C                   PARM      ' '           @PERRO                                             
CUK04C                   IF        @PERRO = ' '                                                     
CUK04C                   EVAL      ZXARVMX2 = @PESUBS                                               
CUK04C                   EVAL      SUCARTI = ZXARTIX2                                               
CUK04C                   EVAL      SUCVARI = ZXVARIX2                                               
CUK04C                   EVAL      SUCMODE = ZXMODEX2                                               
CUK04C                   EVAL      ZXChgArt = '1'                                                   
CUK04C                   ENDIF                                                                      
CUK04C                   ENDIF                                                                      
CUK04C                   ENDSR                                                                      
                                                                                                    
CUK04**************************************************************                                
CUK04* Tratar falta de stock en componente de conjunto            *                                
CUK04**************************************************************                                
CUK04C     CS_NoStkCjto  BEGSR                                                                      
CUK04C                   EVAL      W12COMP = NDCOMP                                                 
CUK04C                   EVAL      W12VARI = NDVAR2                                                 
CUK04C                   EVAL      W12MODE = NDMOD2                                                 
CUK04C                   EVAL      PXALPH = ' '                                                     
CUK04C                   EVAL      PXNUM = ZXCANT                                                   
CUK04C                   EVAL      PXDCCD= @RtvDecUn(NDCOMP:NDVAR2:NDMOD2:                          
CUK04C                                               NDUNIM)                                        
CUK04C                   EVAL      PXEDTC= '2'                                                      
CUK04C                   EXSR      CS_Edita                                                         
CUK04C                   MOVE      PXALPH        W12CANT                                            
CUK04C                   EVAL      PXALPH = ' '                                                     
CUK04C                   EVAL      PXNUM = ZXSDIS                                                   
CUK04C                   EXSR      CS_Edita                                                         
CUK04C                   MOVE      PXALPH        W12STOK                                            
CUK04C                   IF        W12STOK = ' '                                                    
CUK04C                   MOVE      '0'           W12STOK                                            
CUK04C                   ENDIF                                                                      
CUK04C                   EXFMT     W12                                                              
CUK04C                   IF        *IN10                                                            
CUK04C                   CALL      'CO0186'                                                         
CUK04C                   PARM      @PCIAS        @PECIAS                                            
CUK04C                   PARM      SUFDLGA       @PEDLGA                                            
CUK04C                   PARM      SUCARTI       @PEARTI                                            
CUK04C                   PARM      SUCVARI       @PEVARI                                            
CUK04C                   PARM      SUCMODE       @PEMODE                                            
CUK04C                   PARM      SUCTCOJ       @PETCOJ                                            
CUK04C                   PARM      ' '           @PEDESC                                            
CUK04C                   PARM      MILGCA        @PELOGE                                            
CUK04C                   PARM      ' '           @PEOPCI                                            
CUK04C                   PARM      ' '           @PERRO                                             
CUK04C                   IF        @PERRO = ' '                                                     
CUK04C                   EVAL      SUCARTI = @PEARTI                                                
CUK04C                   EVAL      SUCVARI = @PEVARI                                                
CUK04C                   EVAL      SUCMODE = @PEMODE                                                
CUK04C                   EVAL      SUCTCOJ = @PETCOJ                                                
CUK04C                   EVAL      ZXChgArt = '1'                                                   
CUK04C                   ENDIF                                                                      
CUK04C                   ENDIF                                                                      
CUK04C                   ENDSR                                                                      
                                                                                                    
CUK04**************************************************************                                
CUK04* Llamada al PRD650                                          *                                
CUK04**************************************************************                                
CUK04C     CS_Edita      BEGSR                                                                      
CUK04C                   CALL      'PRD650'                                                         
CUK04C                   PARM                    PXNUM                          CAMP NUMÈRIC        
CUK04C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
CUK04C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
CUK04C                   PARM                    PXDCCD                         Nº DECIMALS         
CUK04C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
CUK04C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
CUK04C                   PARM                    PXNMER                         RETORN ERROR        
CUK04C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
CUK04C                   ENDSR                                                                      
13042 **************************************************************                                
13042 * SUBRUTINA CONTROL DEL SFL S01                              *                                
13042 *------------------------------------------------------------*                                
13042C     CS_CABCAP     BEGSR                                                                      
13042 *                                                                                             
13042C                   EVAL      XXBIMP=*ZEROS                                                    
13042C                   EVAL      XXIIV1=*ZEROS                                                    
13042C                   EVAL      XXIIV2=*ZEROS                                                    
13042C                   EVAL      XXCOST=*ZEROS                                                    
13042 *                                                                                             
13042C                   CALL      'CN0337'                                                         
13042C                   PARM      *BLANKS       @XJOBC                                             
13042C                   PARM      '1'           @XB2B                                              
13042C                   PARM      S0CIAS        @XCIAS                                             
13042C                   PARM      S0DLGA        @XDLGA                                             
13042C                   PARM      S0NPCO        @XNPCO                                             
13042C                   PARM      S0TPED        @XTPED                                             
13042C                   PARM      S0DATP        @XDATP                                             
13042C                   PARM      S0NOPL        @XNOPL                                             
13042C                   PARM      'X'           @XEERR                                             
13042 *                                                                                             
13042C                   EVAL      PXNUM=0                                                          
13042C                   EVAL      RYCIAS=@PCIAS                                                    
13042C                   EVAL      RYDLGA=@PDLGA                                                    
13042C                   EVAL      RYNPCO=@PNPCO                                                    
13042C                   EVAL      RYTPED=@PTPED                                                    
13042C                   EVAL      RYDATP=@PDATP                                                    
13042C                   EVAL      RYNOPL=@PNOPL                                                    
13042C                   EVAL      RYTPED=@PTPED                                                    
13042C     KCOCAIT       SETLL     COCAIT                                                           
13042C     KCOCAIT       READE     COCAIT                                                           
13042C                   DOW       NOT%EOF                                                          
13042C                   EVAL      XXBIMP=XXBIMP+RYBIMP                                             
13042C                   EVAL      XXIIV1=XXIIV1+RYIIV1                                             
13042C                   EVAL      XXIIV2=XXIIV2+RYIIV2                                             
13042C                   EVAL      XXCOST=XXCOST+RYCOST                                             
13042C     KCOCAIT       READE     COCAIT                                                           
13042C                   ENDDO                                                                      
13042 *                                                                                             
13042C                   EVAL      PXNUM= XXBIMP+XXIIV1+XXIIV2                                      
13042C                   EVAL      PXALPH=*BLANKS                                                   
13042C                   CALL      'PRD650'                                                         
13042C                   PARM                    PXNUM                                              
13042C                   PARM                    PXALPH                                             
13042C                   PARM                    PXFLDD                                             
13042C                   PARM      2             PXDCCD                                             
13042C                   PARM                    PXFMD1                                             
13042C                   PARM      'M'           PXEDTC                                             
13042C                   PARM                    PXNMER                                             
13042C                   PARM                    PXTIPA                                             
13042C                   MOVE      PXALPH        P21TOTL                                            
13042                                                                                               
13042C                   EVAL      PXNUM= XXCOST                                                    
13042C                   EVAL      PXALPH=*BLANKS                                                   
13042C                   CALL      'PRD650'                                                         
13042C                   PARM                    PXNUM                                              
13042C                   PARM                    PXALPH                                             
13042C                   PARM                    PXFLDD                                             
13042C                   PARM      2             PXDCCD                                             
13042C                   PARM                    PXFMD1                                             
13042C                   PARM      'M'           PXEDTC                                             
13042C                   PARM                    PXNMER                                             
13042C                   PARM                    PXTIPA                                             
13042C                   MOVE      PXALPH        P31TOTC                                            
13042                                                                                               
13042C                   EVAL      PXNUM= (XXBIMP-XXCOST)                                           
13042C                   EVAL      PXALPH=*BLANKS                                                   
13042C                   CALL      'PRD650'                                                         
13042C                   PARM                    PXNUM                                              
13042C                   PARM                    PXALPH                                             
13042C                   PARM                    PXFLDD                                             
13042C                   PARM      2             PXDCCD                                             
13042C                   PARM                    PXFMD1                                             
13042C                   PARM      'M'           PXEDTC                                             
13042C                   PARM                    PXNMER                                             
13042C                   PARM                    PXTIPA                                             
13042C                   MOVE      PXALPH        P31TOTB                                            
13042                                                                                               
13042C                   EVAL      PXALPH=*BLANKS                                                   
13042C                   EVAL      PXNUM = XXBIMP                                                   
13042C                   CALL      'PRD650'                                                         
13042C                   PARM                    PXNUM                                              
13042C                   PARM                    PXALPH                                             
13042C                   PARM                    PXFLDD                                             
13042C                   PARM      2             PXDCCD                                             
13042C                   PARM                    PXFMD1                                             
13042C                   PARM      'M'           PXEDTC                                             
13042C                   PARM                    PXNMER                                             
13042C                   PARM                    PXTIPA                                             
13042C                   MOVE      PXALPH        P11NETL                                            
13042C                   MOVE      PXALPH        P21NETL                                            
13042C                   MOVE      PXALPH        P31NETL                                            
13042                                                                                               
13042C                   EVAL      PXALPH=*BLANKS                                                   
13042C                   EVAL      PXNUM = XXIIV1+XXIIV2                                            
13042C                   CALL      'PRD650'                                                         
13042C                   PARM                    PXNUM                                              
13042C                   PARM                    PXALPH                                             
13042C                   PARM                    PXFLDD                                             
13042C                   PARM      2             PXDCCD                                             
13042C                   PARM                    PXFMD1                                             
13042C                   PARM      'M'           PXEDTC                                             
13042C                   PARM                    PXNMER                                             
13042C                   PARM                    PXTIPA                                             
13042C                   MOVE      PXALPH        P21IVAL                                            
13042                                                                                               
13042C                   IF        ZZNPG2=*BLANKS OR ZZNPG2='0'                                     
13042C                   IF        ZZRDT1>='1'                                                      
13042C                   IF        XXBIMP<>0                                                        
13042C                   EVAL      PXNUM=(1-(XXCOST/XXBIMP))*100                                    
13042C                   ENDIF                                                                      
13042C                   ELSE                                                                       
13042C                   IF        XXCOST<>0                                                        
13042C                   EVAL      PXNUM=(XXBIMP/XXCOST)*100                                        
13042C                   EVAL      PXNUM=PXNUM-100                                                  
13042C                   ENDIF                                                                      
13042C                   ENDIF                                                                      
13042C                   EVAL      PXALPH=' '                                                       
13042C                   CALL      'PRD650'                                                         
13042C                   PARM                    PXNUM                                              
13042C                   PARM                    PXALPH                                             
13042C                   PARM                    PXFLDD                                             
13042C                   PARM      1             PXDCCD                                             
13042C                   PARM                    PXFMD1                                             
13042C                   PARM      'M'           PXEDTC                                             
13042C                   PARM                    PXNMER                                             
13042C                   PARM                    PXTIPA                                             
13042C                   MOVE      PXALPH        P11RDTO                                            
13042C                   MOVE      PXALPH        P21RDTO                                            
13042C                   MOVE      PXALPH        P31RDTO                                            
13042C                   EVAL      P11SPOR = '%'                                                    
13042C                   EVAL      P21SPOR = '%'                                                    
13042C                   EVAL      P31SPOR = '%'                                                    
13042C                   ELSE                                                                       
13042C                   EVAL      P11RDTO = *BLANKS                                                
13042C                   EVAL      P21RDTO = *BLANKS                                                
13042C                   EVAL      P31RDTO = *BLANKS                                                
13042C                   ENDIF                                                                      
13042                                                                                               
13042C                   SELECT                                                                     
13042C                   WHEN      ZXNUMVI=1                                                        
13042C                   EVAL      PPRESU = PPDATA1                                                 
13042C                   WHEN      ZXNUMVI=2                                                        
13042C                   EVAL      PPRESU = PPDATA2                                                 
13042C                   WHEN      ZXNUMVI=3                                                        
13042C                   EVAL      PPRESU = PPDATA3                                                 
13042C                   OTHER                                                                      
C1688**13042             EVAL      PPRESU = *BLANKS                                                 
C1688C                   EVAL      PPRESU = PPDATA1                                                 
13042C                   ENDSL                                                                      
13042 *                                                                                             
13042C                   ENDSR                                                                      
13612 **************************************************************************                    
13612 * AJUSTAR S5FREP A SEMANA                                                *                    
13612 *------------------------------------------------------------------------*                    
13612C     CS_FECWEEK    BEGSR                                                                      
30812C                   EVAL      ZXLINE=S5LINE                                                    
13612 *                                                                                             
13612C                   CLEAR                   SSSWEEK                                            
13612 *                                                                                             
13612C     KCODEPE0      SETLL     CODEPE                                                           
13612C*30812 KCODEPE0      READE     CODEPE                                                         
30812C     KCODEPE0      READE(N)  CODEPE                                                           
13612C                   DOW       NOT %EOF(CODEPE)                                                 
26712C                   EVAL      M5ARTI=S5ARTI                                                    
26712C                   EVAL      M5VARI=S5VARI                                                    
26712C                   EVAL      M5MODE=S5MODE                                                    
26712C                   EXSR      CS_ARTSRV                                                        
26712C                   IF        NOT ARTSRV                                                       
04712C                   IF        S5NCOE<='00'                                                     
IN944C                             AND S5CMRE<>'1'                                                  
13612 *                                                                                             
13612C                   EVAL      @PEFRRE=S5FRRE                                                   
13612C                   CALL      'MM2707'                                                         
13612C                   PARM      @PCIAS        @PECIAS                                            
13612C                   PARM                    @PEFRRE                                            
13612C                   PARM      *ZEROS        @PEWEEK                                            
13612C                   PARM      *BLANKS       @PEERRO                                            
13612 *                                                                                             
13612C                   IF        SSSWEEK(@PEWEEK)<S5FRRE                                          
13612C                   EVAL      SSSWEEK(@PEWEEK)=S5FRRE                                          
29B12C                   EVAL      SSSDISP(@PEWEEK)=S5DISP                                          
13612C                   ENDIF                                                                      
13612 *                                                                                             
04712C                   ENDIF                                                                      
26712C                   ENDIF                                                                      
13612C*30812 KCODEPE0      READE     CODEPE                                                         
30812C     KCODEPE0      READE(N)  CODEPE                                                           
13612C                   ENDDO                                                                      
13612 *                                                                                             
13612C     KCODEPE0      SETLL     CODEPE                                                           
13612C     KCODEPE0      READE     CODEPE                                                           
13612C                   DOW       NOT %EOF(CODEPE)                                                 
26712C                   EVAL      M5ARTI=S5ARTI                                                    
26712C                   EVAL      M5VARI=S5VARI                                                    
26712C                   EVAL      M5MODE=S5MODE                                                    
26712C                   EXSR      CS_ARTSRV                                                        
26712C                   IF        NOT ARTSRV                                                       
04712C                   IF        S5NCOE<='00'                                                     
IN944C                             AND S5CMRE<>'1'                                                  
13612 *                                                                                             
13612C                   EVAL      @PEFRRE=S5FRRE                                                   
13612C                   CALL      'MM2707'                                                         
13612C                   PARM      @PCIAS        @PECIAS                                            
13612C                   PARM                    @PEFRRE                                            
13612C                   PARM      *ZEROS        @PEWEEK                                            
13612C                   PARM      *BLANKS       @PEERRO                                            
13612 *                                                                                             
13612C                   IF        S5FRRE<SSSWEEK(@PEWEEK)                                          
13612C                   EVAL      S5FRRE=SSSWEEK(@PEWEEK)                                          
29B12C                   EVAL      S5DISP=SSSDISP(@PEWEEK)                                          
13612C                   EVAL      S5FRRR=S5FRRE                                                    
PGE21C                   EVAL      S5DAT8=*DATE                                                     
PGE21C                   TIME                    S5HORA                                             
PGE21C                   EVAL      S5USUA=SDSUSR                                                    
13612C                   UPDATE    RCODEPE                                                          
IN947C                   EVAL      @PETIPP='05'                                                     
16B12C                   EVAL      @PCIAS=S5CIAS                                                    
16B12C                   EVAL      @PDLGA=S5DLGA                                                    
16B12C                   EVAL      @PNPCO=S5NPCO                                                    
16B12C                   EVAL      @PTPED=S5TPED                                                    
16B12C                   EVAL      @PDATP=S5DATP                                                    
16B12C                   EVAL      @PNOPL=S5NOPL                                                    
16B12C                   EVAL      @PEARTI=S5ARTI                                                   
16B12C                   EVAL      @PEVARI=S5VARI                                                   
16B12C                   EVAL      @PEMODE=S5MODE                                                   
16B12C                   EVAL      @PELINE=S5LINE                                                   
07113C                   EVAL      @PEERRO='*'                                                      
16B12C                   EXSR      CS_COHFEN                                    I0                 
13612C                   ENDIF                                                                      
13612 *                                                                                             
04712C                   ENDIF                                                                      
26712C                   ENDIF                                                                      
13612C     KCODEPE0      READE     CODEPE                                                           
13612C                   ENDDO                                                                      
