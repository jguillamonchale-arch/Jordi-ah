C0031 **************************************************************                                
C0031 * GUARDA LOGISTICA DEL OL                                    *                                
C0031 *------------------------------------------------------------*                                
C0031C     CS_LOGOL      BEGSR                                                                      
C0031 *                                                                                             
F-2OLC*C0031      @PCIAS        SETLL     MSALMA                                                    
F-2OLC*C0031      @PCIAS        READE     MSALMA                                                    
F-2OLC*C0031                    DOW       NOT %EOF(MSALMA)                                          
F-2OLC*C0031                    IF        M0TAL1='8' AND M0BAJA<>'1'                                
F-2OLC*C0031                    EVAL      ZXLOGOL=M0LOGS                                            
F-2OLC*C0031                    LEAVE                                                               
F-2OLC*C0031                    ENDIF                                                               
F-2OLC*C0031      @PCIAS        READE     MSALMA                          84                        
F-2OLC*C0031                    ENDDO                                                               
F-2OLc*                                                                                             
F-2OLc                   eval      i2OL = *zero                                                     
F-2OLc                   eval      zztal1 = '8'                                                     
F-2OLc                   open      msalma08                                                         
F-2OLc     Kalma08       setll     msalma08                                                         
F-2OLc     Kalma08       reade     msalma08                                                         
F-2OLc                   dow       not %eof(msalma08)                                               
F-2OLc                   if        m0tal1='8' and m0baja<>'1'                                       
F-2OLc                             and i2OL < %elem(T_logol)                                        
F-2OLc                   eval      i2OL += 1                                                        
F-2OLc                   eval      T_logol(i2OL) = m0logs                                           
F-2OLc                   eval      T_maga(i2OL) = m0maga                                            
F-2OLc                   endif                                                                      
F-2OLc     Kalma08       reade     msalma08                                                         
F-2OLc                   enddo                                                                      
F-2OLc                   close     msalma08                                                         
F-2OLc*                                                                                             
C0031C                   ENDSR                                                                      
C0031 **************************************************************                                
C0031 * SUBRUTINA PARA RENUMERAR LÍNEAS DE COENVÍOS                *                                
C0031 *------------------------------------------------------------*                                
C0031C     CS_RENUMCO    BEGSR                                                                      
C0031 *                                                                                             
C0031C                   EVAL      ZXCONCOE=*BLANKS                                                 
C0031C                   EVAL      ZXCONTCOEN=0                                                     
C0031C                   EVAL      CC=0                                                             
C0031C                   CLEAR                   SSSNCOE                                            
C0031C                   CLEAR                   SSSLINCO                                           
C0031 *                                                                                             
C0031 * 1ª Pasada, Guardo en Series                                                                 
C0031 *                                                                                             
C0031C     KCODEPE20X    SETLL     CODEPE20                                                         
C0031C     KCODEPE20X    READE(N)  CODEPE20                                                         
C0031C                   DOW       NOT %EOF(CODEPE20)                                               
26712C                   EVAL      M5ARTI=C_S5ARTI                                                  
26712C                   EVAL      M5VARI=C_S5VARI                                                  
26712C                   EVAL      M5MODE=C_S5MODE                                                  
26712C                   EXSR      CS_ARTSRV                                                        
26712C                   IF        NOT ARTSRV                                                       
C0031C                   IF        C_S5NCOE>='01' AND C_S5NCOE<='99'                                
C0031 *                                                                                             
C0031 * ROMPE COENVÍO                                                                               
C0031 *                                                                                             
C0031C                   IF        C_S5NCOE<>ZXCONCOE                                               
C0031C                             AND ZXCONCOE<>*BLANKS                                            
C0031C                   EVAL      CC=CC+1                                                          
C0031C                   EVAL      SSSNCOE(CC)=ZXCONCOE                                             
C0031C                   MOVE      ZXCONTCOEN    SSSLINCO(CC)                                       
C0031C                   EVAL      ZXCONTCOEN=0                                                     
C0031C                   ENDIF                                                                      
C0031 *                                                                                             
C0031C                   EVAL      ZXCONTCOEN=ZXCONTCOEN+1                                          
C0031C                   EVAL      ZXCONCOE=C_S5NCOE                                                
C0031 *                                                                                             
C0031C                   ENDIF                                                                      
26712C                   ENDIF                                                                      
C0031C     KCODEPE20X    READE(N)  CODEPE20                                                         
C0031C                   ENDDO                                                                      
C0031 *                                                                                             
C0031 * EL ÚLTIMO                                                                                   
C0031 *                                                                                             
C0031C                   IF        ZXCONCOE>='01' AND ZXCONCOE<='99'                                
C0031C                   EVAL      CC=CC+1                                                          
C0031C                   EVAL      SSSNCOE(CC)=ZXCONCOE                                             
C0031C                   MOVE      ZXCONTCOEN    SSSLINCO(CC)                                       
C0031C                   ENDIF                                                                      
C0031 *                                                                                             
C0031 * 2º Pasada: Actualizo                                                                        
C0031 *                                                                                             
C0031C                   EVAL      ZXCONCOE=*BLANKS                                                 
C0031C                   EVAL      ZXCONTCOEN=0                                                     
C0031C                   EVAL      CC=0                                                             
C0031C     KCODEPE20X    SETLL     CODEPE20                                                         
C0031C     KCODEPE20X    READE     CODEPE20                                                         
C0031C                   DOW       NOT %EOF(CODEPE20)                                               
26712C                   EVAL      M5ARTI=C_S5ARTI                                                  
26712C                   EVAL      M5VARI=C_S5VARI                                                  
26712C                   EVAL      M5MODE=C_S5MODE                                                  
26712C                   EXSR      CS_ARTSRV                                                        
26712C                   IF        NOT ARTSRV                                                       
C0031 *                                                                                             
C0031 * Inicializo valores                                                                          
C0031 *                                                                                             
C0031C                   EVAL      C_S5NCOI='00'                                                    
C0031C                   EVAL      C_S5NCOF='00'                                                    
C0031 *                                                                                             
C0031 * Sólo para coenvíos                                                                          
C0031 *                                                                                             
C0031C                   IF        C_S5NCOE>='01' AND C_S5NCOE<='99'                                
C0031 *                                                                                             
C0031 * ROMPE COENVÍO INICIALIZO CONTADOR DE LÍNEAS                                                 
C0031 *                                                                                             
C0031C                   IF        C_S5NCOE<>ZXCONCOE                                               
C0031C                             AND ZXCONCOE<>*BLANKS                                            
C0031C                   EVAL      ZXCONTCOEN=0                                                     
C0031C                   ENDIF                                                                      
C0031 *                                                                                             
C0031C                   EVAL      ZXCONTCOEN=ZXCONTCOEN+1                                          
C0031C                   EVAL      CC=1                                                             
C0031C     C_S5NCOE      LOOKUP    SSSNCOE(CC)                            55                        
C0031C                   IF        *IN55                                                            
C0031C                   MOVE      ZXCONTCOEN    C_S5NCOI                                           
C0031C                   EVAL      C_S5NCOF=SSSLINCO(CC)                                            
C0031C                   ENDIF                                                                      
C0031 *                                                                                             
C0031C                   EVAL      ZXCONCOE=C_S5NCOE                                                
C0031 *                                                                                             
C0031C                   ENDIF                                                                      
C0031 *                                                                                             
C0031 * Siempre Actualizo (Aunque no tenga Coenvío)                                                 
C0031 *                                                                                             
PGE21C                   EVAL      C_S5DAT8=*DATE                                                   
PGE21C                   TIME                    C_S5HORA                                           
PGE21C                   EVAL      C_S5USUA=SDSUSR                                                  
C0031C                   UPDATE    RCODEPE20                                                        
C0031 *                                                                                             
26712C                   ENDIF                                                                      
C0031C     KCODEPE20X    READE     CODEPE20                                                         
C0031C                   ENDDO                                                                      
C0031 *                                                                                             
C0031C                   ENDSR                                                                      
                                                                                                    
30056 **************************************************************                                
30056 * SUBRUTINA PASAR A HISTORICO LA MODIFICACION                *                                
30056 *------------------------------------------------------------*                                
30056C     CS_COHCON     BEGSR                                                                      
30056 *                                                                                             
30056C                   EVAL      SWCIAS=S5CIAS                                                    
30056C                   EVAL      SWDLGA=S5DLGA                                                    
30056C                   EVAL      SWNPCO=S5NPCO                                                    
30056C                   EVAL      SWTPED=S5TPED                                                    
30056C                   EVAL      SWDATP=S5DATP                                                    
30056C                   EVAL      SWNOPL=S5NOPL                                                    
30056C                   EVAL      SWLINP=S5LINE                                                    
                                                                                                    
30056C                   EVAL      SWDAT1=ZZDATS                                                    
30056C                   IF        SWDAT1=0                                                         
30056C                   EVAL      SWDAT1=*DATE                                                     
30056C                   ENDIF                                                                      
30056C                   TIME                    SWHORA                                             
30056C     *NOKEY        CLEAR     *ALL          RCOHCON                                            
30056C                   DOW       CHAIN=*OFF                                                       
30056C     KCOHCON       CHAIN     COHCON                             81                            
30056C                   IF        CHAIN=*OFF                                                       
30056C                   EVAL      SWHORA=SWHORA+1                                                  
30056C                   ENDIF                                                                      
30056C                   ENDDO                                                                      
                                                                                                    
30056C                   IF        CHAIN=*ON                                                        
30056C                   EVAL      SWFRRE=S5FRRE                                                    
25051C                   EVAL      SWFRR2=S5FRRE                                                    
30056C                   EVAL      SWDT1C=S5DT1C                                                    
30056C                   EVAL      SWDT2C=S5DT2C                                                    
30056C                   EVAL      SWDT3C=S5DT3C                                                    
30056C                   EVAL      SWDT4C=S5DT4C                                                    
30056C                   EVAL      SWCANC=S5CANC                                                    
30056C                   EVAL      SWUNIM=S5UNIM                                                    
30056C                   EVAL      SWPRCC=S5PRCC                                                    
30056C                   EVAL      SWMONC=S5MONC                                                    
30056C                   EVAL      SWCADC=S5CADC                                                    
30056C                   EVAL      SWUNDC=S5UNDC                                                    
30056C                   EVAL      SWJOBP=ZZPANT                                                    
30056C                   EVAL      SWTRAB=ZZUSUA                                                    
30056C                   EVAL      SWCAUS=*BLANKS                                                   
                                                                                                    
30056C                   EVAL      SWPANT=ZZPANT                                                    
30056C                   EVAL      SWUSUA=ZZUSUA                                                    
30056C                   EVAL      SWDAT8=SWDAT1                                                    
                                                                                                    
30056C                   WRITE     RCOHCON                                                          
                                                                                                    
30056C                   ENDIF                                                                      
                                                                                                    
30056C                   ENDSR                                                                      
14066* ================================================================== *                        
14066* SUBRUTINA DE CALCULA DE COSTES ADICIONALES.                        *                        
14066* ================================================================== *                        
14066C     CS_MSACOS     BEGSR                                                                      
14066C                   EVAL      M5CIAS=S5CIAS                                                    
14066C                   EVAL      M5ARTI=S5ARTI                                                    
14066C                   EVAL      M5VARI=S5VARI                                                    
14066C                   EVAL      M5MODE=S5MODE                                                    
14066C     KMSARTI00     CHAIN     MSARTI00                                                         
                                                                                                    
14066C                   EVAL      NMCIAS=ZZCIAS                                                    
14066C                   EVAL      NMARTI=S5ARTI                                                    
14066C                   EVAL      NMVARI=S5VARI                                                    
14066C                   EVAL      NMMODE=S5MODE                                                    
14066C                   EVAL      NMTCOJ=*BLANKS                                                   
14066C                   EVAL      NMMAGA=*BLANKS                                                   
14066                                                                                               
14066C                   EVAL      READ1=*OFF                                                       
14066C     KMSACOS       SETLL     MSACOS                                                           
14066C     KMSACOS       READE     MSACOS                                 83                        
14066C                   DOW       READ1=*OFF                                                       
14066*Solo cargar conceptos que estén activos                                                      
14066C                   EVAL      PECIAS=S5CIAS                                                    
14066C                   EVAL      PECTAB='CCOS'                                                    
14066C                   EVAL      PECLTA=NMCLTA                                                    
14066C     KPMTABD       CHAIN     PMTABD                                                           
14066C                   IF        %FOUND(PMTABD) AND PEBAJA<'1'                                    
14066C                   IF        NMCOAD='1'                                                       
14066C                   SELECT                                                                     
14066C                   WHEN      M5TCOS = '0'                                                     
14066C                   EVAL      ZXCOST = ZXCOST + (                                              
14066C                               M5COSU * NMCOSU / 100) * ZXCANTR * ZXCOCAM3                    
14066C                   WHEN      M5TCOS = '1'                                                     
14066C                   EVAL      ZXCOST = ZXCOST + (                                              
14066C                               M5COSP * NMCOSP / 100) * ZXCANTR * ZXCOCAM3                    
14066C                   WHEN      M5TCOS = '2'                                                     
14066C                   EVAL      ZXCOST = ZXCOST + (                                              
14066C                               M5COSM * NMCOSM / 100) * ZXCANTR * ZXCOCAM3                    
14066C                   ENDSL                                                                      
14066C                   ELSE                                                                       
14066C                   SELECT                                                                     
14066C                   WHEN      M5TCOS = '0'                                                     
14066C                   EVAL      ZXCOST = ZXCOST + (NMCOSU * ZXCANTR)                             
14066C                                      * ZXCOCAM3                                              
14066C                   WHEN      M5TCOS = '1'                                                     
14066C                   EVAL      ZXCOST = ZXCOST + (NMCOSP * ZXCANTR)                             
14066C                                      * ZXCOCAM3                                              
14066C                   WHEN      M5TCOS = '2'                                                     
14066C                   EVAL      ZXCOST = ZXCOST + (NMCOSM * ZXCANTR)                             
14066C                                      * ZXCOCAM3                                              
14066C                   ENDSL                                                                      
14066C                   ENDIF                                                                      
14066C                   ENDIF                                                                      
14066C     KMSACOS       READE     MSACOS                                 83                        
14066C                   ENDDO                                                                      
14066C                   ENDSR                                                                      
                                                                                                    
27038 **************************************************************                                
27038 * COMMON SUBRUTINE (CS_) :                                   *                                
27038 * Recuperar CATERORIA ROTACIÓN CONSERVARLA PARA ANALISIS TCT *                                
27038 *------------------------------------------------------------*                                
27038C     CS_BUSROT     BEGSR                                                                      
      * BLANQUEAMOS VALORES A BUSCAR                                                                
27038C                   EVAL      S5CROT=*BLANKS                                                   
27038C                   EVAL      S5CROP=*BLANKS                                                   
27038 * BUSCAMOS EL ALMACEN DEL QUE DEBEMOS RECUPERAR LA INFORMACIÓN                                
27038C                   EVAL      MICIAS=S5CIAS                                                    
27038C                   EVAL      MIDLGA=S5DLGA                                                    
27038C                   EVAL      MILGCA=S5LOGE                                                    
27038C                   EVAL      MIMAGA=*BLANKS                                                   
27038C     KMSLOGI       CHAIN     MSLOAD                             81                            
      *                                                                                             
27038C                   EVAL      M1CIAS=S5CIAS                                                    
27038C                   EVAL      M1MAGA=MIMAGA                                                    
27038C                   EVAL      M1ARTI=S5ARTI                                                    
27038C                   EVAL      M1VARI=S5VARI                                                    
27038C                   EVAL      M1MODE=S5MODE                                                    
27038C     KMSSTOK       CHAIN     MSSTOK                             81                            
27038C                   IF        CHAIN=*OFF                                                       
27038C                   EVAL      S5CROT=M1CROT                                                    
27038C                   EVAL      S5CROP=M1PLUS                                                    
27038C                   ENDIF                                                                      
                                                                                                    
      * SI ESTE ARTICULO ES CONJUNTO-> BUSCAMOS LA CAT.ROT DE LOS COMPO                             
      * BLANQUEAMOS VALORES A BUSCAR                                                                
16058C                   EVAL      S5CROTA=*BLANKS                                                  
16058C                   EVAL      S5CROTB=*BLANKS                                                  
16058C                   EVAL      S5CROTC=*BLANKS                                                  
16058C                   EVAL      ZXCROTA=*ZEROS                                                   
16058C                   EVAL      ZXCROTB=*ZEROS                                                   
16058C                   EVAL      ZXCROTC=*ZEROS                                                   
                                                                                                    
16058C                   IF        S5TCOJ='4'                                                       
16058C                   EXSR      CS_BUSROTC                                                       
     C                   MOVE      ZXCROTA       S5CROTA                                            
     C                   MOVE      ZXCROTB       S5CROTB                                            
     C                   MOVE      ZXCROTC       S5CROTC                                            
16058C                   ENDIF                                                                      
                                                                                                    
16058C                   ENDSR                                                                      
16058 **************************************************************                                
16058 * COMMON SUBRUTINE (CS_) :                                   *                                
16058 * Recuperar CATERORIA ROTACIÓN CONSERVARLA PARA ANALISIS TCT *                                
16058 *------------------------------------------------------------*                                
16058C     CS_BUSROTC    BEGSR                                                                      
      *                                                                                             
16058C                   EVAL      NDCIAS=S5CIAS                                                    
16058C                   EVAL      NDARTI=S5ARTI                                                    
16058C                   EVAL      NDVARI=S5VARI                                                    
16058C                   EVAL      NDMODE=S5MODE                                                    
16058C                   EVAL      NDTCOJ=S5TCOJ                                                    
      *                                                                                             
16058C     KMSCOJD       SETLL     MSCOJD                                                           
16058C     KMSCOJD       READE     MSCOJD                                 84                        
      *                                                                                             
16058C                   DOW       *IN84=*OFF                                                       
      *                                                                                             
16058C                   EVAL      M1CIAS=S5CIAS                                                    
16058C                   EVAL      M1MAGA=MIMAGA                                                    
16058C                   EVAL      M1ARTI=NDCOMP                                                    
16058C                   EVAL      M1VARI=NDVAR2                                                    
16058C                   EVAL      M1MODE=NDMOD2                                                    
16058C     KMSSTOK       CHAIN     MSSTOK                             81                            
16058C                   IF        CHAIN=*OFF AND NDBAJA<'1'                                        
16058C                   IF        M1CROT='A'                                   MODIFICAR           
16058C                   EVAL      ZXCROTA=ZXCROTA+1                                                
16058C                   IF        M1PLUS='+'                                   MODIFICAR           
16058C                   EVAL      ZXCROTC=ZXCROTC+1                                                
16058C                   ENDIF                                                                      
16058C                   ELSE                                                   MODIFICAR           
16058C                   EVAL      ZXCROTB=ZXCROTB+1                                                
16058C                   ENDIF                                                                      
16058C                   ENDIF                                                                      
                                                                                                    
16058C     KMSCOJD       READE     MSCOJD                                 84                        
16058C                   ENDDO                                                                      
     C                                                                                              
16058C                   ENDSR                                                                      
                                                                                                    
FQ580 **************************************************************                                
FQ580 * COMMON SUBRUTINE (CS_) :                                   *                                
FQ580 * Recuperar CATERORIA ROTACIÓN CONSERVARLA PARA ANALISIS TCT *                                
FQ580 *------------------------------------------------------------*                                
FQ580C     CS_BUSROTNEW  BEGSR                                                                      
FQ580 * BLANQUEAMOS VALORES A BUSCAR                                                                
FQ580C                   EVAL      S5CROT=*BLANKS                                                   
FQ580C                   EVAL      S5CROP=*BLANKS                                                   
FQ580C                   EVAL      S5CROTA=*BLANKS                                                  
FQ580C                   EVAL      S5CROTB=*BLANKS                                                  
FQ580C                   EVAL      S5CROTC=*BLANKS                                                  
FQ580C                                                                                              
FQ580C                   EVAL      @QCIAS=S5CIAS                                                    
FQ580C                   EVAL      @QDLGA=S5DLGA                                                    
FQ580C                   EVAL      @QLOGE=S5LOGE                                                    
FQ580C                   EVAL      @QARTI=S5ARTI                                                    
FQ580C                   EVAL      @QVARI=S5VARI                                                    
FQ580C                   EVAL      @QMODE=S5MODE                                                    
FQ580C                   EVAL      @QTCOJ=S5TCOJ                                                    
FQ580C                   EVAL      @QCROT=*BLANKS                                                   
FQ580C                   EVAL      @QCROTA=*BLANKS                                                  
FQ580C                   EVAL      @QCROTB=*BLANKS                                                  
FQ580C                   EVAL      @QCROTC=*BLANKS                                                  
FQ580                                                                                               
CR964                                                                                               
CR964C                   EVAL      @QLOFD=' '                                                       
CR964C                   IF        S5TPE4='2' AND S0PPED<>'99'                                      
CR964C                   EVAL      @QLOFD='1'                                                       
CR964C                   ENDIF                                                                      
FQ580C                   CALL      'CO2755'                                                         
FQ580C                   PARM                    @QCIAS                                             
FQ580C                   PARM                    @QDLGA                                             
FQ580C                   PARM                    @QLOGE                                             
FQ580C                   PARM                    @QARTI                                             
FQ580C                   PARM                    @QVARI                                             
FQ580C                   PARM                    @QMODE                                             
FQ580C                   PARM                    @QTCOJ                                             
FQ580C                   PARM                    @QCROT                                             
FQ580C                   PARM                    @QCROTA                                            
FQ580C                   PARM                    @QCROTB                                            
FQ580C                   PARM                    @QCROTC                                            
CR964C                   PARM                    @QLOFD                                             
FQ580 *                                                                                             
FQ580C                   EVAL      S5CROT=%SUBST(@QCROT:1:1)                                        
FQ580C                   EVAL      S5CROP=%SUBST(@QCROT:2:1)                                        
FQ580 *                                                                                             
FQ580C                   IF        S5TCOJ='4'                                                       
FQ580C                   MOVE      @QCROTA       S5CROTA                                            
FQ580C                   MOVE      @QCROTB       S5CROTB                                            
FQ580C                   MOVE      @QCROTC       S5CROTC                                            
FQ580C                   ENDIF                                                                      
FQ580                                                                                               
FQ580C                   ENDSR                                                                      
FQ365 **************************************************************                                
FQ365 * SUBRUTINA DE validacion de riesgo                          *                                
FQ365 *------------------------------------------------------------*                                
FQ365C     CS_VALRSK     BEGSR                                                                      
15049C     KCOCAPE       CHAIN(N)  COCAPE                             8180                          
FQ365C                   EVAL      PECLTA=S0FPAG                                                    
FQ365C                   EVAL      PECIAS=S0CIAS                                                    
FQ365C                   EVAL      PECTAB='FPAG'                                                    
FQ365C     KPMTABD       CHAIN     PMTABD                             81                            
FQ365C     KCOCLIN       CHAIN     COCLIN                             81                            
FQ365C                   IF        CL_S0CRIS='1' AND PEBL61='1'                                     
FQ365C                   CALL      'CM2520'                                                         
FQ365C                   PARM      S0CIAS        @PECIAS                                            
FQ365C                   PARM      S0CUST        @PECUST                                            
FQ365C                   PARM      S0DLGA        @PEDLGA                                            
FH014C* FQ365            PARM      *BLANKS       @PENPCO                                            
FH014C* FQ365            PARM      *BLANKS       @PETPED                                            
FH014C* FQ365            PARM      *ZEROS        @PEDATP                                            
FH014C* FQ365            PARM      *ZEROS        @PENOPL                                            
FH014C                   PARM      S0NPCO        @PENPCO                                            
FH014C                   PARM      S0TPED        @PETPED                                            
FH014C                   PARM      S0DATP        @PEDATP                                            
FH014C                   PARM      S0NOPL        @PENOPL                                            
FQ365C                   PARM      *BLANKS       @PERRO                                             
FQ365 *                  IF        @PERRO='9'                                                       
FQ365C                   IF        @PERRO='9' OR @PERRO='8'                                         
FQ365C                   DOU       LCKRCD=*OFF                                                      
FQ365C     KCOCAPE       CHAIN     COCAPE                             8180                          
FQ365C                   ENDDO                                                                      
18050C                   IF        %FOUND(COCAPE)                                                   
FQ365C                   EVAL      S0REXC='1'                                                       
FQ365C                   MOVEL     *DATE         S0RCON                                             
07049C                   EVAL      S0PEPE = X1PEPE                                                  
07049C                   EVAL      S0GEXP = X1GEXP                                                  
07049C                   EVAL      S0NPIC = X1NPIC                                                  
07049C                   EVAL      S0LPED = X1LPED                                                  
07049C                   EVAL      S0LODP = X1LODP                                                  
07049C                   EVAL      S0MONI = X1MONI                                                  
07049C                   EVAL      S0WO06 = X1WO06                                                  
07049C                   EVAL      S0FMOP = X1FMOP                                                  
07049C                   EVAL      S0USCO = SDSUSR                                                  
PGE21C                   EVAL      S0DAT8=*DATE                                                     
PGE21C                   TIME                    S0HORA                                             
PGE21C                   EVAL      S0USUA=SDSUSR                                                    
FQ365C                   UPDATE    RCOCAPE                                                          
18050C                   ENDIF                                                                      
FQ365C                   ELSE                                                                       
FQ365C                   DOU       LCKRCD=*OFF                                                      
FQ365C     KCOCAPE       CHAIN     COCAPE                             8180                          
FQ365C                   ENDDO                                                                      
18050C                   IF        %FOUND(COCAPE)                                                   
FQ365C                   EVAL      S0REXC=' '                                                       
FQ365C                   MOVEL     *BLANKS       S0RCON                                             
07049C                   EVAL      S0PEPE = *BLANKS                                                 
07049C                   EVAL      S0GEXP = *BLANKS                                                 
07049C                   EVAL      S0NPIC = *BLANKS                                                 
07049C                   EVAL      S0LPED = *BLANKS                                                 
07049C                   EVAL      S0LODP = *BLANKS                                                 
07049C                   EVAL      S0MONI = *BLANKS                                                 
07049C                   EVAL      S0WO06 = *BLANKS                                                 
07049C                   EVAL      S0FMOP = *BLANKS                                                 
07049C                   EVAL      S0USCO = *BLANKS                                                 
PGE21C                   EVAL      S0DAT8=*DATE                                                     
PGE21C                   TIME                    S0HORA                                             
PGE21C                   EVAL      S0USUA=SDSUSR                                                    
FQ365C                   UPDATE    RCOCAPE                                                          
18050C                   ENDIF                                                                      
FQ365C                   ENDIF                                                                      
FQ36C* RENED Affichage du risque(begin)                                                            
FQ36C                   ELSE                                                                       
FQ36C                   IF        SOCFRA=*ON                                                       
FQ36C                   CALL      'CM2520'                                                         
FQ36C                   PARM      S0CIAS        @PECIAS                                            
FQ36C                   PARM      S0CUST        @PECUST                                            
FQ36C                   PARM      S0DLGA        @PEDLGA                                            
FH014C* FQ365            PARM      *BLANKS       @PENPCO                                            
FH014C* FQ365            PARM      *BLANKS       @PETPED                                            
FH014C* FQ365            PARM      *ZEROS        @PEDATP                                            
FH014C* FQ365            PARM      *ZEROS        @PENOPL                                            
FH014C                   PARM      S0NPCO        @PENPCO                                            
FH014C                   PARM      S0TPED        @PETPED                                            
FH014C                   PARM      S0DATP        @PEDATP                                            
FH014C                   PARM      S0NOPL        @PENOPL                                            
