     C* RECUPEREM ELS VALORS DE L'AREA DE PARÀMETRES DE PROGRAMA                                    
     C                   IF        CHAIN=*OFF                                                       
     C                   SELECT                                                                     
     C                   WHEN      MCS140=' ' OR MCS140='0'                                         
     C                   EVAL      ZXOPT='PK0CLR'                                                   
     C                   WHEN      MCS140='1'                                                       
     C                   EVAL      ZXOPT='S01CLR'                                                   
     C                   WHEN      MCS140='2'                                                       
     C                   EVAL      ZXOPT='S02CLR'                                                   
     C                   WHEN      MCS140='3'                                                       
     C                   EVAL      ZXOPT='S03CLR'                                                   
     C                   WHEN      MCS140='4'                                                       
     C                   EVAL      ZXOPT='S04CLR'                                                   
     C                   WHEN      MCS140='5'                                                       
     C                   EVAL      ZXOPT='S05CLR'                                                   
     C                   WHEN      MCS140='6'                                                       
     C                   EVAL      ZXOPT='S06CLR'                                                   
     C                   WHEN      MCS140='7'                                                       
     C                   EVAL      ZXOPT='S07CLR'                                                   
     C                   WHEN      MCS140='8'                                                       
     C                   EVAL      ZXOPT='S08CLR'                                                   
     C                   ENDSL                                                                      
     C                   EVAL      PA0SV01=MCVIST                                                   
     C                   ENDIF                                                                      
      * ZXMAXVI = Número máximo de vistas en el programa.                                           
      * ( Tendría que ser el mismo que vistas existan en PMPROM )                                   
FQ944C****************** EVAL      ZXMAXVI=4                                    Query-Aut-F4   X    
FQ944C                   EVAL      ZXMAXVI=5                                    Query-Aut-F4   X    
     C* Recupero el número de vista inicial del SETUP                                               
23014 * Es canvia el rang del PA0SV01 de 1 - 3 a 1 - 4                                              
FQ944C*                  IF        PA0SV01>='1' AND PA0SV01 <='4'                                   
FQ944C                   IF        PA0SV01>='1' AND PA0SV01 <='5'                                   
     C                   MOVE      PA0SV01       ZXNUMVI                                            
     C                   ELSE                                                                       
     C                   EVAL      ZXNUMVI=1                                                        
     C                   ENDIF                                                                      
                                                                                                    
      * RECUPEREM DEL FITXER DE SETUP EL FORMAT QUE EM DE MOSTRAR PER OMISIÓ                        
     C                   EVAL      PIPROG='CO0120    '                                              
     C     KMSSETP       CHAIN (N) PMSETP                             81                            
