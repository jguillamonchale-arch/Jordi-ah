14120C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CLACULO DE IMPORTES LINEAS DETALLE ALBARANES       *                              
      *------------------------------------------------------------*                                
      * ZXBIMP=Base imponible                                                                       
      * ZXIIV1=Importe IVA1                                                                         
      * ZXIIV2=Importe IVA2                                                                         
     C     CS_SECCAL2    BEGSR                                                                      
                                                                                                    
     C                   EVAL      XZAUXI=*ZEROS                                                    
     C                   EVAL      XZAUXI1=*ZEROS                                                   
ECOP * Ecotaxe                                                                                     
ECOP C                   EVAL      XZTAXE=0                                                         
ECOP C                   IF        S5ECOP<>*BLANKS                                                  
ECOP C                   CALL      'MN0398'                                                         
ECOP C                   PARM                    @PCIAS                                             
ECOP C                   PARM      S5ECOP        @PEECOP                                            
ECOP C                   PARM      S5DATP        @PEFLCD                                            
ECOP C                   PARM      0             @PETAXE                                            
ECOP C                   EVAL      XZTAXE=@PETAXE                                                   
ECOP C                   END                                                                        
      * Movemos campos a campos de trabaja                                                          
     C                   EVAL      XZCANT=S5CANT                                                    
     C                   IF        S5CANC<>0                                                        
     C                   EVAL      XZCANT=S5CANC                                                    
     C                   ENDIF                                                                      
     C                   EVAL      XZUNIM=S5UNIM                                                    
     C                   EVAL      XZPREC=S5PREC                                                    
     C                   EVAL      XZMONE=S5MONE                                                    
     C                   EVAL      XZCADP=S5CADP                                                    
     C                   EVAL      XZUNDP=S5UNDP                                                    
     C                   EVAL      XZDTO1=S5DTO1                                                    
     C                   EVAL      XZDTO2=S5DTO2                                                    
     C                   EVAL      XZDTO3=S5DTO3                                                    
     C                   EVAL      XZDTO4=S5DTO4                                                    
     C                   IF        XZDTO4=*ZEROS                                                    
     C                   EVAL      XZDTO4=@PDTOE                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        S5PRCC<>0                                                        
     C                   EVAL      XZPREC=S5PRCC                                                    
     C                   EVAL      XZMONE=S5MONC                                                    
     C                   EVAL      XZCADP=S5CADC                                                    
     C                   EVAL      XZUNDP=S5UNDC                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        S5DT1C<>0                                                        
     C                   EVAL      XZDTO1=S5DT1C                                                    
     C                   EVAL      XZDTO2=S5DT2C                                                    
     C                   EVAL      XZDTO3=S5DT3C                                                    
     C                   EVAL      XZDTO4=S5DT4C                                                    
     C                   ENDIF                                                                      
                                                                                                    
      * Buscamos en PMUNAL UNIDADES ALTERNATIVAS                                                    
                                                                                                    
     C                   EVAL      XZCOFU=1                                                         
     C                   IF        XZUNIM<>XZUNDP                                                   
     C                   EVAL      XZCIAS=@PCIAS                                                    
     C                   EVAL      XZARTI=S5ARTI                                                    
     C                   EVAL      XZVARI=S5VARI                                                    
     C                   EVAL      XZMODE=S5MODE                                                    
     C                   EVAL      ZXCA10=XZCANT                                                    
     C                   EVAL      ZXCA11=XZCANT                                                    
     C                   EVAL      ZXUN10=XZUNIM                                                    
     C                   EVAL      ZXUN11=XZUNDP                                                    
     C* CAMBIO de unidades                                                                          
     C/COPY *LIBL/QSRDSRC,SRD021                                                                    
     C                   ENDIF                                                                      
      * Decimales de la moneda                                                                      
     C                   EVAL      MBMONE=ZXMONV                                                    
     C     KMSDIV0       CHAIN     MSDIV0                             81                            
      * Buscamos en % de IVA según fecha del pedido                                                 
                                                                                                    
     C                   EVAL      MVTIVA=S5TIVA                                                    
     C                   EVAL      MVPABI=ZXPABI                                                    
     C                   EVAL      MVFLCD=S0FREP                                                    
     C                   IF        S0FRRE>0                                                         
     C                   EVAL      MVFLCD=S0FRRE                                                    
     C                   ENDIF                                                                      
     C     KMSIVAS       SETGT     MSIVAS                                                           
     C     KMSIVAS0      READPE    MSIVAS                                 83                        
     C                   SELECT                                                                     
     C                   WHEN      ZXTIVC=' '                                                       
     C                   EVAL      MVPIV2=*ZEROS                                                    
     C                   WHEN      ZXTIVC='0'                                                       
     C                   EVAL      MVPIV1=*ZEROS                                                    
     C                   EVAL      MVPIV2=*ZEROS                                                    
     C                   ENDSL                                                                      
                                                                                                    
      * Calculamos los totales de línea en la moneda de la línea                                    
      * después de aplicados los dtos.                                                              
                                                                                                    
     C* Cálculo de valores totales                                                                  
ECOP C/COPY *LIBL/QSRDSRC,SRD022ECO                                                                 
ECOP C                   EVAL      XZDECI=MBDECI                                                    
ECOP C                   EVAL      XZAJUD=MBAJUD                                                    
ECOP C* AJUSTE Y DECIMALES                                                                          
ECOP C/COPY *LIBL/QSRDSRC,SRD001                                                                    
ECOP C                   Z-ADD     XZAUXI        ZXBIMPECO                                          
     C/COPY *LIBL/QSRDSRC,SRD022                                                                    
                                                                                                    
     C                   EVAL      XZDECI=MBDECI                                                    
     C                   EVAL      XZAJUD=MBAJUD                                                    
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
     C                   Z-ADD     XZAUXI        ZXBIMP                                             
ECOP C                   ADD       ZXBIMPECO     ZXBIMP                                             
      * Calculamos el IVA                                                                           
     C                   EVAL      XZAUXI=ZXBIMP*MVPIV1                                             
     C     XZAUXI        DIV(H)    100           XZAUXI                                             
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
     C                   Z-ADD     XZAUXI        ZXIIV1                                             
      * Calculamos el Recargo de equivalencia                                                       
     C                   EVAL      XZAUXI=ZXBIMP*MVPIV2                                             
     C     XZAUXI        DIV(H)    100           XZAUXI                                             
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
     C                   Z-ADD     XZAUXI        ZXIIV2                                             
                                                                                                    
      * Omitimos BASE o IVA segun tipo de IVA                                                       
                                                                                                    
     C                   IF        MVOMTB>='1'                                                      
     C                   EVAL      ZXBIMP=ZXBIMP-ZXBIMP                                             
     C                   ENDIF                                                                      
     C                   IF        MVOMTI>='1'                                                      
     C                   EVAL      ZXIIV1=ZXIIV1-ZXIIV1                                             
     C                   EVAL      ZXIIV2=ZXIIV2-ZXIIV2                                             
     C                   ENDIF                                                                      
     C                   EVAL      PXEDTC='4'                                                       
     C     TSECCAL2      ENDSR                                                                      
23014 **************************************************************                                
23014 * SUBRUTINA CLACULO DE IMPORTES LINEAS DETALLE ALBARANES     *                                
23014 *------------------------------------------------------------*                                
23014 * ZXCAPE  = Quantitat pendent a la comanda                                                    
23014 * ZXUNIM4 = Unitats de la comanda                                                             
23014 * ZXSTOK  = Stock a la logistica                                                              
23014C     CS_SECCAL4    BEGSR                                                                      
23014                                                                                               
23014C                   EVAL      ZXCAPE=(S5CANT-S5CANS)                                           
23014C                   EVAL      ZXUNIM4=S5UNIM                                                   
23014C                   EXSR      CS_CALESTO                                                       
23014C                   EXSR      CS_CALCAPT                                                       
23014                                                                                               
23014C     TSECCAL4      ENDSR                                                                      
23014 **************************************************************************                    
23014C* CALCULEM L'ESTOC                                                                            
23014 **************************************************************************                    
23014C     CS_CALESTO    BEGSR                                                                      
23014C*                                                                                             
23014 * - inicializar campos.                                                                       
23014C                   EVAL      ZXSDIS=0                                                         
23014C                   EVAL      *IN83=*OFF                                                       
23014C                   EVAL      M1CIAS=S5CIAS                                                    
23014C                   EVAL      M1ARTI=S5ARTI                                                    
23014C                   EVAL      M1VARI=S5VARI                                                    
23014C                   EVAL      M1MODE=S5MODE                                                    
                                                                                                    
06049C                   EVAL      MIDLGA=S5DLGA                                                    
23014C                   EVAL      MILGCA=S5LOGE                                                    
23014C                   IF        MILGCA=*BLANKS                                                   
23014C                   EVAL      MILGCA=S0LOGE                                                    
23014C                   ENDIF                                                                      
23014C*Busco lotes en el almacén asociado a la logística de Salida                                  
23014C     KMSLOGI       CHAIN(N)  MSLOAD                             81                            
23014C                   IF        CHAIN=*OFF                                                       
23014C                   EVAL      M1MAGA=MIMAGA                                                    
23014C                   EVAL      ZXMAGA=MIMAGA                                                    
23014C                   ELSE                                                                       
23014C                   EVAL      MIMAGA=*BLANKS                                                   
23014C                   EVAL      ZXMAGA=*BLANKS                                                   
     C                   ENDIF                                                                      
      *                                                                                             
23014C     KMSSTO0       SETLL     MSSTO01                                                          
23014C                                                                                              
23014C                   DOW       *IN83=*OFF                                                       
23014C     KMSSTO00      READE     MSSTO01                                83                        
23014C                   IF        *IN83=*ON                                                        
23014C                   LEAVE                                                                      
23014C                   ENDIF                                                                      
23014 * Si se requiere solo para 1 almacén comparo para que sea dicho almacén                       
23014C                   IF        ZXMAGA<>*BLANKS AND ZXMAGA<>M1MAGA                               
23014C                   LEAVE                                                                      
23014C                   ENDIF                                                                      
23014                                                                                               
23014C                   EVAL      M0CIAS=M1CIAS                                                    
23014C                   EVAL      M0MAGA=M1MAGA                                                    
23014C                   EVAL      M0DLGA=*BLANKS                                                   
23014 * Salvo la central, las delegaciones solo pueden trabajar con su                              
23014 * propio stock                                                                                
23014C     KMSALMA       CHAIN     MSALMA                             81                            
23014C                   IF        ZZDLGA<>S5DLGA AND ZZVSTD<'1'                                    
23014C                   GOTO      TNEX001                                                          
23014C                   ENDIF                                                                      
23014 * El stock será disponible si así lo indica M0ASDI                                            
23014C                   EVAL      ZX=1                                                             
23014C                   IF        M0ASDI<='0'                                                      
23014C                   GOTO      TNEX001                                                          
23014C                   ENDIF                                                                      
10055C                   IF        M0BAJA>='1'                                                      
10055C                   GOTO      TNEX001                                                          
10055C                   ENDIF                                                                      
23014                                                                                               
23014C                   IF        M1CALI=*BLANKS                                                   
23014C                   IF        SSSCALI(1)=*BLANKS AND SSSCAL2(1)='1'                            
23014C                   EVAL      ZXSDIS=ZXSDIS+M1SACT-M1SKRE-M1SKRP-M1SKR1                        
23014C                                   -M1SKR2                                                    
23014C                   ENDIF                                                                      
23014C                   ELSE                                                                       
23014C     M1CALI        LOOKUP    SSSCALI(ZX)                            84                        
23014C                   IF        *IN84=*ON AND SSSCAL2(ZX)='1'                                    
23014C                   EVAL      ZXSDIS=ZXSDIS+M1SACT-M1SKRE-M1SKRP-M1SKR1                        
23014C                                   -M1SKR2                                                    
23014C                   ENDIF                                                                      
23014C                   ENDIF                                                                      
23014                                                                                               
23014C     TNEX001       TAG                                                                        
23014C                   ENDDO                                                                      
23014C                   Z-ADD     ZXSDIS        ZXSTOK                                             
23014                                                                                               
23014C                   ENDSR                                                                      
23014 **************************************************************************                    
23014C* CALCULEM LA QUANTITAT PENDENT TOTAL DE L'ARTICLE A LA COMANDA                               
23014 **************************************************************************                    
23014C     CS_CALCAPT    BEGSR                                                                      
23014 *                                                                                             
23014C                   Z-ADD     *ZEROS        ZXCAPT                                             
23014C                   EVAL      S5_S5CIAS=S5CIAS                                                 
23014C                   EVAL      S5_S5DLGA=S5DLGA                                                 
23014C                   EVAL      S5_S5NPCO=S5NPCO                                                 
23014C                   EVAL      S5_S5TPED=S5TPED                                                 
23014C                   EVAL      S5_S5DATP=S5DATP                                                 
23014C                   EVAL      S5_S5NOPL=S5NOPL                                                 
23014C     KCODEPE35     SETLL     CODEPE35                                                         
23014C                   EVAL      *IN84=*OFF                                                       
23014C                   DOW       *IN84=*OFF                                                       
23014C     KCODEPE35     READE     CODEPE35                               84                        
23014C                   IF        *IN84=*ON                                                        
23014C                   LEAVE                                                                      
23014C                   ENDIF                                                                      
23014C                   IF        S5_S5ARTI=S5ARTI AND                                             
23014C                             S5_S5VARI=S5VARI AND                                             
23014C                             S5_S5MODE=S5MODE                                                 
23014C                   EVAL      ZXCAPT=ZXCAPT+(S5_S5CANT-S5_S5CANS)                              
23014C                   ENDIF                                                                      
23014C                   ENDDO                                                                      
23014 *                                                                                             
23014C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CLACULO DE COEFICIENTE DE CAMBIO                   *                              
      *------------------------------------------------------------*                                
     C     CS_ZXCOCAM    BEGSR                                                                      
      * Búsqueda del cambio para moneda de visualización según SETUP.                               
     C                   EVAL      @PDATA=S5FREP                                                    
     C                   TIME                    @PHORA                                             
     C                   IF        @PDATA=*ZEROS                                                    
     C                   EVAL      @PDATA=S5FREP                                                    
     C                   ENDIF                                                                      
      * Busco el primer cambio existente al comenzar Enero a las 12 horas                           
      * si se desean cambios en el momento de entrada                                               
     C                   IF        MCTFHV='1'                                                       
     C                   EVAL      @PDATA=S5FREP                                                    
     C                   IF        S5FRRE>0                                                         
     C                   EVAL      @PDATA=S5FRRE                                                    
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        @PDATA=*ZEROS                                                    
     C                   EVAL      @PDATA=*DATE                                                     
     C                   ENDIF                                                                      
      * Debo tener en cuenta si existe cambio confirmado                                            
      * para dicha moneda o no existe dicho cambio confirmado                                       
                                                                                                    
     C                   EVAL      ZXCOCAMB=1                                                       
     C                   IF        S0CAMC=0                                                         
     C                   EVAL      S0MONC=S0MONB                                                    
     C                   EVAL      S0CAMC=S0CAMB                                                    
     C                   EVAL      S0CMPC=S0CMPR                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        S0CMPC=0                                                         
     C                   EVAL      S0CMPC=1                                                         
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        S0CAMC=0                                                         
     C                   EVAL      S0MONC=S0MONE                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        S0MONE<>ZXMONV                                                   
     C                   CALL      'MM2555'                                                         
     C                   PARM                    @PCIAS                         PARM Qry-F4         
     C                   PARM      S0MONE        @PMON1                         PARM Qry-F4         
     C                   PARM      ZXMONV        @PMON2                         PARM Qry-F4         
     C                   PARM                    @PDATA                         PARM Qry-F4         
     C                   PARM                    @PHORA                         PARM Qry-F4         
     C                   PARM      0             @PCMCOCO                                           
     C                   PARM      0             @PCMCCCO                                           
     C                   PARM      *BLANKS       @PEERR                         PARM Qry-F4         
     C                   EVAL      ZXCOCAMB=@PCMCCCO                                                
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      *------------------------------------------------------------*                                
      *           RUTINAS PARA EL CONTROL DE CABECERA   NEW HEAD   *                                
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CAMPS DE registre d'alta          *                                
      *------------------------------------------------------------*                                
     C     CS_CABCHK     BEGSR                                                                      
     c                   eval      zxopt2='UPD'                                                     
      * Si el pedido es 'SC' entonces las entradas serán sin cargo                                  
     C                   IF        SUCTPED='SC'                                                     
     C                   EVAL      SUCSCAR='1'                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   if        SUCarti=*blanks                                                  
     C                   eval      zxopt2='DSP'                                                     
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TSUCCHK                                            
                                                                                                    
      * MENSAJES DE AVISO                                                                           
     C                   EVAL      ZXARTIX=SUCARTI                                                  
     C                   EVAL      ZXVARIX=SUCVARI                                                  
     C                   EVAL      ZXMODEX=SUCMODE                                                  
     C                   CALL      'MM2558'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM      S0CUST        @PECUST                                            
     C                   PARM      '0'           @PETCLP                                            
     C                   PARM      ZZIDIO        @PEIDIO                                            
     C                   PARM      ZXARVMX       @PEARVM                                            
     C                   PARM      SUCTCOJ       @PETCOJ                                            
     C                   PARM      '1'           @PETAMS                                            
     C                   PARM                    @PETAAM                                            
     C                   PARM                    @PERRO                                             
     C                   IF        @PETAAM='1'                                                      
     C                   EVAL      ZXOPT='END'                                                      
     C                   EVAL      ERRGRL=*ON                                                       
     C                   GOTO      TSUCCHK                                                          
     C                   ENDIF                                                                      
     * RENED R{cup{ration de la d{signation et du stock (Begin)                                    
    C                   EVAL      ECDES1 = *BLANK                                                  
    C                   EVAL      ECSTK  = *ZEROS                                                  
    C                   EVAL      ECRES  = *ZEROS                                                  
     * RENED R{cup{ration de la d{signation et du stock (End)                                      
      * Al artículo debe existir como código principal o alternativo                                
     C                   EVAL      M5ARAL=SUCARTI                                                   
     C                   EVAL      M5ARTI=SUCARTI                                                   
     C     KMSARTI03     CHAIN     MSARTI03                           81                            
CUK05C                   EXSR      CS_BUSALT                                                        
                                                                                                    
     C                   EVAL      M5VARI=SUCVARI                                                   
     C                   EVAL      M5MODE=SUCMODE                                                   
     C     KMSARTI00     CHAIN     MSARTI00                           81                            
     C                   IF        CHAIN=*ON OR M5BAJA>'0'                                          
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK34=*ON                                                        
     C                   EVAL      WRK35=*ON                                                        
     C                   EVAL      WRK39=*ON                                                        
     C                   EVAL      MSGER='MMM0041'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TSUCCHK                                            
     * RENED R{cup{ration de la d{signation                                                        
    C                   EVAL      ECDES1 = M5DES1                                                  
     * RENED R{cup{ration du stock (Begin)                                                         
01  C                   IF        MCSTOK = '1'                                                     
    C                   EVAL      PARRST = '*'                                                     
    C                   EVAL      PARRVE = '*'                                                     
    C                   EXSR      CS_CUMSTK                                                        
01  C                   ENDIF                                                  MCSTOK = '1'        
     * RENED R{cup{ration du stock (End)                                                           
      * artículo obsoleto                                                                           
BLODIC*                  IF        M5PPV2>'0'                                                       
BLODIC                   IF        M5PPV2='1'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK34=*ON                                                        
     C                   EVAL      WRK35=*ON                                                        
     C                   EVAL      WRK39=*ON                                                        
     C                   EVAL      MSGER='COM0120'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TSUCCHK                                            
     C                   EVAL      SUCARTI=M5ARTI                                                   
      * Si el tipo de conjunto no esta informado buscamos el primero                                
      * definido entre 4 y 6 (ventas) Y 9 MONTAJES                                                  
     C                   IF        SUCTCOJ=*BLANKS                                                  
      * Informamos la variables de la clave                                                         
     C                   EVAL      NDARTI=M5ARTI                                                    
     C                   EVAL      NDVARI=M5VARI                                                    
     C                   EVAL      NDMODE=M5MODE                                                    
     C                   EVAL      ZXTCOJ=*BLANKS                                                   
     C                   EXSR      CS_BUSCOJ                                                        
      * La rutina nos contesta en la variable ZXTCOJ                                                
     C                   EVAL      SUCTCOJ=ZXTCOJ                                                   
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TSUCCHK                                            
      * Validación del conjunto                                                                     
     C                   IF        SUCTCOJ<>*BLANKS                                                 
     C                   EVAL      NDARTI=M5ARTI                                                    
     C                   EVAL      NDVARI=M5VARI                                                    
     C                   EVAL      NDMODE=M5MODE                                                    
     C                   EVAL      NDTCOJ=SUCTCOJ                                                   
29019C*    KMSCOJC       CHAIN     MSCOJD                             81                            
29019C     KMSCOJC       SETLL     MSCOJD                                                           
29019C     KMSCOJC       READE     MSCOJD                                                           
29019C                   DOW       NOT %EOF                                                         
29019C                   IF        NDBAJA<>'1'                                                      
29019C                   LEAVE                                                                      
29019C                   ENDIF                                                                      
29019C     KMSCOJC       READE     MSCOJD                                                           
29019C                   ENDDO                                                                      
29019C*                  IF        CHAIN=*ON OR NDBAJA>='1'                                         
29019C                   IF        %EOF(MSCOJD)                                                     
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK34=*ON                                                        
     C                   EVAL      WRK35=*ON                                                        
     C                   EVAL      WRK39=*ON                                                        
     C                   EVAL      MSGER='MMM0035'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TSUCCHK                                            
