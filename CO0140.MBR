      **************************************************************                                
      * SUBRUTINA QUE visualiza el total del pedido.               *                                
      *------------------------------------------------------------*                                
     C     CS_VERTOTAL   BEGSR                                                                      
     C                   CALL      'CO2542'                                                         
     C                   PARM      SUFCIAS       @PECIAS                                            
     C                   PARM      SUFDLGA       @PEDLGA                                            
     C                   PARM      SUFNPCO       @PENPCO                                            
     C                   PARM      SUFTPED       @PETPED                                            
     C                   PARM      SUFDATP       @PEDATP                                            
     C                   PARM      SUFNOPL       @PENOPL                                            
     C                   PARM      MCMONV        @PEMONV                                            
     C                   PARM      MCTFHV        @PETFHV                                            
     C                   PARM      *BLANKS       @PEERR                                             
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE AÑADIR EN CODEPE LAS LINEAS DE GASTOS ADICIONALES                              
      *------------------------------------------------------------*                                
     C     CS_GADIC      BEGSR                                                                      
      *                                                                                             
      * SOLO AÑADIREMOS LOS GASTOS ADICIONALES SOLO SI NO VA POR                                    
      * MODULO DE EXPORTACION PUESTO QUE ESTOS TIENEN OTRA FORMA DE ENTRAR  ón                      
      * LOS GASTOS ADICIONALES                                                                      
      * EN ZXGENPL ES UNA VARIABLE DE TRABAJO PARA RESTRINGIR LA ENTRADA                            
      * '0'--> SE GENERA P.L.  Y NO G.A.                                                            
      * '1'--> NO SE GENERA P.L. Y SI G.A.                                                          
     C                   EVAL      ZXGENPL='1'                                                      
      * ZZPRPL ' ' -> NINGUNO                                                                       
      * ZZPRPL '0' -> NINGUNO                                                                       
      * ZZPRPL '1' -> SOLO NO COMUNITARIOS                                                          
      * ZZPRPL '2' -> TODOS LOS DE EXPORTACIÓN (COMUNITARIOS Y NO)                                  
      * ZZPRPL '3' -> TODOS                                                                         
     C                   SELECT                                                                     
     C                   WHEN      ZZPRPL=' ' OR ZZPRPL='0'                                         
     C                   EVAL      ZXGENPL='0'                                                      
      *                                                                                             
     C                   WHEN      ZZPRPL='1'                                                       
     C                   IF        ZZPAIS<>S0PAIS                                                   
     C                   EVAL      MEPAIS=S0PAIS                                                    
     C     KMSPAIS       CHAIN     MSPAIS                             81                            
     C                   IF        MEPCEE<>'1'                                                      
     C                   EVAL      ZXGENPL='1'                                                      
     c                   ELSE                                                                       
     C                   EVAL      ZXGENPL='0'                                                      
     C                   ENDIF                                                                      
     C                   ELSE                                                                       
     C                   EVAL      ZXGENPL='0'                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   WHEN      ZZPRPL='2'                                                       
     C                   IF        ZZPAIS=S0PAIS                                                    
     C                   EVAL      ZXGENPL='0'                                                      
     C                   ELSE                                                                       
     C                   EVAL      ZXGENPL='1'                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   WHEN      ZZPRPL='3'                                                       
     C                   EVAL      ZXGENPL='1'                                                      
     C                                                                                              
     C                   ENDSL                                                                      
      *                                                                                             
     C                   IF        CL_S0GACL<>*BLANKS AND ZXGENPL='0'                               
     C                   EVAL      S5DLGA=S0DLGA                                                    
     C                   EVAL      S5CIAS=S0CIAS                                                    
     C                   EVAL      S5DATP=S0DATP                                                    
     C                   EVAL      S5NOPL=S0NOPL                                                    
     C                   EVAL      S5NPCO=S0NPCO                                                    
     C                   EVAL      S5TPED=S0TPED                                                    
     C                   EVAL      S5CANT=1                                                         
     C                   EVAL      S5ARTI=CL_S0GACL                                                 
     C                   EVAL      S5VARI=*BLANKS                                                   
     C                   EVAL      S5MODE=*BLANKS                                                   
     C                   EVAL      S5TCOJ=' '                                                       
     C                   EVAL      PECIAS=S0CIAS                                                    
     C                   EVAL      PECTAB='CCO1'                                                    
     C                   EVAL      PECLTA=CL_S0GACL                                                 
     C     KPMTABD       CHAIN     PMTABD                             81                            
     C                   EVAL      ZXBL62B=PEBL62                                                   
     C                   EVAL      ZXBL64=PEBL64                                                    
                                                                                                    
     C                   EVAL      S5USCO=PEBL61                                                    
     C                   EVAL      S5DES1=PEDESC                                                    
     C                   EVAL      S5MONE=S0MONE                                                    
     C                   EVAL      ZXCOCAMB=1                                                       
     C                   IF        S0MONE<>ZXMONG                                                   
     C                   CALL      'MM2555'                                                         
     C                   PARM      S0CIAS        @PCIAS                         PARM Qry-F4         
     C                   PARM      ZXMONG        @PMON1                         PARM Qry-F4         
     C                   PARM      S0MONE        @PMON2                         PARM Qry-F4         
     C                   PARM      S0DATP        @PDATA                         PARM Qry-F4         
     C                   PARM                    @PHORA                         PARM Qry-F4         
     C                   PARM      0             @PCMCOCO                                           
     C                   PARM      0             @PCMCCCO                                           
     C                   PARM      *BLANKS       @PEERR                         PARM Qry-F4         
     C                   EVAL      ZXCOCAMB=@PCMCCCO                                                
     C                   ENDIF                                                                      
     C                   EVAL      MBCIAS=S0CIAS                                                    
     C                   EVAL      MBMONE=S0MONE                                                    
     C     KMSDIV0       CHAIN     MSDIV0                             81                            
                                                                                                    
     C                   IF        MBDECI=0                                                         
     C                   MOVE      ZXBL64        PXNUM0                                             
     C                   Z-ADD     PXNUM0        S5PREC                                             
     C                   ELSE                                                                       
     C                   IF        MBDECI=1                                                         
     C                   MOVE      ZXBL64        PXNUM1                                             
     C                   Z-ADD     PXNUM1        S5PREC                                             
     C                   ELSE                                                                       
     C                   IF        MBDECI=2                                                         
     C                   MOVE      ZXBL64        PXNUM2                                             
     C                   Z-ADD     PXNUM2        S5PREC                                             
     C                   ELSE                                                                       
     C                   IF        MBDECI=3                                                         
     C                   MOVE      ZXBL64        PXNUM3                                             
     C                   Z-ADD     PXNUM3        S5PREC                                             
     C                   ELSE                                                                       
     C                   IF        MBDECI=4                                                         
     C                   MOVE      ZXBL64        PXNUM4                                             
     C                   Z-ADD     PXNUM4        S5PREC                                             
     C                   ELSE                                                                       
     C                   IF        MBDECI=5                                                         
     C                   MOVE      ZXBL64        PXNUM5                                             
     C                   Z-ADD     PXNUM5        S5PREC                                             
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   EVAL      S5PREC=S5PREC*ZXCOCAMB                                           
FQ944C                   IF        S5FREP=*ZEROS                                                    
     C                   EVAL      S5FREP=S0FREP                                                    
FQ944C                   ENDIF                                                                      
     C                   EVAL      S5TIVA=ZXTIVA                                                    
     C                   EVAL      S5PPRG=S0PPRG                                                    
     C                   EVAL      S5CLTR=S0CLTR                                                    
     C                   EVAL      S5TIV3=S0TIV3                                                    
     C                   EVAL      S5DTO1=0                                                         
     C                   EVAL      S5DTO2=0                                                         
     C                   EVAL      S5DTO3=0                                                         
     C                   EVAL      S5DTO4=0                                                         
     C                   EVAL      S5CADP=1                                                         
     C                   EVAL      S5STUL='0'                                                       
     C                   EVAL      S5INTR='0'                                                       
     C                   EVAL      S5TCST='C2'                                                      
     C                   EVAL      S5ARAL=S5ARTI                                                    
     C                   EVAL      S5FRRR=S0FRRE                                                    
     C                   EVAL      S5FRRR=S5FREP                                                    
     C                   IF        S5FRRE<>0                                                        
     C                   EVAL      S5FRRR=S5FRRE                                                    
     C                   ENDIF                                                                      
     C                   EVAL      S5DAT8=ZZDATS                                                    
     C                   IF        S5DAT8=0                                                         
     C                   EVAL      S5DAT8=*DATE                                                     
     C                   ENDIF                                                                      
     C                   TIME                    S5HORA                                             
     C                   EVAL      S5USUA=ZZUSUA                                                    
     C                   EVAL      S5PANT=SDSJOB                                                    
     C                   EVAL      S5DAT1=S5DAT8                                                    
     C                   EVAL      S5CUST=S0CUST                                                    
     C                   EVAL      S5CMGI=S0CMGI                                                    
     C                   EVAL      S5GRP3=CL_S0GRP3                                                 
     C                   EVAL      S5REFE=S0REFE                                                    
     C                   EVAL      S5TDI1=S0TDI1                                                    
     C                   EVAL      S5TLIN='2'                                                       
     C                   EVAL      S5LINE=1                                                         
     C                   EVAL      S5PHLD=S0PHLD                                                    
     C                   EVAL      S5TPE4=S0TPE4                                                    
     C                   EVAL      S5EDET=S0EDET                                                    
     C                   EVAL      S5MURG=S0MURG                                                    
     C                   EVAL      S5CCPP=M5CCPP                                                    
ECOP C                   EVAL      S5ECOP=M5ECOP                                                    
     C                   EVAL      S5INCI=*BLANKS                                                   
     C                   EVAL      S5TINC=*BLANKS                                                   
FQ937C                   IF        S0COEN>='1'                                                      
FQ937C                   IF        SUCNCOE=*ZEROS                                                   
FQ937C                   IF        S0COEN='1'                                                       
FQ937C                   EVAL      S5NCOE='01'                                                      
FQ937C                   ENDIF                                                                      
FQ937C                   ELSE                                                                       
C0031C*FQ937             EVAL      S5NCOE=SUCNCOE                                                   
FQ937C                   MOVE      SUCNCOE       S5NCOE                                             
FQ937C                   ENDIF                                                                      
FQ937C                   ELSE                                                                       
FQ937C                   EVAL      S5NCOE='00'                                                      
FQ937C                   ENDIF                                                                      
C0031C* FQ944 ********** EVAL      S5FOEP=S5FREP                                                    
C0031C                   EVAL      S5FORE=S5FRRE                                                    
     C                   EXSR      CS_SMIN                                                          
27038 * CONSERVAMOS LA CATEGORIA ROTACIÓN PARA ANALISIS POSTERIORES                                 
FQ580C* 27038            EXSR      CS_BUSROT                                                        
FQ580C                   EXSR      CS_BUSROTNEW                                                     
C1329C*MARCA DEMANDA EXCEPCIONAL                                                                    
C1329C                   IF        S5DEXC=*BLANKS                                                   
C1329C                   EVAL      S5DEXC=S0DEXC                                                    
C1329C                   ENDIF                                                                      
     C                   WRITE     RCODEPE                                                          
07113C                   EVAL      ZXLINEA=S5LINE                                                   
C0031 *                                                                                             
C0031 * Unificar de Fecha de Recepción si Coenvío                                                   
C0031 *                                                                                             
C0031C*24912             IF        S0COEN>='1' AND S0PPED<>'99'                                     
24912C                   IF        THTACT<='0' AND S0PPED<>'99'                                     
C0031C                   EXSR      CS_FRRRCOE                                                       
C0031C                   ENDIF                                                                      
13612C***** 04712        IF        (THWEEK>='1' AND S0TPE4<>'2' AND S0COEN=' ')                     
13612C***** 04712                  OR (THWEEK='2' AND S0TPE4='2' AND S0COEN=' ')                    
04712C                   IF        THTARS='1' AND S0PPED<>'99' AND                                  
29B12C* 04712                      (S0COEN=' ' OR S0COEN='2') AND                                   
NAP45* 29B12                      (S0COEN<='0' OR S0COEN='2') AND                                  
NAP45C                             (S0COEN<='0' OR S0COEN='2' OR S0COEN='3') AND                    
04712C                             ((THWEEK>='1' AND S0TPE4<>'2') OR                                
IN944C*                            (THWEEK='2' AND S0TPE4='2'))                                     
IN944C                             (THWEEK='2' ))                                                   
13612C                   EXSR      CS_FECWEEK                                                       
13612C                   ENDIF                                                                      
