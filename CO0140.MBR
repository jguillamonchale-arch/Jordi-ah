26712C                   EVAL      PECIAS=M5CIAS                                                    
26712C                   EVAL      PECTAB='TIPG'                                                    
26712C                   EVAL      PECLTA=M5TIPG                                                    
26712C     KPMTABD       CHAIN     PMTABD                                                           
