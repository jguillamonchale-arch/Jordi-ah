C1543 *------------------------------------------------------------------------*                    
C1543 * Recuperar Categoría de Rotación de un Artículo                         *                    
C1543 *------------------------------------------------------------------------*                    
C1543c     cs_rtvCRot    BEGSR                                                  BSR                
C1543 *                                                                                             
C1543c                   eval      zyCRot = *blank                                                  
C1543c                   eval      zymaga = *blanks                                                 
C1543c                   exsr      cs_rtvTCia                                                       
C1543**C1543             if        somstcia = '1'                                                   
C1543c                   if        zyTCia <> '1'                                                    
C1543c                   call      'DP0090'                                                         
C1543c                   parm      s5cias        @pecias                                            
C1543c                   parm      s5arti        @pearti                                            
C1543c                   parm      s5vari        @pevari                                            
C1543c                   parm      s5mode        @pemode                                            
C1543c                   parm      *blanks       @peento                                            
C1543c                   parm      *blanks       @peentd                                            
C1543c                   parm      *blanks       @peclas                                            
C1543c                   eval      zyCRot = @peclas                                                 
      *                                                                                             
C1543c                   if        zycrot = *blanks                                                 
C1543c                   eval      m6cias = s5cias                                                  
C1543c                   eval      m6dlga = s5dlga                                                  
C1543c                   eval      m6arti = s5arti                                                  
C1543c                   eval      m6vari = s5vari                                                  
C1543c                   eval      m6mode = s5mode                                                  
C1543c                   eval      m6netl = 2                                                       
C1543c     kmsstst       chain     msstst                                                           
C1543C                   IF        NOT %FOUND OR M6OMIT='1'                                         
C1543C                   eval      M6NETL=1                                                         
C1543c     kmsstst       chain     msstst                                                           
C1543C                   endif                                                                      
C1543c                   if        %found                                                           
C1543C                   EVAL      zycrot=M6CLAS                                                    
C1543c                   else                                                                       
C1543C                   EVAL      zycrot='B '                                                      
C1543c                   endif                                                                      
C1543C                   endif                                                                      
      *                                                                                             
C1543c                   else                                                                       
C1543c                   eval      m0cias = s5cias                                                  
C1543c                   eval      m0loge = s5loge                                                  
C1543c     kmsalma05     chain     msalma05                                                         
C1543c                   if        %found                                                           
C1543c                   eval      zymaga = m0maga                                                  
C1543c                   endif                                                                      
C1543c                   eval      crm1cias = s5cias                                                
C1543c                   eval      crm1arti = s5arti                                                
C1543c                   eval      crm1vari = s5vari                                                
C1543c                   eval      crm1mode = s5mode                                                
C1543c                   eval      crm1maga = zymaga                                                
C1543c     kmsstok01     chain     msstok01                                                         
C1543c                   if        %found                                                           
C1543c                   eval      zyCRot = crm1crot                                                
C1543c                   endif                                                                      
C1543c                   endif                                                                      
C1543 *                                                                                             
C1543c                   endsr                                                  BSR                
C1543 *------------------------------------------------------------------------*                    
C1543 * Recuperar Tipo de Empresa: Comercial, Productiva, Ccial-Productiva     *                    
C1543 *------------------------------------------------------------------------*                    
C1543c     cs_rtvTCia    BEGSR                                                  BSR                
C1543 *                                                                                             
C1543**C1543              eval      somstcia = *blanks                                              
C1543**C1543c             eval      somscias = s5cias                                               
C1543**C1543c             eval      somsdlga = s5dlga                                               
C1543**C1543kmssoci       chain     mssoci                                                          
C1543**C1543              if        not %found                                                      
C1543**C1543somscias      chain     mssoci                                                          
C1543**C1543              endif                                                                     
C1543c                   eval      zyTCia = *blank                                                  
C1543c                   eval      ppampl = *blanks                                                 
C1543c                   move      s5cias        ppcias                                             
C1543c     ppcias        chain     pmlibl                                                           
C1543c                   eval      zyTCia = %subst(ppampl:6:1)                                      
C1543 *                                                                                             
C1543c                   endsr                                                  BSR                
C1543 *------------------------------------------------------------------------*                    
C1543 * Ventana de Confirmación de Anulación                                   *                    
C1543 *------------------------------------------------------------------------*                    
C1543c     cs_confAnul   BEGSR                                                  BSR                
C1543 *                                                                                             
C1543c                   eval      w15SN = '0'                                                      
C1543c                   dow       retro = *off                                                     
C1543c                   exfmt     w15                                                              
C1543c                   select                                                                     
C1543c                   when      help = *on                                                       
C1543C                   CALL      'MMPROM'                                                         
C1543C                   PARM      *blanks       @PEOPT2                                            
C1543C                   PARM      *blanks       @PEPGM                                             
C1543C                   PARM      *blanks       @PEFMT                                             
C1543C                   PARM      'SINO'        @PEFLD                                             
C1543C                   PARM      *BLANKS       @PEERR                                             
C1543C                   IF        @PEERR<'0'                                                       
C1543c                   eval      w15sn = @peopt2                                                  
C1543c                   endif                                                                      
C1543c                   when      retro = *off                                                     
C1543C                   CALL      'MMPROM'                                                         
C1543C                   PARM      *blanks       @PEOPT2                                            
C1543C                   PARM      *blanks       @PEPGM                                             
C1543C                   PARM      *blanks       @PEFMT                                             
C1543C                   PARM      'SINO'        @PEFLD                                             
C1543C                   PARM      'V'           @PEERR                                             
C1543C                   IF        @PEERR>'0'                                                       
C1543C                   EVAL      ERRGRL=*ON                                                       
C1543C                   EVAL      MSGER='ADP0304'                                                  
C1543c                   else                                                                       
C1543c                   eval      retro = *on                                                      
C1543C                   ENDIF                                                                      
C1543c                   when      retro = *on                                                      
C1543c                   eval      @peopt = *blanks                                                 
C1543c                   OTHER                                                                      
C1543c                   eval      retro = *on                                                      
C1543c                   endsl                                                                      
C1543c                   enddo                                                                      
C1543c                   if        w15sn <> '1'                                                     
C1543c                   eval      @peopt = *blanks                                                 
C1543c                   endif                                                                      
C1543c                   eval      retro = *off                                                     
C1543 *                                                                                             
C1543c                   endsr                                                  BSR                
C2170 *****************************************************************--------*                    
C2170 * MOSTRAR PANTALLA PLAZOS DE ENTREGA EN FUNCIÓN DEL SETUP                *                    
C2170 *****************************************************************--------*                    
C2170c     cs_plazos     begsr                                                  BSR                
C2170 *                                                                                             
C2170 * Mostrar pantalla                                                                            
C2170c                   select                                                                     
C2170c                   when      mcmvpe='1'                                                       
C2170c                   eval      @perro=*blanks                                                   
C2170 *                                                                                             
C2170 * Mostrar pantalla solo si no hay stock disponible                                            
C2170c                   when      mcmvpe='2'                                                       
C2170c                   exsr      cs_calesto                                                       
C2170 *                                                                                             
C2170c                   if        zxsdis<zxcant_plz                                                
C2170c                   eval      @perro=*blanks                                                   
C2170c                   else                                                                       
C2170c                   eval      @perro='*'                                                       
C2170c                   endif                                                                      
C2170 *                                                                                             
C2170 * No mostrar pantalla                                                                         
C2170c                   other                                                                      
C2170c                   eval      @perro='*'                                                       
C2170c                   endsl                                                                      
C2170 *                                                                                             
C2170c                   endsr                                                  BSR                
C3460***************************************************************                               
C3460** Finestra de sortida, informan la procedencia de la comanda *                               
C3460*-------------------------------------------------------------*                               
C3460C     cs_proced     BEGSR                                                                      
C3460C                   WRITE     SUFC                                                             
C3460C                   CALL      'CO2566'                                                         
C3460C                   PARM      SUFCIAS       @PECIAS                                            
C3460C                   PARM      SUFDLGA       @PEDLGA                                            
C3460C                   PARM      SUFNPCO       @PENPCO                                            
C3460C                   PARM      SUFTPED       @PETPED                                            
C3460C                   PARM      SUFDATP       @PEDATP                                            
C3460C                   PARM      SUFNOPL       @PENOPL                                            
C3460C                   PARM      *BLANKS       @PEERR                                             
C3460C                   endsr                                                                      
      ******************************************************************************************    
     C* CALCULO DEL PRECIO NETO                                                                     
      ******************************************************************************************    
     C/COPY *LIBL/QSRDSRC,SRD040                                                                    
      ******************************************************************************************    
     C* validación de opciones                                                                      
      ******************************************************************************************    
     C/COPY *LIBL/QSRDSRC,SRD030                                                                    
CUK04* ========================================================================= *                 
CUK04* @RtvDecUn: Recuperar decimales Unidades                                                     
CUK04* ========================================================================= *                 
CUK04P @RtvDecUn       B                                                                            
CUK04D @RtvDecUn       PI             1  0                                                          
CUK04D   Arti                        15    VALUE                                Artículo            
CUK04D   Vari                         3    VALUE                                Variación           
CUK04D   Mode                         3    VALUE                                Modelo              
CUK04D   Unim                         2    VALUE                                Unidad              
CUK04                                                                                               
CUK04C                   EVAL      P6ARTI = Arti                                                    
CUK04C                   EVAL      P6VARI = Vari                                                    
CUK04C                   EVAL      P6MODE = Mode                                                    
CUK04C                   EVAL      P6UNIM = Unim                                                    
CUK04C     KPMUNAL       CHAIN     PMUNAL                                                           
CUK04C                   IF        NOT %FOUND                                                       
CUK04C                   EVAL      P6VARI=*BLANKS                                                   
CUK04C                   EVAL      P6MODE=*BLANKS                                                   
CUK04C     KPMUNAL       CHAIN     PMUNAL                                                           
CUK04C                   ENDIF                                                                      
CUK04C                   IF        %FOUND                                                           
CUK04C                   return    P6DECI                                                           
CUK04C                   ELSE                                                                       
CUK04C                   return    0                                                                
CUK04C                   ENDIF                                                                      
CUK04P                 E                                                                            
F-2OL *---------------------------------------------------------------                              
F-2OL * Add - Procedure GetLogol                                                                    
      /free                                                                                         
       dcl-proc GetLogol;                                                                           
        dcl-pi *n like(m0logs); //Valor de retorn                                                   
          xcias  like(m5cias); //paràmetres                                                         
          xarti  like(m5arti); //    ''                                                             
          xvari  like(m5vari); //    ''                                                             
          xmode  like(m5mode); //    ''                                                             
        end-pi;                                                                                     
        //Vars propies                                                                              
        dcl-s  i int(10);                                                                           
        //-----------------------------                                                             
        // Cerca del magatzem on l'estoc d'aquest article és propi                                  
          for i = 1 to %elem(T_maga);                                                               
            chain (xcias:xarti:xvari:xmode:T_maga(i)) msstok01;                                     
            if %found;// and crm1prop >= '1';                                                       
              return T_logol(i);                                                                    
            endif;                                                                                  
          endfor;                                                                                   
          return 'xxx';                                                                             
                                                                                                    
       end-proc;                                                                                    
      /end-free                                                                                     
F-2OL * End                                                                                         
** CTDATA C                                                                                         
'                                                                                                   
