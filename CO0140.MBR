23014C                   EVAL      S44UNIM=ZXUNIM4                                                  
23014C                   EVAL      S44UNI2=ZXUNIM4                                                  
23014 *                                                                                             
23014C                   EVAL      PXDCCD=2                                                         
23014C                   EVAL      PXALPH=*BLANKS                                                   
23014C                   EVAL      PXNUM=ZXSTOK                                                     
23014C                   CALL      'PRD650'                                                         
23014C                   PARM                    PXNUM                                              
23014C                   PARM                    PXALPH                                             
23014C                   PARM                    PXFLDD                                             
23014C                   PARM                    PXDCCD                                             
23014C                   PARM                    PXFMD1                                             
23014C                   PARM                    PXEDTC                                             
23014C                   PARM                    PXNMER                                             
23014C                   PARM                    PXTIPA                                             
23014C                   MOVE      PXALPH        S44STOK                                            
23014 *                                                                                             
23014C                   EVAL      S44MARC=*BLANKS                                                  
23014C                   IF        ZXCAPT>ZXSTOK                                                    
23014C                   EVAL      S44MARC='*'                                                      
23014C                   ENDIF                                                                      
FQ944 *                                                                                             
FQ944C                   WHEN      ZXNUMVI=5                                                        
FQ944C                   EVAL      S45ARTI=S5ARTI                                                   
FQ944C                   EVAL      S45VARI=S5VARI                                                   
FQ944C                   EVAL      S45MODE=S5MODE                                                   
FQ944C                   EVAL      S45STUL=S5STUL                                                   
FQ944 * FECHA PEDIDO                                                                                
FQ944C                   EVAL      @PVAN=*ZEROS                                                     
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM      S5DATP        @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S45DATP=@PVAA                                                    
FQ944 * FECHA PETICIÓN ENTREGA CLIENTE                                                              
FQ944C                   EVAL      @PVAN=*ZEROS                                                     
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM      S5FREP        @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S45FREP=@PVAA                                                    
FQ944 * FECHA de stock disponible                                                                   
FQ944C                   IF        S5DISP<>*BLANKS                                                  
FQ944C                   EVAL      @PVAN=%FLOAT(S5DISP)                                             
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM                    @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S45DISP=@PVAA                                                    
FQ944C                   ENDIF                                                                      
FQ944C                   MOVE      S5NCOE        S45COEN                                            
FQ944 * FECHA confirmada                                                                            
FQ944C                   EVAL      @PVAN=*ZEROS                                                     
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM      S5FRRE        @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S45FRRE=@PVAA                                                    
FQ944 *                                                                                             
     C                   ENDSL                                                                      
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5DTO1                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S042DTO1                                           
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5DTO2                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S042DTO2                                           
                                                                                                    
     C                   EVAL      S042DES1=S5DES1                                                  
     C                   EVAL      S042ARTI=S5ARTI                                                  
     C                   EVAL      S042TPPR=S5TPPR                                                  
                                                                                                    
     C                   EXSR      CS_KEYPF                                                         
                                                                                                    
      *** En el caso de que se desee que el usuario no visualice costes                             
     C                   IF        ZZNPG2>='1'                                                      
     C                   EXSR      CS_ZZNPG2                                                        
     C                   ENDIF                                                                      
     C                   SELECT                                                                     
     C                   WHEN      ZXNUMVI=1                                                        
     C                   EVAL      SUFDATA=W4DATAV1                                                 
     C                   WHEN      ZXNUMVI=2                                                        
     C                   EVAL      SUFDATA=W4DATAV2                                                 
     C                   WHEN      ZXNUMVI=3                                                        
     C                   EVAL      SUFDATA=W4DATAV3                                                 
23014C                   WHEN      ZXNUMVI=4                                                        
23014C                   EVAL      SUFDATA=W4DATAV4                                                 
FQ944C                   WHEN      ZXNUMVI=5                                                        
FQ944C                   EVAL      SUFDATA=W4DATAV5                                                 
     C                   ENDSL                                                                      
C0031C                   IF        S0COEN>='1'                                                      
FQ937C                   IF        S5NCOE>'00'                                                      
C0031C                   MOVEL     'C'           S042NCOE                                           
C0031C                   MOVE      S5NCOE        S042NCOE                                           
FQ937C                   ELSE                                                                       
FQ937C                   CLEAR                   S042NCOE                                           
FQ937C                   ENDIF                                                                      
C0031C                   ENDIF                                                                      
     C                   EVAL      SUFDAT2=W4DAT2                                                   
      * busca si tiene observaciones.= 'O', me situo para buscar observa-                           
      * ciones en el detalle.                                                                       
     C                   EVAL      SUFDAT3=*BLANKS                                                  
     C                   EVAL      S0LINP=S5LINE                                                    
     C     KCOOBPE       SETLL     COOBPE                                                           
     C     KCOOBPE       READE     COOBPE                                 86                        
     C                   IF        INDBOBS=*OFF                                                     
     C                   EVAL      SUFDAT3='O'                                                      
     C                   ENDIF                                                                      
     C*Marca de impresión                                                                           
     C                   MOVE      S5MIMP        SUFDAT3                                            
     C*Modificamos color según Gravedad y Error de Envios Automáticos                               
     C                   EVAL      INDPRO2=*OFF                                                     
     C                   EVAL      INDPRO4=*OFF                                                     
     C                   IF        S5TINC='1'                                                       
     C                   EVAL      INDPRO2=*ON                                                      
     C                   ELSE                                                                       
     C                   IF        S5INCI<>*BLANKS                                                  
     C                   EVAL      INDPRO4=*ON                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C*                                                                                             
                                                                                                    
     C     S04MFPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PER MOURE CAMPS AL SFL                           *                                
      *------------------------------------------------------------*                                
     C     S05MFP        BEGSR                                                                      
     C                   EVAL      SUFOPCI=*BLANKS                                                  
     C                   EVAL      SFLNXC=*OFF                                                      
                                                                                                    
      * Búsqueda de los valores de visualización                                                    
     C                   EVAL      S51MONV=MCMONV                                                   
     C                   IF        S51MONV=*BLANKS                                                  
     C                   EVAL      S51MONV=S5MONE                                                   
     C                   IF        S51MONV=*BLANKS                                                  
     C                   EVAL      S51MONV=S5MONC                                                   
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   EVAL      S52MONV=S51MONV                                                  
      * Búsqueda del cambio de trabajo                                                              
     C                   EVAL      ZXMONV=S52MONV                                                   
     C                   EVAL      ZXCOCAMB=1                                                       
     C                   EXSR      CS_ZXCOCAM                                                       
                                                                                                    
     C                   SELECT                                                                     
      * Campos para vista 1                                                                         
     C                   WHEN      ZXNUMVI=1                                                        
      * Los valores confirmados prevalecen sobre los previstos                                      
     C                   IF        S5CANC<>0                                                        
     C                   EVAL      S5CANT=S5CANC                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        S5PRCC<>0                                                        
     C                   EVAL      S5PREC=S5PRCC                                                    
     C                   EVAL      S5MONE=S5MONC                                                    
     C                   EVAL      S5COMO=M5MONE                                                    
     C                   EVAL      S5CADP=S5CADC                                                    
     C                   EVAL      S5UNDP=S5UNDC                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        S5DT1C<>0                                                        
     C                   EVAL      S5DTO1=S5DT1C                                                    
     C                   EVAL      S5DTO2=S5DT2C                                                    
     C                   EVAL      S5DTO3=S5DT3C                                                    
     C                   EVAL      S5DTO4=S5DT4C                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        S5FRRE<>0                                                        
FQ944C****************** EVAL      S5FREP=S5FRRE                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      S51CLAB=S5CLAB                                                   
     C                   EVAL      S51VARI=S5VARI                                                   
     C                   EVAL      S51MODE=S5MODE                                                   
     C                   EVAL      S51TCOJ=S5TCOJ                                                   
     C                   MOVE      S5LINE        S51LINE                                            
     C                   EVAL      S51UNIM=S5UNIM                                                   
     C                   EVAL      S51GUIO='/'                                                      
     C                   EVAL      S51UNDP=S5UNDP                                                   
     C                   EVAL      S51TPTA=S5TPTA                                                   
     C                   EVAL      S51STUL=S5STUL                                                   
                                                                                                    
     C                   EVAL      PXDCCD=2                                                         
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5CANT                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S51CANT                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5PREC*ZXCOCAMB                                            
     C                   IF        MCTPRU>='1' AND S5CADP>=1                                        
     C                   EVAL      PXNUM=PXNUM/S5CADP                                               
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      XZAUXI=PXNUM                                                     
     C                   EVAL      XZDECI=ZXDEC0                                                    
     C                   EVAL      XZAJUD=ZXAJU0                                                    
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
     C                   EVAL      PXNUM=XZAUXI                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      ZXDEC0        PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S51PREC                                            
                                                                                                    
     C                   EVAL      PXDCCD=1                                                         
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   IF        MCTPRU>='1' AND S5CADP>=1                                        
     C                   EVAL      PXNUM=1                                                          
     C                   ELSE                                                                       
     C                   EVAL      PXNUM=S5CADP                                                     
     C                   ENDIF                                                                      
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S51CADP                                            
     C                   EVAL      PXDCCD=2                                                         
                                                                                                    
      * Campos para vista 2                                                                         
     C                   WHEN      ZXNUMVI=2                                                        
     C                   MOVE      S5LINE        S52LINE                                            
     C                   EVAL      S52CLAB=S5CLAB                                                   
     C                   EVAL      S52VARI=S5VARI                                                   
     C                   EVAL      S52MODE=S5MODE                                                   
     C                   EVAL      S52TCOJ=S5TCOJ                                                   
      * Búsqueda del precio total                                                                   
     C                   EVAL      ZXMONV=S52MONV                                                   
     C                   EXSR      CS_SECCAL2                                                       
                                                                                                    
     C                   EVAL      PXDCCD=XZDECI                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXBIMP                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S52BIMP                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXIIV1+ZXIIV2                                              
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S52IIVA                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXBIMP+ZXIIV1+ZXIIV2                                       
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S52TOTI                                            
      * Campos para vista 3                                                                         
     C                   WHEN      ZXNUMVI=3                                                        
     C                   MOVE      S5LINE        S53LINE                                            
     C                   EVAL      S53CLAB=S5CLAB                                                   
     C                   EVAL      S53VARI=S5VARI                                                   
     C                   EVAL      S53MODE=S5MODE                                                   
     C                   EVAL      S53TCOJ=S5TCOJ                                                   
      * Búsqueda de los valores de visualización                                                    
     C                   EXSR      CS_SECCAL2                                                       
     C                   EVAL      PXDCCD=XZDECI                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXBIMP                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S53BIMP                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EXSR      CS_RCOSTE                                                        
     C                   EVAL      PXNUM=ZXCOST                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S53COST                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=((ZXCOST)-ZXBIMP)*-1                                       
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      1             PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM      'M'           PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S53BETE                                            
                                                                                                    
     C                   EXSR      CS_RENDIM                                                        
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      0             PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM      'M'           PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S53REND                                            
     C                   MOVE      *BLANKS       PXEDTC                         CODI EDICIO(4,M,    
     C                   IF        (PXNUM=0 AND ZXCOST<>0) OR (PXNUM>999,9)                         
     C                   MOVE      *ALL'*'       S53REND                                            
     C                   ENDIF                                                                      
                                                                                                    
23014 * Campos para vista 4                                                                         
23014C                   WHEN      ZXNUMVI=4                                                        
23014C                   MOVE      S5LINE        S54LINE                                            
23014C                   EVAL      S54CLAB=S5CLAB                                                   
23014C                   EVAL      S54VARI=S5VARI                                                   
23014C                   EVAL      S54MODE=S5MODE                                                   
23014C                   EVAL      S54TCOJ=S5TCOJ                                                   
23014C                   EVAL      S54STUL=S5STUL                                                   
23014 *                                                                                             
