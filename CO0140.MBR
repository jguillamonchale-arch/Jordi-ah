30812C                   EVAL      S5LINE=ZXLINE                                                    
30812C     KCODEPE       CHAIN(N)  CODEPE                                                           
13612C                   ENDSR                                                                      
26712 **************************************************************************                    
26712 * SUBRUTINA PARA COMPROBAR SI ARTÍCULO DE SERVICIOS                      *                    
26712 *------------------------------------------------------------------------*                    
26712C     CS_ARTSRV     BEGSR                                                                      
26712C                   EVAL      ARTSRV=*OFF                                                      
26712C     KMSARTI00     CHAIN     MSARTI00                                                         
