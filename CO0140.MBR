      ***************************************************************                               
16111 * MIRAMOS SI EXISTE RAPPEL ACTIVO.                                                            
      ***************************************************************                               
16111C     CS_BUSRAP     BEGSR                                                                      
                                                                                                    
16111C                   EVAL      ZXARPL0=' '                                                      
16111C                   EVAL      SACUST=S0CUST                                                    
16111C                   EVAL      SATRPL='0'                                                       
16111C                   EVAL      SAFDES=S0DATP                                                    
16111C                   EVAL      SAHORA=S0NOPL                                                    
16111C     KCORAPL03     SETLL     CORAPL03                                                         
16111C     KCORAPL       READPE    CORAPL03                               82                        
16111C                   IF        *IN82=*OFF AND S0DATP>=SAFDES AND                                
16111C                                            S0DATP<=SAFHAS                                    
16111C                   EVAL      ZXARPL0='1'                                                      
16111C                   ELSE                                                                       
16111C                   EVAL      SATRPL='4'                                                       
16111C                   EVAL      SAFDES=S0DATP                                                    
16111C                   EVAL      SAHORA=S0NOPL                                                    
16111C     KCORAPL03     SETLL     CORAPL03                                                         
16111C     KCORAPL       READPE    CORAPL03                               82                        
16111C                   IF        *IN82=*OFF AND S0DATP>=SAFDES AND                                
16111C                                            S0DATP<=SAFHAS                                    
16111C                   EVAL      ZXARPL0='1'                                                      
16111C                   ENDIF                                                                      
16111C                   ENDIF                                                                      
16111C                   ENDSR                                                                      
      ***************************************************************                               
16111 * OBSERVACIONES A SUBFICHERO                                                                  
      ***************************************************************                               
16111C     CS_SFLOBSE    BEGSR                                                                      
     * RENED Pas d'indicateur de stock pour les lignes commentaires                                
    C                   EVAL      *IN59 = *OFF                                                     
     C                   EVAL      INDPRO3=*ON                                                      
     C                   EVAL      SUFPOCI='1'                                                      
     C                   EVAL      SUFSO46=*BLANKS                                                  
     C                   EVAL      SUFDAT3=*BLANKS                                                  
     C                   EVAL      S0LINP=ZXLINP0                                                   
     C                   EVAL      ZX1LINEA=0                                                       
      * Para líneas de cabecera o detalle , permito el campo de opcion                              
     C     KCOOBPE       SETLL     COOBPE                                                           
     C     KCOOBPE       READE     COOBPE                                 86                        
     C                   DOW       INDBOBS=*OFF                                                     
     C                   IF        ZXTLI10<>*BLANKS AND ZXTLI10<>S0TLI1                             
      * En el caso de observaciones que no deban imprimirse, saldran en la                          
      * cabecera                                                                                    
     C                   IF        (ZXTLI10<>'2') OR                                                
     C                             (ZXTLI10='2' AND S0TLI1='1')                                     
     C                   GOTO      TNEXOBSE                                                         
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        S0MSGE<>*BLANKS                                                  
     C                   EVAL      MXMSGE=S0MSGE                                                    
     C                   EVAL      MXIDIO=S0IDIB                                                    
     C     KMSMSGE       CHAIN     MSMSGE                             81                            
     C                   EVAL      S0OB50=MXDE50                                                    
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      S0OB50=*ALL'?'                                                   
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
      * Si es la 1ª linea de cabecera o la 1ª linea de pie permito opcion                           
     C                   IF        (ZXTLI10='1' OR ZXTLI10='2') AND                                 
     C                             (ZX1LINEA<=0)                                                    
     C                   EVAL      INDPRO3=*OFF                                                     
     C                   EVAL      SUFPOCI=*BLANKS                                                  
     C                   EVAL      SUFSO46='1'                                                      
     C                   EVAL      ZX1LINEA=1                                                       
     C                   ENDIF                                                                      
                                                                                                    
05109C                   IF        ZXPOSIC = S0TLI1 OR                                              
05109C                                (S0TLI1 < '1' AND ZXPOSIC='2')                                
     C                   EVAL      S013OBSE=S0OB50                                                  
     C                   EVAL      ZXNRR00=ZXNRR00 + 1                                              
     C                   EVAL      ZXLOP00=ZXLOP00 + 1                                              
     C                   EVAL      SUFOPCI=*BLANKS                                                  
     C                   EVAL      SFLNXC=*OFF                                                      
     C                   EVAL      SUFDATA=W1DOBS                                                   
     C                   EVAL      SUFDAT2=*BLANKS                                                  
                                                                                                    
     C                   EVAL      S5LINE=ZXLINP0                                                   
     C                   EXSR      CS_KEYPF                                                         
                                                                                                    
     C                   WRITE     SUFD                                                             
     C                   EVAL      INDPRO3=*ON                                                      
     C                   EVAL      SUFPOCI='1'                                                      
     C                   EVAL      SUFSO46=*BLANKS                                                  
05109C                   ENDIF                                                                      
     C     TNEXOBSE      TAG                                                                        
     C     KCOOBPE       READE     COOBPE                                 86                        
     C                   ENDDO                                                                      
     C                                                                                              
     C                   EVAL      INDPRO3=*OFF                                                     
     C                   EVAL      SUFPOCI=*BLANKS                                                  
     C                   EVAL      SUFSO46=*BLANKS                                                  
16111C                   ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA DE POSICIONAMENT DEL CURSOR                      *                                
      *------------------------------------------------------------*                                
     C     CS_W07MAIN    BEGSR                                                                      
     C                   EVAL      ZXOPT3='W07'                                                     
     C                   DOW       ZXOPT3='W07'                                                     
     C     ZXOPT4        CASEQ     'CLR'         W07CLR                                             
     C     ZXOPT4        CASEQ     'INZ'         W07INZ                                             
     C     ZXOPT4        CASEQ     'DSP'         W07DSP                                             
     C     ZXOPT4        CASEQ     'CMD'         W07CMD                                             
     C     ZXOPT4        CASEQ     'CHK'         W07CHK                                             
     C     ZXOPT4        CASEQ     'UPD'         W07UPD                                             
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA LIMPIEZA  DE W07                                 *                                
      *------------------------------------------------------------*                                
     C     W07CLR        BEGSR                                                                      
     C                   EVAL      ZXOPT4='INZ'                                                     
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     * RENED Utilisation de l'indicateur 59 pour le stock (Begin)                                  
     C*                  MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO9       *IN(50)                                            
     * RENED Utilisation de l'indicateur 59 pour le stock (End)                                    
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
      *                                                                                             
     C                   EVAL      W07CSCG=*BLANKS                                                  
      *                                                                                             
     C     W07CLRT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ                                   *                                
      *------------------------------------------------------------*                                
     C     W07INZ        BEGSR                                                                      
      *                                                                                             
     C                   EVAL      ZXOPT4='DSP'                                                     
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VISUALITZACIÓ DEL FMT W07                        *                                
      *------------------------------------------------------------*                                
     C     W07DSP        BEGSR                                                                      
      * ENS ENCARREGUEM QUE EL PROPER PAS SIGUI COMPROVAR ENTRADA CMD                               
     C                   EVAL      ZXOPT4='CMD'                                                     
     C                   EVAL      PPWCMD1='CMD3013'                                                
                                                                                                    
     C                   EVAL      @PERRO=*BLANKS                                                   
     C                   EXFMT     W07                                                              
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   EVAL      ERRGRL=*OFF                                                      
     C                   EVAL      MSGER=*BLANKS                                                    
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C     W07DSPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CMDS DEL FMT W07                 *                                 
      *------------------------------------------------------------*                                
     C     W07CMD        BEGSR                                                                      
     C                   EVAL      ZXOPT4='CHK'                                                     
      *VALIDACIONES TECLAS DE FUNCION                                                               
     C                   SELECT                                                                     
      * SOL·LICITUD AJUDA D'CUSTCLES                                                                
     C                   WHEN      HELP=*ON                                                         
     C                   EVAL      ZXOPT4='DSP'                                                     
     C                   EXSR      W07F4                                                            
      * RETROCESO PANTALLA                                                                          
     C                   WHEN      RETRO=*ON                                                        
     C                   EVAL      ZXOPTB='END'                                                     
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDSL                                                                      
                                                                                                    
     C     TW07CMD       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT4='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C     W07CMDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE AYUDA EN CAMPOS DEL   FMT W07                 *                                
      *------------------------------------------------------------*                                
     C     W07F4         BEGSR                                                                      
     C* No se permite acceso a consulta si estamos en opcion de visualizar                          
     C                   IF        INDDSP=*ON                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           W07F4T                                             
                                                                                                    
     C                   IF        FIELD='W07CSCG'                                                  
     C                   EVAL      @PCLTA=*BLANKS                                                   
     C                   EVAL      @PCLTA=W07CSCG                                                   
     C                   CALL      'MMTABL'                                                         
     C                   PARM                    @PCLTA                                             
     C                   PARM      'CSCG'        @PCTAB                                             
     C                   PARM                    @PCIAS                                             
     C                   PARM      *BLANKS       @PERRO                                             
     C                   MOVEL     @PCLTA        W07CSCG                                            
     C                   GOTO      W07F4T                                                           
     C                   ENDIF                                                                      
      * SI NO TIENE F4 SOPORTADO DOY ERROR                                                          
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ADP0304'                                                  
     C     ERRGRL        CABEQ     *ON           W07F4T                                             
                                                                                                    
     C     W07F4T        ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CAMPS DEL FMT P2A                 *                                
      *------------------------------------------------------------*                                
     C     W07CHK        BEGSR                                                                      
     C                   EVAL      ZXOPT4='UPD'                                                     
      * La causa de resolución debe existir y ser válida                                            
     C                   EVAL      PECLTA=W07CSCG                                                   
     C                   EVAL      PECTAB='CSCG'                                                    
     C     KPMTABD       CHAIN     PMTABD                             81                            
     C                   IF        CHAIN=*ON OR PEBAJA='1'                                          
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   EVAL      WRK41=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TW07CHK                                            
                                                                                                    
     C     TW07CHK       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT4='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE ACTUALIZACION DEL FMT W07                     *                                
      *------------------------------------------------------------*                                
     C     W07UPD        BEGSR                                                                      
     C                   EVAL      ZXOPTB='END'                                                     
      * En el caso de la opción de visualiza no actualizo                                           
     C                   IF        INDDSP=*ON                                                       
     C                   GOTO      W07UPDT                                                          
     C                   ENDIF                                                                      
     C                   EVAL      ZXCSCG=W07CSCG                                                   
                                                                                                    
     C     W07UPDT       ENDSR                                                                      
                                                                                                    
FQ607 **************************************************************                                
FQ607 * COMMON SUBRUTINE (CS_) :                                  *                                 
FQ607 * SUBRUTINA DE POSICIONAMENT DEL CURSOR                      *                                
FQ607 *------------------------------------------------------------*                                
FQ607C     CS_W39MAIN    BEGSR                                                                      
FQ607C                   EVAL      ZXOPT3='W39'                                                     
FQ607C                   DOW       ZXOPT3='W39'                                                     
FQ607C     ZXOPT4        CASEQ     'CLR'         W39CLR                                             
FQ607C     ZXOPT4        CASEQ     'INZ'         W39INZ                                             
FQ607C     ZXOPT4        CASEQ     'DSP'         W39DSP                                             
FQ607C     ZXOPT4        CASEQ     'CMD'         W39CMD                                             
FQ607C     ZXOPT4        CASEQ     'CHK'         W39CHK                                             
FQ607C     ZXOPT4        CASEQ     'UPD'         W39UPD                                             
FQ607C                   ENDCS                                                                      
FQ607C                   ENDDO                                                                      
FQ607 *                                                                                             
FQ607C                   ENDSR                                                                      
FQ607 **************************************************************                                
FQ607 * SUBRUTINA LIMPIEZA  DE W39                                 *                                
FQ607 *------------------------------------------------------------*                                
FQ607C     W39CLR        BEGSR                                                                      
FQ607C                   EVAL      ZXOPT4='INZ'                                                     
FQ607C                   MOVEA     ZXZERO10      *IN(30)                                            
FQ607C                   MOVEA     ZXZERO10      *IN(40)                                            
FQ607C                   MOVEA     ZXZERO9       *IN(50)                                            
FQ607C                   EVAL      CSRFILA=0                                                        
FQ607C                   EVAL      CSRCOLU=0                                                        
FQ607 *                                                                                             
FQ607C                   EVAL      W39INFD=S0INFD                                                   
FQ607C                   EVAL      W39LINI=0                                                        
FQ607 *                                                                                             
FQ607C     W39CLRT       ENDSR                                                                      
FQ607 **************************************************************                                
FQ607 * SUBRUTINA INICIALITZACIÓ                                   *                                
FQ607 *------------------------------------------------------------*                                
FQ607C     W39INZ        BEGSR                                                                      
FQ607 *                                                                                             
FQ607C                   EVAL      ZXOPT4='DSP'                                                     
FQ607                                                                                               
FQ607C                   ENDSR                                                                      
FQ607 **************************************************************                                
FQ607 * SUBRUTINA VISUALITZACIÓ DEL FMT W39                        *                                
FQ607 *------------------------------------------------------------*                                
FQ607C     W39DSP        BEGSR                                                                      
FQ607 * ENS ENCARREGUEM QUE EL PROPER PAS SIGUI COMPROVAR ENTRADA CMD                               
FQ607C                   EVAL      ZXOPT4='CMD'                                                     
FQ607C                   EVAL      PPWCMD1='CMD3013'                                                
FQ607                                                                                               
FQ607C                   EVAL      @PERRO=*BLANKS                                                   
FQ607C                   EXFMT     W39                                                              
FQ607C                   MOVEA     ZXZERO10      *IN(30)                                            
FQ607C                   MOVEA     ZXZERO10      *IN(40)                                            
FQ607C                   MOVEA     ZXZERO10      *IN(50)                                            
FQ607C                   EVAL      ERRGRL=*OFF                                                      
FQ607C                   EVAL      MSGER=*BLANKS                                                    
FQ607C                   EVAL      CSRFILA=0                                                        
FQ607C                   EVAL      CSRCOLU=0                                                        
FQ607C     W39DSPT       ENDSR                                                                      
FQ607 **************************************************************                                
FQ607 * SUBRUTINA VALIDACIÓ DELS CMDS DEL FMT W39                 *                                 
FQ607 *------------------------------------------------------------*                                
FQ607C     W39CMD        BEGSR                                                                      
FQ607C                   EVAL      ZXOPT4='CHK'                                                     
FQ607 *VALIDACIONES TECLAS DE FUNCION                                                               
FQ607C                   SELECT                                                                     
FQ607 * SOL·LICITUD AJUDA D'CUSTCLES                                                                
FQ607C                   WHEN      HELP=*ON                                                         
FQ607C                   EVAL      ZXOPT4='DSP'                                                     
FQ607C                   EXSR      W39F4                                                            
FQ607 * RETROCESO PANTALLA                                                                          
FQ607C                   WHEN      RETRO=*ON                                                        
FQ607C                   EVAL      ZXOPTB='END'                                                     
FQ607C                   EVAL      ERRGRL=*ON                                                       
FQ607C                   ENDSL                                                                      
FQ607                                                                                               
FQ607C     TW39CMD       TAG                                                                        
FQ607C                   IF        ERRGRL=*ON                                                       
FQ607C                   EVAL      ZXOPT4='DSP'                                                     
FQ607C                   ENDIF                                                                      
FQ607                                                                                               
FQ607C     W39CMDT       ENDSR                                                                      
FQ607 **************************************************************                                
FQ607 * SUBRUTINA DE AYUDA EN CAMPOS DEL   FMT W39                 *                                
FQ607 *------------------------------------------------------------*                                
FQ607C     W39F4         BEGSR                                                                      
FQ607C* No se permite acceso a consulta si estamos en opcion de visualizar                          
FQ607C                   IF        INDDSP=*ON                                                       
FQ607C                   EVAL      ERRGRL=*ON                                                       
FQ607C                   ENDIF                                                                      
FQ607C     ERRGRL        CABEQ     *ON           W39F4T                                             
FQ607                                                                                               
FQ607C                   IF        FIELD='W39LINI'                                                  
FQ607C                   CALL      'ED0610'                                                         
FQ607C                   PARM      S0INFD        @PEINFD                                            
FQ607C                   PARM      *ZEROS        @PELINI                                            
FQ607C                   EVAL      W39LINI=@PELINI                                                  
FQ607C                   GOTO      W39F4T                                                           
FQ607C                   ENDIF                                                                      
FQ607 * SI NO TIENE F4 SOPORTADO DOY ERROR                                                          
FQ607C                   EVAL      ERRGRL=*ON                                                       
FQ607C                   EVAL      MSGER='ADP0304'                                                  
FQ607C     ERRGRL        CABEQ     *ON           W39F4T                                             
FQ607                                                                                               
FQ607C     W39F4T        ENDSR                                                                      
FQ607 **************************************************************                                
FQ607 * SUBRUTINA VALIDACIÓ DELS CAMPS DEL FMT P2A                 *                                
FQ607 *------------------------------------------------------------*                                
FQ607C     W39CHK        BEGSR                                                                      
FQ607C                   EVAL      ZXOPT4='UPD'                                                     
FQ607C                   EVAL      T4INFD=W39INFD                                                   
FQ607C                   EVAL      T4LINI=W39LINI                                                   
FQ607C     KEDINCI       CHAIN(N)  EDINCI                                                           
FQ607C                   IF        NOT %FOUND(EDINCI)                                               
FQ607C                             Or (%FOUND(EDINCI) And T4LINC > 0)                               
FQ607C                   EVAL      ERRGRL=*ON                                                       
FQ607C                   EVAL      MSGER='ERR3049'                                                  
FQ607C                   EVAL      WRK41=*ON                                                        
FQ607C                   ENDIF                                                                      
FQ607C     ERRGRL        CABEQ     *ON           TW39CHK                                            
FQ607                                                                                               
FQ607C     TW39CHK       TAG                                                                        
FQ607C                   IF        ERRGRL=*ON                                                       
FQ607C                   EVAL      ZXOPT4='DSP'                                                     
FQ607C                   ENDIF                                                                      
FQ607                                                                                               
FQ607C                   ENDSR                                                                      
FQ607 **************************************************************                                
FQ607 * SUBRUTINA DE ACTUALIZACION DEL FMT W39                     *                                
FQ607 *------------------------------------------------------------*                                
FQ607C     W39UPD        BEGSR                                                                      
FQ607C                   EVAL      ZXOPTB='END'                                                     
FQ607 * En el caso de la opción de visualiza no actualizo                                           
FQ607C                   IF        INDDSP=*ON                                                       
FQ607C                   GOTO      W39UPDT                                                          
FQ607C                   ENDIF                                                                      
FQ607C                   EVAL      ZXLINI=W39LINI                                                   
FQ607                                                                                               
FQ607C     W39UPDT       ENDSR                                                                      
FQ607                                                                                               
      **************************************************************                                
      * SUBRUTINA QUE GENERA EL PEDIDO DE COMPRAS                  *                                
      *------------------------------------------------------------*                                
     C     CS_SBMGPC     BEGSR                                                                      
      * Campos de PU2660DS                                                                          
     C                   EVAL      X2CIAS=S5CIAS                                                    
     C                   EVAL      X2DLGA=S5DLGA                                                    
     C                   EVAL      X2NPCO=S5NPCO                                                    
     C                   EVAL      X2TPED=S5TPED                                                    
     C                   EVAL      X2DATP=S5DATP                                                    
     C                   EVAL      X2NOPL=S5NOPL                                                    
     C                   EVAL      X2LINE=S5LINE                                                    
      * Se le asocia el nº de pedido de compra segun ZZPEPE                                         
     C                   EVAL      X2PEPE=ZZPEPE                                                    
     C                   EVAL      X2PRIN='1'                                                       
     C                   EVAL      X2PR01=W38PRVR                                                   
     C                   EVAL      X2DL01=W38DL01                                                   
     C                   EVAL      X2NP01=W38NP01                                                   
     C                   EVAL      X2TP01=W38TP01                                                   
     C                   EVAL      X2DA01=W38DA01                                                   
     C                   EVAL      X2NO01=W38NO01                                                   
      * La orden no se lanzara si se crea aqui (PU2660 no valida terminos                           
      * como cdades std,etc).                                                                       
     C                   EVAL      X2STSP='1'                                                       
     C                   EVAL      X2GDCL=*BLANKS                                                   
      * Si es pedido de entrega directa le coloca la direccion de entrega                           
      * del propio cliente                                                                          
     C                   IF        (S5TPE4='2') OR (S5EDET='1' AND S5TPE4<>'2')                     
     C                   EVAL      X2GDCL='1'                                                       
     C                   ENDIF                                                                      
      * CAMPOS PARA IDENTIFICAR EL TRABAJO                                                          
     C                   EVAL      ZXJNBR=SDSJOB                                                    
     C                   MOVEL     UDATE         ZXDATA                                             
     C                   TIME                    ZXHORA                                             
     C                   EVAL      ZXHORA=ZXHORA+1                                                  
                                                                                                    
     C                   CALL      'MM2559'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM                    @PEDLGA                                            
     C                   PARM      SDSPGM        @PEPROG                                            
     C                   PARM      '         '   @PERCDR                                            
     C                   PARM      'FMTO     '   @PEFIEL                                            
     C                   PARM      '06'          @PEOPCI                                            
     C                   PARM      'LP01206'     @PECCIT                                            
     C                   PARM                    JOTRAT                                             
     C                   PARM                    @PEPRG2                                            
     C                   PARM      '1'           @PEPAR1                                            
     C                   PARM                    @PEPAR2                                            
     C                   PARM      '1'           @PEERR                                             
                                                                                                    
      *                  EVAL      @PEPRG2='PU2660'                                                 
      *  DATOS DE SELECCION                                                                         
     C                   CLEAR                   Z1COMA                                             
     C     DSLDA         CAT       Z1COMA:0      Z1COMA                                             
     C                   EVAL      JOLINE=86                                                        
      *                                                                                             
     C                   CALL      'PRD935'                                                         
     C                   PARM                    JOTRAT                                             
     C                   PARM                    JOLINE                                             
     C                   PARM                    Z1COMA                                             
      *                                                                                             
     C                   CLEAR                   Z1COMA                                             
     C     PU2660        CAT       Z1COMA:0      Z1COMA                                             
     C                   EVAL      JOLINE=88                                                        
     C                   CALL      'PRD935'                                                         
     C                   PARM                    JOTRAT                                             
     C                   PARM                    JOLINE                                             
     C                   PARM                    Z1COMA                                             
     C                                                                                              
      * Sometiendo el trabajo                                                                       
     C                   Z-ADD     100           ZXLOGC           15 5                              
     C                   MOVE      *BLANKS       ZXQCM2          150                                
     C                   MOVEL     'SBMJOB'      ZXQCM2                                             
     C     ZXQCM2        CAT       'CMD(':1      ZXQCM2                                             
     C     ZXQCM2        CAT       'CALL (':0    ZXQCM2                                             
     C     ZXQCM2        CAT       'PRDG20':0    ZXQCM2                                             
     C     ZXQCM2        CAT       'CL)':0       ZXQCM2                                             
     C     ZXQCM2        CAT       'PARM(':1     ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       JOTRAT:0      ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):1        ZXQCM2                                             
     C     ZXQCM2        CAT       @PEPRG2:0     ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
     C     ZXQCM2        CAT       'JOB(':1      ZXQCM2                                             
     C     ZXQCM2        CAT       SDSPGM:0      ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
                                                                                                    
     C                   CALL      'QCMDEXC'                                                        
     C                   PARM                    ZXQCM2                                             
     C                   PARM                    ZXLOGC                                             
     C                                                                                              
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE GENERA EL PEDIDO DE COMPRAS                  *                                
      *------------------------------------------------------------*                                
     C     CS_VALCODEPE  BEGSR                                                                      
     C                   EVAL      ZXLICOMPRA=0                                                     
     C                   IF        S5NP01<>*BLANKS OR S5DA01<>*ZEROS OR                             
     C                             S5NO01<>*ZEROS                                                   
     C                   EVAL      ZXLICOMPRA=1                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        ZXLICOMPRA>=1                                                    
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TVALCODEPE                                         
                                                                                                    
     C     TVALCODEPE    ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA DE POSICIONAMENT DEL CURSOR                      *                                
      *------------------------------------------------------------*                                
     C     CS_W38MAIN    BEGSR                                                                      
     C                   EVAL      ZXOPT3='W38'                                                     
     C                   DOW       ZXOPT3='W38'                                                     
     C     ZXOPT4        CASEQ     'CLR'         W38CLR                                             
     C     ZXOPT4        CASEQ     'INZ'         W38INZ                                             
     C     ZXOPT4        CASEQ     'DSP'         W38DSP                                             
     C     ZXOPT4        CASEQ     'CMD'         W38CMD                                             
     C     ZXOPT4        CASEQ     'CHK'         W38CHK                                             
     C     ZXOPT4        CASEQ     'UPD'         W38UPD                                             
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA LIMPIEZA  DE W38                                 *                                
      *------------------------------------------------------------*                                
     C     W38CLR        BEGSR                                                                      
     C                   EVAL      ZXOPT4='INZ'                                                     
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     * RENED Utilisation de l'indicateur 59 pour le stock (Begin)                                  
     C*                  MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO9       *IN(50)                                            
     * RENED Utilisation de l'indicateur 59 pour le stock (End)                                    
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
      *                                                                                             
     C                   EVAL      W38ARTI=S5ARTI                                                   
     C                   EVAL      W38VARI=S5VARI                                                   
     C                   EVAL      W38MODE=S5MODE                                                   
     C                   EVAL      W38TCOJ=S5TCOJ                                                   
     C                   EVAL      W38DES1=S5DES1                                                   
      * Valores de proveedor y descripcion proveedor dfto                                           
     C                   EVAL      M5ARTI=S5ARTI                                                    
     C                   EVAL      M5VARI=S5VARI                                                    
     C                   EVAL      M5MODE=S5MODE                                                    
     C     KMSARTI00     CHAIN     MSARTI00                           81                            
      *                                                                                             
     C                   EVAL      W38PRV0=M5PRVR                                                   
     C                   IF        W38PRV0=*BLANKS                                                  
     C                   EVAL      W38PRV0=M5PRV2                                                   
     C                   ENDIF                                                                      
     C                   IF        W38PRV0=*BLANKS                                                  
     C                   EVAL      W38PRV0=M5PRV3                                                   
     C                   ENDIF                                                                      
      *                                                                                             
     C                   EVAL      C0CIAS=@PCIAS                                                    
     C                   EVAL      C0PRVR=W38PRV0                                                   
     C                   EVAL      C0DES1=*BLANKS                                                   
     C                   IF        W38PRV0<>*BLANKS                                                 
     C     KPUPROV       CHAIN     PUPROV                             81                            
     C                   EVAL      W38DESC=C0DES1                                                   
     C                   ENDIF                                                                      
      *                                                                                             
     C                   EVAL      W38PRVR=*BLANKS                                                  
     C                   EVAL      W38DL01=*BLANKS                                                  
     C                   EVAL      W38NP01=*BLANKS                                                  
     C                   EVAL      W38TP01=*BLANKS                                                  
     C                   EVAL      W38DA01=*ZEROS                                                   
     C                   EVAL      W38NO01=*ZEROS                                                   
      *                                                                                             
     C     W38CLRT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ                                   *                                
      *------------------------------------------------------------*                                
     C     W38INZ        BEGSR                                                                      
      *                                                                                             
     C                   EVAL      ZXOPT4='DSP'                                                     
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VISUALITZACIÓ DEL FMT W38                        *                                
      *------------------------------------------------------------*                                
     C     W38DSP        BEGSR                                                                      
      * ENS ENCARREGUEM QUE EL PROPER PAS SIGUI COMPROVAR ENTRADA CMD                               
     C                   EVAL      ZXOPT4='CMD'                                                     
     C                   EVAL      PPWCMD1='CMD3013'                                                
                                                                                                    
     C                   EVAL      @PERRO=*BLANKS                                                   
     C                   EXFMT     W38                                                              
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     * RENED Utilisation de l'indicateur 59 pour le stock                                          
     C*                  MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO9       *IN(50)                                            
     * RENED Utilisation de l'indicateur 59 pour le stock (End)                                    
     C                   EVAL      ERRGRL=*OFF                                                      
     C                   EVAL      MSGER=*BLANKS                                                    
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C     W38DSPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CMDS DEL FMT W38                 *                                 
      *------------------------------------------------------------*                                
     C     W38CMD        BEGSR                                                                      
     C                   EVAL      ZXOPT4='CHK'                                                     
      *VALIDACIONES TECLAS DE FUNCION                                                               
     C                   SELECT                                                                     
      * SOL·LICITUD AJUDA D'CUSTCLES                                                                
     C                   WHEN      HELP=*ON                                                         
     C                   EVAL      ZXOPT4='DSP'                                                     
     C                   EXSR      W38F4                                                            
      * RETROCESO PANTALLA                                                                          
     C                   WHEN      RETRO=*ON                                                        
     C                   EVAL      ZXOPTB='END'                                                     
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDSL                                                                      
                                                                                                    
     C     TW38CMD       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT4='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C     W38CMDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE AYUDA EN CAMPOS DEL   FMT W38                 *                                
      *------------------------------------------------------------*                                
     C     W38F4         BEGSR                                                                      
     C* No se permite acceso a consulta si estamos en opcion de visualizar                          
     C                   IF        INDDSP=*ON                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           W38F4T                                             
     C                   IF        FIELD='W38PRVR'                                                  
     C                   CALL      'PU0650'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM                    W38PRVR                                            
     C                   PARM      *BLANKS       @PEERR                                             
     C                   GOTO      W38F4T                                                           
     C                   ENDIF                                                                      
      * Consulta por nº de pedido                                                                   
     C                   IF        (FIELD='W38NP01' OR FIELD='W38TP01')                             
     C                   CALL      'PU0775'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM      W38DL01       W38DL01                                            
     C                   PARM      W38PRVR       @PEPRVR                                            
     C                   PARM                    W38NP01                                            
     C                   PARM                    W38TP01                                            
     C                   PARM                    W38DA01                                            
     C                   PARM                    W38NO01                                            
     C                   PARM      *BLANKS       @PEERR                                             
     C                   GOTO      W38F4T                                                           
     C                   ENDIF                                                                      
                                                                                                    
      * SI NO TIENE F4 SOPORTADO DOY ERROR                                                          
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ADP0304'                                                  
     C     ERRGRL        CABEQ     *ON           W38F4T                                             
                                                                                                    
     C     W38F4T        ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CAMPS DEL FMT P2A                 *                                
      *------------------------------------------------------------*                                
     C     W38CHK        BEGSR                                                                      
     C                   EVAL      ZXOPT4='UPD'                                                     
      * Si es cjto, no se permite pasar a esta pantalla                                             
     C                   IF        W38TCOJ<>*BLANKS                                                 
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MSG0055'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TW38CHK                                            
      * Al menos debe existir cantidad pdte.                                                        
     C                   EVAL      ZXCANTPEN=S5CANT-S5CANS-S5CANR                                   
     C                   IF        ZXCANTPEN<=0                                                     
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MSG0030'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TW38CHK                                            
                                                                                                    
     C                   EVAL      C0CIAS=@PCIAS                                                    
     C                   EVAL      C0NPCO=W38NP01                                                   
     C                   EVAL      C0TPED=W38TP01                                                   
     C     KPUCAPE210    CHAIN     PUCAPE21                           81                            
     C                   EVAL      W38DA01=C0DATP                                                   
     C                   EVAL      W38NO01=C0NOPL                                                   
      * La orden debe existir o esta cerrada no dejo, idem si no pertenece                          
      * al proveedor indicado                                                                       
     C                   IF        CHAIN=*ON OR C0STCO>='89' OR                                     
     C                             C0PRVR<>W38PRVR OR C0DLGA<>W38DL01                               
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MSG0055'                                                  
     C                   EVAL      WRK41=*ON                                                        
     C                   EVAL      WRK40=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TW38CHK                                            
                                                                                                    
     C                   MOVE      C0STCO        ZXSTDI                                             
     C                   IF        (ZXSTDI='W' OR ZXSTDI='R')                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK41=*ON                                                        
     C                   EVAL      MSGER='MSG0071'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TW38CHK                                            
      * - Validar si se permite modificar el pedido o no.                                           
     C                   IF        ZZNPG2 = '1' AND C0CDLL = '1'                                    
     C                   EVAL      ERRGRL = *ON                                                     
     C                   EVAL      MSGER = 'PUR0078'                                                
     c                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TW38CHK                                            
                                                                                                    
      * MENSAJES DE AVISO                                                                           
     C                   EVAL      ZXARTIX=W38ARTI                                                  
     C                   EVAL      ZXVARIX=W38VARI                                                  
     C                   EVAL      ZXMODEX=W38MODE                                                  
     C                   CALL      'MM2558'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM      C0PRVR        @PEPRVR                                            
     C                   PARM      '1'           @PETCLP                                            
     C                   PARM      ZZIDIO        @PEIDIO                                            
     C                   PARM      ZXARVMX       @PEARVM                                            
     C                   PARM      W38TCOJ       @PETCOJ                                            
     C                   PARM      '1'           @PETAMS                                            
     C                   PARM                    @PETAAM                                            
     C                   PARM                    @PERRO                                             
     C                   IF        @PETAAM='1'                                                      
     C                   EVAL      ZXOPT='END'                                                      
     C                   EVAL      ERRGRL=*ON                                                       
     C                   GOTO      TW38CHK                                                          
     C                   ENDIF                                                                      
      * Artículo obsoleto                                                                           
     C                   IF        M5PPC2>'0'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK41=*ON                                                        
     C                   EVAL      MSGER='COM0120'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TW38CHK                                            
      * El artículo debe pertenecer al proveedor si así estaba parametrizado                        
     C                   IF        ZZBAPP>='1'                                                      
     C                   EVAL      C3PRVR=W38PRVR                                                   
     C                   EVAL      ZXARTIX2=W38ARTI                                                 
     C                   EVAL      ZXVARIX2=W38VARI                                                 
     C                   EVAL      ZXMODEX2=W38MODE                                                 
     C                   EVAL      C3ARVM=ZXARVMX2                                                  
     C                   EVAL      C3TCOJ=W38TCOJ                                                   
     C                   EVAL      ZXPUPRP0=' '                                                     
     C     KPUPRP0       CHAIN     PUPRP0                             81                            
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK41=*ON                                                        
     C                   EVAL      MSGER='PUR0077'                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TW38CHK                                            
      * Faltan comprobaciones de cantidades std.????????                                            
      *****                                                                                         
     C     TW38CHK       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT4='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE validacion de INCIDENCIAS                     *                                
      *------------------------------------------------------------*                                
     C     CS_VALINC     BEGSR                                                                      
     C                   CALL      'CO2530'                                                         
     C                   PARM                    @PCIAS                                             
     C                   PARM                    @PDLGA                                             
     C                   PARM                    @PNPCO                                             
     C                   PARM                    @PTPED                                             
     C                   PARM                    @PDATP                                             
     C                   PARM                    @PNOPL                                             
     C                   PARM      *BLANKS       @PERRO                                             
     C                   IF        @PERRO>='1'                                                      
     C                   EXFMT     W34                                                              
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE ACTUALIZACION DEL FMT W38                     *                                
      *------------------------------------------------------------*                                
     C     W38UPD        BEGSR                                                                      
     C                   EVAL      ZXOPTB='END'                                                     
