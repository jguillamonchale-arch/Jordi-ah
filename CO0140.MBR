      **************************************************************                                
      * SUBRUTINA QUE LIMPIA COSTES                                *                                
      *------------------------------------------------------------*                                
     C     CS_ZZNPG2     BEGSR                                                                      
     C                   EVAL      S13COST=*ALL'*'                                                  
     C                   EVAL      S13BETE=*ALL'*'                                                  
     C                   EVAL      S13REND=*ALL'*'                                                  
     C                   EVAL      S23COST=*ALL'*'                                                  
     C                   EVAL      S23BETE=*ALL'*'                                                  
     C                   EVAL      S23REND=*ALL'*'                                                  
     C                   EVAL      S33COST=*ALL'*'                                                  
     C                   EVAL      S33BETE=*ALL'*'                                                  
     C                   EVAL      S33REND=*ALL'*'                                                  
     C                   EVAL      S43COST=*ALL'*'                                                  
     C                   EVAL      S43BETE=*ALL'*'                                                  
     C                   EVAL      S43REND=*ALL'*'                                                  
     C                   EVAL      S53COST=*ALL'*'                                                  
     C                   EVAL      S53BETE=*ALL'*'                                                  
     C                   EVAL      S53REND=*ALL'*'                                                  
     C                   EVAL      S63COST=*ALL'*'                                                  
     C                   EVAL      S63BETE=*ALL'*'                                                  
     C                   EVAL      S63REND=*ALL'*'                                                  
     C                   EVAL      S73COST=*ALL'*'                                                  
     C                   EVAL      S73BETE=*ALL'*'                                                  
     C                   EVAL      S73REND=*ALL'*'                                                  
     C                   EVAL      S83COST=*ALL'*'                                                  
     C                   EVAL      S83BETE=*ALL'*'                                                  
     C                   EVAL      S83REND=*ALL'*'                                                  
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE CALCULA COSTE                                *                                
      *------------------------------------------------------------*                                
     C     CS_RCOSTE     BEGSR                                                                      
     C                   EVAL      ZXCOST=*ZEROS                                                    
     C                   EVAL      M5CIAS=S5CIAS                                                    
     C                   EVAL      M5ARTI=S5ARTI                                                    
     C                   EVAL      M5VARI=S5VARI                                                    
     C                   EVAL      M5MODE=S5MODE                                                    
     C                   EVAL      ZXCIASR=S5CIAS                                                   
     C                   EVAL      ZXARTIR=S5ARTI                                                   
     C                   EVAL      ZXVARIR=S5VARI                                                   
     C                   EVAL      ZXMODER=S5MODE                                                   
     C                   EVAL      ZXTCOJR=S5TCOJ                                                   
     C                   EVAL      ZXMONER=S5COMO                                                   
     C                   EVAL      ZXMONE2=S5MONE                                                   
     C                   IF        MCMONV<>*BLANKS                                                  
     C                   EVAL      ZXMONE2=MCMONV                                                   
     C                   ENDIF                                                                      
     C                   EVAL      ZXUNIMR=S5UNIM                                                   
     C                   EVAL      ZXCOSTR=S5COST                                                   
     C                   EVAL      ZXCANTR=S5CANT                                                   
     C                   EVAL      ZXUNDPR=S5UNDP                                                   
     C                   EVAL      ZXCADPR=S5CADP                                                   
     C                   IF        S5PRCC<>0                                                        
     C                   EVAL      ZXUNDPR=S5UNDC                                                   
     C                   EVAL      ZXCADPR=S5CADC                                                   
     C                   ENDIF                                                                      
     C* CALCULO DEL COSTE                                                                           
     C/COPY *LIBL/QSRDSRC,SRD035                                                                    
14066* Si quieren ver costes adicionales, los acumulamos.                                          
14066C                   IF        MCACOS = '1'                                                     
14066C                   EVAL      ZXCOCAM3 = 1                                                     
14066C                   IF        ZXMONER <> ZXMONE2                                               
14066C                   EVAL      ZXCOCAM3 = @PCMCCCO                                              
14066C                   ENDIF                                                                      
14066C                   EXSR      CS_MSACOS                                                        
14066C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      ******************************************************************************************    
     C* RENDIMIENTO                                                                                 
      ******************************************************************************************    
     C     CS_RENDIM     BEGSR                                                                      
      * Búsqueda de los % Real previsto                                                             
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=0                                                          
     C                   IF        ZZRDT1>='1'                                                      
     C                   IF        ZXBIMP<>0                                                        
     C                   EVAL      PXNUM=(1-(ZXCOST/ZXBIMP))*100                                    
     C                   ENDIF                                                                      
     C                   ELSE                                                                       
     C                   IF        ZXCOST<>0                                                        
     C                   EVAL      PXNUM=(ZXBIMP/ZXCOST)*100                                        
     C                   EVAL      PXNUM=PXNUM-100                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      ******************************************************************************************    
     C* BUSQUEDA DE OTRO STANDARD.                                                                  
      ******************************************************************************************    
     C     CS_STANDAR    BEGSR                                                                      
     C                   EVAL      ZXTCST=MOTCST                                                    
     C                   EVAL      W02CAS2=*BLANKS                                                  
     C                   EVAL      W02UNS2=*BLANKS                                                  
     C                                                                                              
     C     KMSTSCA       SETGT     MSTSCA                                                           
     C     KMSTSCA2      READE     MSTSCA                                 81                        
     C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=MOCAST                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      2             PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
