24912C                   IF        THTARS='1' AND S0PPED<>'99' AND                                  
29B12C* 24912                      (S0COEN=' ' OR S0COEN='2') AND                                   
NAP45* 29B12                      (S0COEN<='0' OR S0COEN='2') AND                                  
NAP45C                             (S0COEN<='0' OR S0COEN='2' OR S0COEN='3') AND                    
24912C                             ((THWEEK>='1' AND S0TPE4<>'2') OR                                
IN944C*                            (THWEEK='2' AND S0TPE4='2'))                                     
