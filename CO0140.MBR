     C                   ENDIF                                                                      
      * Revisión sobre tipo de precios                                                              
     C                   IF        PEBL61>='1'                                                      
C1663C                   CLEAR                   ZXCALC_IN                                          
C1663C                   EVAL      ZXTPRM=' '                                                       
C1663C                   EVAL      @PECALC=ZXCALCULO_IN                                             
C1663C                   EVAL      @PECDEX=*zeros                                                   
     C                   CALL      'CO2600'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM      ZXCUST2       @PECUST                                            
     C                   PARM      ZXARVM2       @PEARVM                                            
     C                   PARM      ZXTCOJ2       @PETCOJ                                            
