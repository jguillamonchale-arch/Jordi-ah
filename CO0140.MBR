     C                   GOTO      W38UPDT                                                          
     C                   ENDIF                                                                      
                                                                                                    
     C     W38UPDT       ENDSR                                                                      
     *----------------------------------------------------------------------------------------    
     *RENED CS_CUMSTK - Cumul des stocks                                                          
     *----------------------------------------------------------------------------------------    
    C     CS_CUMSTK     BEGSR                                                                      
     * Chargement des param}tres d'appel                                                           
    C                   EVAL      PARACT = '*'                                                     
    C                   EVAL      PARCIA = @pCIAS                                                  
    C                   EVAL      PARDLG = @pDLGA                                                  
    C                   EVAL      PARLOG = S0LOGE                                                  
    C                   EVAL      PARART = M5ARTI                                                  
    C                   EVAL      PARVAR = M5VARI                                                  
    C                   EVAL      PARMOD = M5MODE                                                  
    C                   EVAL      PARQST = *ZEROS                                                  
    C                   EVAL      PARQVE = *ZEROS                                                  
    C                   EVAL      PARRAC = *BLANK                                                  
    C                   EVAL      PARQAC = *ZEROS                                                  
    C                   EVAL      PARRIN = *BLANK                                                  
    C                   EVAL      PARQIN = *ZEROS                                                  
    C                   EVAL      PARERR = *BLANK                                                  
02  C                   EVAL      *IN59 = *OFF                                                     
     * Appel du programme de recherche du stock                                                    
02  C                   CALL      'ARTSTK'                             99                          
    C                   PARM                    PARACT                                             
    C                   PARM                    PARCIA                                             
    C                   PARM                    PARDLG                                             
    C                   PARM                    PARLOG                                             
    C                   PARM                    PARART                                             
    C                   PARM                    PARMOD                                             
    C                   PARM                    PARVAR                                             
    C                   PARM                    PARRST                                             
    C                   PARM                    PARQST                                             
    C                   PARM                    PARRVE                                             
    C                   PARM                    PARQVE                                             
    C                   PARM                    PARRAC                                             
    C                   PARM                    PARQAC                                             
    C                   PARM                    PARRIN                                             
    C                   PARM                    PARQIN                                             
    C                   PARM                    PARERR                                             
     * R{cup{ration des param}tres                                                                 
    C                   EVAL      ECSTK = PARQST                                                   
    C                   EVAL      ECRES = PARQVE                                                   
01  C                   IF        PARRST = *ON  OR                                                 
01  C                             PARRST = *OFF                                                    
01  C                   EVAL      *IN59 = PARRST                                                   
01  C                   ENDIF                                                  PARRST = '1' ...    
     *                                                                                            
    C                   ENDSR                                                  CS_CUMSTK           
      ******************************************************************************************    
     C* CALCULO DE BLOQUEAR O PERMITIR RESERVAS AUTOMATICAS                                         
      ******************************************************************************************    
     C     CS_SMIN       BEGSR                                                                      
     C                                                                                              
      *Objetivo : Marcar el campo S5RHLD si la cantidad del pedido es                               
      *           superior al % del stock mínimo definido por la empresa.                           
     C                                                                                              
      * Por defecto permitirá reservas automáticas                                                  
     C                   EVAL      S5RHLD=' '                                                       
     C                                                                                              
      * Recupero % stock mínimo permitido                                                           
     C                   EVAL      ZXPORM=0                                                         
     C                   EVAL      PECIAS=S5CIAS                                                    
     C                   EVAL      PECTAB='INO2'                                                    
     C                   EVAL      PECLTA='CO4055AUTO'                                              
     C     KPMTABD       CHAIN     PMTABD                             81                            
     C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      PXNUM=0                                                          
     C                   EVAL      PXALPH=PEDESC                                                    
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                                              
     C                   PARM                    PXALPH                                             
     C                   PARM                    PXFLDD                                             
     C                   PARM                    PXDCCD                                             
     C                   PARM                    PXFMD1                                             
     C                   PARM                    PXEDTC                                             
     C                   PARM                    PXNMER                                             
     C                   PARM                    PXTIPA                                             
     C                   EVAL      ZXPORM=PXNUM                                                     
      *Recupero Almacen de la logística de salida                                                   
     C                   EVAL      M0CIAS=S5CIAS                                                    
     C                   EVAL      M0LOGE=S5LOGE                                                    
     C     KMSALMA05     CHAIN     MSALMA05                           81                            
     C                   IF        CHAIN=*OFF and M0TAL1='8'                                        
10055C                             AND M0BAJA<'1'                                                   
     C                   EVAL      M1CIAS=S5CIAS                                                    
     C                   EVAL      M1MAGA=M0MAGA                                                    
     C                   EVAL      M1ARTI=S5ARTI                                                    
     C                   EVAL      M1VARI=S5VARI                                                    
     C                   EVAL      M1MODE=S5MODE                                                    
     C                   EVAL      ZXSMIN=0                                                         
     C                   EVAL      ZXPMIN=0                                                         
     C     KMSSTOK       CHAIN     MSSTOK                             81                            
     C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      ZXSMIN=M1SMIN                                                    
     C                   EVAL      ZXPMIN=((ZXSMIN*ZXPORM)/100)                                     
     C                   ENDIF                                                                      
     C                   EVAL      ZXCANP=0                                                         
     C                   IF        S5CANC<>0                                                        
     C                   EVAL      ZXCANP=S5CANC                                                    
     C                   ELSE                                                                       
     C                   EVAL      ZXCANP=S5CANT                                                    
     C                   ENDIF                                                                      
     C*Si la cantidad del Pedido es superior al % permitido del mínimo O                            
     C*No existe mínimo definido                                                                    
     C*No permitiré resevas automáticas                                                             
     C                   IF        ((ZXCANP>=ZXPMIN) AND ZXSMIN<>0) OR                              
     C                             (ZXSMIN=0)                                                       
     C                   EVAL      S5RHLD='1'                                                       
     C                   ENDIF                                                                      
     C*                                                                                             
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                                                                                              
     C                   ENDSR                                                                      
      ******************************************************************************************    
     C* CALCULO DEL PLAZO DE ENTREGA AUTOMATICO                                                     
      ******************************************************************************************    
     C     CS_CALPLE     BEGSR                                                                      
     C                   EVAL      @PETPLA=*BLANKS                                                  
29B12C                   CLEAR                   ZXFDDS                                             
     C                   EVAL      ZXFEPL=*ZEROS                                                    
2505CC                   IF        ZXFREP=*ZEROS                                                    
25051C                   EVAL      ZXFREP=*DATE                                                     
2505CC                   ENDIF                                                                      
20068C                   EVAL      ZXTPLA=*BLANKS                                                   
IN944C*                  IF        S0C420<>'X'                                                      
IN944C                   EVAL      ZXLOGE_ORG=SUCLOGE                                               
IN944C                   EXSR      CS_VALIDA_DLGA                                                   
      * Si no existe parámetro den COPPEC o está desactivado no se ejecutara                        
     C     KCOPPEC       CHAIN     COPPEC                             81                            
     C                   IF        CHAIN=*OFF AND THACTI<'1'                                        
     C                   IF        SUCTCOJ=*BLANKS                                                  
     C                   EVAL      @PEFRRE=ZXFREP                                                   
28B12C*                  IF        @PEFRRE<*DATE                                                    
28B12C*                  EVAL      @PEFRRE=*DATE                                                    
28B12C*                  ENDIF                                                                      
C0031 *                                                                                             
C0031 * Cálculo de Lead-Time Diferente                                                              
C0031 *                                                                                             
25051C                   EVAL      SUFDATP=S0DATP                                                   
25051C                   EVAL      SUFNOPL=S0NOPL                                                   
25051C                   EVAL      SUFNPCO=S0NPCO                                                   
C0031C                   EVAL      @PERRO=*BLANKS                                                   
C0031C                   IF        S0TPE4='2'                                                       
C0031C                   EVAL      @PERRO='2'                                                       
C0031C                   ENDIF                                                                      
C0031 *                                                                                             
C2170 * Mostrar plazos solo si lo piden o si lo piden solo cuando no                                
C2170 * haya stock disponible en el setup                                                           
C2170 *                                                                                             
C2170C*25051             IF        MCMVPE='1'                                                       
C2170C*25051             EVAL      @PERRO=*BLANKS                                                   
C2170C*25051             ELSE                                                                       
C2170C*25051             EVAL      @PERRO='*'                                                       
C2170C*25051             ENDIF                                                                      
      *                                                                                             
C2170C*07113             EVAL      @PERRO='*'                                                       
C2170 *                                                                                             
C2170c                   eval      zxcant_plz=zxcant                                                
C2170c                   exsr      cs_plazos                                                        
C2170 *                                                                                             
     C                   CALL      'CO2610'                                                         
     C                   PARM                    @PCIAS                                             
     C                   PARM      THDLGA        @PEDLGA                                            
     C                   PARM      SUCARTI       @PEARTI                                            
     C                   PARM      SUCVARI       @PEVARI                                            
     C                   PARM      SUCMODE       @PEMODE                                            
     C                   PARM      *BLANKS       @PETCOJ                                            
     C                   PARM                    @PEFRRE                                            
25051C                   PARM      *ZEROS        @PEFDDS                                            
     C                   PARM      ZXCANT        @PECANT                                            
     C                   PARM      SUCUNIM       @PEUNIM                                            
     C                   PARM      SUCLOGE       @PELOGE                                            
     C                   PARM      *BLANKS       @PETPLA                                            
C0031C                   PARM                    @PERRO                                             
IN944C*                  PARM      SUFNPCO       @FDNPCO                                            
IN944C*                  PARM      SUFTPED       @FDTPED                                            
IN944C*                  PARM      SUFDATP       @FDDATP                                            
IN944C*                  PARM      SUFNOPL       @FDNOPL                                            
IN944C                   PARM      *BLANKS       @FDNPCO                                            
IN944C                   PARM      *BLANKS       @FDTPED                                            
IN944C                   PARM      *ZEROS        @FDDATP                                            
IN944C                   PARM      *ZEROS        @FDNOPL                                            
03090C* 13B12            PARM      SUFLINE       @FDLINE                                            
13B12C* 19C12            PARM      *ZEROS        @FDLINE                                            
IN944C*                  PARM      S5LINE        @FDLINE                                            
IN944C                   PARM      *ZEROS        @FDLINE                                            
C0031C***                PARM      *BLANKS       @PERRO                                             
25051C                   EVAL      ZXFDDS=@PEFDDS                                                   
  CSMC                   IF        THTACT<='0'                                                      
     C                   EVAL      ZXFEPL=@PEFRRE                                                   
  CSMC                   ENDIF                                                                      
20068C                   EVAL      ZXTPLA=@PETPLA                                                   
     C                   ELSE                                                                       
     C                   EXSR      CS_PLZCON                                                        
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        ZXWPLZ>='1'                                                      
     C                   EVAL      @PVAN=*ZEROS                                                     
     C                   EVAL      @PVAA=*BLANKS                                                    
     C                   CALL      'MM2510'                                                         
     C                   PARM      ZXFEPL        @PVAN                                              
     C                   PARM                    @PVAA                                              
     C                   PARM      'YYMD'        @PFMI                                              
     C                   PARM      ZZFMFF        @PFMF                                              
     C                   PARM      ZZFMFS        @PSEP                                              
     C                   PARM      ' '           @PEERR                                             
     C                   EVAL      W08FPRE=@PVAA                                                    
     C                   EXFMT     W08                                                              
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
IN944C*                  ELSE                                                                       
IN944 *                  EVAL      ZXFEPL=S0FLAN                                                    
IN944 *                  IF        S0FLAN<>*ZEROS                                                   
IN944 *    KCOPPEC       CHAIN     COPPEC                                                           
IN944 *                  EVAL      CL_S0CUST=S0CUST                                                 
IN944 *    KCOCLIN       CHAIN(N)  COCLIN                             81                            
IN944 *                  IF        CL_S0DD06<>*BLANKS                                               
IN944 *                  IF        %FLOAT(CL_S0DD06)>*ZEROS                                         
IN944 *                  EVAL      THDD06=%FLOAT(CL_S0DD06)                                         
IN944 *                  ENDIF                                                                      
IN944 *                  ENDIF                                                                      
IN944 *                                                                                             
IN944 *                  EVAL      @PEDAT1=S0FLAN                                                   
IN944 *                  EVAL      @PEDAT2=*ZEROS                                                   
IN944 *                  EVAL      @PEDAYS=THDD06                                                   
IN944 *                  CALL      'CO2612'                                                         
IN944 *                  PARM                    @PEDAT1                                            
IN944 *                  PARM                    @PEDAYS                                            
IN944 *                  PARM      *ZEROS        @PEDAT2                                            
IN944 *                  PARM      *BLANKS       @PEERR                                             
IN944 *                  EVAL      ZXFDDS=@PEDAT2                                                   
IN944 *                  ENDIF                                                                      
IN944 *                                                                                             
IN944 *                  ENDIF                                                                      
     C                   ENDSR                                                                      
      ******************************************************************************************    
     C* CALCULO DEL PLAZO DE ENTREGA AUTOMATICO                                                     
      ******************************************************************************************    
     C     CS_PLZCON     BEGSR                                                                      
     C                   EVAL      NDARTI=SUCARTI                                                   
     C                   EVAL      NDVARI=SUCVARI                                                   
     C                   EVAL      NDMODE=SUCMODE                                                   
     C                   EVAL      NDTCOJ=SUCTCOJ                                                   
29B12C                   CLEAR                   ZXFDDS                                             
     C     KMSCOJC       SETLL     MSCOJD                                                           
     C     KMSCOJD       READE     MSCOJD                                 83                        
     C                   DOW       READ1=*OFF                                                       
C1728C*                  IF        NDBAJA<='1'                                                      
C1728C                   IF        NDBAJA<'1'                                                       
     C                   EVAL      @PEFRRE=ZXFREP                                                   
28B12C*                  IF        @PEFRRE<*DATE                                                    
28B12C*                  EVAL      @PEFRRE=*DATE                                                    
28B12C*                  ENDIF                                                                      
     C                   EVAL      @PECANT=ZXCANT*NDCANT                                            
C0031 *                                                                                             
C0031 * Cálculo de Lead-Time Diferente                                                              
C0031 *                                                                                             
25051C                   EVAL      SUFDATP=S0DATP                                                   
25051C                   EVAL      SUFNOPL=S0NOPL                                                   
25051C                   EVAL      SUFNPCO=S0NPCO                                                   
C0031C                   EVAL      @PERRO=*BLANKS                                                   
C0031C                   IF        S0TPE4='2'                                                       
C0031C                   EVAL      @PERRO='2'                                                       
C0031C                   ENDIF                                                                      
C0031 *                                                                                             
C2170 * Mostrar plazos solo si lo piden o si lo piden solo cuando no                                
C2170 * haya stock disponible en el setup                                                           
C2170 *                                                                                             
C2170C*25051             IF        MCMVPE='1'                                                       
C2170C*25051             EVAL      @PERRO=*BLANKS                                                   
C2170C*25051             ELSE                                                                       
C2170C*25051             EVAL      @PERRO='*'                                                       
C2170C*25051             ENDIF                                                                      
C2170C*07113             EVAL      @PERRO='*'                                                       
C2170 *                                                                                             
C2170c                   eval      zxcant_plz=zxcant*ndcant                                         
C2170c                   exsr      cs_plazos                                                        
C2170 *                                                                                             
     C                   CALL      'CO2610'                                                         
     C                   PARM                    @PCIAS                                             
     C                   PARM      THDLGA        @PEDLGA                                            
     C                   PARM      NDCOMP        @PEARTI                                            
     C                   PARM      NDVAR2        @PEVARI                                            
     C                   PARM      NDMOD2        @PEMODE                                            
     C                   PARM      *BLANKS       @PETCOJ                                            
     C                   PARM                    @PEFRRE                                            
25051C                   PARM      *ZEROS        @PEFDDS                                            
     C                   PARM                    @PECANT                                            
     C                   PARM      NDUNIM        @PEUNIM                                            
     C                   PARM      SUCLOGE       @PELOGE                                            
     C                   PARM      *BLANKS       @PETPLA                                            
C0031C                   PARM                    @PERRO                                             
IN944C*                  PARM      SUFNPCO       @FDNPCO                                            
IN944C*                  PARM      SUFTPED       @FDTPED                                            
IN944C*                  PARM      SUFDATP       @FDDATP                                            
IN944C*                  PARM      SUFNOPL       @FDNOPL                                            
IN944C                   PARM      *BLANKS       @FDNPCO                                            
IN944C                   PARM      *BLANKS       @FDTPED                                            
IN944C                   PARM      *ZEROS        @FDDATP                                            
IN944C                   PARM      *ZEROS        @FDNOPL                                            
03090C* 13B12            PARM      SUFLINE       @FDLINE                                            
13B12C                   PARM      *ZEROS        @FDLINE                                            
C0031C***                PARM      *BLANKS       @PERRO                                             
29B12C* 25051            EVAL      ZXFDDS=@PEFDDS                                                   
     C                   IF        @PEFRRE>ZXFEPL                                                   
28B12C                   EVAL      ZXTPLA=@PETPLA                                                   
28B12C                   EVAL      ZXFEPL=@PEFRRE                                                   
28B12C                   EVAL      ZXFDDS=@PEFDDS                                                   
  CSMC                   IF        THTACT<='0'                                                      
     C                   EVAL      ZXFEPL=@PEFRRE                                                   
  CSMC                   ENDIF                                                                      
     C                   ENDIF                                                                      
28B12C*                  IF        @PETPLA>ZXTPLA                                                   
28B12C*                  EVAL      ZXTPLA=@PETPLA                                                   
28B12C*                  ENDIF                                                                      
     C                   ENDIF                                                                      
