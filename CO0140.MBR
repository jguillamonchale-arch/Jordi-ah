28B12C* 31712            ENDIF                                                                      
31712C                   EVAL      @PECANT=S5CANT*NDCANT                                            
C2170 *                                                                                             
C2170 * Mostrar plazos solo si lo piden o si lo piden solo cuando no                                
C2170 * haya stock disponible en el setup                                                           
C2170 *                                                                                             
C2170c                   eval      zxcant_plz=s5cant*ndcant                                         
C2170c                   exsr      cs_plazos                                                        
C2170 *                                                                                             
31712C                   CALL      'CO2610'                                                         
31712C                   PARM                    @PCIAS                                             
31712C                   PARM      S5DLGA        @PEDLGA                                            
31712C                   PARM      NDCOMP        @PEARTI                                            
31712C                   PARM      NDVAR2        @PEVARI                                            
31712C                   PARM      NDMOD2        @PEMODE                                            
31712C                   PARM      *BLANKS       @PETCOJ                                            
