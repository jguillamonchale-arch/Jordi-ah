     C                   EVAL      S21TCOJ=S5TCOJ                                                   
     C                   MOVE      S5LINE        S21LINE                                            
     C                   EVAL      S21UNIM=S5UNIM                                                   
     C                   EVAL      S21GUIO='/'                                                      
     C                   EVAL      S21UNDP=S5UNDP                                                   
     C                   EVAL      S21TPTA=S5TPTA                                                   
     C                   EVAL      S21STUL=S5STUL                                                   
                                                                                                    
     C                   EVAL      PXDCCD=2                                                         
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5CANT                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S21CANT                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5PREC*ZXCOCAMB                                            
     C                   IF        MCTPRU>='1' AND S5CADP>=1                                        
     C                   EVAL      PXNUM=PXNUM/S5CADP                                               
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      XZAUXI=PXNUM                                                     
     C                   EVAL      XZDECI=ZXDEC0                                                    
     C                   EVAL      XZAJUD=ZXAJU0                                                    
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
     C                   EVAL      PXNUM=XZAUXI                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      ZXDEC0        PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S21PREC                                            
                                                                                                    
     C                   EVAL      PXDCCD=1                                                         
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   IF        MCTPRU>='1' AND S5CADP>=1                                        
     C                   EVAL      PXNUM=1                                                          
     C                   ELSE                                                                       
     C                   EVAL      PXNUM=S5CADP                                                     
     C                   ENDIF                                                                      
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S21CADP                                            
     C                   EVAL      PXDCCD=2                                                         
                                                                                                    
      * Campos para vista 2                                                                         
     C                   WHEN      ZXNUMVI=2                                                        
     C                   MOVE      S5LINE        S22LINE                                            
     C                   EVAL      S22ARTI=S5ARTI                                                   
     C                   EVAL      S22VARI=S5VARI                                                   
     C                   EVAL      S22MODE=S5MODE                                                   
     C                   EVAL      S22TCOJ=S5TCOJ                                                   
      * Búsqueda del precio total                                                                   
     C                   EVAL      ZXMONV=S22MONV                                                   
     C                   EXSR      CS_SECCAL2                                                       
                                                                                                    
     C                   EVAL      PXDCCD=XZDECI                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXBIMP                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S22BIMP                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXIIV1+ZXIIV2                                              
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S22IIVA                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXBIMP+ZXIIV1+ZXIIV2                                       
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S22TOTI                                            
      * Campos para vista 3                                                                         
     C                   WHEN      ZXNUMVI=3                                                        
     C                   MOVE      S5LINE        S23LINE                                            
     C                   EVAL      S23ARTI=S5ARTI                                                   
     C                   EVAL      S23VARI=S5VARI                                                   
     C                   EVAL      S23MODE=S5MODE                                                   
     C                   EVAL      S23TCOJ=S5TCOJ                                                   
      * Búsqueda de los valores de visualización                                                    
     C                   EXSR      CS_SECCAL2                                                       
     C                   EVAL      PXDCCD=XZDECI                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXBIMP                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S23BIMP                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EXSR      CS_RCOSTE                                                        
     C                   EVAL      PXNUM=ZXCOST                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S23COST                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=((ZXCOST)-ZXBIMP)*-1                                       
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      1             PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM      'M'           PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S23BETE                                            
                                                                                                    
     C                   EXSR      CS_RENDIM                                                        
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      0             PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM      'M'           PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S23REND                                            
     C                   MOVE      *BLANKS       PXEDTC                         CODI EDICIO(4,M,    
     C                   IF        (PXNUM=0 AND ZXCOST<>0) OR (PXNUM>999,9)                         
     C                   MOVE      *ALL'*'       S23REND                                            
     C                   ENDIF                                                                      
                                                                                                    
23014 * Campos para vista 4                                                                         
