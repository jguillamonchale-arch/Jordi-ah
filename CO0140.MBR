      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA VALIDACIÓ DEL SFL: FORMAT SFL I OPCIONS          *                                
      *------------------------------------------------------------*                                
     C     CS_SFLCHK     BEGSR                                                                      
     C                   EVAL      ACCREF=*ON                                                       
      * Validación del posicionamiento de cabecera                                                  
      * ZXCTSF Controla que si estan situando o cambiando el Subfile                                
      * no tenga en cuenta las altas rapidas.                                                       
     C                   EVAL      ZXCTSF=*BLANKS                                                   
                                                                                                    
     C                   SELECT                                                                     
      * Validación del posicionamiento de cabecera                                                  
     C                   WHEN      PSUARTI <> *BLANKS OR PSUVARI<>*BLANKS                           
     C                             OR PSUDEAP <> *BLANKS                                            
     C                             OR PSUARVP <> *BLANKS                                            
     C                             OR PSUDES1 <> *BLANKS                                            
     C                             OR PSUCLAB <> *BLANKS                                            
     C                             OR PSUARAL <> *BLANKS                                            
     C                             OR PSUFREP <> *BLANKS                                            
     C                             OR PSULINE <> *ZEROS                                             
     C                   EVAL      ERRGRL=*OFF                                                      
     C                   EVAL      CSRCOLU=0                                                        
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      ZXCTSF='1'                                                       
1606 C                   EVAL      ERRGRL=*OFF                                                      
1606 C                   EVAL      CSRCOLU=0                                                        
1606 C                   EVAL      CSRFILA=0                                                        
     C                   IF        PSUFREP<>*BLANKS                                                 
     C                   EVAL                    @PVAN=*ZEROS                                       
     C                   CALL      'MM2510'                                                         
     C                   PARM                    @PVAN                                              
     C                   PARM      PSUFREP       @PVAA                                              
     C                   PARM      ZZFMFF        @PFMI                                              
     C                   PARM      ZZFMFF        @PFMF                                              
     C                   PARM      ZZFMFS        @PSEP                                              
     C                   PARM      ' '           @PEERR                                             
     C                   IF        @PEERR<>*BLANKS                                                  
     C                   EVAL      ZXFMT=CCCFMT                                                     
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK45=*ON                                                        
     C                   EVAL      MSGER='MSG0065'                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           SFLCHKT                                            
     C                   EVAL      ZXFREP=@PVAN                                                     
     C                   EVAL      ZXCOUNT=1                                                        
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      S5FREP=ZXFREP                                                    
     C                   EVAL      S5LINE=PSULINE                                                   
     C                   EVAL      S5ARTI=PSUARTI                                                   
     C                   EVAL      S5VARI=PSUVARI                                                   
     C                   EVAL      S5DES1=PSUDES1                                                   
     C                   EVAL      S5CLAB=PSUCLAB                                                   
     C                   EVAL      S5ARAL=PSUARAL                                                   
     C                   EVAL      S5DEAP=PSUDEAP                                                   
     C                   EVAL      S5ARVP=PSUARVP                                                   
     C                   EVAL      ZXOPT2='CLR'                                                     
                                                                                                    
      * Validacion clase de subarchivo (FORMAT DE LA PANTALLA)                                      
     C                   WHEN      ZXFMT<>CCCFMT                                                    
     C                   EVAL      ZXCTSF='1'                                                       
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEOPT=*BLANKS                                                   
     C                   EVAL      @PEFMT=*BLANKS                                                   
     C                   EVAL      @PEFLD='CFMT'                                                    
     C                   EVAL      @PEOPT=CCCFMT                                                    
