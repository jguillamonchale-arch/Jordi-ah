     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TSUCcHK                                            
                                                                                                    
     C                   IF        ZXCAST<>0                                                        
     C                   EVAL      SUCUNIM=MOUNST                                                   
     C                   EVAL      P6DECI=0                                                         
     C                   EVAL      P6AJUD=0                                                         
     C                   EVAL      P6ARTI=SUCARTI                                                   
     C                   EVAL      P6VARI=SUCVARI                                                   
     C                   EVAL      P6MODE=SUCMODE                                                   
     C                   EVAL      P6UNIM=SUCUNIM                                                   
     C     KPMUNAL       CHAIN     PMUNAL                             81                            
     C                   IF        *IN81=*ON                                                        
     C                   EVAL      P6VARI=*BLANKS                                                   
     C                   EVAL      P6MODE=*BLANKS                                                   
     C     KPMUNAL       CHAIN     PMUNAL                             81                            
     C                   ENDIF                                                                      
     C                   IF        CHAIN=*ON OR MOUNST=*BLANKS                                      
