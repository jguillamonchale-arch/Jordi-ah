C0031 *                                                                                             
C0031C                   IF        W09SINO='1'                                                      
C0031 *                                                                                             
C0031C* FQ937            EVAL      W09NCOE=S5NCOE                                                   
FQ937C                   MOVE      S5NCOE        W09NCOE                                            
C0031 *                                                                                             
C0031 * Fecha Original                                                                              
C0031 *                                                                                             
C0031C                   EVAL      ZXFORR=S5FOEP                                                    
C0031C                   IF        S5FORE<>0                                                        
C0031C                   EVAL      ZXFORR=S5FORE                                                    
C0031C                   ENDIF                                                                      
C0031 *                                                                                             
C0031C                   EVAL      @PVAN=*ZEROS                                                     
C0031C                   EVAL      @PVAA=*BLANKS                                                    
C0031C                   CALL      'MM2510'                                                         
C0031C                   PARM      ZXFORR        @PVAN                                              
C0031C                   PARM                    @PVAA                                              
C0031C                   PARM      'YYMD'        @PFMI                                              
C0031C                   PARM      ZZFMFF        @PFMF                                              
C0031C                   PARM      ZZFMFS        @PSEP                                              
C0031C                   PARM      ' '           @PEERR                                             
C0031C                   EVAL      W09FMLI=@PVAA                                                    
C0031 *                                                                                             
C0031C                   EVAL      @PVAN=*ZEROS                                                     
C0031C                   EVAL      @PVAA=*BLANKS                                                    
C0031C                   CALL      'MM2510'                                                         
C0031C* FQ944            PARM      ZGFRCO        @PVAN                                              
FQ944C                   PARM      ZGFMAX        @PVAN                                              
C0031C                   PARM                    @PVAA                                              
C0031C                   PARM      'YYMD'        @PFMI                                              
C0031C                   PARM      ZZFMFF        @PFMF                                              
C0031C                   PARM      ZZFMFS        @PSEP                                              
C0031C                   PARM      ' '           @PEERR                                             
C0031C                   EVAL      W09FRRR=@PVAA                                                    
C0031 *                                                                                             
17092C                   IF        ZGFMAX<>ZXFORR                                                   
C0031C                   EXFMT     W09                                                              
