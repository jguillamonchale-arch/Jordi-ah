C0031 *                                                                                             
C0031 * Validamos Coenvío                                                                           
C0031 *                                                                                             
C0031C                   IF        S0COEN='1' AND SUCNCOE<>1                                        
C0031C***                          OR S0COEN='2' AND SUCNCOE=0                                      
29B12C* C0031                      OR S0COEN=' ' AND SUCNCOE<>0                                     
29B12C                             OR S0COEN<='0' AND SUCNCOE<>0                                    
C0031C                   EVAL      ERRGRL=*ON                                                       
C0031C                   EVAL      MSGER='ASG1003'                                                  
C0031C                   EVAL      WRK57=*ON                                                        
C0031C                   ENDIF                                                                      
C0031C     ERRGRL        CABEQ     *ON           TSUCCHK                                            
C0031 *                                                                                             
C0031 * Validamos Coenvío <-> Conjuntos                                                             
C0031 * Un conjunto en un pedido a 3os (TPE4='2') siempre debe tener                                
C0031 * Coenvío (S0COEN>='1')                                                                       
C0031 * Un conjunto siempre debe tener Nº de Coenvío                                                
C0031 * Tampoco se permiten artículos si el proveedor no tiene permitido                            
C0031 * en ficha el envío directo                                                                   
C0031 *                                                                                             
C0031C                   IF        S0TPE4='2 '                                                      
FQ284C                   IF        ZEEDV2<>'1'                                                      
C0031C                   IF        S0COEN<'1' AND SUCTCOJ<>' '                                      
C0031C                   EVAL      ERRGRL=*ON                                                       
C0031C                   EVAL      MSGER='ERR3014'                                                  
C0031C                   EVAL      WRK34=*ON                                                        
C0031C                   EVAL      WRK35=*ON                                                        
C0031C                   EVAL      WRK39=*ON                                                        
C0031C                   EVAL      WRK43=*ON                                                        
C0031C                   ENDIF                                                                      
C0031C     ERRGRL        CABEQ     *ON           TSUCCHK                                            
C0031C                   IF        SUCTCOJ<>' ' AND SUCNCOE<1                                       
C0031C                   EVAL      ERRGRL=*ON                                                       
C0031C                   EVAL      MSGER='ERR3014'                                                  
C0031C                   EVAL      WRK34=*ON                                                        
C0031C                   EVAL      WRK35=*ON                                                        
C0031C                   EVAL      WRK39=*ON                                                        
C0031C                   EVAL      WRK43=*ON                                                        
C0031C                   ENDIF                                                                      
C0031C     ERRGRL        CABEQ     *ON           TSUCCHK                                            
FQ284C                   ENDIF                                                                      
C0031C                   EVAL      C0CIAS=@PCIAS                                                    
C0031C                   EVAL      C0PRVR=M5PRVR                                                    
C0031C                   EVAL      C0AMP2=*BLANKS                                                   
C0031C     KPUPROV       CHAIN     PUPROV                             81                            
C0031C                   IF        C0PEVT<'1'                                                       
FQ666C                             AND M5NOED<>'2'                                                  
C0031C                   EVAL      ERRGRL=*ON                                                       
C0031C                   EVAL      MSGER='ERR3016'                                                  
C0031C                   EVAL      WRK34=*ON                                                        
C0031C                   EVAL      WRK35=*ON                                                        
C0031C                   EVAL      WRK39=*ON                                                        
C0031C                   EVAL      WRK43=*ON                                                        
C0031C                   ENDIF                                                                      
