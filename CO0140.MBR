     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   MOVE      SUCCAST       PXALPH                                             
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      0             PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   IF        PXNMER<>0                                                        
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK53=*ON                                                        
     C                   EVAL      MSGER='MSG0022'                                                  
     C                   IF        PXNMER=1                                                         
     C                   EVAL      MSGER='MSG0023'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=2                                                         
     C                   EVAL      MSGER='MSG0024'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=3                                                         
     C                   EVAL      MSGER='MSG0025'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=4                                                         
     C                   EVAL      MSGER='MSG0026'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=5                                                         
     C                   EVAL      MSGER='MSG0032'                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TSUCCHK                                            
