23014C                   EVAL      PXDCCD=2                                                         
23014C                   EVAL      PXALPH=*BLANKS                                                   
23014C                   EVAL      PXNUM=ZXCAPT                                                     
23014C                   CALL      'PRD650'                                                         
23014C                   PARM                    PXNUM                                              
23014C                   PARM                    PXALPH                                             
23014C                   PARM                    PXFLDD                                             
23014C                   PARM                    PXDCCD                                             
23014C                   PARM                    PXFMD1                                             
23014C                   PARM                    PXEDTC                                             
23014C                   PARM                    PXNMER                                             
23014C                   PARM                    PXTIPA                                             
23014C                   MOVE      PXALPH        S44CAPT                                            
