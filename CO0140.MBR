07036 **************************************************************                                
07036 * SUBRUTINA PASAR LITERALES SEGUN IDIOMA.                    *                                
07036 *------------------------------------------------------------*                                
07036C     CS_LITIMP     BEGSR                                                                      
07036                                                                                               
07036C                   EVAL      NKIDIO = ZZIDIO                                                  
07036C                   EVAL      NKPRTF = 'CO0140FM'                                              
07036C     KMSFIID       SETLL     MSFIID                                                           
07036C     KMSFIID       READE     MSFIID                                                           
07036                                                                                               
07036C                   DOW       NOT %EOF                                                         
07036                                                                                               
07036C                   SELECT                                                                     
07036C                   WHEN      NKFIEL  = 'W36ATEN'                                              
07036C                   EVAL      W36ATEN = NKLI80                                                 
07036c                   WHEN      NKFIEL  = 'W36PREC'                                              
07036C                   EVAL      W36PREC = NKLI80                                                 
07036c                   WHEN      NKFIEL  = 'W36TPOR'                                              
07036C                   EVAL      ZXTPOR  = NKLI80                                                 
07036C                   ENDSL                                                                      
07036                                                                                               
07036C     KMSFIID       READE     MSFIID                                                           
07036C                   ENDDO                                                                      
07036C                   ENDSR                                                                      
                                                                                                    
10055C**************************************************************************                    
10055C* CS_CAMBIOUM: CAMBIO UM PEDIDO A UM ARTICULO                                                 
10055C**************************************************************************                    
10055C     CS_CAMBIOUM   BEGSR                                                                      
10055C                   EVAL      ZXZXCANT = ZXCANT                                                
10055C                   IF        SUCUNIM <> M5UNIM                                                
10055C                   EVAL      XZCIAS=ZZCIAS                                                    
10055C                   EVAL      XZARTI=M5ARTI                                                    
10055C                   EVAL      XZVARI=M5VARI                                                    
10055C                   EVAL      XZMODE=M5MODE                                                    
10055C                   EVAL      ZXCA10=ZXZXCANT                                                  
10055C                   EVAL      ZXCA11=ZXZXCANT                                                  
10055C                   EVAL      ZXUN10=SUCUNIM                                                   
10055C                   EVAL      ZXUN11=M5UNIM                                                    
10055C* CAMBIO de unidades                                                                          
10055C/COPY *LIBL/QSRDSRC,SRD021                                                                    
10055C     ZXZXCANT      MULT      XZCOFU        XZAUXI                                             
10055C                   EVAL      XZDECI=XZDE01                                                    
10055C                   EVAL      XZAJUD=XZAJ01                                                    
10055C* AJUSTE Y DECIMALES                                                                          
10055C/COPY *LIBL/QSRDSRC,SRD001                                                                    
10055C                   EVAL      ZXZXCANT=XZAUXI                                                  
10055C                   ENDIF                                                                      
10055C                   ENDSR                                                                      
10055C**************************************************************************                    
10055C* CS_CAMBIOUM2: CAMBIO UM PEDIDO A UM ARTICULO                                                
10055C**************************************************************************                    
10055C     CS_CAMBIOUM2  BEGSR                                                                      
BOTCHC***                EVAL      XZauxi = x_s5cant-x_s5cans                                       
BOTCHC                   EVAL      XZauxi = x_s5cant-(x_s5cans+x_s5canr)                            
10055C                   IF        x_s5uNIM <> M5UNIM                                               
10055C                   EVAL      XZCIAS=ZZCIAS                                                    
10055C                   EVAL      XZARTI=M5ARTI                                                    
10055C                   EVAL      XZVARI=M5VARI                                                    
10055C                   EVAL      XZMODE=M5MODE                                                    
10055C                   EVAL      ZXCA10=XZauxi                                                    
10055C                   EVAL      ZXCA11=XZauxi                                                    
10055C                   EVAL      ZXUN10=x_s5uNIM                                                  
10055C                   EVAL      ZXUN11=M5UNIM                                                    
10055C* CAMBIO de unidades                                                                          
10055C/COPY *LIBL/QSRDSRC,SRD021                                                                    
10055C                   MULT      XZCOFU        XZAUXI                                             
10055C                   EVAL      XZDECI=XZDE01                                                    
10055C                   EVAL      XZAJUD=XZAJ01                                                    
10055C* AJUSTE Y DECIMALES                                                                          
10055C/COPY *LIBL/QSRDSRC,SRD001                                                                    
10055C                   ENDIF                                                                      
10055C                   ENDSR                                                                      
10055C**************************************************************************                    
10055C* CS_STOCKALMA: BUSCA STOCK EN ALMACEN                                                        
10055C**************************************************************************                    
10055C     CS_STOCKALMA  BEGSR                                                                      
10055C                   EVAL      ZXZXSTOCK = 0                                                    
10055C                   EVAL      M0CIAS=ZZCIAS                                                    
10055C                   EVAL      M0LOGE=SUCLOGE                                                   
10055C     KMSALMA05     CHAIN     MSALMA05                                                         
10055C                   EVAL      M1CIAS=ZZCIAS                                                    
10055C                   EVAL      M1ARTI=SUCARTI                                                   
10055C                   EVAL      M1VARI=SUCVARI                                                   
10055C                   EVAL      M1MODE=SUCMODE                                                   
10055C                   EVAL      M1MAGA=M0MAGA                                                    
10055C                   EVAL      M1CALI='A'                                                       
10055C     KMSSTO0       CHAIN     MSSTO01                                                          
10055C                   IF        %FOUND                                                           
