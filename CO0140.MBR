31712C                   PARM      S5TPED        @FDTPED                                            
31712C                   PARM      S5DATP        @FDDATP                                            
31712C                   PARM      S5NOPL        @FDNOPL                                            
31712C                   PARM      S5LINE        @FDLINE                                            
31712C                   IF        @PEFRRE>ZXFEPL                                                   
31712C                   EVAL      ZXFEPL=@PEFRRE                                                   
13B12C                   EVAL      ZXTPLZ=@PETPLA                                                   
29B12C                   EVAL      ZXFSTX=@PEFDDS                                                   
31712C                   ENDIF                                                                      
31712C                   ENDIF                                                                      
31712C     KMSCOJC       READE     MSCOJD                                                           
