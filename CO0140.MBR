     C                   ENDIF                                                                      
     C                   SELECT                                                                     
     C                   WHEN      ZXNUMVI=1                                                        
     C                   EVAL      SUFDATA=W3DATAV1                                                 
     C                   WHEN      ZXNUMVI=2                                                        
     C                   EVAL      SUFDATA=W3DATAV2                                                 
     C                   WHEN      ZXNUMVI=3                                                        
     C                   EVAL      SUFDATA=W3DATAV3                                                 
