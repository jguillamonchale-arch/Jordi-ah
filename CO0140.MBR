     C                   IF        SUCTCOJ<'4' OR SUCTCOJ>'5' AND SUCTCOJ<>'9'                      
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK34=*ON                                                        
     C                   EVAL      WRK35=*ON                                                        
     C                   EVAL      WRK39=*ON                                                        
     C                   EVAL      MSGER='MMM0138'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TSUCCHK                                            
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TSUCCHK                                            
P4254 *                                                                                             
P4254 * Validación de artículo en surtido                                                           
P4254C                   IF        *IN64 OR *IN65 OR *IN66                      i01                 
P4254C                   IF        M5CTSU='1'                                   i02                 
P4254C                   EVAL      X5ARTIZX=SUCARTI                                                 
P4254C                   EVAL      X5VARIZX=SUCVARI                                                 
P4254C                   EVAL      X5MODEZX=SUCMODE                                                 
P4254C     KCOPROA       SETLL     COPROA01                                                         
P4254C     KCOPROA       READE     COPROA01                                                         
P4254 *                                                                                             
P4254C                   DOW       NOT %EOF(COPROA01)                           d03                 
P4254C                   IF        X5BAJA<'1'                                   i04                 
P4254C                   EVAL      X0PROM=X5PROM                                                    
P4254C     KCOPROC       CHAIN     COPROC                                                           
P4254C                   IF        %FOUND(COPROC)                               i05                 
P4254C                             AND X0BAJA<'1'                                                   
P4254C                             AND X0FDES<=*DATE AND X0FHAS>=*DATE                              
P4254C                   EVAL      ZXSURT=*ON                                                       
P4254C                   EVAL      X5CIAS=S5CIAS                                                    
P4254C                   EVAL      X5CUST=S0CUST                                                    
P4254C                   EVAL      X5PROM=X5PROM                                                    
P4254C     KCOPROD       CHAIN     COPROD01                                                         
P4254C                   IF        NOT%FOUND(COPROD01)                          i06                 
P4254C                             OR (%FOUND(COPROD01) AND X5BAJA='1')                             
P4254 * Validación de artículo en surtido en cadena 1er nivel                                       
P4254C                   IF        CL_S0GRP2<>*BLANKS AND CL_S0TGR2>'0'         i07                 
P4254C                   EVAL      PECTAB='GCOM      '                                              
P4254C                   EVAL      PECLTA=CL_S0GRP2                                                 
P4254C                   CLEAR                   PEDESC                                             
P4254C     KPMTABD       CHAIN     PMTABD                                                           
P4254C                   MOVEL     PEDESC        X5CUST                                             
P4254C     KCOPROD       CHAIN     COPROD01                                                         
P4254C                   IF        NOT%FOUND(COPROD01)                          i08                 
P4254C                             OR (%FOUND(COPROD01) AND X5BAJA='1')                             
P4254C                   EVAL      ZXSURT=*OFF                                                      
P4254C                   ELSE                                                   .08                 
P4254C                   LEAVE                                                                      
P4254C                   ENDIF                                                  e08                 
P4254C                   ELSE                                                   .07                 
P4254C                   EVAL      ZXSURT=*OFF                                                      
P4254C                   ENDIF                                                  e07                 
P4254C                   ELSE                                                   .06                 
P4254C                   LEAVE                                                                      
P4254C                   ENDIF                                                  e06                 
P4254C                   ENDIF                                                  e05                 
P4254C                   ENDIF                                                  e04                 
P4254 *                                                                                             
P4254C     KCOPROA       READE     COPROA01                                                         
P4254C                   ENDDO                                                  e03                 
P4254 *                                                                                             
P4254C                   IF        ZXSURT=*OFF                                  i03                 
P4254C                   EXFMT     W14                                                              
P4254C                   ENDIF                                                  e03                 
P4254 *                                                                                             
P4254C                   ENDIF                                                  e02                 
P4254C                   ENDIF                                                  e01                 
P4254 *                                                                                             
      * Validación de logísticas                                                                    
     C                   eval      midlga=@pDLGA                                                    
      * Logística de entradas por defecto                                                           
     C                   EVAL      S5LOGE=S0LOGE                                                    
