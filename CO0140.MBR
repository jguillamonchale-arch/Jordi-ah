FQ944C                   IF        S5DISP<>*BLANKS                                                  
FQ944C                   EVAL      @PVAN=%FLOAT(S5DISP)                                             
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM                    @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S25DISP=@PVAA                                                    
FQ944C                   ENDIF                                                                      
FQ944C                   MOVE      S5NCOE        S25COEN                                            
FQ944 * FECHA confirmada                                                                            
FQ944C                   EVAL      @PVAN=*ZEROS                                                     
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM      S5FRRE        @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S25FRRE=@PVAA                                                    
FQ944 *                                                                                             
     C                   ENDSL                                                                      
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5DTO1                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S022DTO1                                           
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5DTO2                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S022DTO2                                           
                                                                                                    
     C                   IF        S5FRRE<>0                                                        
     C                   EVAL      @PVAA=*BLANKS                                                    
     C                   CALL      'MM2510'                                                         
     C                   PARM      S5FRRE        @PVAN                                              
     C                   PARM                    @PVAA                                              
     C                   PARM      'YYMD'        @PFMI                                              
     C                   PARM      ZZFMFF        @PFMF                                              
     C                   PARM      ZZFMFS        @PSEP                                              
     C                   PARM      ' '           @PEERR                                             
     C                   EVAL      S022FRRE=@PVAA                                                   
     C                   ELSE                                                                       
     C                   EVAL      S022FRRE=*BLANKS                                                 
