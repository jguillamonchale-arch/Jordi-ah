     C                   ENDIF                                                                      
      * Control de calidad por defecto                                                              
     C                   IF        SUCCCCA=*BLANKS                                                  
     C                   EVAL      SUCCCCA=S5CCCA                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      *                                                                                             
      **************************************************************                                
      * SUBRUTINA QUE SELECCIONA REGISTROS DE SUBARCHIVO           *                                
      *------------------------------------------------------------*                                
     C     CS_SELSFL     BEGSR                                                                      
                                                                                                    
     C                   EVAL      ZXSELSFL=0                                                       
                                                                                                    
     C                   IF        (S5FREP<ZXFRE1 OR S5FREP>ZXFRE2)                                 
     C                             AND (S5FREP<>0)                                                  
     C                   EVAL      ZXSELSFL=1                                                       
     C                   GOTO      SELSFLRT                                                         
     C                   ENDIF                                                                      
                                                                                                    
     C     SELSFLRT      ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE GUARDA LAS CLAVES DE TODOS TIPOS DE SFL      *                                
      *------------------------------------------------------------*                                
     C     CS_KEYPF      BEGSR                                                                      
     C                   EVAL      SUFCIAS=S5CIAS                                                   
     C                   EVAL      SUFDLGA=S5DLGA                                                   
     C                   EVAL      SUFNPCO=S5NPCO                                                   
     C                   EVAL      SUFTPED=S5TPED                                                   
     C                   EVAL      SUFDATp=S5DATp                                                   
     C                   EVAL      SUFNOPl=S5nopl                                                   
     C                   EVAL      SUFLINE=S5LINE                                                   
C1663C                   EVAL      SUFDETT=*BLANKS                                                  
C1663C                   IF        S5PRMO<>*BLANKS                                                  
C1663C                   EVAL      SUFDETT='P'                                                      
C1663C                   IF        S5TPRM='9'                                                       
C1663C                   EVAL      SUFDETT='M'                                                      
C1663C                   ENDIF                                                                      
C1663C                   ENDIF                                                                      
      *                                                                                             
10079C                   CALL      'MM2785'                                                         
10079C                   PARM      @PCIAS        @PECIAS                                            
10079C                   PARM      S0CUST        @PECUST                                            
10079C                   PARM      S0DLGA        @PEDLGA                                            
10079C                   PARM      S5ARTI        @PEARTI                                            
10079C                   PARM      S5VARI        @PEVARI                                            
10079C                   PARM      S5MODE        @PEMODE                                            
10079C                   PARM      S5LOGE        @PELGAN                                            
10079C                   PARM      *BLANKS       @PELGNW                                            
10079C                   PARM      'P'           @PEERRO                                            
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE CAMBIO DE VISTA ( F20 ).                      *                                
      *------------------------------------------------------------*                                
     C     CS_CMDVIS     BEGSR                                                                      
                                                                                                    
     C                   IF        ZXNUMVI<ZXMAXVI                                                  
     C                   EVAL      ZXNUMVI=ZXNUMVI+1                                                
     C                   ELSE                                                                       
     C                   EVAL      ZXNUMVI=1                                                        
     C                   ENDIF                                                                      
     C                                                                                              
     C                   EVAL      REFRES=*ON                                                       
                                                                                                    
     C                   ENDSR                                                                      
14120 **************************************************************                                
14120 * SUBRUTINA DE CAMBIO DE VISTA ( F19 ).                      *                                
14120 *------------------------------------------------------------*                                
14120C     CS_CMD19      BEGSR                                                                      
14120                                                                                               
14120C                   IF        ZXNUMVI>1                                                        
14120C                   EVAL      ZXNUMVI-=1                                                       
14120C                   ELSE                                                                       
14120C                   EVAL      ZXNUMVI=ZXMAXVI                                                  
14120C                   ENDIF                                                                      
14120C                                                                                              
14120C                   EVAL      REFRES=*ON                                                       
