16B12C                   EVAL      @PCIAS=C_S5CIAS                                                  
16B12C                   EVAL      @PDLGA=C_S5DLGA                                                  
16B12C                   EVAL      @PNPCO=C_S5NPCO                                                  
16B12C                   EVAL      @PTPED=C_S5TPED                                                  
16B12C                   EVAL      @PDATP=C_S5DATP                                                  
16B12C                   EVAL      @PNOPL=C_S5NOPL                                                  
16B12C                   EVAL      @PEARTI=C_S5ARTI                                                 
16B12C                   EVAL      @PEVARI=C_S5VARI                                                 
16B12C                   EVAL      @PEMODE=C_S5MODE                                                 
16B12C                   EVAL      @PELINE=C_S5LINE                                                 
07113C                   EVAL      @PEERRO='*'                                                      
16B12C                   EXSR      CS_COHFEN                                                        
