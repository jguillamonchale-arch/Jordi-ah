23014C                   PARM                    PXALPH                                             
23014C                   PARM                    PXFLDD                                             
23014C                   PARM                    PXDCCD                                             
23014C                   PARM                    PXFMD1                                             
23014C                   PARM                    PXEDTC                                             
23014C                   PARM                    PXNMER                                             
23014C                   PARM                    PXTIPA                                             
23014C                   MOVE      PXALPH        S54CAPE                                            
23014 *                                                                                             
23014C                   EVAL      PXDCCD=2                                                         
23014C                   EVAL      PXALPH=*BLANKS                                                   
23014C                   EVAL      PXNUM=ZXCAPT                                                     
23014C                   CALL      'PRD650'                                                         
23014C                   PARM                    PXNUM                                              
23014C                   PARM                    PXALPH                                             
23014C                   PARM                    PXFLDD                                             
23014C                   PARM                    PXDCCD                                             
23014C                   PARM                    PXFMD1                                             
23014C                   PARM                    PXEDTC                                             
23014C                   PARM                    PXNMER                                             
23014C                   PARM                    PXTIPA                                             
23014C                   MOVE      PXALPH        S54CAPT                                            
23014 *                                                                                             
23014C                   EVAL      S54UNIM=ZXUNIM4                                                  
23014C                   EVAL      S54UNI2=ZXUNIM4                                                  
23014 *                                                                                             
23014C                   EVAL      PXDCCD=2                                                         
23014C                   EVAL      PXALPH=*BLANKS                                                   
23014C                   EVAL      PXNUM=ZXSTOK                                                     
23014C                   CALL      'PRD650'                                                         
23014C                   PARM                    PXNUM                                              
23014C                   PARM                    PXALPH                                             
23014C                   PARM                    PXFLDD                                             
23014C                   PARM                    PXDCCD                                             
23014C                   PARM                    PXFMD1                                             
23014C                   PARM                    PXEDTC                                             
23014C                   PARM                    PXNMER                                             
23014C                   PARM                    PXTIPA                                             
23014C                   MOVE      PXALPH        S54STOK                                            
23014 *                                                                                             
23014C                   EVAL      S54MARC=*BLANKS                                                  
23014C                   IF        ZXCAPT>ZXSTOK                                                    
23014C                   EVAL      S54MARC='*'                                                      
23014C                   ENDIF                                                                      
FQ944 *                                                                                             
FQ944C                   WHEN      ZXNUMVI=5                                                        
FQ944C                   EVAL      S55ARTI=S5ARTI                                                   
FQ944C                   EVAL      S55VARI=S5VARI                                                   
FQ944C                   EVAL      S55MODE=S5MODE                                                   
FQ944C                   EVAL      S55STUL=S5STUL                                                   
FQ944 * FECHA PEDIDO                                                                                
FQ944C                   EVAL      @PVAN=*ZEROS                                                     
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM      S5DATP        @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S55DATP=@PVAA                                                    
FQ944 * FECHA PETICIÓN ENTREGA CLIENTE                                                              
FQ944C                   EVAL      @PVAN=*ZEROS                                                     
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM      S5FREP        @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S55FREP=@PVAA                                                    
FQ944 * FECHA de stock disponible                                                                   
FQ944C                   IF        S5DISP<>*BLANKS                                                  
FQ944C                   EVAL      @PVAN=%FLOAT(S5DISP)                                             
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM                    @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S55DISP=@PVAA                                                    
FQ944C                   ENDIF                                                                      
FQ944C                   MOVE      S5NCOE        S55COEN                                            
FQ944 * FECHA confirmada                                                                            
FQ944C                   EVAL      @PVAN=*ZEROS                                                     
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM      S5FRRE        @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S55FRRE=@PVAA                                                    
FQ944 *                                                                                             
     C                   ENDSL                                                                      
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5DTO1                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S052DTO1                                           
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5DTO2                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S052DTO2                                           
                                                                                                    
     C                   EVAL      S052DES1=S5DES1                                                  
     C                   EVAL      S052ARTI=S5ARTI                                                  
     C                   EVAL      S052TPPR=S5TPPR                                                  
                                                                                                    
     C                   EXSR      CS_KEYPF                                                         
      *** En el caso de que se desee que el usuario no visualice costes                             
     C                   IF        ZZNPG2>='1'                                                      
     C                   EXSR      CS_ZZNPG2                                                        
     C                   ENDIF                                                                      
     C                   SELECT                                                                     
     C                   WHEN      ZXNUMVI=1                                                        
     C                   EVAL      SUFDATA=W5DATAV1                                                 
     C                   WHEN      ZXNUMVI=2                                                        
     C                   EVAL      SUFDATA=W5DATAV2                                                 
     C                   WHEN      ZXNUMVI=3                                                        
     C                   EVAL      SUFDATA=W5DATAV3                                                 
23014C                   WHEN      ZXNUMVI=4                                                        
23014C                   EVAL      SUFDATA=W5DATAV4                                                 
FQ944C                   WHEN      ZXNUMVI=5                                                        
FQ944C                   EVAL      SUFDATA=W5DATAV5                                                 
     C                   ENDSL                                                                      
C0031C                   IF        S0COEN>='1'                                                      
FQ937C                   IF        S5NCOE>'00'                                                      
C0031C                   MOVEL     'C'           S052NCOE                                           
C0031C                   MOVE      S5NCOE        S052NCOE                                           
FQ937C                   ELSE                                                                       
FQ937C                   CLEAR                   S052NCOE                                           
FQ937C                   ENDIF                                                                      
C0031C                   ENDIF                                                                      
     C                   EVAL      SUFDAT2=W5DAT2                                                   
      * busca si tiene observaciones.= 'O', me situo para buscar observa-                           
      * ciones en el detalle.                                                                       
     C                   EVAL      SUFDAT3=*BLANKS                                                  
     C                   EVAL      S0LINP=S5LINE                                                    
     C     KCOOBPE       SETLL     COOBPE                                                           
     C     KCOOBPE       READE     COOBPE                                 86                        
     C                   IF        INDBOBS=*OFF                                                     
     C                   EVAL      SUFDAT3='O'                                                      
     C                   ENDIF                                                                      
     C*Marca de impresión                                                                           
     C                   MOVE      S5MIMP        SUFDAT3                                            
     C*Modificamos color según Gravedad y Error de Envios Automáticos                               
     C                   EVAL      INDPRO2=*OFF                                                     
     C                   EVAL      INDPRO4=*OFF                                                     
     C                   IF        S5TINC='1'                                                       
     C                   EVAL      INDPRO2=*ON                                                      
     C                   ELSE                                                                       
     C                   IF        S5INCI<>*BLANKS                                                  
     C                   EVAL      INDPRO4=*ON                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C*                                                                                             
                                                                                                    
     C     S05MFPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PER MOURE CAMPS AL SFL                           *                                
      *------------------------------------------------------------*                                
     C     S06MFP        BEGSR                                                                      
     C                   EVAL      SUFOPCI=*BLANKS                                                  
     C                   EVAL      SFLNXC=*OFF                                                      
                                                                                                    
     C                   EVAL      S61MONV=MCMONV                                                   
     C                   IF        S61MONV=*BLANKS                                                  
     C                   EVAL      S61MONV=S5MONE                                                   
     C                   IF        S61MONV=*BLANKS                                                  
     C                   EVAL      S61MONV=S5MONC                                                   
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   EVAL      S62MONV=S61MONV                                                  
      * Búsqueda del cambio de trabajo                                                              
     C                   EVAL      ZXMONV=S62MONV                                                   
     C                   EVAL      ZXCOCAMB=1                                                       
     C                   EXSR      CS_ZXCOCAM                                                       
                                                                                                    
     C                   SELECT                                                                     
      * Campos para vista 1                                                                         
     C                   WHEN      ZXNUMVI=1                                                        
      * Los valores confirmados prevalecen sobre los previstos                                      
     C                   IF        S5CANC<>0                                                        
     C                   EVAL      S5CANT=S5CANC                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        S5PRCC<>0                                                        
     C                   EVAL      S5PREC=S5PRCC                                                    
     C                   EVAL      S5MONE=S5MONC                                                    
     C                   EVAL      S5COMO=M5MONE                                                    
     C                   EVAL      S5CADP=S5CADC                                                    
     C                   EVAL      S5UNDP=S5UNDC                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        S5DT1C<>0                                                        
     C                   EVAL      S5DTO1=S5DT1C                                                    
     C                   EVAL      S5DTO2=S5DT2C                                                    
     C                   EVAL      S5DTO3=S5DT3C                                                    
     C                   EVAL      S5DTO4=S5DT4C                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        S5FRRE<>0                                                        
FQ944C****************** EVAL      S5FREP=S5FRRE                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      S61ARVP=S5ARVP                                                   
     C                   MOVE      S5LINE        S61LINE                                            
     C                   EVAL      S61UNIM=S5UNIM                                                   
     C                   EVAL      S61GUIO='/'                                                      
     C                   EVAL      S61UNDP=S5UNDP                                                   
     C                   EVAL      S61TPTA=S5TPTA                                                   
     C                   EVAL      S61STUL=S5STUL                                                   
                                                                                                    
     C                   EVAL      PXDCCD=2                                                         
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5CANT                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S61CANT                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5PREC*ZXCOCAMB                                            
     C                   IF        MCTPRU>='1' AND S5CADP>=1                                        
     C                   EVAL      PXNUM=PXNUM/S5CADP                                               
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      XZAUXI=PXNUM                                                     
     C                   EVAL      XZDECI=ZXDEC0                                                    
     C                   EVAL      XZAJUD=ZXAJU0                                                    
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
     C                   EVAL      PXNUM=XZAUXI                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      ZXDEC0        PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S61PREC                                            
                                                                                                    
     C                   EVAL      PXDCCD=1                                                         
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   IF        MCTPRU>='1' AND S5CADP>=1                                        
     C                   EVAL      PXNUM=1                                                          
     C                   ELSE                                                                       
     C                   EVAL      PXNUM=S5CADP                                                     
     C                   ENDIF                                                                      
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S61CADP                                            
     C                   EVAL      PXDCCD=2                                                         
                                                                                                    
      * Campos para vista 2                                                                         
     C                   WHEN      ZXNUMVI=2                                                        
     C                   MOVE      S5LINE        S62LINE                                            
     C                   EVAL      S62ARVP=S5ARVP                                                   
      * Búsqueda del precio total                                                                   
     C                   EVAL      ZXMONV=S62MONV                                                   
     C                   EVAL      PXDCCD=1                                                         
     C                   EXSR      CS_SECCAL2                                                       
     C                   EVAL      PXDCCD=XZDECI                                                    
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXBIMP                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S62BIMP                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXIIV1+ZXIIV2                                              
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S62IIVA                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXBIMP+ZXIIV1+ZXIIV2                                       
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S62TOTI                                            
      * Campos para vista 3                                                                         
     C                   WHEN      ZXNUMVI=3                                                        
     C                   MOVE      S5LINE        S63LINE                                            
     C                   EVAL      S63ARVP=S5ARVP                                                   
      * Búsqueda de los valores de visualización                                                    
     C                   EXSR      CS_SECCAL2                                                       
     C                   EVAL      PXDCCD=XZDECI                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXBIMP                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S63BIMP                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EXSR      CS_RCOSTE                                                        
     C                   EVAL      PXNUM=ZXCOST                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S63COST                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=((ZXCOST)-ZXBIMP)*-1                                       
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      1             PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM      'M'           PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S63BETE                                            
                                                                                                    
     C                   EXSR      CS_RENDIM                                                        
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      0             PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM      'M'           PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S63REND                                            
     C                   MOVE      *BLANKS       PXEDTC                         CODI EDICIO(4,M,    
     C                   IF        (PXNUM=0 AND ZXCOST<>0) OR (PXNUM>999,9)                         
     C                   MOVE      *ALL'*'       S63REND                                            
     C                   ENDIF                                                                      
                                                                                                    
23014 * Campos para vista 4                                                                         
