FQ944 *                                                                                             
FQ944C                   WHEN      ZXNUMVI=5                                                        
FQ944C                   EVAL      S75ARTI=S5ARTI                                                   
FQ944C                   EVAL      S75VARI=S5VARI                                                   
FQ944C                   EVAL      S75MODE=S5MODE                                                   
FQ944C                   EVAL      S75STUL=S5STUL                                                   
FQ944 * FECHA PEDIDO                                                                                
FQ944C                   EVAL      @PVAN=*ZEROS                                                     
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM      S5DATP        @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S75DATP=@PVAA                                                    
FQ944 * FECHA PETICIÓN ENTREGA CLIENTE                                                              
FQ944C                   EVAL      @PVAN=*ZEROS                                                     
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM      S5FREP        @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S75FREP=@PVAA                                                    
FQ944 * FECHA de stock disponible                                                                   
FQ944C                   IF        S5DISP<>*BLANKS                                                  
FQ944C                   EVAL      @PVAN=%FLOAT(S5DISP)                                             
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM                    @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S75DISP=@PVAA                                                    
FQ944C                   ENDIF                                                                      
FQ944C                   MOVE      S5NCOE        S75COEN                                            
FQ944 * FECHA confirmada                                                                            
FQ944C                   EVAL      @PVAN=*ZEROS                                                     
FQ944C                   EVAL      @PVAA=*BLANKS                                                    
FQ944C                   CALL      'MM2510'                                                         
FQ944C                   PARM      S5FRRE        @PVAN                                              
FQ944C                   PARM                    @PVAA                                              
FQ944C                   PARM      'YYMD'        @PFMI                                              
FQ944C                   PARM      ZZFMFF        @PFMF                                              
FQ944C                   PARM      ZZFMFS        @PSEP                                              
FQ944C                   PARM      ' '           @PEERR                                             
FQ944C                   EVAL      S75FRRE=@PVAA                                                    
FQ944 *                                                                                             
     C                   ENDSL                                                                      
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5DTO1                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S072DTO1                                           
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5DTO2                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S072DTO2                                           
                                                                                                    
     C                   IF        S5FRRE<>0                                                        
     C                   EVAL      @PVAA=*BLANKS                                                    
     C                   CALL      'MM2510'                                                         
     C                   PARM      S5FRRE        @PVAN                                              
     C                   PARM                    @PVAA                                              
     C                   PARM      'YYMD'        @PFMI                                              
     C                   PARM      ZZFMFF        @PFMF                                              
     C                   PARM      ZZFMFS        @PSEP                                              
     C                   PARM      ' '           @PEERR                                             
     C                   EVAL      S072FRRE=@PVAA                                                   
     C                   ELSE                                                                       
     C                   EVAL      S072FRRE=*BLANKS                                                 
     C                   ENDIF                                                                      
     C                   EVAL      S072TPLA=S5TPLA                                                  
     C                   EVAL      S072ARTI=S5ARTI                                                  
     C                   EVAL      S072VARI=S5VARI                                                  
     C                   EVAL      S072MODE=S5MODE                                                  
     C                   EVAL      S072TCOJ=S5TCOJ                                                  
     C                   EVAL      S072PHLD=*BLANKS                                                 
     C                   IF        S5PHLD>='1'                                                      
     C                   EVAL      S072PHLD='H'                                                     
     C                   ENDIF                                                                      
     C                   EVAL      S072RHLD=*BLANKS                                                 
     C                   IF        S5RHLD>='1'                                                      
     C                   EVAL      S072RHLD='M'                                                     
     C                   ENDIF                                                                      
     C***                EVAL      S072PPRG=S5PPRG                                                  
     C                   EVAL      S072TPPR=S5TPPR                                                  
C1663C                   EVAL      S072TPRM=S5TPRM                                                  
     C***                IF        S5PNUM<>0                                                        
     C***                MOVE      S5PNUM        S072PNUM                                           
     C***                ENDIF                                                                      
                                                                                                    
     C                   EXSR      CS_KEYPF                                                         
                                                                                                    
      *** En el caso de que se desee que el usuario no visualice costes                             
     C                   IF        ZZNPG2>='1'                                                      
     C                   EXSR      CS_ZZNPG2                                                        
     C                   ENDIF                                                                      
     C                   SELECT                                                                     
     C                   WHEN      ZXNUMVI=1                                                        
     C                   EVAL      SUFDATA=W7DATAV1                                                 
     C                   WHEN      ZXNUMVI=2                                                        
     C                   EVAL      SUFDATA=W7DATAV2                                                 
     C                   WHEN      ZXNUMVI=3                                                        
     C                   EVAL      SUFDATA=W7DATAV3                                                 
23014C                   WHEN      ZXNUMVI=4                                                        
23014C                   EVAL      SUFDATA=W7DATAV4                                                 
FQ944C                   WHEN      ZXNUMVI=5                                                        
FQ944C                   EVAL      SUFDATA=W7DATAV5                                                 
     C                   ENDSL                                                                      
C0031C                   IF        S0COEN>='1'                                                      
FQ937C                   IF        S5NCOE>'00'                                                      
C0031C                   MOVEL     'C'           S072NCOE                                           
C0031C                   MOVE      S5NCOE        S072NCOE                                           
FQ937C                   ELSE                                                                       
FQ937C                   CLEAR                   S072NCOE                                           
FQ937C                   ENDIF                                                                      
C0031C                   ENDIF                                                                      
     C                   EVAL      SUFDAT2=W7DAT2                                                   
      * busca si tiene observaciones.= 'O', me situo para buscar observa-                           
      * ciones en el detalle.                                                                       
     C                   EVAL      SUFDAT3=*BLANKS                                                  
     C                   EVAL      S0LINP=S5LINE                                                    
     C     KCOOBPE       SETLL     COOBPE                                                           
     C     KCOOBPE       READE     COOBPE                                 86                        
     C                   IF        INDBOBS=*OFF                                                     
     C                   EVAL      SUFDAT3='O'                                                      
     C                   ENDIF                                                                      
     C*Marca de impresión                                                                           
     C                   MOVE      S5MIMP        SUFDAT3                                            
     C*Modificamos color según Gravedad y Error de Envios Automáticos                               
     C                   EVAL      INDPRO2=*OFF                                                     
     C                   EVAL      INDPRO4=*OFF                                                     
     C                   IF        S5TINC='1'                                                       
     C                   EVAL      INDPRO2=*ON                                                      
     C                   ELSE                                                                       
     C                   IF        S5INCI<>*BLANKS                                                  
     C                   EVAL      INDPRO4=*ON                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C*                                                                                             
                                                                                                    
     C     S07MFPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PER MOURE CAMPS AL SFL                           *                                
      *------------------------------------------------------------*                                
     C     S08MFP        BEGSR                                                                      
     C                   EVAL      SUFOPCI=*BLANKS                                                  
     C                   EVAL      SFLNXC=*OFF                                                      
                                                                                                    
      * Los valores confirmados prevalecen sobre los previstos                                      
     C                   EVAL      S81MONV=MCMONV                                                   
     C                   IF        S81MONV=*BLANKS                                                  
     C                   EVAL      S81MONV=S5MONE                                                   
     C                   IF        S81MONV=*BLANKS                                                  
     C                   EVAL      S81MONV=S5MONC                                                   
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   EVAL      S82MONV=S81MONV                                                  
      * Búsqueda del cambio de trabajo                                                              
     C                   EVAL      ZXMONV=S82MONV                                                   
     C                   EVAL      ZXCOCAMB=1                                                       
     C                   EXSR      CS_ZXCOCAM                                                       
                                                                                                    
     C                   SELECT                                                                     
      * Campos para vista 1                                                                         
     C                   WHEN      ZXNUMVI=1                                                        
      * Los valores confirmados prevalecen sobre los previstos                                      
     C                   IF        S5CANC<>0                                                        
     C                   EVAL      S5CANT=S5CANC                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        S5PRCC<>0                                                        
     C                   EVAL      S5PREC=S5PRCC                                                    
     C                   EVAL      S5MONE=S5MONC                                                    
     C                   EVAL      S5COMO=M5MONE                                                    
     C                   EVAL      S5CADP=S5CADC                                                    
     C                   EVAL      S5UNDP=S5UNDC                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        S5DT1C<>0                                                        
     C                   EVAL      S5DTO1=S5DT1C                                                    
     C                   EVAL      S5DTO2=S5DT2C                                                    
     C                   EVAL      S5DTO3=S5DT3C                                                    
     C                   EVAL      S5DTO4=S5DT4C                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      @PVAA=*BLANKS                                                    
     C                   CALL      'MM2510'                                                         
     C                   PARM      S5FREP        @PVAN                                              
     C                   PARM                    @PVAA                                              
     C                   PARM      'YYMD'        @PFMI                                              
     C                   PARM      ZZFMFF        @PFMF                                              
     C                   PARM      ZZFMFS        @PSEP                                              
     C                   PARM      ' '           @PEERR                                             
     C                   EVAL      S81FREP=@PVAA                                                    
                                                                                                    
     C                   EVAL      S81ARTI=S5ARTI                                                   
     C                   MOVE      S5LINE        S81LINE                                            
     C                   EVAL      S81UNIM=S5UNIM                                                   
     C                   EVAL      S81GUIO='/'                                                      
     C                   EVAL      S81UNDP=S5UNDP                                                   
     C                   EVAL      S81TPTA=S5TPTA                                                   
     C                   EVAL      S81STUL=S5STUL                                                   
                                                                                                    
     C                   EVAL      PXDCCD=2                                                         
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5CANT                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S81CANT                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=S5PREC*ZXCOCAMB                                            
     C                   IF        MCTPRU>='1' AND S5CADP>=1                                        
     C                   EVAL      PXNUM=PXNUM/S5CADP                                               
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      XZAUXI=PXNUM                                                     
     C                   EVAL      XZDECI=ZXDEC0                                                    
     C                   EVAL      XZAJUD=ZXAJU0                                                    
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
     C                   EVAL      PXNUM=XZAUXI                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      ZXDEC0        PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S81PREC                                            
                                                                                                    
     C                   EVAL      PXDCCD=1                                                         
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   IF        MCTPRU>='1' AND S5CADP>=1                                        
     C                   EVAL      PXNUM=1                                                          
     C                   ELSE                                                                       
     C                   EVAL      PXNUM=S5CADP                                                     
     C                   ENDIF                                                                      
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S81CADP                                            
     C                   EVAL      PXDCCD=2                                                         
      * Campos para vista 2                                                                         
     C                   WHEN      ZXNUMVI=2                                                        
     C                   EVAL      @PVAA=*BLANKS                                                    
     C                   CALL      'MM2510'                                                         
     C                   PARM      S5FREP        @PVAN                                              
     C                   PARM                    @PVAA                                              
     C                   PARM      'YYMD'        @PFMI                                              
     C                   PARM      ZZFMFF        @PFMF                                              
     C                   PARM      ZZFMFS        @PSEP                                              
     C                   PARM      ' '           @PEERR                                             
     C                   EVAL      S82FREP=@PVAA                                                    
                                                                                                    
     C                   EVAL      S82ARTI=S5ARTI                                                   
     C                   MOVE      S5LINE        S82LINE                                            
      * Búsqueda del precio total                                                                   
     C                   EVAL      ZXMONV=S82MONV                                                   
     C                   EXSR      CS_SECCAL2                                                       
                                                                                                    
     C                   EVAL      PXDCCD=XZDECI                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXBIMP                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S82BIMP                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXIIV1+ZXIIV2                                              
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        S82IIVA                                            
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXBIMP+ZXIIV1+ZXIIV2                                       
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
