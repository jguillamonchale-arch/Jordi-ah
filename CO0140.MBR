C1543 *                                                                                             
C1543c                   IF        (%trim(@PEOPT) = '4' or @PEOPT = 'OE')                           
C1543c                              and s0pped = '99' and s0tpe4 <> '2'                             
C1543C                   EVAL      S5NPCO=PK0NPCO                                                   
C1543C                   EVAL      S5TPED=PK0TPED                                                   
C1543C                   EVAL      S5DATP=PK0DATP                                                   
C1543C                   EVAL      S5NOPL=PK0NOPL                                                   
C1543C                   EVAL      S5LINE=PK0LINE                                                   
C1543C     KCODEPE       CHAIN(N)  CODEPE                                                           
C1543c                   if        %found                                                           
C1543c     *iso          test(d e)               s5dat1                                             
C1543c                   if        not %error                                                       
C1543c     *iso          move      s5dat1        zyfrec                                             
C1543c                   eval      m5cias = s5cias                                                  
C1543c                   eval      m5arti = s5arti                                                  
C1543c                   eval      m5vari = s5vari                                                  
C1543c                   eval      m5mode = s5mode                                                  
C1543c                   exsr      cs_rtvCRot                                                       
C1543c     kmsarti00     chain     msarti00                                                         
C1543c                   if        %found and zyCRot = 'B'                                          
C1543c                   move      m5ppblt       zyppblt                                            
C1543c                   eval      m6cias = s5cias                                                  
C1543c                   eval      m6dlga = s5dlga                                                  
C1543c                   eval      m6arti = s5arti                                                  
C1543c                   eval      m6vari = s5vari                                                  
C1543c                   eval      m6mode = s5mode                                                  
C1543c                   eval      m6netl = 2                                                       
C1543c     kmsstst       chain     msstst                                                           
C1543c                   if        %found                                                           
C1543c                   eval      zydias = %diff(zyhoy:zyfrec:*d)                                  
C1543c                   if        m6lead <> *zero                                                  
C1543c                   if        ((zydias / m6lead) * 100.0) > zyppblt                            
C1543c                             and zyppblt <> *zero                                             
C1543c                   if        zyAutBPB                                                         
C1543c                   exsr      cs_confAnul                                                      
C1543c                   endif                                                                      
C1543c                   if        not zyAutBPB                                                     
C1543C                   EVAL      ERRGRL=*ON                                                       
C1543C                   EVAL      WRK40=*ON                                                        
C1543C                   EVAL      MSGER='MSG9935'                                                  
C1543c                   endif                                                                      
C1543c                   endif                                                                      
C1543C                   endif                                                                      
C1543C                   endif                                                                      
C1543C                   endif                                                                      
C1543C                   endif                                                                      
C1543C                   endif                                                                      
C1543C                   ENDIF                                                                      
C1543C     ERRGRL        CABEQ     *ON           PK0CHK0T                                           
                                                                                                    
     C                   EVAL      S5NPCO=PK0NPCO                                                   
     C                   EVAL      S5TPED=PK0TPED                                                   
     C                   EVAL      S5DATP=PK0DATP                                                   
     C                   EVAL      S5NOPL=PK0NOPL                                                   
     C                   EVAL      S5LINE=PK0LINE                                                   
     C                   SELECT                                                                     
     C                   WHEN      PK0OPCI=' 1' OR PK0OPCI='1 '                                     
      * Si la línea es 0 busca la siguiente línea libre                                             
     C                   IF        PK0LINE=0                                                        
     C                   CALL      'CO2527'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM                    @PEDLGA                                            
     C                   PARM      PK0NPCO       @PENPCO                                            
     C                   PARM      PK0TPED       @PETPED                                            
     C                   PARM      PK0DATP       @PEDATP                                            
     C                   PARM      PK0NOPL       @PENOPL                                            
     C                   PARM      PK0LINE       @PELINE                                            
     C                   PARM      *BLANKS       @PEERR                                             
     C                   EVAL      PK0LINE=@PELINE                                                  
     C                   IF        @PEERR>'0'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK41=*ON                                                        
     C                   EVAL      MSGER='MMM0102'                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PK0CHK0T                                           
                                                                                                    
     C                   EVAL      S5LINE=PK0LINE                                                   
30056C*    KCODEPE       CHAIN     CODEPE                             81                            
30056C     KCODEPE       CHAIN(N)  CODEPE                             81                            
     C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK40=*ON                                                        
     C                   EVAL      WRK41=*ON                                                        
     C                   EVAL      MSGER='MSG0008'                                                  
     C                   ELSE                                                                       
     C     KCODEPE       CHAIN     CODEP201                           81                            
     C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK40=*ON                                                        
     C                   EVAL      WRK41=*ON                                                        
     C                   EVAL      MSGER='MSG0008'                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PK0CHK0T                                           
                                                                                                    
     C* Validamos cantidad                                                                          
     C                   EVAL      P6DECI=0                                                         
     C                   EVAL      P6AJUD=0                                                         
     C                   EVAL      P6ARTI=PK0ARTI                                                   
     C                   EVAL      P6VARI=PK0VARI                                                   
     C                   EVAL      P6MODE=PK0MODE                                                   
     C                   EVAL      P6UNIM=PK0UNIM                                                   
     C     KPMUNAL       CHAIN     PMUNAL                             81                            
     C                   IF        *IN81=*ON                                                        
     C                   EVAL      P6VARI=*BLANKS                                                   
     C                   EVAL      P6MODE=*BLANKS                                                   
     C     KPMUNAL       CHAIN     PMUNAL                             81                            
     C                   ENDIF                                                                      
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK46=*ON                                                        
     C                   EVAL      MSGER='MSG0055'                                                  
     C                   ENDIF                                                                      
     C                   EVAL      PXDCCD=P6DECI                                                    
     C                   MOVE      P6AJUD        PXTIPA                                             
     C     ERRGRL        CABEQ     *ON           PK0CHK0T                                           
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   MOVE      PK0CANT       PXALPH                                             
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   IF        PXNMER<>0                                                        
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK46=*ON                                                        
     C                   EVAL      MSGER='MSG0022'                                                  
     C                   IF        PXNMER=1                                                         
     C                   EVAL      MSGER='MSG0023'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=2                                                         
     C                   EVAL      MSGER='MSG0024'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=3                                                         
     C                   EVAL      MSGER='MSG0025'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=4                                                         
     C                   EVAL      MSGER='MSG0026'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=5                                                         
     C                   EVAL      MSGER='MSG0032'                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PK0CHK0T                                           
     C                   MOVE      PXALPH        PK0CANT                                            
     C                   EVAL      ZXCANT=PXNUM                                                     
      * La cantidad de cantidades std. no utilizará decimales                                       
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   MOVE      PK0CAST       PXALPH                                             
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      0             PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   IF        PXNMER<>0                                                        
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK47=*ON                                                        
     C                   EVAL      MSGER='MSG0022'                                                  
     C                   IF        PXNMER=1                                                         
     C                   EVAL      MSGER='MSG0023'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=2                                                         
     C                   EVAL      MSGER='MSG0024'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=3                                                         
     C                   EVAL      MSGER='MSG0025'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=4                                                         
     C                   EVAL      MSGER='MSG0026'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=5                                                         
     C                   EVAL      MSGER='MSG0032'                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PK0CHK0T                                           
     C                   MOVE      PXALPH        PK0CAST                                            
     C                   EVAL      ZXCAST=PXNUM                                                     
                                                                                                    
     C                   IF        PXNUM<0                                                          
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK47=*ON                                                        
     C                   EVAL      MSGER='MSG0031'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PK0CHK0T                                           
      * No pueden existir a la vez cantidad y cantidad std.                                         
     C                   IF        (ZXCANT<>0 AND ZXCAST<>0)                                        
     C                             OR (ZXCANT=0 AND ZXCAST=0)                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK47=*ON                                                        
     C                   EVAL      WRK46=*ON                                                        
     C                   EVAL      MSGER='PUR0029'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PK0CHK0T                                           
      * Validación de la cantidad std.                                                              
     C                   EVAL      MOARTI=PK0ARTI                                                   
     C                   EVAL      MOTCST=PK0TCST                                                   
     C                   EVAL      MOVARI=PK0VARI                                                   
     C                   EVAL      MOMODE=PK0MODE                                                   
     C     KMSTSCA       CHAIN     MSTSCA                             81                            
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      MOVARI=*BLANKS                                                   
     C                   EVAL      MOMODE=*BLANKS                                                   
     C     KMSTSCA       CHAIN     MSTSCA                             81                            
     C                   ENDIF                                                                      
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MMM0032'                                                  
     C                   EVAL      WRK48=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PK0CHK0T                                           
                                                                                                    
     C                   IF        ZXCAST<>0                                                        
     C                   EVAL      PK0UNIM=MOUNST                                                   
     C                   EVAL      P6DECI=0                                                         
     C                   EVAL      P6AJUD=0                                                         
     C                   EVAL      P6ARTI=PK0ARTI                                                   
     C                   EVAL      P6VARI=PK0VARI                                                   
     C                   EVAL      P6MODE=PK0MODE                                                   
     C                   EVAL      P6UNIM=PK0UNIM                                                   
     C     KPMUNAL       CHAIN     PMUNAL                             81                            
     C                   IF        *IN81=*ON                                                        
     C                   EVAL      P6VARI=*BLANKS                                                   
     C                   EVAL      P6MODE=*BLANKS                                                   
     C     KPMUNAL       CHAIN     PMUNAL                             81                            
     C                   ENDIF                                                                      
     C                   IF        CHAIN=*ON OR MOUNST=*BLANKS                                      
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MMM0282'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PK0CHK0T                                           
                                                                                                    
     C                   MOVE      P6AJUD        PXTIPA                                             
     C                   MOVE      *BLANKS       PXALPH                                             
     C                   EVAL      PXNUM=ZXCAST*MOCAST                                              
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      P6DECI        PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        PK0CANT                                            
     C                   EVAL      PK0CAST=*BLANKS                                                  
     C                   EVAL      ZXCAST=0                                                         
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PK0CHK0T                                           
     C                   EVAL      S3CUST=S0CUST                                                    
     C                   EVAL      ZXARTIX=PK0ARTI                                                  
     C                   EVAL      ZXVARIX=PK0VARI                                                  
     C                   EVAL      ZXMODEX=PK0MODE                                                  
     C                   EVAL      S3ARVM=ZXARVMX                                                   
     C                   EVAL      S3TCOJ=PK0TCOJ                                                   
     C                   EVAL      ZXCOCLP0=' '                                                     
     C     *NOKEY        CLEAR     *ALL          RCOCLP0                                            
     C     KCOCLP0       CHAIN     COCLP0                             81                            
      * Puesto que para clientes omito la creación de COCLP0 porque pueden vender todos             
      * los productos, me baso en CO2535 para ver de donde saca los parámetros para simular         
      * dicha creación.                                                                             
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      NDARTI=PK0ARTI                                                   
     C                   EVAL      NDVARI=PK0VARI                                                   
     C                   EVAL      NDMODE=PK0MODE                                                   
     C                   EVAL      NDTCOJ=PK0TCOJ                                                   
     C                   EXSR      CS_COCLP0                                                        
     C                   ENDIF                                                                      
      * Si mandan las cantidades std segun cliente:                                                 
     C                   IF        CL_S0TTC3>='1'                                                   
C1859c                   if        z_p7tcde = '1' and s0most = '1'                                  
C1859C                   EVAL      S3TTC4=CL_S0TTC2                                                 
C1859C                   ELSE                                                                       
     C                   EVAL      S3TTCS=CL_S0TTC2                                                 
C1859C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      * La cantidad debe superar el valor mínimo establecido según COCLP0                           
     C                   EVAL      XZCOFU=1                                                         
     C                   IF        S3CAST>0                                                         
     C                   EVAL      XZCIAS=S3CIAS                                                    
     C                   EVAL      XZARTI=PK0ARTI                                                   
     C                   EVAL      XZVARI=PK0VARI                                                   
     C                   EVAL      XZMODE=PK0MODE                                                   
     C                   EVAL      ZXCA10=S3CAST                                                    
     C                   EVAL      ZXCA11=S3CAST                                                    
     C                   EVAL      ZXUN10=S3UNST                                                    
     C                   EVAL      ZXUN11=PK0UNIM                                                   
     C* CAMBIO de unidades                                                                          
     C/COPY *LIBL/QSRDSRC,SRD021                                                                    
                                                                                                    
     C*  CONVERSION DE UNA CANTIDAD-UNIDAD INICIAL A CANTIDAD-UNIDAD                                
     C*  FINAL                                                                                      
     C/COPY *LIBL/QSRDSRC,SRD002                                                                    
     C     S3CAST        MULT      XZCOFU        XZAUXI                                             
     C                   EVAL      XZDECI=XZDE01                                                    
     C                   EVAL      XZAJUD=XZAJ01                                                    
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
      * En cualquier caso la cantidad no puede ser inferior al lote mínimo                          
      * del proveedor y además si es requerido, debe ser además múltiplo                            
      * de dicha cantidad                                                                           
     C                   EVAL      ZXCAST2=XZAUXI                                                   
     C                   EVAL      ZXUNST2=PK0UNIM                                                  
     C                   IF        ZXCANT<ZXCAST2                                                   
27027 *                  EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='COM0041'                                                  
     C                   EVAL      WRK46=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PK0CHK0T                                           
                                                                                                    
     C                   IF        ZXCAST2<>0                                                       
     C     ZXCANT        DIV       ZXCAST2       ZXENTE                                             
     C                   MVR                     ZXNMVR                                             
     C                   ELSE                                                                       
     C                   EVAL      ZXENTE=0                                                         
     C                   EVAL      ZXNMVR=0                                                         
     C                   ENDIF                                                                      
     C                   IF        S3TLCO='1' AND ZXNMVR<>0                                         
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='COM0042'                                                  
     C                   EVAL      WRK46=*ON                                                        
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        (S3TLCO='3' OR S3TLCO='4')  AND (ZXNMVR<>0)                      
     C                   EVAL      PK0UNIM=ZXUNST2                                                  
     C                   IF        S3TLCO='3'                                                       
     C                   EVAL      ZXENTE=ZXENTE+1                                                  
     C                   ENDIF                                                                      
C1859 *                                                                                             
C1859c                   if        z_p7tcde = '1' and s0most = '1'                                  
C1859C                   IF        S3TTC4='4' and ZXENTE=0                                          
C1859C                   EVAL      ZXENTE=ZXENTE+1                                                  
C1859C                   ENDIF                                                                      
C1859C                   ELSE                                                                       
07053C                   IF        S3TTCS='4' and ZXENTE=0                                          
07053C                   EVAL      ZXENTE=ZXENTE+1                                                  
07053C                   ENDIF                                                                      
C1859C                   ENDIF                                                                      
C1859 *                                                                                             
     C                   EVAL      PXNUM=ZXCAST2*ZXENTE                                             
     C                   MOVE      *BLANKS       PXALPH                                             
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      P6DECI        PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        PK0CANT                                            
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='PUR0044'                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PK0CHK0T                                           
      * La cantidad,además, debe ser múltiplo o no de la cantidad estándard                         
C1859c                   if        z_p7tcde = '1' and s0most = '1'                                  
C1859C                   EVAL      ZXTTCS=S3TTC4                                                    
C1859C                   ELSE                                                                       
C1859C                   EVAL      ZXTTCS=S3TTCS                                                    
C1859C                   ENDIF                                                                      
C1859C*                  IF        S3TTCS>'0' AND PK0TCST<>*BLANKS                                  
C1859C                   IF        ZXTTCS>'0' AND PK0TCST<>*BLANKS                                  
     C                             AND MOCAST>0                                                     
     C                   EVAL      XZCIAS=MOCIAS                                                    
     C                   EVAL      XZARTI=PK0ARTI                                                   
     C                   EVAL      XZVARI=PK0VARI                                                   
     C                   EVAL      XZMODE=PK0MODE                                                   
     C                   EVAL      ZXCA10=MOCAST                                                    
     C                   EVAL      ZXCA11=MOCAST                                                    
     C                   EVAL      ZXUN10=MOUNST                                                    
     C                   EVAL      ZXUN11=PK0UNIM                                                   
     C* CAMBIO de unidades                                                                          
     C/COPY *LIBL/QSRDSRC,SRD021                                                                    
                                                                                                    
     C     MOCAST        MULT      XZCOFU        XZAUXI                                             
     C                   EVAL      XZDECI=XZDE01                                                    
     C                   EVAL      XZAJUD=XZAJ01                                                    
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
      * En cualquier caso la cantidad no puede ser inferior al lote mínimo                          
      * del proveedor y además si es requerido, debe ser además múltiplo                            
      * de dicha cantidad                                                                           
     C                   EVAL      ZXCAST=XZAUXI                                                    
     C                   EVAL      ZXUNST=PK0UNIM                                                   
     C                   IF        ZXCAST<>0                                                        
     C     ZXCANT        DIV       ZXCAST        ZXENTE                                             
     C                   MVR                     ZXNMVR                                             
     C                   ENDIF                                                                      
C1859c                   if        z_p7tcde = '1' and s0most = '1'                                  
C1859C                   EVAL      ZXTTCS=S3TTC4                                                    
C1859C                   ELSE                                                                       
C1859C                   EVAL      ZXTTCS=S3TTCS                                                    
C1859C                   ENDIF                                                                      
C1859C*                  IF        S3TTCS='1' AND ZXNMVR<>0                                         
C1859C                   IF        ZXTTCS='1' AND ZXNMVR<>0                                         
      * Muestro cual es la cantidad estandar                                                        
      *                                                                                             
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=MOCAST                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      2             PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        W02CAST                                            
      *                                                                                             
     C                   EVAL      W02UNST=MOUNST                                                   
      * BUSCAMOS SI EXISTE ALGUN OTRO STANDARD Y LO MOSTRAMOS                                       
     C                   EXSR      CS_STANDAR                                                       
      *                                                                                             
     C                   EXFMT     W02                                                              
     C                   SELECT                                                                     
     C                   WHEN      RETRO=*ON                                                        
     C                   EVAL      ZXOPT='PK0DSP  '                                                 
     C                   GOTO      PK0CHKT                                                          
     C                   ENDSL                                                                      
     C                   ENDIF                                                                      
                                                                                                    
C1859c                   if        z_p7tcde = '1' and s0most = '1'                                  
C1859C                   EVAL      ZXTTCS=S3TTC4                                                    
C1859C                   ELSE                                                                       
C1859C                   EVAL      ZXTTCS=S3TTCS                                                    
C1859C                   ENDIF                                                                      
C1859C*                  IF        S3TTCS='2' AND ZXNMVR<>0                                         
C1859C                   IF        ZXTTCS='2' AND ZXNMVR<>0                                         
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='PUR0043'                                                  
     C                   EVAL      WRK46=*ON                                                        
     C                   ENDIF                                                                      
                                                                                                    
C1859C*                  IF        (S3TTCS='3' OR S3TTCS='4')  AND (ZXNMVR<>0)                      
C1859C                   IF        (ZXTTCS='3' OR ZXTTCS='4')  AND (ZXNMVR<>0)                      
     C                   EVAL      PK0UNIM=ZXUNST                                                   
C1859C*                  IF        S3TTCS='3'                                                       
C1859C                   IF        ZXTTCS='3'                                                       
     C                   EVAL      ZXENTE=ZXENTE+1                                                  
     C                   ENDIF                                                                      
