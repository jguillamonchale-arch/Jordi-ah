BLODIC                   EXSR      CS_CAMBIOUM                                                      
BLODIC                   EXSR      CS_STOCKALMA                                                     
BLODIC                   IF        ZXZXCANT > ZXZXSTOCK                                             
BLODIC                   EVAL      ERRGRL=*ON                                                       
BLODIC                   EVAL      WRK34=*ON                                                        
BLODIC                   EVAL      WRK35=*ON                                                        
BLODIC                   EVAL      WRK39=*ON                                                        
BLODIC                   EVAL      MSGER='COM0123'                                                  
BLODIC                   ENDIF                                                                      
BLODIC                   WHEN      M5PPV2='3'                                                       
BLODIC                   EXSR      CS_CAMBIOUM                                                      
BLODIC                   EXSR      CS_STOCKZOPA                                                     
BLODIC                   IF        ZXZXCANT > ZXZXSTOCK                                             
BLODIC                   EVAL      ERRGRL=*ON                                                       
BLODIC                   EVAL      WRK34=*ON                                                        
BLODIC                   EVAL      WRK35=*ON                                                        
BLODIC                   EVAL      WRK39=*ON                                                        
BLODIC                   EVAL      MSGER='COM0123'                                                  
BLODIC                   ENDIF                                                                      
BLODIC                   WHEN      M5PPV2='4'                                                       
BLODIC                   EXSR      CS_CAMBIOUM                                                      
BLODIC                   EXSR      CS_STOCKCIAS                                                     
BLODIC                   IF        ZXZXCANT > ZXZXSTOCK                                             
BLODIC                   EVAL      ERRGRL=*ON                                                       
