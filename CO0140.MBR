FQ284 **************************************************************                                
FQ284 * Rutina Base para Fluidra direct                            *                                
FQ284 **************************************************************                                
FQ284C     FD_BASE       BEGSR                                                                      
FQ284 *                                                                                             
FQ284 * Determinar el tipo de empresa en la que estoy                                               
FQ284 *                                                                                             
FQ284C                   SELECT                                                                     
FQ284 * Comercial                                                                                   
FQ284C                   WHEN      S0PPED<>'99' AND ZZALOL<'1'                                      
FQ284C                   EVAL      @FDORIG=0                                                        
FQ284 * Productiva                                                                                  
FQ284C                   WHEN      S0PPED='99' AND ZZALOL<'1'                                       
FQ284C                   EVAL      @FDORIG=2                                                        
FQ284 * Trace                                                                                       
FQ284C                   WHEN      ZZALOL='1'                                                       
FQ284C                   EVAL      @FDORIG=3                                                        
FQ284 *                                                                                             
FQ284C                   ENDSL                                                                      
FQ284 *                                                                                             
FQ284C                   ENDSR                                                                      
07060 **************************************************************                                
07060 * SUBRUTINA RECALCULO IMPORTES                               *                                
07060 **************************************************************                                
07060C     CS_RECALC     BEGSR                                                                      
07060C                   MOVE      SDSJNBR       ZXJNBR                                             
07060C                   MOVE      UDATE         ZXDATA                                             
07060C                   TIME                    ZXHORA                                             
07060 *                                                                                             
07060C                   CLEAR                   Z1COMA                                             
07060C     DSLDA         CAT(P)    Z1COMA:0      Z1COMA                                             
07060C                   Z-ADD     86            JOLINE                                             
07060C                   CALL      'PRD935'                                                         
07060C                   PARM                    JOTRAT                                             
07060C                   PARM                    JOLINE                                             
07060C                   PARM                    Z1COMA                                             
07060 *                                                                                             
07060C                   MOVE      @PCIAS        @PECIAS2                                           
07060C                   EVAL      X5CIAS=S0CIAS                                                    
07060C                   EVAL      X5DLGA=S0DLGA                                                    
07060C                   EVAL      X5NPCO=S0NPCO                                                    
07060C                   EVAL      X5DATP=S0DATP                                                    
07060C                   EVAL      X5TPED=S0TPED                                                    
07060C                   EVAL      X5NOPL=S0NOPL                                                    
07060C                   CLEAR                   Z1COMA                                             
07060C     CO2540        CAT       Z1COMA:0      Z1COMA                                             
07060C                   EVAL      JOLINE=88                                                        
07060C                   CALL      'PRD935'                                                         
07060C                   PARM                    JOTRAT                                             
07060C                   PARM                    JOLINE                                             
07060C                   PARM                    Z1COMA                                             
07060                                                                                               
07060C                   EVAL      @PEPRG2='CO2540    '                                             
07060                                                                                               
07060C                   Z-ADD     150           ZXLOGC           15 5                              
07060C                   MOVE      *BLANKS       ZXQCM2          150                                
07060C     ZXQCM2        CAT       'CALL (':0    ZXQCM2                                             
07060C     ZXQCM2        CAT       'PRDGJ8':0    ZXQCM2                                             
07060C     ZXQCM2        CAT       'CL)':0       ZXQCM2                                             
07060C     ZXQCM2        CAT       'PARM(':1     ZXQCM2                                             
07060C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
07060C     ZXQCM2        CAT       JOTRAT:0      ZXQCM2                                             
07060C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
07060C     ZXQCM2        CAT       C(1):1        ZXQCM2                                             
07060C     ZXQCM2        CAT       @PEPRG2:0     ZXQCM2                                             
07060C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
07060C     ZXQCM2        CAT       C(1):1        ZXQCM2                                             
07060C     ZXQCM2        CAT       C(1):1        ZXQCM2                                             
07060C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
07060                                                                                               
07060C                   CALL      'QCMDEXC'                                                        
07060C                   PARM                    ZXQCM2                                             
07060C                   PARM                    ZXLOGC                                             
07060                                                                                               
07060C                   ENDSR                                                                      
07060 **************************************************************                                
07060 * SUBRUTINA CALCULO DIFERENCIAS RENDIMIENTO.                 *                                
07060 **************************************************************                                
07060C     CS_CHKRDTO    BEGSR                                                                      
07060C                   SETOFF                                       1012                          
07060C                   EVAL      WRK48 = (ZZABRD = '1')                                           
07060C                   EVAL      ZXCOST=*ZEROS                                                    
07060C                   EVAL      ZXCOCAMB=1                                                       
07060C                   EXSR      CS_ZXCOCAM                                                       
07060C                   EXSR      CS_CMDCIM                                                        
07060C                   EVAL      PXNUM=*ZEROS                                                     
07060C                   IF        ZXVNET<>0                                                        
07060C                   EVAL      PXNUM=(1-(ZXCOST/ZXVNET))*100                                    
07060C                   ENDIF                                                                      
07060C*                  IF        PXNUM < ZXRDMI                                                   
07060C                   IF        PXNUM < XZPRCPA                                                  
07060C                   EVAL      PXALPH=*BLANKS                                                   
07060C                   CALL      'PRD650'                                                         
07060C                   PARM                    PXNUM                                              
07060C                   PARM                    PXALPH                                             
07060C                   PARM                    PXFLDD                                             
07060C                   PARM      0             PXDCCD                                             
07060C                   PARM                    PXFMD1                                             
07060C                   PARM      'Q'           PXEDTC                                             
07060C                   PARM                    PXNMER                                             
07060C                   PARM                    PXTIPA                                             
07060C                   EVAL      W10RDTOP = %TRIM(PXALPH)                                         
07060C                   EVAL      W10RDTOE = %CHAR(XZPRCPA)                                        
07060C                   EVAL      W10NPCO  = S0NPCO                                                
07060C                   EVAL      SUFOPCI=*BLANKS                                                  
07060C                   EVAL      SFLNXC=*OFF                                                      
07060C                   DOW       NOT *IN10 AND NOT *IN12                                          
07060C                   EXFMT     W10                                                              
07060C                   ENDDO                                                                      
07060* Si pulsan F10 y el rendimiento es inferior al definido, bloquearemos el                     
07060C                   IF        NOT *IN12 AND WRK48 = '1'                                        
07060C                   EVAL      ERRGRL = *ON                                                     
07060C                   ENDIF                                                                      
07060C                   ENDIF                                                                      
07060C                   ENDSR                                                                      
07060 **************************************************************                                
07060 * Calcula importes para todas las vistas                     *                                
07060 *------------------------------------------------------------*                                
07060C     CS_CMDCIM     BEGSR                                                                      
07060                                                                                               
07060C                   EVAL      SYCIAS=S0CIAS                                                    
07060C                   EVAL      SYDLGA=S0DLGA                                                    
07060C                   EVAL      SYNPCO=S0NPCO                                                    
07060C                   EVAL      SYTPED=S0TPED                                                    
07060C                   EVAL      SYDATP=S0DATP                                                    
07060C                   EVAL      SYNOPL=S0NOPL                                                    
07060C                   EVAL      ZXVIVA=0                                                         
07060C                   EVAL      ZXVNET=0                                                         
07060                                                                                               
07060C     KCOCAIM       SETLL     COCAIM                                                           
07060C     KCOCAIM       READE(N)  COCAIM                                 84                        
07060C                   DOW       READ2=*OFF                                                       
07060C                   EVAL      ZXVNET=ZXVNET+SYBIMP                                             
07060C                   EVAL      ZXVIVA=ZXVIVA+SYIIV1+SYIIV2                                      
07060C                   EXSR      CS_ZXCOCA2                                                       
07060C                   EVAL      ZXCOST=ZXCOST+(SYCOST*ZXCOCAM2)                                  
07060C     KCOCAIM       READE(N)  COCAIM                                 84                        
07060C                   ENDDO                                                                      
07060                                                                                               
07060                                                                                               
07060* Si queremos acumular costes adicionales, en lugar de coger el coste del                     
07060* COCAIM, leeremos los artículos del pedido y acumularemos su coste + C.Ad                    
07060C                   IF        MCACOS = '1'                                                     
07060C                   EXSR      CS_COSADI                                                        
07060C                   ENDIF                                                                      
07060                                                                                               
07060 * Los descuentos a utilizar serán los previstos salvo que exista precio co                    
07060C                   EVAL      ZXDTO11=S0DTO1                                                   
07060C                   EVAL      ZXDTO21=S0DTO2                                                   
07060C                   EVAL      ZXDTO31=S0DTO3                                                   
07060C                   EVAL      ZXDTO41=S0DTO4                                                   
07060C                   IF        S0CAMC<>0                                                        
07060C                   EVAL      ZXDTO11=S0DT1C                                                   
07060C                   EVAL      ZXDTO21=S0DT1C                                                   
07060C                   EVAL      ZXDTO31=S0DT1C                                                   
07060C                   EVAL      ZXDTO41=S0DT1C                                                   
07060C                   ENDIF                                                                      
07060 * Trato los dtos sobre pedido                                                                 
07060C                   EVAL      XZAUXI=ZXVNET                                                    
07060 * DTO1                                                                                        
07060C                   EVAL      XZAUXI1=XZAUXI*ZXDTO11                                           
07060C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
07060C                   EVAL      XZAUXI=XZAUXI-XZAUXI1                                            
07060 * DTO2                                                                                        
07060C                   EVAL      XZAUXI1=XZAUXI *ZXDTO21                                          
07060C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
07060C                   EVAL      XZAUXI =XZAUXI -XZAUXI1                                          
07060 * DTO3                                                                                        
07060C                   EVAL      XZAUXI1=XZAUXI *ZXDTO31                                          
07060C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
07060C                   EVAL      XZAUXI =XZAUXI -XZAUXI1                                          
07060 * DTO4                                                                                        
07060C                   EVAL      XZAUXI1=XZAUXI *ZXDTO41                                          
07060C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
07060C                   EVAL      XZAUXI =XZAUXI -XZAUXI1                                          
07060                                                                                               
07060C                   EVAL(H)   ZXVNET=XZAUXI                                                    
07060                                                                                               
07060C                   EVAL      XZAUXI=ZXVIVA                                                    
07060 * DTO1                                                                                        
07060C                   EVAL      XZAUXI1=XZAUXI*ZXDTO11                                           
07060C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
07060C                   EVAL      XZAUXI=XZAUXI-XZAUXI1                                            
07060 * DTO2                                                                                        
07060C                   EVAL      XZAUXI1=XZAUXI *ZXDTO21                                          
07060C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
07060C                   EVAL      XZAUXI =XZAUXI -XZAUXI1                                          
07060 * DTO3                                                                                        
07060C                   EVAL      XZAUXI1=XZAUXI *ZXDTO31                                          
07060C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
07060C                   EVAL      XZAUXI =XZAUXI -XZAUXI1                                          
07060 * DTO4                                                                                        
07060C                   EVAL      XZAUXI1=XZAUXI *ZXDTO41                                          
07060C     XZAUXI1       DIV(H)    100           XZAUXI1                                            
07060C                   EVAL      XZAUXI =XZAUXI -XZAUXI1                                          
07060                                                                                               
07060C                   EVAL(H)   ZXVIVA=XZAUXI                                                    
07060 * Decimales de la moneda                                                                      
07060C                   EVAL      MBMONE=ZXMONV                                                    
07060C     KMSDIV0       CHAIN     MSDIV0                             81                            
07060                                                                                               
07060C                   EVAL      PXALPH=*BLANKS                                                   
07060C                   EVAL      PXNUM=ZXVNET*ZXCOCAMB                                            
07060C                   EVAL      ZXVTOT=PXNUM                                                     
07060C                   CALL      'PRD650'                                                         
07060C                   PARM                    PXNUM                                              
07060C                   PARM                    PXALPH                                             
07060C                   PARM                    PXFLDD                                             
07060C                   PARM      MBDECI        PXDCCD                                             
07060C                   PARM                    PXFMD1                                             
07060C                   PARM                    PXEDTC                                             
07060C                   PARM                    PXNMER                                             
07060C                   PARM                    PXTIPA                                             
07060C                   MOVE      PXALPH        ZXVNETA                                            
07060                                                                                               
07060C***                EXSR      CS_ZXCOCA2                                                       
07060C                   EVAL      PXALPH=*BLANKS                                                   
07060C***                EVAL      PXNUM=ZXVIVA*ZXCOCAM2                                            
07060C                   EVAL      PXNUM=ZXVIVA*ZXCOCAMB                                            
07060C                   EVAL      ZXVTOT=ZXVTOT+PXNUM                                              
07060C                   CALL      'PRD650'                                                         
07060C                   PARM                    PXNUM                                              
07060C                   PARM                    PXALPH                                             
07060C                   PARM                    PXFLDD                                             
07060C                   PARM      MBDECI        PXDCCD                                             
07060C                   PARM                    PXFMD1                                             
07060C                   PARM                    PXEDTC                                             
07060C                   PARM                    PXNMER                                             
07060C                   PARM                    PXTIPA                                             
07060C                   MOVE      PXALPH        ZXVIVAA                                            
07060                                                                                               
07060C                   EVAL      PXALPH=*BLANKS                                                   
07060C                   EVAL      PXNUM=ZXVTOT                                                     
07060C                   CALL      'PRD650'                                                         
07060C                   PARM                    PXNUM                                              
07060C                   PARM                    PXALPH                                             
07060C                   PARM                    PXFLDD                                             
07060C                   PARM      MBDECI        PXDCCD                                             
07060C                   PARM                    PXFMD1                                             
07060C                   PARM                    PXEDTC                                             
07060C                   PARM                    PXNMER                                             
07060C                   PARM                    PXTIPA                                             
07060C                   MOVE      PXALPH        ZXVTOTA                                            
07060                                                                                               
07060C                   EVAL      PXDCCD=2                                                         
07060C                   EVAL      PXEDTC='4'                                                       
07060C                   ENDSR                                                                      
07060 **************************************************************                                
07060 * SUBRUTINA CLACULO DE COEFICIENTE DE CAMBIO                   *                              
07060 *------------------------------------------------------------*                                
07060C     CS_ZXCOCA2    BEGSR                                                                      
07060C                   EVAL      @PDATA=S0FPED                                                    
07060C                   TIME                    @PHORA                                             
07060C                   IF        @PDATA=*ZEROS                                                    
07060C                   EVAL      @PDATA=ZZDATS                                                    
07060C                   ENDIF                                                                      
07060 * Busco el primer cambio existente al comenzar Enero a las 12 horas                           
07060 * si se desean cambios en el momento de entrada                                               
07060C                   IF        MCTFHV='1'                                                       
07060C                   EVAL      @PDATA=S0FREP                                                    
07060C                   IF        S0FRRE>0                                                         
07060C                   EVAL      @PDATA=S0FRRE                                                    
07060C                   ENDIF                                                                      
07060C                   ENDIF                                                                      
07060                                                                                               
07060C                   IF        @PDATA=*ZEROS                                                    
07060C                   EVAL      @PDATA=*DATE                                                     
07060C                   ENDIF                                                                      
07060                                                                                               
07060C                   EVAL      ZXCAMC=S0CAMB                                                    
07060C                   EVAL      ZXCMPC=S0CMPR                                                    
07060C                   IF        S0CAMC<>0                                                        
07060C                   EVAL      ZXCAMC=S0CAMC                                                    
07060C                   EVAL      ZXCMPC=S0CMPC                                                    
07060C                   ENDIF                                                                      
07060                                                                                               
07060C                   EVAL      ZXCOCAM2=1                                                       
07060C                   IF        SYCOMO<>S0MONE                                                   
07060C                   CALL      'MM2555'                                                         
07060C                   PARM                    @PCIAS                                             
07060C                   PARM      SYCOMO        @PMON1                                             
07060C                   PARM      S0MONE        @PMON2                                             
07060C                   PARM                    @PDATA                                             
07060C                   PARM                    @PHORA                                             
07060C                   PARM      0             @PCMCOCO                                           
07060C                   PARM      0             @PCMCCCO                                           
07060C                   PARM      *BLANKS       @PEERR                                             
07060C                   EVAL      ZXCOCAM2=@PCMCCCO                                                
07060C                   ENDIF                                                                      
07060                                                                                               
07060                                                                                               
07060C                   ENDSR                                                                      
07060 **************************************************************                                
07060 * SUBRUTINA CALCULO COSTES ADICIONALES                         *                              
07060 *------------------------------------------------------------*                                
07060C     CS_COSADI     BEGSR                                                                      
07060C                   EVAL      ZXCOST = 0                                                       
07060C                   EXSR      CS_ZXCOCA3                                                       
07060                                                                                               
07060C                   EVAL      S5CIAS = S0CIAS                                                  
07060C                   EVAL      S5DLGA = S0DLGA                                                  
07060C                   EVAL      S5NPCO = S0NPCO                                                  
07060C                   EVAL      S5TPED = S0TPED                                                  
07060C                   EVAL      S5DATP = S0DATP                                                  
07060C                   EVAL      S5NOPL = S0NOPL                                                  
07060C     KCODEPE       SETLL     CODEPE                                                           
07060C     KCODEPE       READE     CODEPE                                                           
07060C                   DOW       NOT %EOF                                                         
07060                                                                                               
07060C     KMSARTI00     CHAIN     MSARTI00                                                         
07060C                   IF        %FOUND                                                           
07060C                   SELECT                                                                     
07060C                   WHEN      M5TCOS = '0'                                                     
07060C                   EVAL      ZXCOST = ZXCOST +(M5COSU * S5CANT) * ZXCOCAM3                    
07060C                   WHEN      M5TCOS = '1'                                                     
07060C                   EVAL      ZXCOST = ZXCOST +(M5COSP * S5CANT) * ZXCOCAM3                    
07060C                   WHEN      M5TCOS = '2'                                                     
07060C                   EVAL      ZXCOST = ZXCOST +(M5COSM * S5CANT) * ZXCOCAM3                    
07060C                   ENDSL                                                                      
07060                                                                                               
07060C                   EXSR      CS_MSACOS                                                        
07060C                   ENDIF                                                                      
07060C     KCODEPE       READE     CODEPE                                                           
07060C                   ENDDO                                                                      
07060                                                                                               
07060C                   ENDSR                                                                      
07060 **************************************************************                                
07060 * SUBRUTINA CLACULO DE COEFICIENTE DE CAMBIO                   *                              
07060 *------------------------------------------------------------*                                
07060C     CS_ZXCOCA3    BEGSR                                                                      
07060C                   EVAL      @PDATA=S5DATP                                                    
07060C                   TIME                    @PHORA                                             
07060C                   IF        @PDATA=*ZEROS                                                    
07060C                   EVAL      @PDATA=ZZDATS                                                    
07060C                   ENDIF                                                                      
07060* Busco el primer cambio existente al comenzar Enero a las 12 horas                           
07060* si se desean cambios en el momento de entrada                                               
07060                                                                                               
07060C                   IF        MCTFHV='1'                                                       
07060C                   EVAL      @PDATA=ZZDATS                                                    
07060C                   ENDIF                                                                      
07060                                                                                               
07060C                   IF        @PDATA=*ZEROS                                                    
07060C                   EVAL      @PDATA=*DATE                                                     
07060C                   ENDIF                                                                      
07060                                                                                               
07060C                   EVAL      ZXCOCAM3=1                                                       
07060C                   IF        ZZMONE <> S0MONE                                                 
07060C                   CALL      'MM2555'                                                         
07060C                   PARM                    @PCIAS                                             
07060C                   PARM      ZZMONE        @PMON1                                             
07060C                   PARM      S0MONE        @PMON2                                             
07060C                   PARM                    @PDATA                                             
07060C                   PARM                    @PHORA                                             
07060C                   PARM      0             @PCMCOCO                                           
07060C                   PARM      0             @PCMCCCO                                           
07060C                   PARM      *BLANKS       @PEERR                                             
07060C                   EVAL      ZXCOCAM3=@PCMCCCO                                                
07060C                   ENDIF                                                                      
07060                                                                                               
07060C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE CONTROLA ELS POSSIBLES ERRORS DE PROGRAMA    *                                
      *------------------------------------------------------------*                                
FQ799C     CS_UT2725     BEGSR                                                                      
FQ799C                   CALL      'UT2725'                             55                          
FQ799C                   PARM      @PCIAS        @PECIAS                                            
FQ799C                   PARM      S0DLGA        @PEDLGA                                            
FQ799C                   PARM      S0NPCO        @PENPCO                                            
FQ799C                   PARM      S0TPED        @PETPED                                            
FQ799C                   PARM      S0DATP        @PEDATP                                            
FQ799C                   PARM      S0NOPL        @PENOPL                                            
FQ799C                   PARM                    @PELINE                                            
FQ799C                   PARM      S0CUST        @PECLPR                                            
FQ799C                   PARM      'COCAPE'      @PEFILE                                            
FQ799C                   PARM                    @PEFILD                                            
