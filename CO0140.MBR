31712 *------------------------------------------------------------------------*                    
31712C     CS_PLZCNJ     BEGSR                                                                      
31712C                   CLEAR                   ZXFEPL                                             
13B12C                   CLEAR                   ZXTPLZ                                             
29B12C                   CLEAR                   ZXFSTX                                             
31712C                   EVAL      NDARTI=S5ARTI                                                    
31712C                   EVAL      NDVARI=S5VARI                                                    
