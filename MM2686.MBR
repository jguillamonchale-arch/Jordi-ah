     C                   EVAL      P6CIAS=@PCIAS                                                    
     C                   EVAL      M5ARTI=@PARTI                                                    
     C                   EVAL      M5VARI=@PVARI                                                    
     C                   EVAL      M5MODE=@PMODE                                                    
     C                   EVAL      NDCIAS=@PCIAS                                                    
     C                   EVAL      MDCIAS=@PCIAS                                                    
     C                   EVAL      ZXOPT1='CHK'                                                     
      * Si ZXERRO='A' en @PVOLU=0., no continuo                                                     
     C                   IF        ZXERRO='A' AND @PVOLU<=0                                         
     C                   EVAL      @PCAST=0                                                         
     C                   EVAL      @PPBRU=0                                                         
20032C                   IF        %PARMS>=18                                                       
20032C                   EVAL      @PPNET=0                                                         
20032C                   EndIf                                                                      
     C                   EVAL      @PPBRU=0                                                         
     C                   EVAL      @PNBUL=0                                                         
     C                   EVAL      ZXOPT='END'                                                      
     C                   ENDIF                                                                      
     C                   IF        ZXERRO='A'                                                       
     C                   EVAL      ZXPVOLU=@PVOLU                                                   
     C                   ENDIF                                                                      
      * Si viene informado el contenedor                                                            
     C                   IF        @PTCT1<>*BLANKS                                                  
     C                   EVAL      PECTAB='TCT1'                                                    
     C                   EVAL      PECLTA=*BLANKS                                                   
     C                   EVAL      PECLTA=@PTCT1                                                    
     C                   EVAL      PEBL65=*BLANKS                                                   
     C     KPMTABD       CHAIN     PMTABD                             81                            
     C                   EVAL      ZXBL63TC=PEBL63                                                  
      * Transformación de unidades de longitud para tema de containers                              
     C                   EVAL      ZXUN10=ZXUNMETC                                                  
     C                   EVAL      ZXUN11=@PUMED                                                    
     C                   EXSR      CS_SRD041                                                        
      * Transformacion numerica largo ancho alto.                                                   
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXALPH=ZXLONGTC                                                  
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                                              
