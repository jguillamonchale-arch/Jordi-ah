     C                   EVAL      ZXERRO=@PERRO                                                    
     C                   EVAL      @PERRO=*BLANKS                                                   
     C                   EVAL      PECIAS=@PCIAS                                                    
     C                   EVAL      MOCIAS=@PCIAS                                                    
     C                   EVAL      MOARTI=@PARTI                                                    
     C                   EVAL      MOVARI=@PVARI                                                    
     C                   EVAL      MOMODE=@PMODE                                                    
