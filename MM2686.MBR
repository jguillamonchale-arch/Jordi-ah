     C                   DOW       ZXOPT1 <> 'END'                                                  
     C     ZXOPT1        CASEQ     'CHK'         SUBCHK                                             
     C     ZXOPT1        CASEQ     'UPD'         SUBUPD                                             
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
                                                                                                    
20032C                   IF        %PARMS>=18                                                       
20032C                   EVAL      @PPNET=ZXPNET                                                    
20032C                   ENDIF                                                                      
     C                   SETON                                        LR                            
