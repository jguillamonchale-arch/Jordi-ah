FGI25C                   eval      t1ctab='MTSO'                                                    
FGI25C                   eval      t1cele=P2mCATA                                                   
FGI25C     kgmtabd00     chain     gmtabd00                                                         
FGI25C                   if        not %found(gmtabd00)                                             
FGI25C                   EVAL      WRK40=*ON                                                        
FGI25C                   EVAL      ERRGRL=*ON                                                       
FGI25C                   EVAL      MSGER='MSG0301'                                                  
FGI25C                   ENDIF                                                                      
FGI25C     ERRGRL        CABEQ     *ON           TP2mCHK                                            
FGI25C                   EVAL      P2HDES1=PEDESC                                                   
FGI25C     TP2mCHK       TAG                                                                        
FGI25C                   IF        ERRGRL=*ON                                                       
FGI25C                   EVAL      ZXOPT2='DSP'                                                     
FGI25C                   ENDIF                                                                      
FGI25C                   ENDSR                                                                      
FGI25 **************************************************************                                
FGI25 * SUBRUTINA DE ACTUALIZACION DEL FMT P2m                     *                                
FGI25 *------------------------------------------------------------*                                
FGI25C     P2mUPD        BEGSR                                                                      
FGI25C                   EVAL      ZXOPT='END'                                                      
FGI25                                                                                               
FGI25 * En el caso de la opción de visualiza no actualizo                                           
FGI25C                   IF        (INDDSP=*ON AND CONFIR=*OFF)                                     
FGI25C                             OR (INDDLT=*ON AND CONFIR=*OFF)                                  
FGI25C                   leavesr                                                                    
FGI25C                   ENDIF                                                                      
FGI25 *                                                                                             
FGI25C                   EVAL      T4FAMT=P2mcata                                                   
FGI25C     KEDPAR2       CHAIN     EDPAR2                             81                            
FGI25 *                                                                                             
FGI25C                   EXSR      P2mMPF                                                           
FGI25 *                                                                                             
FGI25C                   IF        CHAIN=*OFF                                                       
FGI25C                   UPDATE    REDPAR2                                                          
FGI25C                   ELSE                                                                       
FGI25C                   EVAL      T4DAT1=*DATE                                                     
FGI25C                   WRITE     REDPAR2                                                          
FGI25C                   ENDIF                                                                      
FGI25C                   IF        INDDLT=*ON                                                       
FGI25C                   EXSR      CS_DLTREG                                                        
FGI25C                   ENDIF                                                                      
FGI25C                   ENDSR                                                                      
FGI25 **************************************************************                                
FGI25 * SUBRUTINA PASAR DE PANTALLA P2m A FICHERO                  *                                
FGI25 *------------------------------------------------------------*                                
FGI25C     P2mMPF        BEGSR                                                                      
FGI25 *                                                                                             
FGI25C                   EVAL      T4FAMT=P2mcata                                                   
FGI25C                   EVAL      T4DAT8=*DATE                                                     
FGI25C                   EVAL      T4USUA=SDSUSR                                                    
FGI25C                   EVAL      T4PANT=SDSJOB                                                    
FGI25C                   TIME                    T4HORA                                             
FGI25 *                                                                                             
FGI25C                   ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA DE POSICIONAMENT DEL CURSOR                      *                                
      *------------------------------------------------------------*                                
     C     CS_POCUR2     BEGSR                                                                      
      * OBTENIM LA POSICIO DEL CURSOR                                                               
     C     FMTPOCUR      DIV       256           CSRFILA                                            
     C                   MVR                     CSRCOLU                                            
     C                   ENDSR                                                                      
      *                                                                                             
      **************************************************************                                
      * SUBRUTINA QUE CONTROLA ELS POSSIBLES ERRORS DE PROGRAMA    *                                
      *------------------------------------------------------------*                                
     C/COPY *LIBL/QSRDSRC,SRD020                                                                    
