     D  T4AMPL         DS                                                                           
     D     T4OPL1              1      3                                                             
     D     T4OPL2              4      6                                                             
     D     T4RESE              7      7                                                             
     D     T4RTRE              8      8                                                             
     D     T4LVIR              9     11                                                             
      *                                                                                             
      * DEFINICIO DE CAMPS DE TREBALL                                                               
      *                                                                                             
     D  Z_P            S              2  0 INZ(1)                                                   
     D  ZXPTRETORN     S              6A   INZ                                                      
                                                                                                    
     D  ZXPRIO         S                   LIKE(T4PRIO)                                             
     IRPMTAB2                                                                                       
     I              PECIAS                      XXCIAS                                              
      **************************************************************                                
      * RUTINA PRINCIPAL DEL PGM : DISTRIBUCIÓ DEL PAS PELS FMTS   *                                
      *------------------------------------------------------------*                                
     C     ZXOPT1        DOWNE     'END'                                                            
     C     ZXOPT1        CASEQ     'P2B'         P2BMAIN                                            
     C     ZXOPT1        CASEQ     'P2C'         P2CMAIN                                            
     C     ZXOPT1        CASEQ     'P2D'         P2DMAIN                                            
     C     ZXOPT1        CASEQ     'P2E'         P2EMAIN                                            
     C     ZXOPT1        CASEQ     'P2F'         P2FMAIN                                            
     C     ZXOPT1        CASEQ     'P2G'         P2GMAIN                                            
     C     ZXOPT1        CASEQ     'P2H'         P2HMAIN                                            
FGI25C     ZXOPT1        CASEQ     'P2M'         P2MMAIN                                            
     C                   CAS                     P2BMAIN                                            
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
     C                   SETON                                        LR                            
