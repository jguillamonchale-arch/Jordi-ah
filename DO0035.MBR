     C                   EVAL      ZXOPT2='UPD'                                                     
     C                   IF        INDCRT=*ON                                                       
     C                   EVAL      T4FAMT=P2HPPED                                                   
     C                   EVAL      T4PRVR=@PPRVR                                                    
     C                   EVAL      T4ARVT=@PARVT                                                    
     C                   EVAL      T4PRIO=@PPRIO                                                    
     C                   EVAL      T4CIA2=@PCIA2                                                    
     C                   EVAL      T4MAGA=@PMAGA                                                    
     C     KEDPAR2       CHAIN     EDPAR2                                                           
     C                   IF        %FOUND                                                           
     C                   EVAL      WRK40=*ON                                                        
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MSG0301'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2HCHK                                            
     C                   ENDIF                                                                      
      *                                                                                             
     C                   EVAL      PECTAB='PPED'                                                    
     C                   EVAL      PECLTA=P2HPPED                                                   
     C     KPMTABD       CHAIN     PMTABD                                                           
     C                   IF        NOT%FOUND                                                        
     C                   EVAL      WRK40=*ON                                                        
