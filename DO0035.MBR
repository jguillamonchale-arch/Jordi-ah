     C                   EVAL      MSGER='MSG0301'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2HCHK                                            
     C                   EVAL      P2HDES1=PEDESC                                                   
     C     TP2HCHK       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
     C                   ENDSR                                                                      
