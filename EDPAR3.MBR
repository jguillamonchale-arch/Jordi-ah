     A                                      COLHDG('OMITIR DISP.OBSOLE  ')                          
IT244A            T5MASI         5S 2       TEXT('%MINIMO ASIGNACION ')                             
IT244A                                      COLHDG('%MIN. ASIGNAC.  ')                              
     A          K T5CIAS                                                                            
     A          K T5MAGA                                                                            
