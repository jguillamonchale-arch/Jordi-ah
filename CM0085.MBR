      *------------------------------------------------------------*                                
     C     S01CMD        BEGSR                                                                      
     C                   EVAL      ZXOPT2='CHK'                                                     
     C                   EXSR      CS_SFLCMD                                                        
     C     S01CMDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DEL SFL: FORMAT SFL I OPCIONS          *                                
      *------------------------------------------------------------*                                
     C     S01CHK        BEGSR                                                                      
     C                   EVAL      ZXOPT2='DSP'                                                     
                                                                                                    
      * SUBRUTINA COMÚ DE VALIDACIÓ DEL SFL                                                         
     C                   EXSR      CS_SFLCHK                                                        
                                                                                                    
     C     S01CHKT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE NETEJA DEL SFL                                *                                
      *------------------------------------------------------------*                                
     C     S01CLR        BEGSR                                                                      
     C                   EVAL      ZXOPT='S01INZ'                                                   
     C                   EVAL      CCCFMT='1'                                                       
     C                   MOVEA     ZXZERO10      *IN(90)                                            
     C                   EVAL      INPOS01=*ON                                                      
     C                   EXSR      CS_SFLCLR                                                        
     C                   EXSR      CS_SETLL01                                                       
     C     S01CLRT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL SFL S012                              *                               
      *------------------------------------------------------------*                                
     C     CS_SETLL01    BEGSR                                                                      
     C                   EVAL      EOF=*OFF                                                         
     C                   EVAL      READ1=*OFF                                                       
     C                   EVAL      S0DLGA=ZXDLGA                                                    
     C                   EVAL      S0CUST=ZXCUST                                                    
                                                                                                    
FQ365C     KCOCAPE25     SETLL     COCAPE25                                                         
                                                                                                    
     C     SETLL01       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL SFL S012                              *                               
      *------------------------------------------------------------*                                
     C     CS_SETLL1B    BEGSR                                                                      
     C                   EVAL      S0DLGA=ZXDLGA                                                    
     C                   EVAL      S0CUST=ZXCUST                                                    
                                                                                                    
     C     KCMA04024     SETLL     CMA04024                                                         
                                                                                                    
     C     SETLL01B      ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL SFL S02                              *                                
      *------------------------------------------------------------*                                
     C     S02MAIN       BEGSR                                                                      
     C                   DOW       ZXOPT1='S02'                                                     
     C     ZXOPT2        CASEQ     'CLR'         S02CLR                                             
     C     ZXOPT2        CASEQ     'INZ'         S02INZ                                             
     C     ZXOPT2        CASEQ     'DSP'         S02DSP                                             
     C     ZXOPT2        CASEQ     'CMD'         S02CMD                                             
     C     ZXOPT2        CASEQ     'CHK'         S02CHK                                             
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ I CARREGA DEL SFL                 *                                
      *------------------------------------------------------------*                                
     C     S02INZ        BEGSR                                                                      
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   EXSR      CS_SFLIN1                                                        
                                                                                                    
     C                   DOW       ZXLOP00 < ZXLIPAG                                                
     C                   EVAL      ZXFILE=' '                                                       
     C                   EXSR      CS_READ02                                                        
     C* Cargo el máximo de 204 registros                                                            
     C                   IF        ZXNRR00>ZXSFLSIZ                                                 
     C                   EVAL      EOF=*ON                                                          
     C                   ENDIF                                                                      
     C                   IF        EOF=*ON                                                          
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   EXSR      CS_SELSFL                                                        
     C                   IF        ZXSELSFL=1                                                       
     C                   GOTO      TNEXRE02                                                         
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        INDPRO2=*ON AND S0TPED<>@PTPED                                   
     C                   GOTO      TNEXRE02                                                         
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ZXNRR00=ZXNRR00 + 1                                              
     C                   EVAL      ZXLOP00=ZXLOP00 + 1                                              
     C                   EXSR      CS_MOVFP                                                         
     C                   EXSR      CS_SAVFK                                                         
     C                   WRITE     SUFD                                                             
     C     TNEXRE02      TAG                                                                        
     C                   ENDDO                                                                      
                                                                                                    
     C* LESTURA DEL FICHERO DE ALBARANES DIRECTOS                                                   
     C                   EXSR      CS_SETLL2B                                                       
     C                   EXSR      S02INZB                                                          
      *                                                                                             
     C                   EXSR      CS_SFLIN2                                                        
     C     S02INZT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ I CARREGA DEL SFL                 *                                
      *------------------------------------------------------------*                                
     C     S02INZB       BEGSR                                                                      
     C                   EVAL      ZXOPT2='DSP'                                                     
                                                                                                    
     C                   DOW       ZXLOP00 < ZXLIPAG                                                
     C                   EVAL      ZXFILE='1'                                                       
     C                   EXSR      CS_READ02B                                                       
     C* Cargo el máximo de 204 registros                                                            
     C                   IF        ZXNRR00>ZXSFLSIZ                                                 
     C                   EVAL      EOF=*ON                                                          
     C                   ENDIF                                                                      
     C                   IF        EOF=*ON                                                          
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   EXSR      CS_SELSFL                                                        
     C                   IF        ZXSELSFL=1                                                       
     C                   GOTO      TNEXRE02B                                                        
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        INDPRO2=*ON AND S0TPED<>@PTPED                                   
     C                   GOTO      TNEXRE02B                                                        
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ZXNRR00=ZXNRR00 + 1                                              
     C                   EVAL      ZXLOP00=ZXLOP00 + 1                                              
     C                   EXSR      CS_MOVFP                                                         
     C                   EXSR      CS_SAVFK                                                         
     C                   WRITE     SUFD                                                             
     C     TNEXRE02B     TAG                                                                        
     C                   ENDDO                                                                      
                                                                                                    
     C     S02INZBT      ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL SFL S02                              *                                
      *------------------------------------------------------------*                                
     C     CS_READ02     BEGSR                                                                      
                                                                                                    
     C     KCOCAPE0      READE     COCAPE23                               82                        
                                                                                                    
     C     READ02T       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL SFL S02                              *                                
      *------------------------------------------------------------*                                
     C     CS_READ02B    BEGSR                                                                      
                                                                                                    
     C     KCMA0400      READE     CMA040                                 82                        
                                                                                                    
     C     READ02BT      ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VISUALITZACIÓ SFL                                *                                
      *------------------------------------------------------------*                                
     C     S02DSP        BEGSR                                                                      
     C                   EVAL      ZXOPT2='CMD'                                                     
     C                   IF        ZZNPGM=' '                                                       
     C                   EVAL      PPPCMD1='CMD3041'                                                
     C                   ELSE                                                                       
     C                   EVAL      PPPCMD1='CMD3041'                                                
     C                   ENDIF                                                                      
     C                   EVAL      SUFHED1='HCM0851'                                                
                                                                                                    
     C                   EXSR      CS_SFLDSP                                    SI REGS             
     C     S02DSPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CMD'S                             *                                
      *------------------------------------------------------------*                                
     C     S02CMD        BEGSR                                                                      
     C                   EVAL      ZXOPT2='CHK'                                                     
     C                   EXSR      CS_SFLCMD                                                        
     C     S02CMDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DEL SFL: FORMAT SFL I OPCIONS          *                                
      *------------------------------------------------------------*                                
     C     S02CHK        BEGSR                                                                      
     C                   EVAL      ZXOPT2='DSP'                                                     
                                                                                                    
      * SUBRUTINA COMÚ DE VALIDACIÓ DEL SFL                                                         
     C                   EXSR      CS_SFLCHK                                                        
                                                                                                    
     C     S02CHKT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE NETEJA DEL SFL                                *                                
      *------------------------------------------------------------*                                
     C     S02CLR        BEGSR                                                                      
     C                   EVAL      ZXOPT2='INZ'                                                     
     C                   EVAL      CCCFMT='2'                                                       
     C                   MOVEA     ZXZERO10      *IN(90)                                            
     C                   EVAL      INPOS02=*ON                                                      
     C                   EXSR      CS_SFLCLR                                                        
     C                   EXSR      CS_SETLL02                                                       
     C     S02CLRT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL SFL S022                              *                               
      *------------------------------------------------------------*                                
     C     CS_SETLL02    BEGSR                                                                      
     C                   EVAL      S0DLGA=ZXDLGA                                                    
     C                   EVAL      S0NPCO=ZXNPCO                                                    
     C                   EVAL      S0TPED=ZXTPED                                                    
                                                                                                    
     C     KCOCAPE23     SETLL     COCAPE23                                                         
                                                                                                    
     C     SETLL02       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL SFL S022                              *                               
      *------------------------------------------------------------*                                
     C     CS_SETLL2B    BEGSR                                                                      
     C                   EVAL      S0DLGA=ZXDLGA                                                    
     C                   EVAL      S0NPCO=ZXNPCO                                                    
     C                   EVAL      S0TPED=ZXTPED                                                    
                                                                                                    
     C     KCMA04011     SETLL     CMA040                                                           
                                                                                                    
     C     SETLL22B      ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA INICIAL PARA PANTALL                                                              
      *------------------------------------------------------------*                                
     C     PA0MAIN       BEGSR                                                                      
     C                   DOW       ZXOPT1='PA0'                                                     
     C     ZXOPT2        CASEQ     'CLR'         PA0CLR                                             
     C     ZXOPT2        CASEQ     'INZ'         PA0INZ                                             
     C     ZXOPT2        CASEQ     'DSP'         PA0DSP                                             
     C     ZXOPT2        CASEQ     'CMD'         PA0CMD                                             
     C     ZXOPT2        CASEQ     'CHK'         PA0CHK                                             
     C     ZXOPT2        CASEQ     'UPD'         PA0UPD                                             
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
     C     PA0MAINT      ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE NETEJA DE PA0                                 *                                
      *------------------------------------------------------------*                                
     C     PA0CLR        BEGSR                                                                      
     C                   EVAL      ZXOPT2='INZ'                                                     
     C     *NOKEY        CLEAR     *ALL          RPMSETP                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C     PA0CLRT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE INICI DE PA0                                 *                                 
      *------------------------------------------------------------*                                
     C     PA0INZ        BEGSR                                                                      
     C     KMSSETP       CHAIN (N) PMSETP                             81                            
     C                   CLEAR                   CM0085                                             
     C     PIDATR        CAT       CM0085:0      CM0085                                             
     C                   EXSR      CS_MOVFP                                                         
                                                                                                    
     C                   EVAL      ZXOPT2='DSP'                                                     
     C     PA0INZT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VISUALITZACIÓ DE PA0                             *                                
      *------------------------------------------------------------*                                
     C     PA0DSP        BEGSR                                                                      
     C                   EVAL      ZXOPT2='CMD'                                                     
     C                   EVAL      PPPCMD1='CMD3031'                                                
     C                   EXFMT     PA0                                                              
     C                   EVAL      ERRGRL=*OFF                                                      
     C                   EVAL      MSGER=*BLANKS                                                    
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
                                                                                                    
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C     PA0DSPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CMD'S                             *                                
      *------------------------------------------------------------*                                
     C     PA0CMD        BEGSR                                                                      
     C                   EVAL      ZXOPT2='CHK'                                                     
                                                                                                    
     C                   SELECT                                                                     
                                                                                                    
      * F03=FINALITZAR                                                                              
     C                   WHEN      EXIT=*ON                                                         
     C                   EVAL      ZXOPT1='END'                                                     
                                                                                                    
      * F04=AJUDA DE CAMPS                                                                          
     C                   WHEN      HELP=*ON                                                         
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   EXSR      CS_POSCUR                                                        
                                                                                                    
     C                   IF        FIELD='PA0DROP'                                                  
     C                   EVAL      @PEFMT=*BLANKS                                                   
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEFLD='DROP'                                                    
     C                   CALL      'MMPROM'                                     Query-Aut-F4   X    
     C                   PARM      *BLANKS       @PEOPT                         PARM Qry-F4         
     C                   PARM      *BLANKS       @PEPGM                         PARM Qry-F4         
     C                   PARM      *BLANKS       @PEFMT                         PARM Qry-F4         
     C                   PARM                    @PEFLD                         PARM Qry-F4         
     C                   PARM      *BLANKS       @PEERR                         PARM Qry-F4         
                                                                                                    
     C                   IF        @PEERR>'0'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ADP0304'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PA0CMDT                                            
      * Si no han realizado ninguna selección no tocamos nada                                       
     C                   IF        @PEERR='A'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PA0CMDT                                            
     C                   EVAL      PA0DROP=@PEOPT                                                   
     C                   GOTO      TPA0F4                                                           
     C                   ENDIF                                                                      
      * Ayudas en tablas                                                                            
     C                   IF        FIELD='PA0DLGA'                                                  
     C                   EVAL      @PCLTA=*BLANKS                                                   
     C                   EVAL      @PCTAB=*BLANKS                                                   
     C                   EVAL      @PCTAB=ZXFIE4                                                    
     C                   EVAL      @PCLTA=PA0DLGA                                                   
                                                                                                    
     C                   CALL      'MMTABL'                                     Query-Aut-F4   X    
     C                   PARM                    @PCLTA                         PARM Qry-F4         
     C                   PARM                    @PCTAB                         PARM Qry-F4         
     C                   PARM                    @PCIAS                         PARM Qry-F4         
     C                   PARM                    @PEERR                         PARM Qry-F4         
                                                                                                    
     C                   IF        @PEERR>'0'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ADP0304'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PA0CMDT                                            
      * Si no han realizado ninguna selección no tocamos nada                                       
     C                   IF        @PEERR='A'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PA0CMDT                                            
      *                                                                                             
     C                   EVAL      PA0DLGA=@PCLTA                                                   
                                                                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        FIELD='PA0TDOC'                                                  
     C                   CALL      'MMPROM'                                     Query-Aut-F4   X    
     C                   PARM      *BLANKS       @PEOPT                         PARM Qry-F4         
     C                   PARM      SDSPGM        @PEPGM                         PARM Qry-F4         
     C                   PARM      'PA0      '   @PEFMT                         PARM Qry-F4         
     C                   PARM      'PA0TDOC  '   @PEFLD                         PARM Qry-F4         
     C                   PARM      *BLANKS       @PEERR                         PARM Qry-F4         
                                                                                                    
     C                   IF        @PEERR>'0'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ADP0304'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PA0CMDT                                            
      * Si no han realizado ninguna selección no tocamos nada                                       
     C                   IF        @PEERR='A'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           PA0CMDT                                            
     C                   EVAL      PA0TDOC=@PEOPT                                                   
     C                   GOTO      PA0CMDT                                                          
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        FIELD='PA0S001'                                                  
     C                   EVAL      @PEFMT=*BLANKS                                                   
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEFLD='CFMT'                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        FIELD='PA0DROP'                                                  
     C                   EVAL      PA0DROP=@PEOPT                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        FIELD='PA0SE01' OR FIELD='PA0SE02'                               
     C                             OR FIELD='PA0SE03' OR FIELD='PA0SE04'                            
     C                             OR FIELD='PA0SE05' OR FIELD='PA0SE06'                            
     C                   EVAL      @PEFMT=*BLANKS                                                   
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEFLD='SECP'                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   CALL      'MMPROM'                                     Query-Aut-F4   X    
     C                   PARM      *BLANKS       @PEOPT                         PARM Qry-F4         
     C                   PARM      SDSPGM        @PEPGM                         PARM Qry-F4         
     C                   PARM                    @PEFMT                         PARM Qry-F4         
     C                   PARM                    @PEFLD                         PARM Qry-F4         
     C                   PARM      *BLANKS       @PEERR                         PARM Qry-F4         
                                                                                                    
     C                   IF        @PEERR>'0'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   IF        FIELD='PA0S001'                                                  
     C***                EVAL      WRK40=*ON                                                        
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        FIELD='PA0SE01' OR FIELD='PA0SE02'                               
     C                             OR FIELD='PA0SE03' OR FIELD='PA0SE04'                            
     C                             OR FIELD='PA0SE05' OR FIELD='PA0SE06'                            
     C                   EVAL      WRK41=*ON                                                        
     C                   ENDIF                                                                      
     C                   EVAL      MSGER='ADP0304'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TPA0F4                                             
      * Si no han realizado ninguna selección no tocamos nada                                       
     C                   IF        @PEERR='A'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TPA0F4                                             
      *                                                                                             
     C                   IF        FIELD='PA0S001'                                                  
     C                   EVAL      PA0S001=@PEOPT                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        FIELD='PA0SE01' OR FIELD='PA0SE02'                               
     C                             OR FIELD='PA0SE03' OR FIELD='PA0SE04'                            
     C                             OR FIELD='PA0SE05' OR FIELD='PA0SE06'                            
     C                   IF        FIELD='PA0SE01'                                                  
     C                   EVAL      PA0SE01=@PEOPT                                                   
     C                   ENDIF                                                                      
     C                   IF        FIELD='PA0SE02'                                                  
     C                   EVAL      PA0SE02=@PEOPT                                                   
     C                   ENDIF                                                                      
     C                   IF        FIELD='PA0SE03'                                                  
     C                   EVAL      PA0SE03=@PEOPT                                                   
     C                   ENDIF                                                                      
     C                   IF        FIELD='PA0SE04'                                                  
     C                   EVAL      PA0SE04=@PEOPT                                                   
     C                   ENDIF                                                                      
     C                   IF        FIELD='PA0SE05'                                                  
     C                   EVAL      PA0SE05=@PEOPT                                                   
     C                   ENDIF                                                                      
     C                   IF        FIELD='PA0SE06'                                                  
     C                   EVAL      PA0SE06=@PEOPT                                                   
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C     TPA0F4        TAG                                                                        
     C     ERRGRL        CABEQ     *ON           PA0CMDT                                            
                                                                                                    
     C                   ENDSL                                                                      
                                                                                                    
     C     PA0CMDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DE PANTALLA PA0                        *                                
      *------------------------------------------------------------*                                
     C     PA0CHK        BEGSR                                                                      
     C                   EVAL      ZXOPT2='UPD'                                                     
      * VALIDACIO DE LES OPCIONS DE DETALL DE PA0                                                   
     C* Validación de PA0S001                                                                       
     C                   EVAL      @PEFMT=*BLANKS                                                   
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEOPT=*BLANKS                                                   
     C                   EVAL      @PEOPT=PA0S001                                                   
     C                   EVAL      @PEFLD='CFMT'                                                    
     C                   CALL      'MMPROM'                                     Query-Aut-F4   X    
     C                   PARM                    @PEOPT                         PARM Qry-F4         
     C                   PARM      SDSPGM        @PEPGM                         PARM Qry-F4         
     C                   PARM                    @PEFMT                         PARM Qry-F4         
     C                   PARM                    @PEFLD                         PARM Qry-F4         
     C                   PARM      'V'           @PEERR                         PARM Qry-F4         
                                                                                                    
     C                   IF        @PEERR>='0' AND PA0S001<>*BLANKS                                 
     C                             AND PA0S001<>'0'                                                 
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK40=*ON                                                        
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TPA0CHK                                            
                                                                                                    
     C* Validación de PA0DROP                                                                       
     C                   EVAL      @PEFMT=*BLANKS                                                   
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEOPT=*BLANKS                                                   
     C                   EVAL      @PEOPT=PA0DROP                                                   
     C                   EVAL      @PEFLD='DROP'                                                    
     C                   CALL      'MMPROM'                                     Query-Aut-F4   X    
     C                   PARM                    @PEOPT                         PARM Qry-F4         
     C                   PARM      *BLANKS       @PEPGM                         PARM Qry-F4         
     C                   PARM                    @PEFMT                         PARM Qry-F4         
     C                   PARM                    @PEFLD                         PARM Qry-F4         
     C                   PARM      'V'           @PEERR                         PARM Qry-F4         
                                                                                                    
     C                   IF        @PEERR>='0' AND PA0S001<>*BLANKS                                 
     C                             AND PA0S001<>'0'                                                 
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK44=*ON                                                        
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TPA0CHK                                            
                                                                                                    
     C* Validación de PA0TDOC                                                                       
     C                   EVAL      @PEFMT='PA0'                                                     
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEOPT=*BLANKS                                                   
     C                   EVAL      @PEOPT=PA0TDOC                                                   
     C                   EVAL      @PEFLD='PA0TDOC'                                                 
     C                   CALL      'MMPROM'                                     Query-Aut-F4   X    
     C                   PARM                    @PEOPT                         PARM Qry-F4         
     C                   PARM      'CM0085'      @PEPGM                         PARM Qry-F4         
     C                   PARM                    @PEFMT                         PARM Qry-F4         
     C                   PARM                    @PEFLD                         PARM Qry-F4         
     C                   PARM      'V'           @PEERR                         PARM Qry-F4         
                                                                                                    
     C                   IF        @PEERR>='0'                                                      
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK42=*ON                                                        
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TPA0CHK                                            
                                                                                                    
      * Validacion de la DELEGACION                                                                 
     C                   EVAL      PECIAS=@PCIAS                                                    
     C                   EVAL      PECTAB='DLGA      '                                              
     C                   EVAL      PECLTA=*BLANKS                                                   
     C                   EVAL      PECLTA=PA0DLGA                                                   
     C     KPMTABD       CHAIN     PMTABD                             81                            
     C                   IF        CHAIN=*ON OR PEBAJA='1'                                          
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   EVAL      WRK43=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TPA0CHK                                            
                                                                                                    
     C                   IF        ZZDLGA<>*BLANKS AND PA0DLGA<>ZZDLGA                              
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   EVAL      WRK43=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TPA0CHK                                            
FH002 *                                                                                             
FH002 * Validacion del Gestor de Riesgos                                                            
FH002 *                                                                                             
FH002 *     hay 3 posibles opciones:                                                                
FH002 *                                                                                             
FH002 *              1) En blanco= se seleccionan documentos de                                     
FH002 *                            clientes sin gestor asignado                                     
FH002 *                                                                                             
FH002 *              2) '*'      = se seleccionan todos los documentos                              
FH002 *                                                                                             
FH002 *              3) XXXXXXXX = se seleccionan documentos de                                     
FH002 *                            clientes con el gestor informado                                 
FH002 *                            asignado                                                         
FH002 *                                                                                             
FH002C                   IF        PA0GCSC='*         ' OR                                          
FH002C                             PA0GCSC=*BLANKS                                                  
FH002C                   GOTO      TPA0CHK                                                          
FH002C                   ENDIF                                                                      
FH002 *                                                                                             
FH002C                   EVAL      G0CONO=0                                                         
FH002C                   EVAL      G0GCSC=PA0GCSC                                                   
FH002C     KZQGCSC00     CHAIN     ZQGCSC00                                                         
FH002C                   IF        NOT %FOUND(ZQGCSC00)                                             
FH002C                   EVAL      ERRGRL=*ON                                                       
FH002C                   EVAL      MSGER='ASG1003'                                                  
FH002C                   EVAL      WRK47=*ON                                                        
FH002C                   ENDIF                                                                      
FH002C     ERRGRL        CABEQ     *ON           TPA0CHK                                            
FH002 *                                                                                             
                                                                                                    
     C     TPA0CHK       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C     PA0CHKT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA ACTUALITZACIO PANTALLA PA0                        *                               
      *------------------------------------------------------------*                                
     C     PA0UPD        BEGSR                                                                      
      * Actualización datos de PMSETUP                                                              
     C                   DOU       LCKRCD=*OFF                                                      
     C     KMSSETP       CHAIN     PMSETP                             8180                          
     C                   ENDDO                                                                      
     C                   CLEAR                   PIDATR                                             
     C                   EXSR      CS_MOVPF                                                         
     C     CM0085        CAT       PIDATR:0      PIDATR                                             
     C                   EVAL      PIDAT8=ZZDATS                                                    
     C                   TIME                    PIHORA                                             
     C                   EVAL      PIPANT=SDSJOB                                                    
     C                   EVAL      PIUSUA=SDSUSR                                                    
                                                                                                    
     C                   IF        CHAIN=*OFF                                                       
     C                   UPDATE    RPMSETP                                                          
     C                   ELSE                                                                       
     C                   EVAL      PIDAT1=PIDAT8                                                    
     C                   WRITE     RPMSETP                                                          
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ZXDLGA1=PA0DLGA                                                  
     C                   EVAL      ZXTDOC=PA0TDOC                                                   
FX002C                   EVAL      ZXGCSC=PA0GCSC                                                   
     C                   EVAL      ZXOPT='S01CLR'                                                   
     C                   EVAL      ZXFMT='0'                                                        
     C                   EVAL      ZXDROP='0'                                                       
     C                   IF        PA0DROP<>' ' AND PA0DROP<='1'                                    
     C                   EVAL      ZXDROP=PA0DROP                                                   
     C                   ENDIF                                                                      
     C                   EVAL      ZXTRAB=MQTRAB                                                    
                                                                                                    
     C* Limpieza de parametros de subarchivo                                                        
     C                   EVAL      ACCREF=*ON                                                       
     C                   EXSR      CS_CLRK                                                          
                                                                                                    
     C                   SELECT                                                                     
     C                   WHEN      PA0S001=' ' OR PA0S001='0'                                       
     C                   EVAL      ZXOPT='S01CLR'                                                   
     C                   WHEN      PA0S001='1'                                                      
     C                   EVAL      ZXOPT='S01CLR'                                                   
     C                   WHEN      PA0S001='7'                                                      
     C                   EVAL      ZXOPT='S02CLR'                                                   
     C                   ENDSL                                                                      
                                                                                                    
     C                   EVAL      ZXFPED=ZZDATS                                                    
     C                   EVAL      ZXFREP=ZZDATS                                                    
                                                                                                    
     C                   EVAL      ERRGRL=*ON                                                       
     C     PA0UPDT       ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA DE NETEJA DEL SFL                                *                                
      *------------------------------------------------------------*                                
     C     CS_SFLCLR     BEGSR                                                                      
     C                   EVAL      SFLDSP=*OFF                                                      
     C                   EVAL      SFLCTL=*OFF                                                      
     C                   EVAL      SFLCLR=*ON                                                       
     C                   WRITE     SUFC                                                             
     C                   EVAL      SFLDSP=*ON                                                       
     C                   EVAL      SFLCTL=*ON                                                       
     C                   EVAL      SFLCLR=*OFF                                                      
     C                   CLEAR                   SUFRCDN                        SFLRCDNBR           
     C                   RESET                   ZXNRR00                        ULT.NRR             
     C                   RESET                   ZXNNN00                        ULT.NRR             
     C                   EVAL      ZXFMT=CCCFMT                                                     
      * Inicialitza la variable que indica inici de carrega de subarxiu                             
     C                   EVAL      ZXCOMCAR=0                                                       
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   EVAL      SFLDROP=ZXDROP                                                   
     C                   EVAL      ZXLIPAG=ZXLIPA2                                                  
     C                   IF        SFLDROP=*OFF                                                     
     C                   EVAL      ZXLIPAG=ZXLIPA2*2                                                
     C                   ENDIF                                                                      
     C     SFLCLRT       ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA INICIALITZACIÓ DEL SFL (1º PART)                 *                                
      *------------------------------------------------------------*                                
     C     CS_SFLIN1     BEGSR                                                                      
     C                   RESET                   ZXLOP00                                            
     C****               RESET                   ZXLIPAG                                            
                                                                                                    
     C                   IF        INDPRO1=*OFF                                                     
     C                   CLEAR                   PSUCUST                                            
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        INDPRO2=*OFF                                                     
     C                   CLEAR                   PSUTPED                                            
     C                   ENDIF                                                                      
09022C                   IF        INDPRO3=*OFF                                                     
09022C                   CLEAR                   PSUFPED                                            
09022C                   ENDIF                                                                      
                                                                                                    
     C                   CLEAR                   PSUNPCO                                            
     C                   CLEAR                   PSUDLGA                                            
                                                                                                    
     C                   EVAL      ZXNRR00=ZXNNN00                                                  
     C                   IF        ACCREF=*ON                                                       
     C                   RESET                   ZXNRR00                                            
     C     ZXCOUNT       DIV       ZXLIPAG       ZXNUPAG                                            
     C                   MVR                     ZXRESTO                                            
     C                   IF        ZXRESTO>0 OR ZXNUPAG=0                                           
     C                   EVAL      ZXNUPAG=ZXNUPAG+1                                                
     C                   ENDIF                                                                      
     C                   EVAL      ZXLIPAG=ZXNUPAG*ZXLIPAG                                          
     C                   ENDIF                                                                      
     C                   RESET                   ZXNNN00                        ULT.NRR             
     C                   EVAL      SFLEND=*OFF                                                      
     C                   EVAL      EOF=*OFF                                                         
     C     SFLIN1T       ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA DE MOURE CAMPS                                   *                                
      *------------------------------------------------------------*                                
     C     CS_MOVFP      BEGSR                                                                      
     C                   SELECT                                                                     
     C                   WHEN      ZXOPT1='S01'                                                     
     C                   EVAL      SUFOPCI=*BLANKS                                                  
     C                   EVAL      SFLNXC=*OFF                                                      
     C                   EXSR      S01MFP                                                           
                                                                                                    
     C                   WHEN      ZXOPT1='S02'                                                     
     C                   EVAL      SUFOPCI=*BLANKS                                                  
     C                   EVAL      SFLNXC=*OFF                                                      
     C                   EXSR      S02MFP                                                           
09022                                                                                               
09022C                   WHEN      ZXOPT1='S03'                                                     
09022C                   EVAL      SUFOPCI=*BLANKS                                                  
09022C                   EVAL      SFLNXC=*OFF                                                      
09022C                   EXSR      S03MFP                                                           
                                                                                                    
     C                   WHEN      ZXOPT1='PA0'                                                     
     C                   EVAL      PA0S001=MQS085                                                   
     C                   EVAL      PA0DROP=MQSDRP                                                   
     C                   EVAL      PA0TRAB=MQTRAB                                                   
     C                   EVAL      PA0TDOC=MQTDOC                                                   
FH002C                   EVAL      PA0GCSC=MQGCSC                                                   
     C                   EVAL      PA0DLGA=MQDLGA                                                   
     C                   MOVEA     MQSECP        SSSECPA                                            
     C                   EVAL      PA0SE01=SSSECPA(1)                                               
     C                   EVAL      PA0SE02=SSSECPA(2)                                               
     C                   EVAL      PA0SE03=SSSECPA(3)                                               
     C                   EVAL      PA0SE04=SSSECPA(4)                                               
     C                   EVAL      PA0SE05=SSSECPA(5)                                               
     C                   EVAL      PA0SE06=SSSECPA(6)                                               
                                                                                                    
     C                   ENDSL                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA DE MOURE CAMPS a FICHERO                         *                                
      *------------------------------------------------------------*                                
     C     CS_MOVPF      BEGSR                                                                      
     C                   SELECT                                                                     
     C                   WHEN      ZXOPT1='PA0'                                                     
     C                   CLEAR                   SSSECPA                                            
     C                   EVAL      MQS085=PA0S001                                                   
     C                   EVAL      MQTRAB=PA0TRAB                                                   
     C                   EVAL      MQSDRP=PA0DROP                                                   
     C                   EVAL      MQTDOC=PA0TDOC                                                   
FH002C                   EVAL      MQGCSC=PA0GCSC                                                   
     C                   EVAL      MQDLGA=PA0DLGA                                                   
     C                   EVAL      SSSECPA(1)=PA0SE01                                               
     C                   EVAL      SSSECPA(2)=PA0SE02                                               
     C                   EVAL      SSSECPA(3)=PA0SE03                                               
     C                   EVAL      SSSECPA(4)=PA0SE04                                               
     C                   EVAL      SSSECPA(5)=PA0SE05                                               
     C                   EVAL      SSSECPA(6)=PA0SE06                                               
     C                   MOVEA     SSSECPA       MQSECP                                             
                                                                                                    
     C                   ENDSL                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * GUARDO LA CLAU DE POSICIONAMENT DEL PRIMER REGISTRE DESPRES*                                
      * DE LA NETEJA DEL SUBARXIU                                  *                                
      *------------------------------------------------------------*                                
     C     CS_SAVFK      BEGSR                                                                      
     C                   IF        ZXCOMCAR=0                                                       
                                                                                                    
     C                   EVAL      ZXNPCO_1=S0NPCO                                                  
     C                   EVAL      ZXCUST_1=S0CUST                                                  
     C                   EVAL      ZXDLGA_1=S0DLGA                                                  
     C                   EVAL      ZXTPED_1=S0TPED                                                  
     C                   EVAL      ZXFPED_1=S0FPED                                                  
     C                   EVAL      ZXCOMCAR=1                                                       
                                                                                                    
     C                   ENDIF                                                                      
     C     CS_SAVFKT     ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA INICIALITZACIÓ DEL SFL  (2ª PART)                *                                
      *------------------------------------------------------------*                                
     C     CS_SFLIN2     BEGSR                                                                      
     C                   EVAL      ZXNNN00=ZXNRR00                                                  
     C                   EVAL      SUFRCDN=ZXNRR00                                                  
     C                   EVAL      ACCREF=*ON                                   SFLRCDNBR           
     C                   IF        EOF=*ON                                                          
     C                   EVAL      SFLEND=*ON                                                       
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        ZXNRR00=0                                                        
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C                   EVAL      SFLDSP=*OFF                                                      
     C                   ELSE                                                                       
     C                   EVAL      SFLDSP=*ON                                                       
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        ZXCOUNT>ZXNNN00                                                  
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C                   ENDIF                                                                      
     C     SFLIN2T       ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA VALIDACIÓ DELS CMD'S                             *                                
      *------------------------------------------------------------*                                
     C     CS_SFLCMD     BEGSR                                                                      
     C                   IF        VLDCMDKEY=*OFF                                                   
     C                   GOTO      SFLCMDT                                                          
     C                   ENDIF                                                                      
     C                   EVAL      ACCREF=*ON                                                       
     C                   EXSR      CS_SECCMD                                                        
     C     ERRGRL        CABEQ     *ON           SFLCMDT                                            
     C                                                                                              
     C                   SELECT                                                                     
      * F03=SORTIR DEL PROGRAMA                                                                     
     C                   WHEN      EXIT=*ON                                                         
     C                   EVAL      ZXOPT1='END'                                                     
      * F04=AJUDA DE PANTALLA                                                                       
     C                   WHEN      HELP=*ON                                                         
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   EXSR      CS_POSCUR                                                        
     C                   EVAL      ACCREF=*OFF                                                      
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEFMT=RECORD                                                    
     C                   EVAL      @PEFLD=FIELD                                                     
                                                                                                    
 01   * Laetitia Recherche des clients (begin)                                                      
 02  C                   IF        FIELD='PSUCUST'                                                  
 02  C                   CALL      'CO0650'                                                         
 02  C                   PARM                    @PCIAS                                             
 02  C                   PARM      *BLANKS       @PCUST                                             
 02  C                   PARM      *BLANKS       @PEERR                                             
 03  C                   IF        @PCUST <>PSUCUST                                                 
 03  C                   EVAL      PSUCUST=@PCUST                                                   
 03  C                   EVAL      ZXOPT2='CHK'                                                     
 03  C                   EVAL      ERRGRL=*ON                                                       
 03  C     ERRGRL        CABEQ     *ON           HELPT                                              
 03  C                   ENDIF                                                                      
 03  C                   ENDIF                                                                      
      * laetitia (fin)                                                                              
     C                   IF        FIELD='CCCFMT'                                                   
     C                   EVAL      @PEFMT=*BLANKS                                                   
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEFLD='CFMT'                                                    
     C                   ENDIF                                                                      
     C                   IF        FIELD='SUFOPCI'                                                  
     C                   EVAL      @PEFMT=*BLANKS                                                   
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEFLD='OPCI      '                                              
     C                   ENDIF                                                                      
     C                   CALL      'MMPROM'                                     Query-Aut-F4   X    
     C                   PARM      *BLANKS       @PEOPT                         PARM Qry-F4         
     C                   PARM      SDSPGM        @PEPGM                         PARM Qry-F4         
     C                   PARM                    @PEFMT                         PARM Qry-F4         
     C                   PARM                    @PEFLD                         PARM Qry-F4         
     C                   PARM      *BLANKS       @PEERR                         PARM Qry-F4         
      * Si el dato no tiene soporte F4 avisamos                                                     
     C                   IF        @PEERR>'0'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK40=*ON                                                        
     C                   EVAL      MSGER='ADP0304'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           HELPT                                              
      * Si no han realizado ninguna selección no tocamos nada                                       
     C                   IF        @PEERR='A'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           HELPT                                              
     C                   IF        FIELD='CCCFMT'                                                   
     C*                  EVAL      ERRGRL=*ON                                                       
     C                   EVAL      CCCFMT=@PEOPT                                                    
     C                   ENDIF                                                                      
     C                   IF        FIELD='SUFOPCI'                                                  
     C*                  EXSR      CS_POSCUR                                                        
     C                   EVAL      ZXNRR00=SFLPOS1+CSRFILA-9                                        
     C                   IF        SFLDROP=*ON                                                      
     C                   EVAL      ZXNRR00=SFLPOS1+(CSRFILA-9)/2                                    
     C                   ENDIF                                                                      
     C     ZXNRR00       CHAIN     SUFD                               81                            
     C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      SUFOPCI=@PEOPT                                                   
     C                   EVAL      SFLNXC=*ON                                                       
     C                   UPDATE    SUFD                                                             
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     HELPT         TAG                                                                        
     C     ERRGRL        CABEQ     *ON           SFLCMDT                                            
     C                   EXSR      CS_CLRK                                                          
     C                   IF        ZXFMT<>CCCFMT                                                    
     C                   EVAL      ACCREF=*ON                                                       
     C                   EVAL      ZXCOUNT=1                                                        
     C     CCCFMT        CASEQ     ' '           S01CLR                                             
     C     CCCFMT        CASEQ     '0'           S01CLR                                             
     C     CCCFMT        CASEQ     '1'           S01CLR                                             
     C     CCCFMT        CASEQ     '2'           S02CLR                                             
09022C     CCCFMT        CASEQ     '3'           S03CLR                                             
     C                   CAS                     S01CLR                                             
     C                   ENDCS                                                                      
     C                   ENDIF                                                                      
      * F05=REFRESCAR PANTALLA                                                                      
     C                   WHEN      REFRES=*ON                                                       
     C                   EXSR      CS_RSTFK                                                         
     C                   EVAL      ZXOPT2='CLR'                                                     
      * F13=SETUP DEL PROGRAMA                                                                      
     C                   WHEN      SETUP=*ON                                                        
     C                   EVAL      ZXOPT='PA0CLR'                                                   
     C                   EVAL      ZXCOUNT=SFLPOS1                                                  
      * F14=TREBALLAR AMB EL SPOOL                                                                  
     C                   WHEN      WRKSPL=*ON                                                       
     C                   EVAL      ACCREF=*OFF                                                      
     C                   CLEAR                   ZXQCMD                                             
     C                   EVAL                    ZXQCMD='WRKSPLF'                                   
     C                   CALL      'QCMDEXC'                                                        
     C                   PARM                    ZXQCMD                                             
     C                   PARM                    ZXLOGC                                             
      * F16=TREBALLAR AMB TREBALLS SOTMESOS                                                         
     C                   WHEN      WRKSBM=*ON                                                       
     C                   EVAL      ACCREF=*OFF                                                      
     C                   CLEAR                   ZXQCMD                                             
     C                   EVAL                    ZXQCMD='WRKSBMJOB'                                 
     C                   CALL      'QCMDEXC'                                                        
     C                   PARM                    ZXQCMD                                             
     C                   PARM                    ZXLOGC                                             
      * F22=TREBALLAR AMB TRANSCRIPTORS                                                             
     C                   WHEN      WRKWTR=*ON                                                       
     C                   EVAL      ACCREF=*OFF                                                      
     C                   CLEAR                   ZXQCMD                                             
     C                   EVAL                    ZXQCMD='WRKWTR'                                    
     C                   CALL      'QCMDEXC'                                                        
     C                   PARM                    ZXQCMD                                             
     C                   PARM                    ZXLOGC                                             
      * PAGINAR                                                                                     
     C                   WHEN      ROLLUP=*ON                                                       
     C                   EVAL      ACCREF=*OFF                                                      
     C                   EVAL      ZXOPT2='INZ'                                                     
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C                   ENDSL                                                                      
                                                                                                    
     C     SFLCMDT       TAG                                                                        
     C                   IF        ERRGRL=*ON AND ACCREF=*ON                                        
     C                   EVAL      ACCREF=*OFF                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA VALIDACIÓ DEL SFL: FORMAT SFL I OPCIONS          *                                
      *------------------------------------------------------------*                                
     C     CS_SFLCHK     BEGSR                                                                      
     C                   EVAL      ACCREF=*ON                                                       
      * Validación del posicionamiento de cabecera                                                  
     C                   IF        CCCFMT='1'                                                       
     C*                  EVAL      PSUDLGA=PSUDLG1                                                  
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='2'                                                       
     C*                  EVAL      PSUDLGA=PSUDLG2                                                  
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        PSUCUST <> *BLANKS OR PSUTPED<>*BLANKS                           
     C                             OR PSUDLGA <> *BLANKS                                            
     C                             OR PSUNPCO <> *BLANKS                                            
09022C                             OR PSUFPED <> *BLANKS                                            
                                                                                                    
09022C                   IF        PSUFPED<>*BLANKS                                                 
09022C                   EVAL                    @PVAN=*ZEROS                                       
09022C                   CALL      'MM2510'                                                         
09022C                   PARM                    @PVAN                                              
09022C                   PARM      PSUFPED       @PVAA                                              
09022C                   PARM      ZZFMFF        @PFMI                                              
09022C                   PARM      ZZFMFF        @PFMF                                              
09022C                   PARM      ZZFMFS        @PSEP                                              
09022C                   PARM      ' '           @PEERR                                             
09022C                   IF        @PEERR<>*BLANKS                                                  
09022C                   EVAL      ZXFMT=CCCFMT                                                     
09022C                   EVAL      ERRGRL=*ON                                                       
09022C                   EVAL      WRK45=*ON                                                        
09022C                   EVAL      MSGER='MSG0065'                                                  
09022C                   ENDIF                                                                      
09022C                   EVAL      ZXFPED=@PVAN                                                     
09022C                   ENDIF                                                                      
09022C     ERRGRL        CABEQ     *ON           SFLCHKT                                            
      * Si el artículo ya estaba protegido no resituo si no tocan algo distinto                     
      * a lo protegido                                                                              
     C                   IF        INDPRO1=*ON                                                      
     C                   IF        INDPRO2=*ON                                                      
     C                   IF        PSUCUST=*BLANKS                                                  
     C                   GOTO      SFLCHKAT                                                         
     C                   ENDIF                                                                      
     C                   ELSE                                                                       
     C                   IF        PSUTPED=*BLANKS AND PSUNPCO=*BLANKS                              
     C                   GOTO      SFLCHKAT                                                         
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ZXCOUNT=1                                                        
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      S0NPCO=PSUNPCO                                                   
     C                   EVAL      S0TPED=PSUTPED                                                   
     C                   EVAL      S0CUST=PSUCUST                                                   
     C                   EVAL      S0DLGA=PSUDLGA                                                   
     C                   EVAL      S0FPED=ZXFPED                                                    
09022C*                  EVAL      S0FPED=PSUFPED                                                   
                                                                                                    
     C                   EVAL      ZXCUST=PSUCUST                                                   
     C                   EVAL      ZXDLGA=PSUDLGA                                                   
     C                   EVAL      ZXTPED=PSUTPED                                                   
09022C                   EVAL      ZXNPCO=PSUNPCO                                                   
09022C*                  EVAL      ZXFPED=PSUFPED                                                   
                                                                                                    
     C                   EVAL      ZXOPT2='CLR'                                                     
     C     ERRGRL        CABEQ     *ON           SFLCHKT                                            
     C                   ENDIF                                                                      
     C     SFLCHKAT      TAG                                                                        
                                                                                                    
      * Validacion clase de subarchivo (FORMAT DE LA PANTALLA)                                      
     C                   SELECT                                                                     
     C                   WHEN      ZXFMT<>CCCFMT                                                    
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEOPT=*BLANKS                                                   
     C                   EVAL      @PEFMT=*BLANKS                                                   
     C                   EVAL      @PEFLD='CFMT'                                                    
     C                   EVAL      @PEOPT=CCCFMT                                                    
     C                   CALL      'MMPROM'                                     Query-Aut-F4   X    
     C                   PARM                    @PEOPT                         PARM Qry-F4         
     C                   PARM      SDSPGM        @PEPGM                         PARM Qry-F4         
     C                   PARM                    @PEFMT                         PARM Qry-F4         
     C                   PARM                    @PEFLD                         PARM Qry-F4         
     C                   PARM      'V'           @PEERR                         PARM Qry-F4         
                                                                                                    
     C                   IF        @PEERR>'0'                                                       
     C                   EVAL      ZXFMT=CCCFMT                                                     
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK40=*ON                                                        
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           SFLCHKT                                            
      * Si el subarchivo es valido continuo                                                         
     C                   EVAL      ZXCOUNT=1                                                        
     C                   EVAL      ZXOPT1='S01'                                                     
     C                   EVAL      ZXOPT2='CLR'                                                     
     C                   IF        CCCFMT=' '                                                       
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      ZXOPT1='S01'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='0'                                                       
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      ZXOPT1='S01'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='1'                                                       
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      ZXOPT1='S01'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        CCCFMT='2'                                                       
     C                   EXSR      CS_CLRK                                                          
     C                   EVAL      ZXOPT1='S02'                                                     
     C                   ENDIF                                                                      
09022C                   IF        CCCFMT='3'                                                       
09022C                   EXSR      CS_CLRK                                                          
09022C                   EVAL      ZXOPT1='S03'                                                     
09022C                   ENDIF                                                                      
                                                                                                    
     C                   OTHER                                                                      
     C                   EXSR      CS_CHKOPT                                                        
     C     ERRGRL        CABEQ     *ON           SFLCHKT                                            
     C                   ENDSL                                                                      
                                                                                                    
     C     SFLCHKT       TAG                                                                        
     C                   IF        ERRGRL=*ON AND ACCREF=*ON                                        
     C                   EVAL      ACCREF=*OFF                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA DE 1er REGISTRE DE PANTALLA DE SUBARXIUS         *                                
      *------------------------------------------------------------*                                
     C     CS_RSTFK      BEGSR                                                                      
     C                   EVAL      S0NPCO=ZXNPCO_1                                                  
     C                   EVAL      S0CUST=ZXCUST_1                                                  
     C                   EVAL      S0TPED=ZXTPED_1                                                  
     C                   EVAL      S0DLGA=ZXDLGA_1                                                  
     C     RSTFKT        ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA DE NETEJA DE CAMPS DE POSIBLES CLAUS             *                                
      *------------------------------------------------------------*                                
     C     CS_CLRK       BEGSR                                                                      
     C                   CLEAR                   S0NPCO                                             
     C                   CLEAR                   S0CUST                                             
     C                   CLEAR                   S0TPED                                             
     C                   CLEAR                   S0DLGA                                             
09022C                   CLEAR                   S0FPED                                             
     C     CLRKT         ENDSR                                                                      
      **************************************************************                                
      * COMMON SUBRUTINE (CS_) :                                  *                                 
      * SUBRUTINA DE TRATAMIENTO DE OPCIONES EN SUBARCHIVO         *                                
      *------------------------------------------------------------*                                
     C     CS_CHKOPT     BEGSR                                                                      
      * Validacion clase de subarchivo                                                              
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEOPT=*BLANKS                                                   
     C                   EVAL      @PEFMT=*BLANKS                                                   
     C                   EVAL      @PEFLD='CFMT'                                                    
     C                   EVAL      @PEOPT=CCCFMT                                                    
     C                   CALL      'MMPROM'                                     Query-Aut-F4   X    
     C                   PARM                    @PEOPT                         PARM Qry-F4         
     C                   PARM      SDSPGM        @PEPGM                         PARM Qry-F4         
     C                   PARM                    @PEFMT                         PARM Qry-F4         
     C                   PARM                    @PEFLD                         PARM Qry-F4         
     C                   PARM      'V'           @PEERR                         PARM Qry-F4         
                                                                                                    
     C                   IF        @PEERR>'0'                                                       
     C                   EVAL      ZXFMT=CCCFMT                                                     
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK40=*ON                                                        
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           CHKOPTT                                            
      * VALIDACIO DE LES OPCIONS DE DETALL DEL SFL                                                  
     C                   EVAL      ACCREF=*OFF                                                      
     C                   EVAL      EOF=*OFF                                                         
     C                   IF        SFLDSP=*ON                                                       
                                                                                                    
     C                   DO        *HIVAL                                                           
     C                   READC     SUFD                                   82                        
     C                   IF        EOF=*ON                                                          
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
     C                   EVAL      ACCREF=*ON                                                       
     C                   EVAL      ZXOPT2='CLR'                                                     
      * Validacion opciones de subarchivo                                                           
     C                   EVAL      SFLNXC=*OFF                                                      
     C                   IF        SUFOPCI=*BLANKS                                                  
     C                   GOTO      TNEXOPC                                                          
     C                   ELSE                                                                       
     C                   EVAL      ZXCOUNT=ZXNRR00                                                  
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEFMT=*BLANKS                                                   
     C                   EVAL      @PEFLD='OPCI'                                                    
     C                   EVAL      @PEOPT=SUFOPCI                                                   
     C                   EVAL      @PEPGM=SDSPGM                                                    
     C                   EXSR      CS_SECMDOP                                                       
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      WRK41=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TNEXOPC                                            
                                                                                                    
     C                   SELECT                                                                     
                                                                                                    
     C                   WHEN      @PEOPT=' 2' OR @PEOPT='2 '                   MODIFICAR           
     C                   CALL      'CM0086'                                                         
