      * RECUPERACIÓ DE LA LDA DE COMPRES                                                            
     C     *DTAARA       DEFINE    PURLDA        DSLDA                                              
     C     *LOCK         IN        DSLDA                                                            
     C                   MOVEL     'C'           ZZSECP                                             
     C                   OUT       DSLDA                                                            
     C     *ENTRY        PLIST                                                                      
     C                   PARM                    @PCUST                                             
     C                   PARM                    @PERRO                                             
                                                                                                    
FQ665C                   EVAL      ZXCOCAMB=1                                                       
FQ665C                   EVAL      MVCIAS=ZZCIAS                                                    
     C                   EVAL      Z1ASTE='*'                                                       
     C                   EVAL      PXFMD1=ZZFMD1                                                    
     C                   EVAL      PXDCCD=2                                                         
     C* CAPÇALERES D'OPCIONS DEL SFL  (CODIS D'ARXIU DE MISSATGES)                                  
     C                   EVAL      SUFOPC2=*BLANKS                                                  
     C                   IF        ZZNPGM=' '                                                       
     C                   EVAL      SUFOPC1='OCM0085'                                                
     C                   ELSE                                                                       
     C                   EVAL      SUFOPC1='OCM0085'                                                
     C                   ENDIF                                                                      
     C* TITOLS DE PANTALLES (CODIS D'ARXIU DE MISSATGES)                                            
     C                   IF        ZZNPGM=' '                                                       
     C                   EVAL      CCCCTIT='TCM0085'                                                
     C                   ELSE                                                                       
     C                   EVAL      CCCCTIT='TCM0085'                                                
     C                   ENDIF                                                                      
     C* ACTIVEM EL SFLDSPCTL                                                                        
     C                   EVAL      SFLCTL=*ON                                                       
      * ACTUALITZACIÓ DELS CAMPS DEL PMSETP I ALTRES CAMPS AMB VALORS COMUNS                        
     C                   EVAL      @PCIAS=ZZCIAS                                                    
     C                   EVAL      @PEDLGA=ZZDLGA                                                   
     C                   EVAL      @PECIAS=ZZCIAS                                                   
     C                   EVAL      @PEDLGA=ZZDLGA                                                   
     C                   EVAL      S0CIAS=ZZCIAS                                                    
     C                   EVAL      S0DLGA=ZZDLGA                                                    
     C                   EVAL      S0CUST=@PCUST                                                    
     C                   EVAL      S0TPED=@PTPED                                                    
     C                   EVAL      PICIAS=ZZCIAS                                                    
     C                   EVAL      PIPROG=SDSPGM                                                    
     C                   EVAL      PIUSU1=ZZUSUA                                                    
     C                   EVAL      ZXDLGA=ZZDLGA                                                    
     C                   EVAL      ZXCUST=@PCUST                                                    
                                                                                                    
     C                   EVAL      S0DES1=*BLANKS                                                   
     C                   EVAL      S0CLAB=*BLANKS                                                   
     C* Puesto que en cada pedido se puede poner una clave o descripción                            
     C* distinta o modificada se decide tomar los datos del fichero de                              
     C* proveedores para tener los valores de posicionamiento                                       
     C     KCOCLIN       CHAIN     COCLIN                             81                            
     C                   EVAL      ZXDES1=S0DES1                                                    
     C                   EVAL      ZXCLAB=S0CLAB                                                    
     C                   EVAL      ZXTPED=@PTPED                                                    
     C                   EVAL      ZXFPED=0                                                         
     C                   EVAL      ZXFREP=0                                                         
                                                                                                    
      *************************************************                                             
     C* Protección de campos según parámetros llegados                                              
     C                   EXSR      CS_PROTECT                                                       
      *************************************************                                             
      * RECUPEREM DEL FITXER DE SETUP EL FORMAT QUE EM DE MOSTRAR PER OMISIÓ                        
     C     KMSSETP       CHAIN (N) PMSETP                             81                            
     C                   CLEAR                   CM0085                                             
     C     PIDATR        CAT       CM0085:0      CM0085                                             
     C                   EVAL      ZXTDOC=MQTDOC                                                    
     C                   EVAL      ZXDLGA1=MQDLGA                                                   
     C                   EVAL      ZXDROP=MQSDRP                                                    
     C                   EVAL      ZXFMT=MQS085                                                     
     C                   EVAL      ZXTRAB=MQTRAB                                                    
FH002C                   EVAL      ZXGCSC=MQGCSC                                                    
     C                   IF        ZXDROP=' ' OR ZXDROP>'1'                                         
     C                   EVAL      ZXDROP='0'                                                       
     C                   ENDIF                                                                      
                                                                                                    
     C* RECUPEREM ELS VALORS DE L'AREA DE PARÀMETRES DE PROGRAMA                                    
     C                   IF        CHAIN=*OFF                                                       
     C                   SELECT                                                                     
     C                   WHEN      MQS085=' ' OR MQS085='0'                                         
     C                   EVAL      ZXOPT='S01CLR'                                                   
     C                   WHEN      MQS085='1'                                                       
     C                   EVAL      ZXOPT='S01CLR'                                                   
     C                   WHEN      MQS085='2'                                                       
     C                   EVAL      ZXOPT='S02CLR'                                                   
09022C                   WHEN      MQS085='3'                                                       
09022C                   EVAL      ZXOPT='S03CLR'                                                   
     C                   ENDSL                                                                      
     C                   ENDIF                                                                      
FQ665C                   IF        ZZE046='4'                                                       
FQ665C                   EVAL      INDFRA=*ON                                                       
FQ665C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ERRGRL=*ON                                                       
FH002 *                                                                                             
FH002 *   DIVISION=BUSCAR EQUIVALENCIA DE EMPRESA                                                   
FH002 *                                                                                             
FH002C                   MOVEL     *BLANKS       @PXVAL1                                            
FH002C                   MOVEL     ZZCIAS        @PXVAL1                                            
FH002                                                                                               
FH002C                   CALL      'GX2500'                                                         
FH002C                   PARM      100           @PXCONO                                            
FH002C                   PARM      *BLANKS       @PXDIV2                                            
FH002C                   PARM      0             @PXCIA2                                            
FH002C                   PARM      '1'           @PXMODO                                            
FH002C                   PARM      1             @PXFLDQ                                            
FH002C                   PARM      'CIAS     '   @PXFLD1                                            
FH002C                   PARM      *BLANKS       @PXFLD2                                            
FH002C                   PARM      *BLANKS       @PXFLD3                                            
FH002C                   PARM                    @PXVAL1                                            
FH002C                   PARM      *BLANKS       @PXVAL2                                            
FH002C                   PARM      *BLANKS       @PXVAL3                                            
FH002C                   PARM      'DIVI     '   @PXFLDR                                            
FH002C                   PARM      *BLANKS       @PXVALO                                            
FH002C                   PARM      *BLANKS       @PXVALT                                            
FH002C                   PARM      *BLANKS       @PXDESC                                            
FH002C                   PARM      *ZEROS        @PXPRIO                                            
FH002C                   PARM      *BLANKS       @PXERRO                                            
FH002C                   IF        @PXERRO=*BLANKS                                                  
FH002C                   MOVEL(P)  @PXVALO       ZXDIVI                                             
FH002C                   ELSE                                                                       
FH002C                   MOVEL     ZZCIAS        ZXCIAS                                             
FH002C                   EVAL      ZXDIVI=ZXCIAS                                                    
FH002C                   ENDIF                                                                      
FH002 *                                                                                             
     C                   ENDSR                                                                      
      **************************************************************                                
      * SOBRE PROTECCION DE CAMPOS                                 *                                
      *------------------------------------------------------------*                                
     C     CS_PROTECT    BEGSR                                                                      
     C                   IF        @PCUST<>*BLANKS                                                  
     C                   EVAL      INDPRO1=*ON                                                      
     C                   EVAL      PSUCUST=ZXCUST                                                   
     C     KCOCLIN       CHAIN     COCLIN                             81                            
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        @PTPED<>*BLANKS                                                  
     C                   EVAL      INDPRO2=*ON                                                      
     C                   EVAL      PSUTPED=@PTPED                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL SFL S01                              *                                
      *------------------------------------------------------------*                                
     C     S01MAIN       BEGSR                                                                      
     C                   DOW       ZXOPT1='S01'                                                     
     C     ZXOPT2        CASEQ     'CLR'         S01CLR                                             
     C     ZXOPT2        CASEQ     'INZ'         S01INZ                                             
     C     ZXOPT2        CASEQ     'DSP'         S01DSP                                             
     C     ZXOPT2        CASEQ     'CMD'         S01CMD                                             
     C     ZXOPT2        CASEQ     'CHK'         S01CHK                                             
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ I CARREGA DEL SFL                 *                                
      *------------------------------------------------------------*                                
     C     S01INZ        BEGSR                                                                      
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   EXSR      CS_SFLIN1                                                        
                                                                                                    
     C                   DOW       ZXLOP00 < ZXLIPAG                                                
     C                   EVAL      ZXFILE=' '                                                       
     C                   EXSR      CS_READ01                                                        
     C* Cargo el máximo de 204 registros                                                            
     C                   IF        ZXNRR00>ZXSFLSIZ                                                 
     C                   EVAL      EOF=*ON                                                          
     C                   ENDIF                                                                      
     C                   IF        EOF=*ON                                                          
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   EXSR      CS_SELSFL                                                        
     C                   IF        ZXSELSFL=1                                                       
     C                   GOTO      TNEXRE01                                                         
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ZXNRR00=ZXNRR00 + 1                                              
     C                   EVAL      ZXLOP00=ZXLOP00 + 1                                              
     C                   EXSR      CS_MOVFP                                                         
     C                   EXSR      CS_SAVFK                                                         
     C                   WRITE     SUFD                                                             
     C     TNEXRE01      TAG                                                                        
     C                   ENDDO                                                                      
                                                                                                    
     C* LESTURA DEL FICHERO DE ALBARANES DIRECTOS                                                   
     C                   EXSR      CS_SETLL1B                                                       
     C                   EXSR      S01INZB                                                          
      *                                                                                             
     C                   EXSR      CS_SFLIN2                                                        
     C     S01INZT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL SFL S02                              *                                
      *------------------------------------------------------------*                                
     C     CS_READ01     BEGSR                                                                      
                                                                                                    
FQ365C     KCOCAPE0      READE     COCAPE25                               82                        
                                                                                                    
     C     READ01T       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ I CARREGA DEL SFL                 *                                
      *------------------------------------------------------------*                                
     C     S01INZB       BEGSR                                                                      
     C                   EVAL      ZXOPT2='DSP'                                                     
                                                                                                    
     C                   DOW       ZXLOP00 < ZXLIPAG                                                
     C                   EVAL      ZXFILE='1'                                                       
     C                   EXSR      CS_READ01B                                                       
     C* Cargo el máximo de 204 registros                                                            
     C                   IF        ZXNRR00>ZXSFLSIZ                                                 
     C                   EVAL      EOF=*ON                                                          
     C                   ENDIF                                                                      
     C                   IF        EOF=*ON                                                          
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   EXSR      CS_SELSFL                                                        
     C                   IF        ZXSELSFL=1                                                       
     C                   GOTO      TNEXRE01B                                                        
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      ZXNRR00=ZXNRR00 + 1                                              
     C                   EVAL      ZXLOP00=ZXLOP00 + 1                                              
     C                   EXSR      CS_MOVFP                                                         
     C                   EXSR      CS_SAVFK                                                         
     C                   WRITE     SUFD                                                             
     C     TNEXRE01B     TAG                                                                        
     C                   ENDDO                                                                      
                                                                                                    
     C     S01INZBT      ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL SFL S02                              *                                
      *------------------------------------------------------------*                                
     C     CS_READ01B    BEGSR                                                                      
                                                                                                    
     C     KCMA0400      READE     CMA04024                               82                        
                                                                                                    
     C     READ01BT      ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VISUALITZACIÓ SFL                                *                                
      *------------------------------------------------------------*                                
     C     S01DSP        BEGSR                                                                      
     C                   EVAL      ZXOPT2='CMD'                                                     
     C                   IF        ZZNPGM=' '                                                       
     C                   EVAL      PPPCMD1='CMD3041'                                                
     C                   ELSE                                                                       
     C                   EVAL      PPPCMD1='CMD3041'                                                
     C                   ENDIF                                                                      
     C                   EVAL      SUFHED1='HCM0850'                                                
     C*                                                                                             
     C                   EXSR      CS_SFLDSP                                    SI REGS             
     C     S01DSPT       ENDSR                                                                      
      **************************************************************                                
