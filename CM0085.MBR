FQ665C                   EVAL      ZXUNDC1=S5UNDP                                                   
FQ665C                   EVAL      ZXARTI1=S5ARTI                                                   
FQ665C                   EVAL      ZXVARI1=S5VARI                                                   
FQ665C                   EVAL      ZXMODE1=S5MODE                                                   
FQ665C                   EVAL      ZXCANS1=S5CANT-S5CANS                                            
FQ665C                   EVAL      ZXPRCC1=S5PREC                                                   
FQ665C                   EVAL      ZXCADC1=S5CADP                                                   
FQ665C                   EVAL      ZXDTO11=S5DTO1                                                   
FQ665C                   EVAL      ZXDTO21=S5DTO2                                                   
FQ665C                   EVAL      ZXDTO31=S5DTO3                                                   
FQ665C                   EVAL      ZXDTO41=S5DTO4                                                   
FQ665C                   EVAL      ZXTIVA1=S5TIVA                                                   
FQ665C                   EVAL      ZXECOP1=S5ECOP                                                   
FQ665 * Vemos si hay cantidad confirmada                                                            
FQ665C                   IF        S5CANC<>*ZEROS                                                   
FQ665C                   EVAL      ZXCANS1=S5CANC-S5CANS                                            
FQ665C                   ENDIF                                                                      
FQ665 * Vemos si hay precio confirmado                                                              
FQ665C                   IF        S5PRCC<>*ZEROS                                                   
FQ665C                   EVAL      ZXPRCC1=S5PRCC                                                   
FQ665C                   EVAL      ZXMONE1=S5MONC                                                   
FQ665C                   EVAL      ZXCADC1=S5CADC                                                   
FQ665C                   EVAL      ZXUNDC1=S5UNDC                                                   
FQ665C                   EVAL      ZXDTO11=S5DT1C                                                   
FQ665C                   EVAL      ZXDTO21=S5DT2C                                                   
FQ665C                   EVAL      ZXDTO31=S5DT3C                                                   
FQ665C                   EVAL      ZXDTO41=S5DT4C                                                   
FQ665C                   ENDIF                                                                      
FQ665                                                                                               
FQ665C                   EXSR      CS_CALDET                                                        
FQ665C                   EVAL      ZXDOCUM=ZXDOCUM+ZXBIMP1                                          
FQ665C                   ENDIF                                                                      
FQ665C     KCODEPE08     READE     CODEPE08                               83                        
FQ665C                   ENDDO                                                                      
FQ665                                                                                               
FQ665C                   ENDSR                                                                      
FQ665 **************************************************************                                
FQ665 * SUBRUTINA DE CALCULOS DE NETOS                             *                                
FQ665 *------------------------------------------------------------*                                
FQ665C     CS_CALDET     BEGSR                                                                      
FQ665* Ecotaxe                                                                                     
FQ665C                   EVAL      XZTAXE=0                                                         
FQ665C                   IF        ZXECOP1<>*BLANKS                                                 
FQ665C                   CALL      'MN0398'                                                         
FQ665C                   PARM                    @PCIAS                                             
FQ665C                   PARM      ZXECOP1       @PEECOP                                            
FQ665C                   PARM      ZXFLCD1       @PEFLCD                                            
FQ665C                   PARM      0             @PETAXE                                            
FQ665C                   EVAL      XZTAXE=@PETAXE                                                   
FQ665C                   END                                                                        
FQ665 * Obtenemos cambio de MONEDA                                                                  
FQ665C                   EVAL      ZXMONE2=S0MON4                                                   
FQ665 *                                                                                             
FQ665C                   IF        INDFRA=*ON AND S0TGR2='2'                                        
FQ665C                   EVAL      ZXMONE2=ZXMON4                                                   
FQ665C                   ENDIF                                                                      
FQ665C                   EXSR      CS_ZXCOCAM                                                       
FQ665                                                                                               
FQ665C                   EVAL      XZAUXI=*ZEROS                                                    
FQ665C                   EVAL      MBMONE=ZXMONE1                                                   
FQ665C                   EVAL      XZDECI=XZDECM                                                    
FQ665C                   EVAL      XZAJUD=XZAJUM                                                    
FQ665                                                                                               
FQ665 * Buscamos en PMUNAL UNIDADES ALTERNATIVAS                                                    
FQ665                                                                                               
FQ665C                   EVAL      XZCOFU=1                                                         
FQ665 *                  IF        ZXUNIM<>ZXUNDC1                                                  
FQ665C                   IF        ZXUNIM1<>ZXUNDC1                                                 
FQ665C                   EVAL      XZCIAS=@PCIAS                                                    
FQ665C                   EVAL      XZARTI=ZXARTI1                                                   
FQ665C                   EVAL      XZVARI=ZXVARI1                                                   
FQ665C                   EVAL      XZMODE=ZXMODE1                                                   
FQ665C                   EVAL      ZXCA10=ZXCANS1                                                   
FQ665C                   EVAL      ZXCA11=ZXCANS1                                                   
FQ665C                   EVAL      ZXUN10=ZXUNIM1                                                   
FQ665C                   EVAL      ZXUN11=ZXUNDC1                                                   
FQ665C* CAMBIO de unidades                                                                          
FQ665C/COPY *LIBL/QSRDSRC,SRD021                                                                    
FQ665C                   ENDIF                                                                      
FQ665                                                                                               
FQ665 * Calculamos el precio de nueva linea o modificada                                            
FQ665                                                                                               
FQ665C                   EVAL      XZCANT=ZXCANS1                                                   
FQ665C                   EVAL      XZPREC=ZXPRCC1                                                   
FQ665C                   EVAL      XZCADP=ZXCADC1                                                   
FQ665C                   EVAL      XZDTO1=ZXDTO11                                                   
FQ665C                   EVAL      XZDTO2=ZXDTO21                                                   
FQ665C                   EVAL      XZDTO3=ZXDTO31                                                   
FQ665C                   EVAL      XZDTO4=ZXDTO41                                                   
FQ665C/COPY *LIBL/QSRDSRC,SRD022ECO                                                                 
FQ665C                   EVAL      XZAUXI=XZAUXI*ZXCOCAMB1                                          
FQ665C                   EVAL      ZXBIMP1ECO=XZAUXI                                                
FQ665C                   EVAL      ZXBIMPOECO=XZAUXI                                                
FQ665C/COPY *LIBL/QSRDSRC,SRD022                                                                    
FQ665                                                                                               
FQ665C                   EVAL      XZAUXI=XZAUXI*ZXCOCAMB1                                          
FQ665C                   EVAL      ZXBIMP1=XZAUXI                                                   
FQ665C                   EVAL      ZXBIMPO=XZAUXI                                                   
FQ665 * Buscamos en % de IVA                                                                        
FQ665                                                                                               
FQ665C                   EVAL      MVTIVA=ZXTIVA1                                                   
FQ665C                   EVAL      MVPABI=ZXPABI                                                    
FQ665C                   EVAL      MVFLCD=ZXFLCD1                                                   
FQ665C     KMSIVAS       SETGT     MSIVAS                                                           
FQ665C     KMSIVASA      READPE    MSIVAS                                 83                        
FQ665                                                                                               
FQ665C                   SELECT                                                                     
FQ665C                   WHEN      ZXTIVC=' '                                                       
FQ665C                   EVAL      MVPIV2=*ZEROS                                                    
FQ665C                   WHEN      ZXTIVC='0'                                                       
FQ665C                   EVAL      MVPIV1=*ZEROS                                                    
FQ665C                   EVAL      MVPIV2=*ZEROS                                                    
FQ665C                   ENDSL                                                                      
FQ665                                                                                               
FQ665 * Calculamos el DTOPP                                                                         
FQ665C                   IF        ZXDTPP1>*ZEROS                                                   
FQ665C                   EVAL      XZAUXI=XZAUXI*ZXDTPP1                                            
FQ665C     XZAUXI        DIV(H)    100           XZAUXI                                             
FQ665C                   EVAL      ZXBIMP1=ZXBIMP1-XZAUXI                                           
FQ665C                   ENDIF                                                                      
FQ665* Ecotaxe                                                                                     
FQ665C                   EVAL      ZXBIMP1=ZXBIMP1+ZXBIMP1ECO                                       
FQ665C                   EVAL      ZXBIMPO=ZXBIMPO+ZXBIMPOECO                                       
FQ665 * Calculamos el IVA                                                                           
FQ665C                   EVAL      XZAUXI=ZXBIMP1*MVPIV1                                            
FQ665C     XZAUXI        DIV(H)    100           XZAUXI                                             
FQ665C                   EVAL      ZXIIVA1=XZAUXI                                                   
FQ665 * Calculamos el Recargo de equivalencia                                                       
FQ665C                   EVAL      XZAUXI=ZXBIMP1*MVPIV2                                            
FQ665C     XZAUXI        DIV(H)    100           XZAUXI                                             
FQ665C                   EVAL      ZXIIVA2=XZAUXI                                                   
FQ665 * Calculamos el IVA en EUROS                                                                  
FQ665C                   EVAL      ZXBIMP1=ZXBIMP1+ZXIIVA1+ZXIIVA2                                  
FQ665C                   EVAL      XZAUXI=ZXBIMP1                                                   
FQ665C* AJUSTE Y DECIMALES                                                                          
FQ665C/COPY *LIBL/QSRDSRC,SRD001                                                                    
FQ665C                   EVAL      ZXBIMP1=XZAUXI                                                   
FQ665                                                                                               
FQ665 * Omitimos BASE o IVA segun tipo de IVA                                                       
FQ665                                                                                               
FQ665C                   IF        MVOMTB>='1'                                                      
FQ665C                   EVAL      ZXBIMP1=ZXBIMP1-ZXBIMPO                                          
FQ665C                   ENDIF                                                                      
FQ665C                   IF        MVOMTI>='1'                                                      
FQ665C                   EVAL      ZXBIMP1=ZXBIMP1-ZXIIVA1                                          
FQ665C                   EVAL      ZXBIMP1=ZXBIMP1-ZXIIVA2                                          
FQ665C                   ENDIF                                                                      
FQ665C                   ENDSR                                                                      
FQ665 **************************************************************                                
FQ665 * SUBRUTINA CLACULO DE COEFICIENTE DE CAMBIO                   *                              
FQ665 *------------------------------------------------------------*                                
FQ665C     CS_ZXCOCAM    BEGSR                                                                      
FQ665 * Búsqueda del cambio para moneda de visualización según SETUP.                               
FQ665C                   EVAL      @PDATA=ZXFLCD1                                                   
FQ665C                   TIME                    @PHORA                                             
FQ665C                   IF        @PDATA=*ZEROS                                                    
FQ665C                   EVAL      @PDATA=ZZDATS                                                    
FQ665C                   ENDIF                                                                      
FQ665                                                                                               
FQ665C                   IF        @PDATA=*ZEROS                                                    
FQ665C                   EVAL      @PDATA=*DATE                                                     
FQ665C                   ENDIF                                                                      
FQ665 * Debo tener en cuenta si existe cambio confirmado                                            
FQ665 * para dicha moneda o no existe dicho cambio confirmado                                       
FQ665C                   EVAL      ZXCOCAMB1=1                                                      
FQ665C                   IF        ZXMONE2<>ZXMONE1                                                 
FQ665C                   CALL      'MM2555'                                                         
FQ665C                   PARM                    @PCIAS                                             
FQ665C                   PARM      ZXMONE1       @PMON1                                             
FQ665C                   PARM      ZXMONE2       @PMON2                                             
FQ665C                   PARM                    @PDATA                                             
FQ665C                   PARM                    @PHORA                                             
FQ665C                   PARM      0             @PCMCOCO                                           
FQ665C                   PARM      0             @PCMCCCO                                           
FQ665C                   PARM      *BLANKS       @PEERR                                             
FQ665C                   EVAL      ZXCOCAMB1=@PCMCCCO                                               
FQ665C                   ENDIF                                                                      
FQ665                                                                                               
FQ665C                   ENDSR                                                                      
