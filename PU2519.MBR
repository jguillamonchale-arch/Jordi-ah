I0155 **************************************************************                                
I0155 * SUBRUTINA QUE BUSCA LA LOGISTICA                           *                                
I0155 *------------------------------------------------------------*                                
I0155C     CS_BUSLOG     BEGSR                                                                      
I0155C                   eval      ZXLOGE=C5LOGE                                                    
I0155C                   eval      M0CIAS=ZZCIAS                                                    
I0155C                   eval      M0LOGE=C5LOGE                                                    
I0155C     Kmsalma05     Chain (N) Msalma05                           81                            
I0155C                   IF        CHAIN=*OFF                                                       
I0155C                   IF        C5TPE4='2'                                                       
I0155C                   EVAL      PECIAS=ZZCIAS                                                    
I0155C                   EVAL      PECTAB='INO2'                                                    
I0155C                   EVAL      PECLTA='MAGD' + %trim(M0MAGA)                                    
I0155C     KPMTABD       CHAIN     PMTABD                             81                            
I0155C                   IF        CHAIN=*OFF                                                       
I0155C                   EVAL      C5LOGE=PEDESC                                                    
I0155C                   ENDIF                                                                      
I0155C                   ELSE                                                                       
I0155C                   EVAL      PECIAS=ZZCIAS                                                    
I0155C                   EVAL      PECTAB='INO2'                                                    
I0155C                   EVAL      PECLTA='MAGP' + %trim(C0PRVR)                                    
I0155C     KPMTABD       CHAIN     PMTABD                             81                            
I0155C                   IF        CHAIN=*OFF                                                       
I0155C                   EVAL      C5LOGE=PEDESC                                                    
I0155C                   ENDIF                                                                      
I0155C                   ENDIF                                                                      
I0155C                   ENDIF                                                                      
I0155C                   ENDSR                                                                      
