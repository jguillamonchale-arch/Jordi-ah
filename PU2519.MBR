     C                   ENDIF                                                                      
     C                   IF        ZXUTCOMU=1                                                       
17076 **                 IF        U0TENV='1'                                                       
17076C                   IF        MIALOL='1'                                                       
     C                   EVAL      C0EVOL='1'                                                       
