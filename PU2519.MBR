      * Cambio de nº de orden en direcciones                                                        
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPUCAPEX      CHAIN     PUDIPE                             8180                          
     C                   ENDDO                                                                      
     C                   DOW       CHAIN=*OFF                                                       
     C                   IF        ZXUPDAT1=1                                                       
     C                   EVAL      C2NPCO=@PNPCO                                                    
     C                   ENDIF                                                                      
     C                   IF        ZXUTCOMU=1                                                       
     C*                  IF        C2TDVA>='1'                                                      
17076 **                 IF        U0TENV='1'                                                       
17076C                   IF        MIALOL='1'                                                       
     C                   EVAL      C2EVOL='1'                                                       
     C                   ELSE                                                                       
     C                   IF        U0TENV='5'                                                       
     C                   EVAL      C2EVPR='1'                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C*                  ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   UPDATE    RPUDIPE                                                          
      * Si está activado el envío de pedidos a proveedor grabo en                                   
      * el fichero para traspaso de pedidos a proveedor                                             
     C                   IF        ZXUTCOMU=1 AND C2TDVA>='1'                                       
     C                   EVAL      C2OPC0='1'                                                       
     C                   EVAL      C2EVR0=ZXEVR0                                                    
     C                   EVAL      C2TENV=U0TENV                                                    
     C                   EVAL      C2DEST=U0DEST                                                    
     C                   EVAL      C2TDES=U0TDES                                                    
     C                   EVAL      C2CIDT=U0CIA1                                                    
     C                   EVAL      C2CLDT=U0CLP1                                                    
     C                   EVAL      C2USU0=SDSUSR                                                    
     C                   EVAL      C2PAN0=ZZPANT                                                    
     C                   EVAL      C2DAT0=ZZDATS                                                    
     C                   TIME                    ZXTIME                                             
     C                   MOVEL     ZXTIME        C2HOR0                                             
     C                   DOU       LCKRCD=*OFF                                                      
     C                   EVAL      C2HOR0=C2HOR0+1                                                  
     C                   EVAL      C2PROG=SDSPGM                                                    
     C                   EXSR      CS_ENCRIP                                                        
     C                   WRITE     RTR0038                              80                          
     C                   ENDDO                                                                      
C0035C                   IF        ZXUTCOMU5>=1                                                     
C0035C                   EVAL      C2TENV=ZXTENV5                                                   
C0035C                   EVAL      C2DEST=ZXDEST5                                                   
C0035C                   EVAL      C2TDES=ZXTDES5                                                   
C0035C                   EVAL      C2CIDT=ZXCIA15                                                   
C0035C                   EVAL      C2CLDT=ZXCLP15                                                   
C0035C                   EVAL      C2EVR0='5'                                                       
C0035C                   EVAL      ZXEVOL5=C2EVOL                                                   
C0035C                   EVAL      C2EVOL=' '                                                       
C0035C                   DOU       LCKRCD=*OFF                                                      
C0035C                   EVAL      C2HOR0=C2HOR0+1                                                  
C0035C                   EVAL      C2PROG=SDSPGM                                                    
C0035C                   WRITE     RTR0038                              80                          
C0035C                   ENDDO                                                                      
C0035C                   EVAL      C2EVOL=ZXEVOL5                                                   
C0035C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPUCAPEX      READE     PUDIPE                               8081                        
     C                   ENDDO                                                                      
     C                   ENDDO                                                                      
      * SI NO TIENE QUE CONTINUAR ACTUALIZANDO PORQUE SOLO TIENE QUE                                
      * QUE GRABAR PSUDEP, ENTONCES ACABO EL BUCLE                                                  
     C     ZXUPDAT1      CABEQ     0             UPDATET                                            
      * Cambio de nº de orden en cuentas contables                                                  
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPUCAPEX      CHAIN     PUPECO                             8180                          
     C                   ENDDO                                                                      
     C                   DOW       CHAIN=*OFF                                                       
     C                   EVAL      CUNPCO=@PNPCO                                                    
     C                   UPDATE    RPUPECO                                                          
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPUCAPEX      READE     PUPECO                               8081                        
     C                   ENDDO                                                                      
     C                   ENDDO                                                                      
                                                                                                    
      * Cambio de nº de orden de los importes                                                       
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPUCAPEX      CHAIN     PUCAIM                             8180                          
     C                   ENDDO                                                                      
     C                   DOW       CHAIN=*OFF                                                       
     C                   EVAL      CYNPCO=@PNPCO                                                    
     C                   UPDATE    RPUCAIM                                                          
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPUCAPEX      READE     PUCAIM                               8081                        
     C                   ENDDO                                                                      
     C                   ENDDO                                                                      
                                                                                                    
      * Cambio de nº de orden de compra en la cabecera de orden                                     
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPUCAPEX      CHAIN     PUCAPE                             8180                          
     C                   ENDDO                                                                      
17076 **                 IF        U0TENV='1'                                                       
17076C                   IF        MIALOL='1'                                                       
     C                   EVAL      C0EVOL='1'                                                       
     C                   ELSE                                                                       
     C                   IF        U0TENV='5'                                                       
C0144 **                 EVAL      C0EVPR='1'                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   EVAL      C0STCO='20'                                                      
     C                   EVAL      C0NPCO=@PNPCO                                                    
     C                   UPDATE    RPUCAPE                                                          
      **** Actualizaciones de pedidos de ventas relacionados.                                       
      * Si proviene de una orden de ventas, asocio en la orden de ventas                            
      * la orden de compras                                                                         
     C                   IF        C0NPVE<>*BLANKS                                                  
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXALPH=C0CIVE                                                    
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      0             PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   EVAL      S0CIAS=PXNUM                                                     
                                                                                                    
     C                   EVAL      S0DLGA=C0DLVE                                                    
     C                   EVAL      S0NPCO=C0NPVE                                                    
     C                   EVAL      S0TPED=C0TPED                                                    
                                                                                                    
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPE0      CHAIN     COCAPE                             8180                          
     C                   ENDDO                                                                      
     C                   DOW       (CHAIN=*OFF)                                                     
     C                   IF        (C0CUST=S0CUST)                                                  
     C**                 IF        (C0DAVE<>*ZEROS AND C0DAVE=S0DATP) OR                            
     C**                           (C0DAVE<=*ZEROS)                                                 
      * Si el sistema no tiene pedido asociado o este es de la misma                                
      * empresa (puede ocurrir que haga referencia al pedido de compra                              
      * de la empresa origen -traspasos automaticos comercial-productiva)                           
      * y por tanto no puede machacarse.                                                            
     C                   MOVEL     C0CIAS        ZXCI01                                             
     C                   IF        (S0CI01=*BLANKS OR S0CI01=ZXCI01)                                
     C                   EVAL      S0PR01=C0PRVR                                                    
     C                   MOVEL     C0CIAS        S0CI01                                             
     C                   EVAL      S0DL01=C0DLGA                                                    
     C                   EVAL      S0NP01=C0NPCO                                                    
     C                   EVAL      S0DA01=C0DATP                                                    
     C                   EVAL      S0NO01=C0NOPL                                                    
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   UPDATE    RCOCAPE                                                          
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPE0      READE     COCAPE                               8081                        
     C                   ENDDO                                                                      
     C                   ENDDO                                                                      
     C                   ENDIF                                                                      
      **** Fin Actualizaciones de pedidos de ventas relacionados.                                   
      *                                                                                             
     C     UPDATET       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE CALCULO DE CHECKSUM                           *                                
      *------------------------------------------------------------*                                
     C     CS_CHKSUM     BEGSR                                                                      
     C                   EVAL      ZXCHKS=0                                                         
     C     KPUCAPEX      SETLL     PUDEPE                                                           
     C     KPUCAPEX      READE(N)  PUDEPE                                 83                        
     C                   DOW       READ1=*OFF                                                       
     C                   EVAL      ZXCHKS=ZXCHKS+1                                                  
     C     KPUCAPEX      READE(N)  PUDEPE                                 83                        
     C                   ENDDO                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * ENCRIPTADOR DE DIRECCIONES                                 *                                
      *------------------------------------------------------------*                                
     C     CS_ENCRIP     BEGSR                                                                      
      *                                                                                             
      * Se encriptan los Datos de la Dirección de Envío si la Empresa                               
      * lo tiene como Parámetro y si la Dirección es para Cliente Terceros                          
      * y el País Destino es de la CEE.                                                             
      *                                                                                             
28022 *                                                                                             
28022 * Las empresas con ERP Movex tampoco se encriptan porque no las ven                           
28022 *                                                                                             
28022C                   MOVEL(P)  C2CIDT        PPCIAS                                             
28022C     PPCIAS        CHAIN     PMLIBL                                                           
28022C                   IF        %FOUND(PMLIBL) AND PPMVXV<>'V'                                   
     C                   IF        (ZZENCR='1' AND C0TPE4='2' AND C2CDIR='1')                       
     C                             OR (ZZENCR='1' AND C0EDET='1' AND C2CDIR='1')                    
      *                                                                                             
     C                   EVAL      MECIAS=C2CIAS                                                    
     C                   EVAL      MEPAIS=C2PAIS                                                    
     C     KMSPAIS       CHAIN     MSPAIS                                                           
     C                   IF        (%FOUND(MSPAIS) AND MEPCEE='1' AND                               
     C                              C0TPE4='2')                                                     
     C                             OR (C0EDET='1' AND C0TPE4<>'2')                                  
      *                                                                                             
     C                   IF        C2RAOS<>*BLANKS                                                  
     C                   EVAL      @PECADENA=*BLANKS                                                
     C                   EVAL      @PECADENA=C2RAOS                                                 
     C                   CALL      'UT2570'                                                         
     C                   PARM                    @PECADENA                                          
     C                   PARM      '1'           @PEACCION                                          
     C                   PARM      *BLANKS       @PEERROR                                           
     C                   IF        @PEERROR=*BLANKS                                                 
     C                   EVAL      C2RAOS=@PECADENA                                                 
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        C2RAO2<>*BLANKS                                                  
     C                   EVAL      @PECADENA=*BLANKS                                                
     C                   EVAL      @PECADENA=C2RAO2                                                 
     C                   CALL      'UT2570'                                                         
     C                   PARM                    @PECADENA                                          
     C                   PARM      '1'           @PEACCION                                          
     C                   PARM      *BLANKS       @PEERROR                                           
     C                   IF        @PEERROR=*BLANKS                                                 
     C                   EVAL      C2RAO2=@PECADENA                                                 
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        C2DIRE<>*BLANKS                                                  
     C                   EVAL      @PECADENA=*BLANKS                                                
     C                   EVAL      @PECADENA=C2DIRE                                                 
     C                   CALL      'UT2570'                                                         
     C                   PARM                    @PECADENA                                          
     C                   PARM      '1'           @PEACCION                                          
     C                   PARM      *BLANKS       @PEERROR                                           
     C                   IF        @PEERROR=*BLANKS                                                 
     C                   EVAL      C2DIRE=@PECADENA                                                 
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        C2DIR2<>*BLANKS                                                  
     C                   EVAL      @PECADENA=*BLANKS                                                
     C                   EVAL      @PECADENA=C2DIR2                                                 
     C                   CALL      'UT2570'                                                         
     C                   PARM                    @PECADENA                                          
     C                   PARM      '1'           @PEACCION                                          
     C                   PARM      *BLANKS       @PEERROR                                           
     C                   IF        @PEERROR=*BLANKS                                                 
     C                   EVAL      C2DIR2=@PECADENA                                                 
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        C2POBL<>*BLANKS                                                  
     C                   EVAL      @PECADENA=*BLANKS                                                
     C                   EVAL      @PECADENA=C2POBL                                                 
     C                   CALL      'UT2570'                                                         
     C                   PARM                    @PECADENA                                          
     C                   PARM      '1'           @PEACCION                                          
     C                   PARM      *BLANKS       @PEERROR                                           
     C                   IF        @PEERROR=*BLANKS                                                 
     C                   EVAL      C2POBL=@PECADENA                                                 
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        C2POST<>*BLANKS                                                  
     C                   EVAL      @PECADENA=*BLANKS                                                
     C                   EVAL      @PECADENA=C2POST                                                 
     C                   CALL      'UT2570'                                                         
     C                   PARM                    @PECADENA                                          
     C                   PARM      '1'           @PEACCION                                          
     C                   PARM      *BLANKS       @PEERROR                                           
     C                   IF        @PEERROR=*BLANKS                                                 
     C                   EVAL      C2POST=@PECADENA                                                 
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
FQ722C*                  IF        C2TELE<>*BLANKS                                                  
FQ722C*                  EVAL      @PECADENA=*BLANKS                                                
FQ722C*                  EVAL      @PECADENA=C2TELE                                                 
