C0035C                   EVAL      C5TDES=ZXTDES5                                                   
C0035C                   EVAL      C5CIDT=ZXCIA15                                                   
C0035C                   EVAL      C5CLDT=ZXCLP15                                                   
C0035C                   EVAL      C5EVR0='5'                                                       
C0035C                   EVAL      ZXEVOL5=C5EVOL                                                   
C0035C                   EVAL      C5EVOL=' '                                                       
C0035C                   DOU       LCKRCD=*OFF                                                      
C0035C                   EVAL      C5HOR0=C5HOR0+1                                                  
C0035C                   EVAL      C5PROG=SDSPGM                                                    
I0155C                   EXSR      CS_BUSLOG                                                        
C0035C                   WRITE     RTR0036                              80                          
I0155C                   eval      C5LOGE=ZXLOGE                                                    
C0035C                   ENDDO                                                                      
C0035C                   EVAL      C5EVOL=ZXEVOL5                                                   
C0035C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      ***************************************************************                               
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPUCAPEX      READE     PUDEPE                               8081                        
     C                   ENDDO                                                                      
     C                   ENDDO                                                                      
      *                                                                                             
      * Cambio de nº de orden en observaciones                                                      
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPUCAPEX      CHAIN     PUOBPE                             8180                          
     C                   ENDDO                                                                      
