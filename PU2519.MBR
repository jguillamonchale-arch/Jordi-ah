I0155 *                                                                                             
      * RECUPERACIÓ DE LA LDA DE COMPRES                                                            
     C     *DTAARA       DEFINE    PURLDA        DSLDA                                              
     C                   IN        DSLDA                                                            
FQ284C                   EVAL      ZEAMPL=ZZAMPL                                                    
                                                                                                    
     C     *ENTRY        PLIST                                                                      
     C                   PARM                    @PCIAS                                             
     C                   PARM                    @PDLGA                                             
     C                   PARM                    @PNPCO                                             
     C                   PARM                    @PTPED                                             
     C                   PARM                    @PDATP                                             
     C                   PARM                    @PNOPL                                             
     C                   PARM                    @PERRO                                             
                                                                                                    
     C                   EVAL      PXFMD1=ZZFMD1                                                    
     C                   EVAL      ZXERRO=@PERRO                                                    
     C                   EVAL      ZXERR2=ZXERRO                                                    
     C                   EVAL      @PERRO=*BLANKS                                                   
     C                   EVAL      PECIAS=@PCIAS                                                    
     C                   EVAL      PECTAB='NPCO'                                                    
     C                   EVAL      PDCIAS=@PCIAS                                                    
     C                   EVAL      PDCTAB='NPCO'                                                    
     C                   MOVE      @PCIAS        ZXCIAS2                                            
     C                   EVAL      ZXDLGA2=@PDLGA                                                   
     C                   EVAL      ZXTPED2=@PTPED                                                   
     C                   EVAL      PECLTA=ZXCLTA                                                    
      * Guardo las clave original                                                                   
     C                   EVAL      ZXCIAS=@PCIAS                                                    
     C                   EVAL      ZXDLGA=@PDLGA                                                    
     C                   EVAL      ZXNPCO=@PNPCO                                                    
     C                   EVAL      ZXTPED=@PTPED                                                    
     C                   EVAL      ZXDATP=@PDATP                                                    
     C                   EVAL      ZXNOPL=@PNOPL                                                    
                                                                                                    
     C                   EVAL      ZXOPT1='CHK'                                                     
                                                                                                    
     C     TINZSR        ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CHECK. DEFINICIO DE TOTS ELS PARÀMETRES          *                                
      * GENERALS DEL PROGRAMA.                                     *                                
      *------------------------------------------------------------*                                
     C     SUBCHK        BEGSR                                                                      
                                                                                                    
     C                   EVAL      ZXOPT='UP1'                                                      
     C                   IF        ZXERR2='1'                                                       
     C                   EVAL      ZXOPT='UP2'                                                      
     C                   ENDIF                                                                      
     C     TSUBCHK       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE CONTROLA ELS POSSIBLES ERRORS DE PROGRAMA    *                                
      *------------------------------------------------------------*                                
     C     CHKTABD       BEGSR                                                                      
                                                                                                    
     C                   EVAL      ERRGRL=*OFF                                                      
                                                                                                    
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPMTABD       CHAIN     PMTABD                             8180                          
     C                   ENDDO                                                                      
     C                   IF        CHAIN=*ON OR PEBAJA=*ON                                PMTABD    
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TCHKTABD                                           
                                                                                                    
     C                   MOVEL     PEDESC        ZXNORT                                             
     C     ZXNODE        IFEQ      *BLANKS                                                          
     C                   MOVE      *ZEROS        ZXNODE                                             
     C                   MOVEL     UYEAR         ZXNODE                                             
     C                   ENDIF                                                                      
     C     ZXNOHA        IFEQ      *BLANKS                                                          
     C                   MOVE      *ALL'9'       ZXNOHA                                             
     C                   MOVEL     UYEAR         ZXNOHA                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXALPH=ZXNODE                                                    
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   EVAL      ZXNORD=PXNUM                                                     
      *                                                                                             
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXALPH=ZXNOHA                                                    
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   EVAL      ZXNORH=PXNUM                                                     
                                                                                                    
     C                   ADD       1             ZXNORD                                             
     C     ZXNORD        IFGT      ZXNORH                                                           
     C                   MOVE      '3'           @PERRO                                             
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TCHKTABD                                           
     C     TCHKTABD      ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA UPDATE                                           *                                
      *------------------------------------------------------------*                                
     C     SUBUP1        BEGSR                                                                      
      * Da nº a @PNPCO                                                                              
     C                   EVAL      ZXOPT='END'                                                      
     C                   IF        ZXERR2='2'                                                       
     C                   EVAL      ZXOPT='UP2'                                                      
     C                   ENDIF                                                                      
      * Si ya tiene nº de salida no continuo en esta subrutina                                      
     C                   IF        @PNPCO<>*BLANKS                                                  
     C                   GOTO      TFIN                                                             
     C                   ENDIF                                                                      
      *                                                                                             
      * @PERRO DE SALIDA:                                                                           
      * @PERRO='1' ==> NO SE HA ENCONTRADO TABLA O SON BAJA                                         
      * @PERRO='2' ==> Nº DE ORDEN YA EXISTE                                                        
      * @PERRO='3' ==> NO QUEDAN MAS NUMEROS PARA OTORGAR                                           
     C                   MOVE      ZXERRO        ZXINBA            1                                
     C     KPMTABL       CHAIN     PMTABL                             8180                          
     C                   IF        CHAIN=*ON                                          PMTABL        
     C                   MOVE      '1'           @PERRO                                             
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ELSE                                                                       
     C                   IF        PDBAJA=*ON                                                       
     C                   MOVE      '1'           @PERRO                                             
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TFIN                                               
      * 1º intento con todos los valores de parámetros CIAS+DLGA+TPED                               
     C                   EVAL      ZXCLTA1=*BLANKS                                                  
     C                   EXSR      CHKTABD                                                          
     C                   EVAL      ZXCLTA1=PECLTA                                                   
     C                   IF        ERRGRL=*OFF                                                      
     C                   GOTO      TFI9                                                             
     C                   ENDIF                                                                      
                                                                                                    
      * SI NO CONSEGUIMOS CON TODOS LOS CIAS+DLGA+TPED, se intenta según                            
      * CIAS+DLGA si DLGA ES<>*BLANKS                                                               
     C                   MOVE      *BLANKS       @PERRO                                             
     C                   EVAL      ZXCLTA2=*BLANKS                                                  
     C                   IF        @PDLGA<>*BLANKS                                                  
     C                   EVAL      ZXTPED2=*BLANKS                                                  
     C                   EVAL      PECLTA=ZXCLTA                                                    
     C                   IF        PECLTA<>ZXCLTA1                                                  
     C                   EXSR      CHKTABD                                                          
     C                   EVAL      ZXCLTA2=PECLTA                                                   
     C                   IF        ERRGRL=*OFF                                                      
     C                   GOTO      TFI9                                                             
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
      * SI NO CONSEGUIMOS CON CIAS+DLGA SE INTENTARA CON CIAS+TPED                                  
     C                   MOVE      *BLANKS       @PERRO                                             
     C                   EVAL      ZXCLTA3=*BLANKS                                                  
     C                   IF        @PTPED<>*BLANKS                                                  
     C                   EVAL      ZXDLGA2=*BLANKS                                                  
     C                   EVAL      ZXTPED2=@PTPED                                                   
     C                   EVAL      PECLTA=ZXCLTA                                                    
     C                   IF        PECLTA<>ZXCLTA1 AND PECLTA<>ZXCLTA2                              
     C                   EXSR      CHKTABD                                                          
     C                   EVAL      ZXCLTA3=PECLTA                                                   
     C                   IF        ERRGRL=*OFF                                                      
     C                   GOTO      TFI9                                                             
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
      * SI NO CONSEGUIMOS CON CIAS+TPED SE INTENTARA CON CIAS                                       
     C                   MOVE      *BLANKS       @PERRO                                             
     C                   EVAL      ZXDLGA2=*BLANKS                                                  
     C                   EVAL      ZXTPED2=*BLANKS                                                  
     C                   EVAL      PECLTA=ZXCLTA                                                    
     C                   IF        PECLTA<>ZXCLTA1 AND PECLTA<>ZXCLTA2                              
     C                             AND PECLTA<>ZXCLTA3                                              
     C                   EXSR      CHKTABD                                                          
     C                   IF        ERRGRL=*OFF                                                      
     C                   GOTO      TFI9                                                             
     C                   ENDIF                                                                      
     C                   ELSE                                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
      * Si llega hasta aquí es que no ha podido recoger nº                                          
     C                   IF        ERRGRL=*ON                                                       
     C                   MOVE      '1'           @PERRO                                             
     C                   GOTO      TFIN                                                             
     C                   ENDIF                                                                      
                                                                                                    
     C     TFI9          TAG                                                                        
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXNORD                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        ZXNODE                                             
      * Si el nº es menor de 9999 le pondremos ceros delante                                        
      * por similitud al traspaso realizado desde la antigua aplicación                             
     C                   IF        PXNUM<=9999                                                      
     C                   Z-ADD     PXNUM         ZXNODEN           5 0                              
     C                   MOVE      ZXNODEN       ZXNODE                                             
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXNORH                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        ZXNOHA                                             
                                                                                                    
     C                   MOVEA     ZXNODE        SSSNUME                                            
     C                   MOVE      *BLANKS       ZXNODE                                             
     C                   DO        10            ZX                                                 
     C                   IF        SSSNUME(ZX)<>*BLANKS                                             
     C                   MOVEA     SSSNUME(ZX)   ZXNODE                                             
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
     C                   ENDDO                                                                      
                                                                                                    
     C                   MOVEA     ZXNOHA        SSSNUME                                            
     C                   MOVE      *BLANKS       ZXNOHA                                             
     C                   DO        10            ZX                                                 
     C                   IF        SSSNUME(ZX)<>*BLANKS                                             
     C                   MOVEA     SSSNUME(ZX)   ZXNOHA                                             
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
     C                   ENDDO                                                                      
                                                                                                    
     C                   MOVEL     ZXNORT        PEDESC                                             
     C  N81              UPDATE    RPMTABD                                      *UPD PMTABD         
     C                   MOVEL     ZXNODE        @PNPCO                                             
      * Si el numerador contiene letras, entonces modifico                                          
     C                   IF        PEBL65<>*BLANKS                                                  
     C     PEBL65        CAT       @PNPCO:0      @PNPCO                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C     TFIN          TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT1='END'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C     TSUBUP1       ENDSR                                                                      
                                                                                                    
      **************************************************************                                
      * SUBRUTINA UPDATE                                           *                                
      *------------------------------------------------------------*                                
     C     SUBUP2        BEGSR                                                                      
     C* Aquí viene la actualización de PUCAPE, PUDEPE, estatus, PUDIPE                              
     C* PUPECO, PUOBPE ,etc.                                                                        
     C                   EVAL      ZXUTCOMU=0                                                       
     C                   EVAL      ZXOPT='END'                                                      
                                                                                                    
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPUCAPEX      CHAIN     PUCAPE                             8180                          
     C                   ENDDO                                                                      
                                                                                                    
     C                   MOVE      'R'           C0STCO                                             
     C                   IF        ZXERRO='1'                                                       
     C                   EVAL      C0STCO='20'                                                      
     C                   ENDIF                                                                      
     C                   UPDATE    RPUCAPE                              80                          
      * Actualización del resto de ficheros asociados al pedido                                     
     C                   EVAL      ZXUPDAT1=0                                                       
     C                   IF        ZXERRO='2'OR (ZZEPP1>='1' AND ZZALOL<'1' )                       
     C                             OR (ZZEPP6>='1' AND ZZALOL>='1')                                 
     C                             OR (ZZEPP8>='1' AND ZZALOL<'1')                                  
     C                   IF        ZXERRO='2'                                                       
     C                   EVAL      ZXUPDAT1=1                                                       
     C                   ENDIF                                                                      
     C                   EXSR      CS_UPDATE                                                        
DPMCTC                   EXSR      CS_DPM                                                           
C1631C                   EXSR      CS_EDICOM                                                        
     C                   ENDIF                                                                      
     C     TSUBUP2       ENDSR                                                                      
      *                                                                                             
      **************************************************************                                
      * SUBRUTINA UPDATE                                           *                                
      *------------------------------------------------------------*                                
     C     CS_UPDATE     BEGSR                                                                      
      * Si el proveedor con el que trabajan es para grabación, entonces                             
      * marco para que grabe                                                                        
     C                   IF        (ZZEPP6>='1' AND ZZALOL>='1')                                    
     C                   EVAL      ZXEVR0='2'                                                       
      * Busqueda Cias OL                                                                            
     C                   EVAL      PECTAB='INOL'                                                    
     C                   EVAL      PECLTA='DESTSGA   '                                              
     C     KPMTAB2       CHAIN     PMTAB2                             81                            
     C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      U1DEST=PEDESC                                                    
     C     U1DEST        CHAIN     UTDEST                             81                            
     C                   IF        CHAIN=*OFF AND U1DSGA='1'                                        
     C                   EVAL      U0DEST=U1DEST                                                    
     C                   EVAL      U0TENV='9'                                                       
     C                   EVAL      U0CLP0=*BLANKS                                                   
      *****              EVAL      ZXUTCOMU=1                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        ZZALOL<'1'                                                       
     C                   EVAL      MICIAS=C0CIAS                                                    
     C                   EVAL      MIDLGA=C0DLGA                                                    
     C                   EVAL      MILGCA=C0LOGE                                                    
     C     KMSLOGI       CHAIN     MSLOGI                             81                            
     C                   IF        MIALOL='1'                                                       
     C                   EVAL      ZXEVR0=' '                                                       
     C                   EVAL      U0TENV='1'                                                       
     C                   ELSE                                                                       
     C                   EVAL      U0TENV='5'                                                       
     C                   EVAL      ZXEVR0='5'                                                       
     C                   ENDIF                                                                      
     C                   IF        ZZEPP1>='1' OR ZZEPP8>='1'                                       
     C                   EVAL      U0CIAS=C0CIAS                                                    
     C                   EVAL      U0CLP0=C0PRVR                                                    
      * El registro no debe ser baja ni puede estar desactivado y                                   
      * debe permitir traspaso automatico de pedidos                                                
     C     KUTCOM0       CHAIN     UTCOM0                             81                            
     C                   IF        (CHAIN=*OFF AND U0BAJA<='0' AND                                  
     C                             U0ACTI<='0')AND (U0EPP1>='1')                                    
C0144C                   IF        C0EVPR>='1' And U0TENV='5'                                       
C0144C                             Or U0TENV<>'5'                                                   
     C                   EVAL      ZXUTCOMU=1                                                       
C0144C                   ENDIF                                                                      
     C                   ENDIF                                                                      
C0035 * Si enviamos pedido a OL también lo hacemos a productiva                                     
C0144C                   IF        U0TENV='1' and C0EVPR>='1'                                       
C0035C                   EVAL      ZXTENV1=U0TENV                                                   
C0035C                   EVAL      ZXDEST1=U0DEST                                                   
C0035C                   EVAL      ZXTDES1=U0TDES                                                   
C0035C                   EVAL      ZXCIA11=U0CIA1                                                   
C0035C                   EVAL      ZXCLP11=U0CLP1                                                   
C0035C                   EVAL      U0TENV='5'                                                       
C0035C     KUTCOM0       CHAIN     UTCOM0                             81                            
C0035C                   IF        (CHAIN=*OFF AND U0BAJA<='0' AND                                  
C0035C                             U0ACTI<='0')AND (U0EPP1>='1')                                    
C0035C                   EVAL      ZXUTCOMU5=1                                                      
C0035C                   EVAL      ZXTENV5=U0TENV                                                   
C0035C                   EVAL      ZXDEST5=U0DEST                                                   
C0035C                   EVAL      ZXTDES5=U0TDES                                                   
C0035C                   EVAL      ZXCIA15=U0CIA1                                                   
C0035C                   EVAL      ZXCLP15=U0CLP1                                                   
22037C                   ENDIF                                                                      
C0035C                   EVAL      U0TENV=ZXTENV1                                                   
C0035C                   EVAL      U0DEST=ZXDEST1                                                   
C0035C                   EVAL      U0TDES=ZXTDES1                                                   
C0035C                   EVAL      U0CIA1=ZXCIA11                                                   
C0035C                   EVAL      U0CLP1=ZXCLP11                                                   
22037C**                 ENDIF                                                                      
C0035C                   ENDIF                                                                      
C0035 *                                                                                             
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *PRIMERO GRABAMOS REGISTRO ENVIO PUCAPE                                                       
      ***************************************************************                               
      * Si está activado el envío de pedidos a proveedor grabo en                                   
      * el fichero para traspaso de pedidos a proveedor                                             
     C                   IF        ZXUTCOMU=1                                                       
     C                   IF        ZXUPDAT1=1                                                       
     C                   EVAL      C0NPCO=@PNPCO                                                    
     C                   ENDIF                                                                      
     C                   EVAL      C0OPC0='1'                                                       
     C                   EVAL      C0EVR0=ZXEVR0                                                    
     C                   EVAL      C0TENV=U0TENV                                                    
     C                   EVAL      C0DEST=U0DEST                                                    
     C                   EVAL      C0TDES=U0TDES                                                    
     C                   EVAL      C0CIDT=U0CIA1                                                    
     C                   EVAL      C0CLDT=U0CLP1                                                    
     C                   EVAL      C0USU0=SDSUSR                                                    
     C                   EVAL      C0PAN0=ZZPANT                                                    
     C                   EVAL      C0DAT0=ZZDATS                                                    
     C                   TIME                    ZXTIME                                             
     C                   MOVEL     ZXTIME        C0HOR0                                             
      *  Activaremos el campo de CHEKSUM                                                            
     C                   EXSR      CS_CHKSUM                                                        
     C                   EVAL      C0CHKS=ZXCHKS                                                    
                                                                                                    
     C                   DOU       LCKRCD=*OFF                                                      
     C                   EVAL      C0HOR0=C0HOR0+1                                                  
     C                   EVAL      C0PROG=SDSPGM                                                    
C0088 *                                                                                             
C0088C                   IF        C0REFP<>*BLANKS AND                                              
FQ284C                             ZEEDV2<>'1' AND C0TPE4<>'2'                                      
C0088C                   EVAL      C0CAUT=*BLANKS                                                   
C0088C                   ENDIF                                                                      
C0088 *                                                                                             
I0155C                   EXSR      CS_BUSLOG2                                                       
     C                   WRITE     RTR0035                              80                          
I0155C                   eval      C0LOGE=ZXLOGE                                                    
     C                   ENDDO                                                                      
C0035C                   IF        ZXUTCOMU5>=1                                                     
C0035C                   EVAL      C0TENV=ZXTENV5                                                   
C0035C                   EVAL      C0DEST=ZXDEST5                                                   
C0035C                   EVAL      C0TDES=ZXTDES5                                                   
C0035C                   EVAL      C0CIDT=ZXCIA15                                                   
C0035C                   EVAL      C0CLDT=ZXCLP15                                                   
C0035C                   EVAL      C0EVR0='5'                                                       
C0035C                   EVAL      ZXEVOL5=C0EVOL                                                   
C0035C                   EVAL      C0EVOL=' '                                                       
C0035C                   EVAL      C0EALB='1'                                                       
C0035C                   DOU       LCKRCD=*OFF                                                      
C0035C                   EVAL      C0HOR0=C0HOR0+1                                                  
C0035C                   EVAL      C0PROG=SDSPGM                                                    
I0155C                   EXSR      CS_BUSLOG2                                                       
C0035C                   WRITE     RTR0035                              80                          
I0155C                   eval      C0LOGE=ZXLOGE                                                    
C0035C                   ENDDO                                                                      
C0035C                   EVAL      C0EVOL=ZXEVOL5                                                   
C0035C                   EVAL      C0EALB=' '                                                       
C0035C                   ENDIF                                                                      
      * ACTUALIZAMOS EVOL O EVPR SEGÚN TOQUE                                                        
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPUCAPEX      CHAIN     PUCAPE                             8180                          
     C                   ENDDO                                                                      
                                                                                                    
17076 **                 IF        U0TENV='1'                                                       
17076C                   IF        MIALOL='1'                                                       
     C                   EVAL      C0EVOL='1'                                                       
     C                   ELSE                                                                       
     C                   IF        U0TENV='5'                                                       
C0144 **                 EVAL      C0EVPR='1'                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDIF                                                                      
                                                                                                    
      * Cambio de nº de orden en detalle                                                            
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPUCAPEX      CHAIN     PUDEPE                             8180                          
     C                   ENDDO                                                                      
     C                   DOW       CHAIN=*OFF                                                       
     C                   IF        ZXUTCOMU=1                                                       
17076 **                 IF        U0TENV='1'                                                       
17076C                   IF        MIALOL='1'                                                       
     C                   EVAL      C5EVOL='1'                                                       
     C                   ELSE                                                                       
     C                   IF        U0TENV='5'                                                       
     C                   EVAL      C5EVPR='1'                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   IF        ZXUPDAT1=1                                                       
     C                   EVAL      C5NPCO=@PNPCO                                                    
     C                   UPDATE    RPUDEPE                                                          
      **** Actualizaciones de pedidos de ventas relacionados.                                       
      * Si proviene de una orden de ventas, asocio en la orden de ventas                            
      * la orden de compras                                                                         
     C                   IF        C5NPVE<>*BLANKS                                                  
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXALPH=C5CIVE                                                    
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM      0             PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   EVAL      S5CIAS=PXNUM                                                     
                                                                                                    
     C                   EVAL      S5CUST=C5CUST                                                    
     C                   EVAL      S5DLGA=C5DLVE                                                    
     C                   EVAL      S5NPCO=C5NPVE                                                    
      **                 EVAL      S5TPED=C5TPED                                                    
      **                 EVAL      S5LINE=C5LINE                                                    
     C                   EVAL      S5TPED=C5TPVE                                                    
     C                   EVAL      S5LINE=C5LIVE                                                    
                                                                                                    
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCODEPE120    CHAIN     CODEPE12                           8180                          
     C                   ENDDO                                                                      
     C                   IF        (CHAIN=*OFF)                                                     
      * Si no tiene grabados datos , la informacion de ventas contiene                              
     C**                 IF        ((C5DAVE<>*ZEROS AND C5DAVE=S5DATP) OR                           
     C**                           (C5DAVE<=*ZEROS)) AND (C5LINE=S5LINE)                            
      * Si el sistema no tiene pedido asociado o este es de la misma                                
      * empresa (puede ocurrir que haga referencia al pedido de compra                              
      * de la empresa origen -traspasos automaticos comercial-productiva)                           
      * y por tanto no puede machacarse.                                                            
     C                   MOVEL     C5CIAS        ZXCI01                                             
     C                   IF        (S5CI01=*BLANKS OR S5CI01=ZXCI01)                                
     C                   EVAL      S5PR01=C5PRVR                                                    
     C                   MOVEL     C5CIAS        S5CI01                                             
     C                   EVAL      S5DL01=C5DLGA                                                    
     C                   EVAL      S5NP01=C5NPCO                                                    
     C                   EVAL      S5DA01=C5DATP                                                    
     C                   EVAL      S5NO01=C5NOPL                                                    
     C                   EVAL      S5LI01=C5LINE                                                    
     C                   ENDIF                                                                      
     C                   UPDATE    RCODEPE                                                          
     C                   ENDIF                                                                      
      **** Fin Actualizaciones de pedidos de ventas relacionados.                                   
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      ***************************************************************                               
      * Si está activado el envío de pedidos a proveedor grabo en                                   
      * el fichero para traspaso de pedidos a proveedor                                             
     C                   IF        ZXUTCOMU=1                                                       
     C                   EVAL      C5CUSF=C0CUST                                                    
     C                   EVAL      C5OPC0='1'                                                       
     C                   EVAL      C5EVR0=ZXEVR0                                                    
     C                   EVAL      C5TENV=U0TENV                                                    
     C                   EVAL      C5DEST=U0DEST                                                    
     C                   EVAL      C5TDES=U0TDES                                                    
     C                   EVAL      C5CIDT=U0CIA1                                                    
     C                   EVAL      C5CLDT=U0CLP1                                                    
     C                   EVAL      C5USU0=SDSUSR                                                    
     C                   EVAL      C5PAN0=ZZPANT                                                    
     C                   EVAL      C5DAT0=ZZDATS                                                    
     C                   TIME                    ZXTIME                                             
     C                   MOVEL     ZXTIME        C5HOR0                                             
     C                   DOU       LCKRCD=*OFF                                                      
     C                   EVAL      C5HOR0=C5HOR0+1                                                  
     C                   EVAL      C5PROG=SDSPGM                                                    
I0155C                   EXSR      CS_BUSLOG                                                        
     C                   WRITE     RTR0036                              80                          
