      * Estructura de Programa                                                                      
      **********************************************************************                        
      *                                                                                             
      * Generamos el/los ficheros de trabajo deseados en QTEMP                                      
      *                                                                                             
     C                   CALL      'UTIFQTMPCL'                                                     
     C                   PARM      'ED0050W   '  @PEFILE1                                           
     C                   PARM      *BLANKS       @PELOG11                                           
     C                   PARM      *BLANKS       @PELOG12                                           
     C                   PARM      *BLANKS       @PELOG13                                           
     C                   PARM      *BLANKS       @PEFILE2                                           
     C                   PARM      *BLANKS       @PELOG21                                           
     C                   PARM      *BLANKS       @PELOG22                                           
     C                   PARM      *BLANKS       @PELOG23                                           
     C                   PARM      *BLANKS       @PEFILE3                                           
     C                   PARM      *BLANKS       @PELOG31                                           
     C                   PARM      *BLANKS       @PELOG32                                           
     C                   PARM      *BLANKS       @PELOG33                                           
     C                   PARM      *BLANKS       @PEPROGR                                           
     C                   PARM      *BLANKS       @PEPARMS                                           
      *                                                                                             
      * Abrir Ficheros QTEMP                                                                        
      *                                                                                             
     C                   OPEN      ED0050W                                                          
      *                                                                                             
     C                   EXSR      CS_LOGOL                                                         
      * Proceso                                                                                     
     C                   EXSR      CS_PROCESO                                                       
      *                                                                                             
      * Cerrar Ficheros QTEMP                                                                       
      *                                                                                             
     C                   CLOSE     ED0050W                                                          
                                                                                                    
     C                   IF        S0PPED<>'26'                                                     
     C                                                                                              
C8918C* NO ACTUA DOM SI TRASPORTISTA NO ED AL CONFIRMAR                                             
C8918C                   EVAL      ZXNODOM=*BLANKS                                                  
OLFGIC                   EVAL      T3CIAS = @PCIAS                                                  
OLFGIC                   EVAL      T3DLGA = @PDLGA                                                  
OLFGIC     KEDPARM       CHAIN     EDPARM                                                           
OLFGIC                   IF        %FOUND AND T3ADOM='1'                                            
OLFGIC                             AND S0STCO<'20'                                                  
C8918C*                            AND (T3OFEX<>'1' OR                                              
C8918C*                            (T3OFEX='1' AND S0EDME<>'5'))                                    
OLFGIC                   EVAL      N1CIAS = @PCIAS                                                  
OLFGIC                   EVAL      N1TTTA = S0TTTA                                                  
OLFGIC     KMSTRTA       CHAIN     MSTRTA                                                           
OLFGIC                   IF        %FOUND(MSTRTA) And N1NOED='2'                                    
C8918C                   EVAL      ZXNODOM='1'                                                      
OLFGIC*                  ELSE                                                                       
C8918C                   ENDIF                                                                      
C8918C                   ENDIF                                                                      
OLFGIC*FIN TRASPORTISTA                                                                             
C8918C                   IF        ZXNODOM=*BLANKS                                                  
     C                   CALL      'DOOM01'                                                         
     C                   PARM                    @PCIAS                                             
     C                   PARM                    @PDLGA                                             
     C                   PARM                    @PNPCO                                             
     C                   PARM                    @PTPED                                             
     C                   PARM                    @PDATP                                             
     C                   PARM                    @PNOPL                                             
     c                   parm                    @3LINE                                             
C0981C*                                                                                             
OLFGIC                   ENDIF                                                                      
C0891C*                  ENDIF                                                                      
C0891C*                                                                                             
     C                   ENDIF                                                                      
                                                                                                    
      *                                                                                             
     C                   SETON                                        LR                            
