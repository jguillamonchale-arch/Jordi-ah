I0184 *                                                                                             
     C                   ENDSR                                                                      
FQ842                                                                                               
FQ842 **************************************************************************                    
FQ842 * SUBRUTINA COMPROBAR SI HAY QUE CAMBIAR LOGÍSTICA DE ENTREGA            *                    
FQ842 *------------------------------------------------------------------------*                    
FQ842C     CS_CHKLOGE    BEGSR                                                                      
FQ842C                   EVAL      S0CIAS = @PCIAS                                                  
FQ842C                   EVAL      S0DLGA = @PDLGA                                                  
FQ842C                   EVAL      S0NPCO = @PNPCO                                                  
FQ842C                   EVAL      S0TPED = @PTPED                                                  
FQ842C                   EVAL      S0DATP = @PDATP                                                  
FQ842C                   EVAL      S0NOPL = @PNOPL                                                  
FQ842C     KCOCAPE       CHAIN     COCAPE                                                           
b0142C                   IF        %FOUND(COCAPE)                                                   
FQ842C                   IF        S0EDLG='1'                                                       
FQ842C                   EXSR      CS_CHGLOGE                                                       
FQ842C                   ELSE                                                                       
FQ842C                   IF        S0MOST<>'1'                                                      
FQ842C                   EVAL      P7CIAS=S0CIAS                                                    
FQ842C                   EVAL      P7DLGA=S0DLGA                                                    
FQ842C     KPMEMPR       CHAIN     PMEMPR                                                           
FQ842C                   IF        %FOUND(PMEMPR) AND P7AUTS<>*BLANKS                               
FQ842C*                  IF        %FOUND(PMEMPR)                                                   
FQ842C                   EXSR      CS_CHGLOGE                                                       
FQ842C                   ENDIF                                                                      
FQ842C                   ENDIF                                                                      
FQ842C                   ENDIF                                                                      
FQ842C                   ENDIF                                                                      
FQ842C                   ENDSR                                                                      
FQ842 **************************************************************************                    
FQ842 * SUBRUTINA CAMBIAR LOGÍSTICA DE ENTREGA                                 *                    
FQ842 *------------------------------------------------------------------------*                    
FQ842C     CS_CHGLOGE    BEGSR                                                                      
FQ842C                   EVAL      S5CIAS=S0CIAS                                                    
FQ842C                   EVAL      S5DLGA=S0DLGA                                                    
FQ842C                   EVAL      S5NPCO=S0NPCO                                                    
FQ842C                   EVAL      S5TPED=S0TPED                                                    
FQ842C                   EVAL      S5DATP=S0DATP                                                    
FQ842C                   EVAL      S5NOPL=S0NOPL                                                    
FQ842C     KCODEPE       SETLL     CODEPE                                                           
FQ842C     KCODEPE       READE     CODEPE                                                           
FQ842C                   DOW       NOT %EOF(CODEPE)                                                 
      *                                                                                             
Q0258**CR554c                   if            s5lb2b <> *blanks                                     
Q0258**CR554c                             and s5tped = '25'                                         
Q0258**CR554c                   ITER                                                                
Q0258**CR554c                   endif                                                               
Q0258 *                                                                                             
Q0258c                   if            s5lb2b = *blanks                                             
Q0258c                              or s5tped <> '25'                                               
      *                                                                                             
FQ842C                   EVAL      M0CIAS=S5CIAS                                                    
FQ842C                   EVAL      M0LOGE=S5LOGE                                                    
FQ842C     KMSALMA05     CHAIN     MSALMA05                                                         
FQ842C                   IF        %FOUND(MSALMA05)                                                 
HD123C                             AND (M0TAL1<>'7' OR M0TAL1<>'8')                                 
FQ842C                   EVAL      T3CIAS=M0CIAS                                                    
FQ842C                   EVAL      T3DLGA=M0DLGA                                                    
FQ842C     KEDPARM       CHAIN     EDPARM                                                           
FQ842C                   IF        %FOUND(EDPARM) AND T3OPL1<>*BLANKS AND                           
FQ844C                             T3OPL1<>S5LOGE                                                   
HD123C                             AND S5LOGE<>T3LVIR                                               
FQ842C                   EXSR      CS_UT2725                                                        
FQ842C                   EVAL      S5LOGE=T3OPL1                                                    
CR554c                   exsr      CS_set_s5lb2b                                                    
FQ842C                   UPDATE    RCODEPE                                                          
FQ842C                   ENDIF                                                                      
FQ842C                   ENDIF                                                                      
Q0258 *                                                                                             
Q0258c                   endif                                                                      
Q0258 *                                                                                             
FQ842C     KCODEPE       READE     CODEPE                                                           
FQ842C                   ENDDO                                                                      
FQ842C                   ENDSR                                                                      
FQ842 **************************************************************                                
FQ842 * FICHERO AUDITORIA                                          *                                
FQ842 *------------------------------------------------------------*                                
FQ842C     CS_UT2725     BEGSR                                                                      
FQ842 *                                                                                             
FQ842C                   EVAL      @PECIAS=S5CIAS                                                   
FQ842C                   EVAL      @PEDLGA=S5DLGA                                                   
FQ842C                   EVAL      @PENPCO=S5NPCO                                                   
FQ842C                   EVAL      @PETPED=S5TPED                                                   
FQ842C                   EVAL      @PEDATP=S5DATP                                                   
FQ842C                   EVAL      @PENOPL=S5NOPL                                                   
FQ842C                   EVAL      @PELINE=S5LINE                                                   
FQ842C                   EVAL      @PEFILD='S5LOGE'                                                 
FQ842C                   EVAL      @PECAUD='CO51'                                                   
FQ842C                   EVAL      @PEVAL1=S5LOGE                                                   
FQ842C                   EVAL      @PEVAL2=T3OPL1                                                   
FQ842C                   EVAL      @PECLPR=S5CUST                                                   
FQ842C                   EVAL      @PEFILE='CODEPE'                                                 
FQ842 *                                                                                             
FQ842C                   CALL      'UT2725'                             55                          
FQ842C                   PARM                    @PECIAS                                            
FQ842C                   PARM                    @PEDLGA                                            
FQ842C                   PARM                    @PENPCO                                            
FQ842C                   PARM                    @PETPED                                            
FQ842C                   PARM                    @PEDATP                                            
FQ842C                   PARM                    @PENOPL                                            
FQ842C                   PARM                    @PELINE                                            
FQ842C                   PARM                    @PECLPR                                            
FQ842C                   PARM                    @PEFILE                                            
FQ842C                   PARM                    @PEFILD                                            
FQ842C                   PARM                    @PECAUD                                            
FQ842C                   PARM                    @PEVAL1                                            
FQ842C                   PARM                    @PEVAL2                                            
FQ842C                   PARM      *BLANKS       @PEACCI                                            
FQ842C                   PARM      *BLANKS       @PEERR                                             
FQ842C                   PARM      SDSPGM        @PEPGMO                                            
FQ842C                   PARM      *BLANKS       @PEARVM                                            
FQ842 *                                                                                             
FQ842C                   ENDSR                                                                      
CR554 *····························································*                                
CR554 * Actualizar campo S5LB2B                                    *                                
CR554 *····························································*                                
CR554 *                                                                                             
CR542C     CS_set_s5lb2b BEGSR                                                                      
CR554 *                                                                                             
CR554c                   eval      u_l = %lookup(s5loge:zxLogS)                                     
CR554c                   if        u_l <> *zero and u_l <> 4                                        
CR554c                   if        s5lb2b = *blank                              ????????????????    
CR554c                   move      zxOrd(u_l)    s5lb2b                                             
CR554c                   endif                                                                      
CR554c                   endif                                                                      
CR554 *                                                                                             
CR554c                   endsr                                                                      
CR554 *                                                                                             
C1636 **********************************************************************                        
C1636 * Comprobar Stock Artículos "B"                                                               
C1636 **********************************************************************                        
C1636C     CS_VFYARTB    BEGSR                                                                      
C1636 *                                                                                             
C1636c                   eval      zycant = 1                                                       
C1636c                   eval      m5cias = s5cias                                                  
C1636c                   movel     @pcias        ppcias                                             
C1636 *                                                                                             
C1636 * Miramos si es Conjunto de Venta                                                             
C1636c                   eval      FileCojc_erp= 'PURLIBF' + ppcias +                               
C1636c                                          '/MSCOJC'                                           
C1636c                   open(e)   MSCOJC                                                           
C1636c                   if        not %error                                                       
C1636c                   eval      ndcias = s5cias                                                  
C1636c                   eval      ndarti = s5arti                                                  
C1636c                   eval      ndvari = s5vari                                                  
C1636c                   eval      ndmode = s5mode                                                  
C1636c                   eval      ndtcoj = '4'                                                     
C1636c     kmscojc       chain     MSCOJC                                                           
C1636c                   if        %found and ndbaja < '1'                                          
C1636c                   close(e)  MSCOJC                                                           
C1636c                   LEAVESR                                                                    
C1636c                   endif                                                                      
C1636c                   close(e)  MSCOJC                                                           
C1636 *                                                                                             
C1636 * Logística asociada a la delegación                                                          
C1636c                   eval      micias = p7cias                                                  
C1636c                   eval      midlga = p7dlga                                                  
C1636c                   eval      milgca = p7logs                                                  
C1636c     kmsload       chain     MSLOAD                                                           
C1636c     kmsload       chain     MSLOGI                                                           
C1636c                   if        %found(MSLOAD) and %found(MSLOGI)                                
C1636c                   eval      m0cias = s0cias                                                  
C1636c                   eval      m0loge = p7logs                                                  
C1636c     kmsalma05     chain     MSALMA05                                                         
C1636c                   if        %found                                                           
C1636 * Busco su Categoría de Rotación                                                              
C1636c                   eval      m1cias = s5cias                                                  
C1636c                   eval      m1arti = s5arti                                                  
C1636c                   eval      m1vari = s5vari                                                  
C1636c                   eval      m1mode = s5mode                                                  
C1636c                   eval      m1maga = m0maga                                                  
C1636c     kmsstok       chain     MSSTOK                                                           
C1636c                   if        %found and m1crot = 'B'                                          
C1636 * Busco Stock en el Almacén de la logística                                                   
C1636c                   eval      m1cias = s5cias                                                  
C1636c                   eval      m1arti = s5arti                                                  
C1636c                   eval      m1vari = s5vari                                                  
C1636c                   eval      m1mode = s5mode                                                  
C1636c                   eval      m1maga = m0maga                                                  
C1636c                   eval      m1cali = 'A'                                                     
C1636c     kmssto010     chain     MSSTO01                                                          
C1636c                   if        %found                                                           
C1636                                                                                               
C1636c                   eval      zystdd  = *zero                                                  
C1636c                   eval      zystka  = *zero                                                  
C1636c                   eval      zycans0 = *zero                                                  
C1636c                   eval      zycane0 = *zero                                                  
C1636c                   eval      zydepo0 = *zero                                                  
C1636c                   eval      z1cant = s5cant - s5canr - s5cans                                
C1636                                                                                               
C1636 * Solo tratamos si el almacén tiene stock                                                     
C1636c                   if        m1sact > *zero                                                   
C1636c                   eval      zystka = m1sact                                                  
C1636 * Busqueda cantidades de stock pdte servir,fabricar,deposito...                               
C1636c                   exsr      cs_Rtv_Stk                                                       
C1636 * Stock disponible                                                                            
C1636c                   eval      zystdd = zystka - zycans0 - zycane0                              
C1636c                   if        zydepo0 > *zero                                                  
C1636c                   eval      zystdd = zystdd - zydepo0                                        
C1636c                   endif                                                                      
C1636c                   eval      t2dart = s5arti + s5vari + s5mode                                
C1636c                   eval      t2dcan = z1cant                                                  
C1636c                   eval      t2ddis = zystdd                                                  
C1636c                   eval      t2dalm = m1maga                                                  
C1636 * Si stock disponible es mayor o igual a cantidad pedido                                      
C1636c                   if        zystdd >= z1cant                                                 
C1636c                   eval      t2va14 = 1                                                       
C1636c                   endif                                                                      
C1636c                   endif                                                                      
C1636c                   endif                                                                      
C1636c                   endif                                                                      
C1636c                   endif                                                                      
C1636c                   endif                                                                      
C1636c                   endif                                                                      
C1636 *                                                                                             
C1636c                   ENDSR                                                                      
C1636 **********************************************************************                        
C1636 *  Busqueda cantidades de stock pdte servir,fabricar,deposito...                              
C1636 **********************************************************************                        
C1636C     cs_Rtv_Stk    BEGSR                                                                      
C1636                                                                                               
C1636C                   EVAL      @PEDATD=*DATE                                                    
C1636C                   EVAL      @PEDATH=*DATE                                                    
C1636C                   MOVE      @PEDATD       ZXDATD                                             
C1636C                   MOVE      @PEDATH       ZXDATH                                             
C1636C                   SUBDUR    1000  :*D     ZXDATD                                             
C1636C                   ADDDUR    1000  :*D     ZXDATH                                             
C1636C                   MOVE      ZXDATD        @PEDATD                                            
C1636C                   MOVE      ZXDATH        @PEDATH                                            
C1636                                                                                               
C1636C                   EVAL      @PECIAS=M1CIAS                                                   
C1636C                   EVAL      @PEARTI=M1ARTI                                                   
C1636C                   EVAL      @PEVARI=M1VARI                                                   
C1636C                   EVAL      @PEMODE=M1MODE                                                   
C1636                                                                                               
C1636C                   EVAL      M5CIAS=M1CIAS                                                    
C1636C                   EVAL      M5ARTI=M1ARTI                                                    
C1636C                   EVAL      M5VARI=M1VARI                                                    
C1636C                   EVAL      M5MODE=M1MODE                                                    
C1636C     KMSARTI00     CHAIN     MSARTI00                           81                            
C1636                                                                                               
C1636 * Pendiente de servir                                                                         
C1636C                   EVAL      @PETISE=' '                                                      
C1636C                   CALL      'MM2600'                                                         
C1636C                   PARM                    @PECIAS                                            
C1636C                   PARM      ZZDLGA        @PEDLGA                                            
C1636C                   PARM                    @PEARTI                                            
C1636C                   PARM                    @PEVARI                                            
C1636C                   PARM                    @PEMODE                                            
C1636C                   PARM                    @PETCOJ                                            
C1636C                   PARM                    @PEDATD                                            
C1636C                   PARM                    @PEDATH                                            
C1636C                   PARM                    @PECUST                                            
C1636C                   PARM      0             @PECANT                                            
C1636C                   PARM      0             @PECAN1                                            
C1636C                   PARM                    M1MAGA                                             
C1636C                   PARM                    @PETISE           4                                
C1636C                   PARM      '1'           @PERRO            1                                
C1636C                   EVAL      zycans0 = @PECANT * zycant                                       
C1636                                                                                               
C1636 * Pendiente de traspasos depositos                                                            
C1636C                   EVAL      @PETISE=' '                                                      
C1636C                   CALL      'MM2604'                                                         
C1636C                   PARM                    @PECIAS                                            
C1636C                   PARM      ZZDLGA        @PEDLGA                                            
C1636C                   PARM                    @PEARTI                                            
C1636C                   PARM                    @PEVARI                                            
C1636C                   PARM                    @PEMODE                                            
C1636C                   PARM                    @PETCOJ                                            
C1636C                   PARM                    @PEDATD                                            
C1636C                   PARM                    @PEDATH                                            
C1636C                   PARM      0             @PECANT                                            
C1636C                   PARM      0             @PECAN1                                            
C1636C                   PARM                    M1MAGA                                             
C1636C                   PARM                    @PETISE           4                                
C1636C                   PARM      *BLANKS       @PERRO            1                                
C1636C                   EVAL      zydepo0 = @PECANT * zycant                                       
C1636                                                                                               
C1636 * Esto solo para empresas que utilizan nuestra produccion                                     
C1636c                   eval      @PECAN1=0                                                        
C1636c                   eval      @PECAN2=0                                                        
C1636c                   IF        ZZTCIA='1' OR ZZTCIA='2'                                         
C1636c                   EVAL      @PEDATD=*DATE                                                    
C1636c                   EVAL      @PEDATH=*DATE                                                    
C1636c                   MOVE      @PEDATD       ZXDATD                                             
C1636c                   MOVE      @PEDATH       ZXDATH                                             
C1636c                   SUBDUR    1000  :*D     ZXDATD                                             
C1636c                   ADDDUR    1000  :*D     ZXDATH                                             
C1636c                   MOVE      ZXDATD        @PEDATD                                            
C1636c                   MOVE      ZXDATH        @PEDATH                                            
C1636 * Solo realizaré la búsqueda en artículos susceptibles de ser utilizados en                   
C1636 * es decir, que sean estructuras o componentes.                                               
C1636c     KMSARTI00     CHAIN     PMCAOR01                           81                            
C1636c                   IF        CHAIN=*ON                                                        
C1636c     KMSARTI00     CHAIN     PMCAOR08                           81                            
C1636c                   ENDIF                                                                      
C1636                                                                                               
C1636 * Búsqueda de las necesidades a tener en cuenta en OF's                                       
C1636C                   EVAL      @PECAN1=0                                                        
C1636C                   EVAL      @PECAN2=0                                                        
C1636C     KMSARTI00     CHAIN     PMDEOR05                           81                            
C1636C                   IF        CHAIN=*OFF                                                       
C1636 * Si MÑSNCC>='1', entonces (DOLL) se desea que se presente el                                 
C1636 * material asignado                                                                           
C1636C                   EVAL      @PERRO=*BLANKS                                                   
C1636C                   CALL      'MM2602'                                                         
C1636C                   PARM                    @PECIAS                                            
C1636C                   PARM                    @PEARTI                                            
C1636C                   PARM                    @PEVARI                                            
C1636C                   PARM                    @PEMODE                                            
C1636C                   PARM                    @PEDATD                                            
C1636C                   PARM                    @PEDATH                                            
C1636C                   PARM      0             @PECAN1                                            
C1636C                   PARM      0             @PECAN2                                            
C1636C                   PARM                    M1MAGA                                             
C1636C                   PARM                    M5MAGD                                             
C1636C                   PARM                    @PERRO                                             
C1636C                   ENDIF                                                                      
C1636C                   ENDIF                                                                      
C1636C                   EVAL      zycane0 = @PECAN2 * zycant                                       
C1636                                                                                               
C1636C                   ENDSR                                                                      
C1636 *                                                                                             
C1636 *                                                                                             
C1636 *                                                                                             
C1636 *                                                                                             
C1579 ******************************************************************                            
C1579 * MIRAMOS SI EL PEDIDO ES POOLWEB Y RECUPERAMOS EL PROVEEDOR                                  
C1579 **********************************************************************                        
C1579C     CS_POOLWEB    BEGSR                                                                      
C1579 *                                                                                             
C1579C                   eval      zxpweb='0'                                                       
C1579 *                                                                                             
C1579 * Para saber si es un proveedor Poolweb,lo buscamos en la tabla                               
C1579 * PWEB con la procedencia del pedido.                                                         
C1579C                   eval      pecias=@pcias                                                    
C1579C                   eval      pectab='PWEB'                                                    
C1579C                   eval      peclta=s0pped                                                    
C1579C     kpmtabd       chain     pmtabd                                                           
C1579                                                                                               
C1579C                   if        %found(pmtabd)                                                   
C1579C                   eval      zxpweb='1'                                                       
C1579C                   endif                                                                      
C1579                                                                                               
C1579C                   ENDSR                                                                      
IT228 **************************************************************                                
IT228 * GUARDA LOGISTICA DEL OL                                    *                                
IT228 *------------------------------------------------------------*                                
IT228C     CS_LOGOL      BEGSR                                                                      
IT228 * Add-begin                                                                                   
                  i2ol = *zero;                                                                     
                  open msalma08;                                                                    
                  setll (@PCIAS:'8') msalma08;                                                      
                  reade (@PCIAS:'8') msalma08;                                                      
                  dow not %eof(msalma08);                                                           
                    if m0tal1 = '8' and m0baja <> '1' and                                           
                        i2OL < %elem(T_logol) ;                                                     
                      i2OL += 1;                                                                    
                      T_logol(i2OL) = m0logs;                                                       
                    endif;                                                                          
                    reade (@PCIAS:'8') msalma08;                                                    
                  enddo;                                                                            
                  close msalma08;                                                                   
IT228 * Add-end                                                                                     
IT228C                   ENDSR                                                                      
IT228 **************************************************************                                
IT228 * RECALCULAR LOGISTICA VIRTUAL                               *                                
IT228 *------------------------------------------------------------*                                
IT228 *                                                                                             
IT228C     LOG_VIRTUAL   BEGSR                                                                      
IT228 *                                                                                             
IT228 * Obtener logística virtual                                                                   
IT228 *                                                                                             
IT228C                   CALL      'MM1411'                                                         
IT228C                   PARM                    s5CIAS                                             
IT228C                   PARM      S5LOGE        @PALMA                                             
IT228C                   PARM      '1'           @PTIPO                                             
IT228C                   PARM                    s5DLGA                                             
IT228C                   PARM      *blanks       @PRESP                                             
IT228 *                                                                                             
IT228C                   IF        @PRESP <> *BLANKS                                                
IT228C                   EVAL      M0MAGA = @PRESP                                                  
IT228C                   ENDIF                                                                      
IT228C                   ENDSR                                                                      
IT228 *                                                                                             
IT228 ******************************************************************                            
IT228 *   Recuperar almacén a partir de la logística del pedido venta                               
IT228 **********************************************************************                        
IT228C     SRrecu        BEGSR                                                                      
IT228C                                                                                              
IT228C                   EVAL      M5CIAS = S5CIAS                                                  
IT228C                   EVAL      M1MAGA = @PRESP                                                  
IT228C                   EVAL      M1ARTI = S5ARTI                                                  
IT228C                   EVAL      M1VARI = S5VARI                                                  
IT228C                   EVAL      M1MODE = S5MODE                                                  
IT228 *                                                                                             
IT228c     KMSSTOK       CHAIN     MSSTOK                             90                            
IT228C                   IF        %FOUND                                                           
IT228C                   IF        m1prvr <> *blanks                                                
IT228C                   movel     M1PRVR        ZXPRV                                              
IT228C                   ENDIF                                                  ECSTK <= *ZEROS     
IT228C                   ENDIF                                                  ECSTK <= *ZEROS     
IT228 *                                                                                             
IT228C                   ENDSR                                                                      
I0184 ******************************************************************************************    
I0184 * OBTENER PLANTA PARA ACCEDER A DATOS DEL ARTÍCULO                                            
I0184 ******************************************************************************************    
I0184 *                                                                                             
I0184P GET_FACI        B                                                                            
I0184D GET_FACI        PI                  LIKE(MMCIAS)                                             
I0184D   @DIVI                             LIKE(MMPROP) VALUE                                       
I0184D   @FACI                             LIKE(MMCIAS) VALUE                                       
I0184D   @ITNO                             LIKE(MMITNO) VALUE                                       
I0184 *                                                                                             
I0184C                   IF        ZXMULTIPLA                                                       
I0184 *                                                                                             
I0184 * Si existe registro en ZAQITN en el que la división es propietaria, entonces                 
I0184 * se devuelve la planta propietaria del artículo.                                             
I0184 *                                                                                             
I0184C                   EVAL      MMITNO = @ITNO                                                   
I0184C     KZAQITN00     CHAIN     ZAQITN00                                                         
I0184C                   IF        %FOUND  AND  MMPROP = @DIVI  AND                                 
I0184C                             MMCIAS <> *BLANKS                                                
I0184C                   RETURN    MMCIAS                                                           
I0184C                   ENDIF                                                                      
I0184 *                                                                                             
I0184 * Si la división no es la propietaria, se hace bucle sobre la tabla FACP y                    
I0184 * se devuelve la primera para la que exista MITFAC                                            
I0184 *                                                                                             
I0184C                   MOVEL(P)  MXCONO        M9CONO                                             
I0184C                   EVAL      M9ITNO = @ITNO                                                   
I0184 *                                                                                             
I0184C                   EVAL      T1CTAB = 'FACP'                                                  
I0184C                   EVAL      T1DESC = @DIVI                                                   
I0184C     KGMTABD01     SETLL     GMTABD01                                                         
I0184C     KGMTABD01     READE     GMTABD01                                                         
I0184 *                                                                                             
I0184C                   DOW       NOT %EOF                                                         
I0184 *                                                                                             
I0184C                   EVAL      M9FACI = T1CELE                                                  
I0184C     KMITFAC00     SETLL     MITFAC00                                                         
I0184C                   IF        %EQUAL                                                           
I0184C                   RETURN    M9FACI                                                           
I0184C                   ENDIF                                                                      
I0184 *                                                                                             
I0184C     KGMTABD01     READE     GMTABD01                                                         
I0184C                   ENDDO                                                                      
I0184 *                                                                                             
I0184C                   ENDIF                                                                      
I0184 *                                                                                             
I0184 * Si la división no es multiplanta, o la búsqueda anterior no ha dado frutos,                 
I0184 * devolver la planta entrada                                                                  
I0184 *                                                                                             
I0184C                   RETURN    @FACI                                                            
I0184 *                                                                                             
I0184P                 E                                                                            
