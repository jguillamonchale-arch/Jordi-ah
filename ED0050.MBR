C1579c                   endif                                                                      
FQ726                                                                                               
FQ726 * Si parámetro de Solo Forzada, compruebo que sea ED Forzada                                  
FQ726C                   IF        T3EDFO = '1'                                                     
FQ726C                   IF        S5TPE4 = '2' Or S0TPE4 = '2'                                     
FQ726C                   EVAL      T2FORZ = 1                                                       
FQ726C                   ELSE                                                                       
FQ726C                   EVAL      T2VA12 = 1                                                       
FQ726C                   GOTO      TFINAL                                                           
FQ726C                   ENDIF                                                                      
FQ726C                   ENDIF                                                                      
FQ842 * Si ENTREGA EN DELEGACIÓN o procedencia pedido esta activado                                 
FQ842 * no chequearemos  cliente                                                                    
FQ842C                   IF        S0EDLG='1'                                                       
FQ842C*                            OR S0PPED='25'                                                   
FQ842C                   ELSE                                                                       
                                                                                                    
      * Comprobar Parámetro Cliente                                                                 
In211C                   IF        ((S5TPE4 = '2' Or S0TPE4 = '2')                                  
In211C                             And T3NCLF <> '1') Or                                            
In211C                             (S5TPE4 <> '2' And S0TPE4 <> '2')                                
     C                   EXSR      CS_CLIENT                                                        
b03  C                   IF        T2VA00 = 1                                                       
     C                   GOTO      TFINAL                                                           
e03  C                   ENDIF                                                                      
In211C                   ENDIF                                                                      
FQ842C                   ENDIF                                                                      
C1579C     TSERVI        TAG                                                                        
                                                                                                    
      * Comprobar si el artículo es de servicio                                                     
     C                   EVAL      M5CIAS = S5CIAS                                                  
     C                   EVAL      M5ARTI = S5ARTI                                                  
     C                   EVAL      M5VARI = S5VARI                                                  
     C                   EVAL      M5MODE = S5MODE                                                  
     C     KMSARTI00     CHAIN     MSARTI00                                                         
b03  C                   IF        %FOUND(MSARTI00)                                                 
     C                   EVAL      PECIAS = S5CIAS                                                  
     C                   EVAL      PECTAB = 'TIPG'                                                  
     C                   EVAL      PECLTA = *BLANKS                                                 
     C                   EVAL      PECLTA = M5TIPG                                                  
     C     KPMTABD       CHAIN     PMTABD                                                           
b04  C                   IF        %FOUND(PMTABD)                                                   
     C                   EVAL      ZXSERV = PEBL61                                                  
x04  C                   ELSE                                                                       
     C                   EVAL      ZXSERV = *BLANKS                                                 
e04  C                   ENDIF                                                                      
e03  C                   ENDIF                                                                      
                                                                                                    
b03  C                   IF        ZXSERV <> '1'                                                    
      * Comprobar Parámetro Proveedor                                                               
b04  C                   IF        M5SIOL <> '2'                                                    
     C                   EXSR      CS_PROVEED                                                       
b05  C                   IF        T2VA02 = 1 Or T2VA01 = 1                                         
     C                   GOTO      TFINAL                                                           
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
                                                                                                    
      * Comprobar Parámetro Artículo                                                                
     C                   EXSR      CS_ARTICUL                                                       
b04  C                   IF        T2VA03 = 1                                                       
     C                   GOTO      TFINAL                                                           
e04  C                   ENDIF                                                                      
                                                                                                    
      * Validaciones para Alta ED (precio compra, artículo, etc...)                                 
     C                   EVAL      @PLINE = S5LINE                                                  
     C                   EXSR      CS_VALED51                                                       
b04  C                   IF        T2VA08 = 1                                                       
FQ942C                             OR T2CJTO = 1                                                    
     C                   GOTO      TFINAL                                                           
e04  C                   ENDIF                                                                      
                                                                                                    
      * Comprobar si ED Forzada                                                                     
b04  C                   IF        S5TPE4 = '2' Or S0TPE4 = '2'                                     
     C                   EVAL      T2FORZ = 1                                                       
     C                   EVAL      ZXFORZ = 1                                                       
     C                   GOTO      TFINAL                                                           
x04  C                   ELSE                                                                       
     C                   EVAL      T2FORZ = 0                                                       
e04  C                   ENDIF                                                                      
                                                                                                    
FQ842C                   IF        S0EDLG<>'1'                                                      
      * Comprobar Parámetro Transportista                                                           
     C                   EXSR      CS_TRANSPO                                                       
b04  C                   IF        T2VA04 = 1                                                       
     C                   GOTO      TFINAL                                                           
e04  C                   ENDIF                                                                      
FQ842C                   ENDIF                                                                      
FQ618                                                                                               
FQ618 * Comprobar Paràmetre Forma de Pagament                                                       
FQ618C                   EXSR      CS_FORPAGO                                                       
FQ618C                   IF        T2VA11 = 1                                                       
FQ618C                   GOTO      TFINAL                                                           
FQ618C                   ENDIF                                                                      
FQ726                                                                                               
FQ842C                   IF        S0EDLG<>'1'                                                      
FQ726 * Comprobar Logísticas                                                                        
FQ726C                   IF        T3LOGI = '1'                                                     
FQ726C                   EXSR      CS_LOGISTI                                                       
FQ726C                   ENDIF                                                                      
FQ726C                   IF        T2VA13 = 1                                                       
FQ726C                   GOTO      TFINAL                                                           
FQ726C                   ENDIF                                                                      
FQ842C                   ENDIF                                                                      
                                                                                                    
      * Comprobar si el artículo es Obsoleto                                                        
b04  C                   IF        T3OBSO = '1'                                                     
     C                   EXSR      CS_ARTOBSO                                                       
e04  C                   ENDIF                                                                      
b04  C                   IF        T2VA05 = 1                                                       
     C                   GOTO      TFINAL                                                           
e04  C                   ENDIF                                                                      
                                                                                                    
      * Comprobar sobreestock del artículo                                                          
FQ726C**                 IF        T3SSTO = '1'                                                     
FQ726C                   IF        T3SSTO >= '1'                                                    
     C                   EXSR      CS_SOBRSTK                                                       
e04  C                   ENDIF                                                                      
b04  C                   IF        T2VA06 = 1                                                       
     C                   GOTO      TFINAL                                                           
e04  C                   ENDIF                                                                      
C1636 *                                                                                             
C1636 * Comprobar Stock Artículos "B" (si Parámetro Verificar Artículos "B" = '1')                  
C1636 * Si Delegación es Autoservicio MIXTO (AUTS in '1' '2' y OPL1 = blanco)                       
C1636 * ó  Delegación Convencional (AUTS = blanco ó '0')                                            
C1636c                   clear                   rpmempr                                            
C1636c                   eval      p7cias = @pcias                                                  
C1636c                   eval      p7dlga = @pdlga                                                  
C1636c     kpmempr       chain     PMEMPR                                                           
C1636C                   IF        T3VFYB = '1'                                 Verif. Art. "B"     
C1636c                             and ( (    (P7AUTS = '1' or P7AUTS = '2')    Autoservicio        
C1636c                                     and T3OPL1 = *blanks                 Mixto               
C1636c                                    )                                                         
C1636c                                   or P7AUTS < '1'                        No Autoserv.        
C1636c                                 )                                                            
C1636C                   EXSR      CS_VFYARTB                                   Check Stock.        
C1636C                   ENDIF                                                                      
C1636C                   IF        T2VA14 = 1                                                       
C1636C                   GOTO      TFINAL                                                           
C1636C                   ENDIF                                                                      
                                                                                                    
      * Comprobar Stock en Trace                                                                    
FQ726C                   IF        T3STCK = '1'                                                     
     C                   EXSR      CS_STCKTRA                                                       
FQ726C                   ENDIF                                                                      
b04  C                   IF        T2VA07 = 1                                                       
     C                   GOTO      TFINAL                                                           
e04  C                   ENDIF                                                                      
                                                                                                    
     C     TFINAL        TAG                                                                        
      * Grabo fichero de Trabajo                                                                    
b04  C                   IF        T2VA00=0 And T2VA01=0 And T2VA02=0 And                           
     C                             T2VA03=0 And T2VA04=0 And T2VA05=0 And                           
FQ618C                             T2VA06=0 And T2VA07=0 And T2VA08=0 And                           
FQ726C                             T2VA11=0 And T2VA12=0 And T2VA13=0                               
FQ942C                             AND T2CJTO=0                                                     
C1636C                             And T2VA14=0                                                     
     C                   EVAL      T2ENTD = 1                                                       
     C                   EVAL      ZXPEDD = 1                                                       
FQ726 * Calculo Importe línea pedido, si no es solo Forzadas                                        
C2510C*FQ726 ***         IF        T3EDFO <> '1'                                                    
C2510c*C1579 ***                   And zxpweb<>'1'                                                  
C2510C                   IF        zxpweb<>'1'                                                      
     C                   EXSR      CS_IMPORTE                                                       
     C                   EVAL      ZXIMPO = ZXIMPO + ZXBIMP                                         
FQ726C                   ENDIF                                                                      
x04  C                   ELSE                                                                       
     C                   EVAL      T2ENTD = 0                                                       
     C                   EVAL      ZXPEDT = 1                                                       
e04  C                   ENDIF                                                                      
CR554c     TWRITE        TAG                                                                        
     C                   WRITE     RED0050W                                                         
      *                                                                                             
e03  C                   ENDIF                                                                      
     C     KCODEPE       READE     CODEPE                                                           
e02  C                   ENDDO                                                                      
                                                                                                    
FQ726 * Comprobar Importe líneas Pedido ED, si no es solo Forzadas                                  
C2510C*FQ726 ***         IF        T3EDFO <> '1'                                                    
C2510c*C1579 ***                   And zxpweb<>'1'                                                  
C2510C                   IF        zxpweb<>'1'                                                      
b02  C                   IF        ZXFORZ = 1 And T3NIMF <> '1'                                     
     C                             Or ZXFORZ = 0                                                    
b03  C                   IF        ZXPEDD = 1                                                       
CR533c                             and (s0tped <> 'SC' or t3fdsc <> '1')                            
     C                   EXSR      CS_IMPLINE                                                       
e03  C                   ENDIF                                                                      
e02  C                   ENDIF                                                                      
FQ726C                   ENDIF                                                                      
                                                                                                    
      * Comprobar Pedido Completo                                                                   
     C                   EXSR      CS_PEDTOTA                                                       
                                                                                                    
      * Actualizar Marca ED en CODEPE TPE4='2'                                                      
     C                   EXSR      CS_MARCAED                                                       
                                                                                                    
FQ726 * Comprobar Puntos de Expedición, si no es solo Forzadas                                      
FQ726C                   IF        T3EDFO <> '1'                                                    
C1579c                             And zxpweb<>'1'                                                  
     C                   EXSR      CS_BUSPEXP                                                       
FQ726C                   ENDIF                                                                      
                                                                                                    
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar Parámetro Proveedor                                                               
      **********************************************************************                        
     C     CS_PROVEED    BEGSR                                                                      
                                                                                                    
     C                   EVAL      M5CIAS=S5CIAS                                                    
     C                   MOVEL     @PCIAS        PPCIAS                                             
                                                                                                    
      * Miramos si es Conjunto de Venta                                                             
     C                   EVAL      FileCojc_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/MSCOJC'                                           
     C                   OPEN (E)  MSCOJC                                                           
b01  C                   IF        Not %ERROR                                                       
     C                   EVAL      ZXTCOJ=' '                                                       
     C                   EVAL      NDCIAS=S5CIAS                                                    
     C                   EVAL      NDARTI=S5ARTI                                                    
     C                   EVAL      NDMODE=S5MODE                                                    
     C                   EVAL      NDVARI=S5VARI                                                    
     C                   EVAL      NDTCOJ='4'                                                       
     C     KMSCOJC       CHAIN     MSCOJC                                                           
b02  C                   IF        %FOUND(MSCOJC) AND NDBAJA<'1'                                    
      * Miramos si es Conjunto de Compra                                                            
     C                   EVAL      NDTCOJ='1'                                                       
     C     KMSCOJC       CHAIN     MSCOJC                                                           
b03  C                   IF        %FOUND(MSCOJC) AND NDBAJA<'1'                                    
      * Si es Conjunto de Ventas y de Compra No lo trataremos como Cjto                             
     C                   EVAL      ZXTCOJ=' '                                                       
x03  C                   ELSE                                                                       
      * Si es Conjunto de Ventas y No de Compra Si lo tratamos                                      
     C                   EVAL      ZXTCOJ='4'                                                       
e03  C                   ENDIF                                                                      
x02  C                   ELSE                                                                       
      * Si No es Conjunto de Venta , Pues no es Conjunto y punto                                    
     C                   EVAL      ZXTCOJ=' '                                                       
e02  C                   ENDIF                                                                      
     C                   CLOSE(E)  MSCOJC                                                           
      * Es Conjunto                                                                                 
b02  C                   IF        ZXTCOJ='4'                                                       
     C                   EVAL      FileCojd_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/MSCOJD'                                           
     C                   OPEN (E)  MSCOJD                                                           
b03  C                   IF        Not %ERROR                                                       
     C                   EVAL      NDCIAS=S5CIAS                                                    
     C                   EVAL      NDARTI=S5ARTI                                                    
     C                   EVAL      NDMODE=S5MODE                                                    
     C                   EVAL      NDVARI=S5VARI                                                    
     C                   EVAL      NDTCOJ = ZXTCOJ                                                  
     C     KMSCOJC       SETLL     MSCOJD                                                           
     C     KMSCOJC       READE     MSCOJD                                                           
d04  C                   DOW       NOT %EOF(MSCOJD)                                                 
b05  C                   IF        NDBAJA <> '1'                                                    
     C                   EVAL      M5ARTI=NDCOMP                                                    
     C                   EVAL      M5VARI=NDVAR2                                                    
     C                   EVAL      M5MODE=NDMOD2                                                    
     C     KMSARTI00     CHAIN     MSARTI00                                                         
      * Valido Proveedor                                                                            
FDX01 * Siempre que el componente no sea artículo propio                                            
FDX01C                   IF        M5SIOL<>'2'                                                      
     C                   EXSR      CS_PROVEE2                                                       
b06  C                   IF        T2VA02 = 1                                                       
     C                   LEAVE                                                                      
e06  C                   ENDIF                                                                      
FDX01C                   ENDIF                                                                      
e05  C                   ENDIF                                                                      
     C     KMSCOJC       READE     MSCOJD                                                           
e04  C                   ENDDO                                                                      
e03  C                   ENDIF                                                                      
     C                   CLOSE(E)  MSCOJD                                                           
x02  C                   ELSE                                                                       
      * NO Es Conjunto                                                                              
     C                   EVAL      M5ARTI=S5ARTI                                                    
     C                   EVAL      M5VARI=S5VARI                                                    
     C                   EVAL      M5MODE=S5MODE                                                    
     C     KMSARTI00     CHAIN     MSARTI00                                                         
      * Valido Proveedor                                                                            
     C                   EXSR      CS_PROVEE2                                                       
e02  C                   ENDIF                                                                      
                                                                                                    
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar Parámetro Cliente                                                                 
      **********************************************************************                        
     C     CS_CLIENT     BEGSR                                                                      
                                                                                                    
     C                   EVAL      C_S0CIAS=S5CIAS                                                  
     C                   EVAL      C_S0CUST=S5CUST                                                  
     C     KCOCLIN       CHAIN     COCLIN                                                           
b01  C                   IF        %FOUND(COCLIN) And                                               
     C                             (C_S0CEVT = ' ' Or C_S0CEVT = '0')                               
     C                   EVAL      T2VA00 = 1                                                       
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar Parámetro Proveedor                                                               
      **********************************************************************                        
     C     CS_PROVEE2    BEGSR                                                                      
                                                                                                    
IT228c                   EVAL      ZXPRV = *blanks                                                  
IT228c                   EVAL      @PRESP= *blanks                                                  
IT228C                   if        (%lookup(S5LOGE:T_logol)>0)                                      
IT228C                   EVAL      M0CIAS=S5CIAS                                                    
IT228C                   EVAL      M0LOGE=S5LOGE                                                    
IT228C     KMSALMA05     CHAIN     MSALMA05                                                         
IT228C                   IF        %FOUND AND M0BAJA<>'1'                                           
IT228C                   EVAL      @PRESP=M0MAGA                                                    
IT228C                   exsr      SRrecu                                                           
IT228C                   ENDIF                                                                      
IT228C                   ELSE                                                                       
IT228C                   EXSR      LOG_VIRTUAL                                                      
IT228C                   exsr      SRrecu                                                           
IT228C                   ENDIF                                                                      
     C                   EVAL      C0CIAS=S5CIAS                                                    
IT228C                   if        ZXPRV = *blanks                                                  
     C                   EVAL      C0PRVR=M5PRVR                                                    
IT228C                   ELSE                                                                       
IT228C                   EVAL      C0PRVR=ZXPRV                                                     
IT228C                   ENDIF                                                                      
     C     KPUPROV       CHAIN     PUPROV                                                           
b01  C                   IF        %FOUND(PUPROV) And                                               
     C                             (C0PEVT = ' ' Or C0PEVT = '0')                                   
FQ666 * Comprobar que el artículo no sea independiente del proveedor                                
FQ666 * M5NOED='2'                                                                                  
FQ666C                   EVAL      M5CIAS=S5CIAS                                                    
FQ666C                   EVAL      M5ARTI=S5ARTI                                                    
FQ666C                   EVAL      M5VARI=S5VARI                                                    
FQ666C                   EVAL      M5MODE=S5MODE                                                    
FQ666C     KMSARTI00     CHAIN     MSARTI00                                                         
FQ666C                   IF        %FOUND(MSARTI00) and M5NOED<>'2'                                 
     C                   EVAL      T2VA02 = 1                                                       
FQ666C                   ENDIF                                                                      
x01  C                   ELSE                                                                       
                                                                                                    
      * Comprobar si el Proveedor es externo                                                        
     C                   EVAL      Q1CIAS=C0CIAS                                                    
     C                   EVAL      Q1PRVR=C0PRVR                                                    
     C     KGXEQPR       CHAIN     GXEQPR                                                           
     C                   IF        %FOUND(GXEQPR) And Q1PGRP = '1'                                  
     C                   EVAL      T2VA01 = 0                                                       
     C                   ELSE                                                                       
     C                   EVAL      T2VA01 = 1                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar Parámetro Artículo                                                                
      **********************************************************************                        
     C     CS_ARTICUL    BEGSR                                                                      
                                                                                                    
     C                   EVAL      M5CIAS=S5CIAS                                                    
     C                   EVAL      M5ARTI=S5ARTI                                                    
     C                   EVAL      M5VARI=S5VARI                                                    
     C                   EVAL      M5MODE=S5MODE                                                    
     C     KMSARTI00     CHAIN     MSARTI00                                                         
b01  C                   IF        %FOUND(MSARTI00) And M5NOED = '1'                                
     C                   EVAL      T2VA03 = 1                                                       
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar Parámetro Transportista                                                           
      **********************************************************************                        
     C     CS_TRANSPO    BEGSR                                                                      
                                                                                                    
     C                   EVAL      N1CIAS = S0CIAS                                                  
     C                   EVAL      N1TTTA = S0TTTA                                                  
     C     KMSTRTA       CHAIN     MSTRTA                                                           
b01  C                   IF        %FOUND(MSTRTA) And N1NOED ='1'                                   
     C                   EVAL      T2VA04 = 1                                                       
e01  C                   ENDIF                                                                      
M1078C                   IF        %FOUND(MSTRTA) And N1NOED ='2'                                   
M1078C                   EVAL      T2VA04 = 1                                                       
M1078C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
FQ618 **********************************************************************                        
FQ618 * Comprobar Paràmetre Forma de Pagament                                                       
FQ618 **********************************************************************                        
FQ618C     CS_FORPAGO    BEGSR                                                                      
FQ618                                                                                               
FQ618C                   EVAL      PECIAS = S0CIAS                                                  
FQ618C                   EVAL      PECTAB = 'FPAG'                                                  
FQ618C                   EVAL      PECLTA = *BLANKS                                                 
FQ618C                   EVAL      PECLTA = S0FPAG                                                  
FQ618C     KPMTABD       CHAIN     PMTABD                                                           
FQ618C                   IF        %FOUND(PMTABD)                                                   
FQ618C                   EVAL      ZXBL64 = PEBL64                                                  
FQ618C                   ELSE                                                                       
FQ618C                   EVAL      ZXBL64 = *BLANKS                                                 
FQ618C                   ENDIF                                                                      
FQ618C                   IF        ZXNOED ='1'                                                      
FQ618C                   EVAL      T2VA11 = 1                                                       
FQ618C                   ENDIF                                                                      
FQ842C                                                                                              
FQ842C                   IF        T2VA11=1                                                         
FQ842C                   EVAL      RXCIAS=S0CIAS                                                    
FQ842C                   EVAL      RXDLGA=S0DLGA                                                    
FQ842C                   EVAL      RXNPCO=S0NPCO                                                    
FQ842C                   EVAL      RXTPED=S0TPED                                                    
FQ842C                   EVAL      RXDATP=S0DATP                                                    
FQ842C                   EVAL      RXNOPL=S0NOPL                                                    
FQ842C     KCOCAIP       CHAIN     COCAIP                                                           
FQ842C                   IF        %FOUND                                                           
FQ842C                   EVAL      T2VA11=0                                                         
FQ842C                   ENDIF                                                                      
FQ842C                   ENDIF                                                                      
FQ618                                                                                               
FQ618C                   ENDSR                                                                      
FQ726 **********************************************************************                        
FQ726 * Comprobar logísticas                                                                        
FQ726 **********************************************************************                        
FQ726C     CS_LOGISTI    BEGSR                                                                      
FQ726                                                                                               
FQ726 * De momento la linea será ED hasta que diga lo contrario                                     
FQ726C                   EVAL      T2VA13 = 0                                                       
FQ726                                                                                               
FQ726 * Miro la logística de la linea del pedido                                                    
FQ726C                   EVAL      MICIAS=S5CIAS                                                    
FQ726C                   EVAL      MIDLGA=S5DLGA                                                    
FQ726C                   EVAL      MILGCA=S5LOGE                                                    
FQ726C     KMSLOAD       CHAIN     MSLOGI                                                           
FQ726 * Si no tiene el parámetro de Entregas Directas No puede ser ED                               
FQ726C                   IF        %FOUND(MSLOGI) And MIMI01<>'1'                                   
FQ726C                             Or Not %FOUND(MSLOGI)                                            
FQ726C                   EVAL      T2VA13 = 1                                                       
FQ726C                   ENDIF                                                                      
FQ726                                                                                               
FQ726C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar si el artículo es Obsoleto                                                        
      **********************************************************************                        
     C     CS_ARTOBSO    BEGSR                                                                      
                                                                                                    
     C                   EVAL      M5CIAS=S5CIAS                                                    
     C                   EVAL      M5ARTI=S5ARTI                                                    
     C                   EVAL      M5VARI=S5VARI                                                    
     C                   EVAL      M5MODE=S5MODE                                                    
     C     KMSARTI00     CHAIN     MSARTI00                                                         
b01  C                   IF        %FOUND(MSARTI00) And M5PROB = 'OB'                               
     C                   EVAL      ZXARTIX = M5ARTI                                                 
     C                   EVAL      ZXVARIX = M5VARI                                                 
     C                   EVAL      ZXMODEX = M5MODE                                                 
     C                   EVAL      Z1CANT = S5CANT - S5CANR - S5CANS                                
     C                   EVAL      ZXVSTK = 1                                                       
     C                   EXSR      CS_STCKPRO                                                       
b02  C                   IF        ZXSTPR = 0                                                       
     C                   EVAL      ZXLG05 = 0                                                       
     C                   EVAL      ZXVSTK = 1                                                       
     C                   EXSR      CS_STCKDEL                                                       
b03  C                   IF        ZXSTDL = 1                                                       
     C                   EVAL      T2VA05 = 1                                                       
FQ726C                   EVAL      T2LOGU = P7LOGS                                                  
     C                   EVAL      S5LOGE = P7LOGS                                                  
CR554c                   exsr      CS_set_s5lb2b                                                    
     C                   UPDATE    RCODEPE                                                          
e03  C                   ENDIF                                                                      
x02  C                   ELSE                                                                       
     C                   EVAL      T2VA05 = 1                                                       
e02  C                   ENDIF                                                                      
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar sobreestock del artículo                                                          
      **********************************************************************                        
     C     CS_SOBRSTK    BEGSR                                                                      
                                                                                                    
     C                   EVAL      ZXCANT = 1                                                       
     C                   EVAL      M5CIAS=S5CIAS                                                    
     C                   MOVEL     @PCIAS        PPCIAS                                             
                                                                                                    
      * Miramos si es Conjunto de Venta                                                             
     C                   EVAL      FileCojc_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/MSCOJC'                                           
     C                   OPEN (E)  MSCOJC                                                           
b01  C                   IF        Not %ERROR                                                       
     C                   EVAL      ZXTCOJ=' '                                                       
     C                   EVAL      NDCIAS=S5CIAS                                                    
     C                   EVAL      NDARTI=S5ARTI                                                    
     C                   EVAL      NDMODE=S5MODE                                                    
     C                   EVAL      NDVARI=S5VARI                                                    
     C                   EVAL      NDTCOJ='4'                                                       
     C     KMSCOJC       CHAIN     MSCOJC                                                           
b02  C                   IF        %FOUND(MSCOJC) AND NDBAJA<'1'                                    
      * Miramos si es Conjunto de Compra                                                            
     C                   EVAL      NDTCOJ='1'                                                       
     C     KMSCOJC       CHAIN     MSCOJC                                                           
b03  C                   IF        %FOUND(MSCOJC) AND NDBAJA<'1'                                    
      * Si es Conjunto de Ventas y de Compra No lo trataremos como Cjto                             
     C                   EVAL      ZXTCOJ=' '                                                       
x03  C                   ELSE                                                                       
      * Si es Conjunto de Ventas y No de Compra Si lo tratamos                                      
     C                   EVAL      ZXTCOJ='4'                                                       
e03  C                   ENDIF                                                                      
x02  C                   ELSE                                                                       
      * Si No es Conjunto de Venta , Pues no es Conjunto y punto                                    
     C                   EVAL      ZXTCOJ=' '                                                       
e02  C                   ENDIF                                                                      
     C                   CLOSE(E)  MSCOJC                                                           
      * Es Conjunto                                                                                 
b02  C                   IF        ZXTCOJ='4'                                                       
     C                   EVAL      FileCojd_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/MSCOJD'                                           
     C                   OPEN (E)  MSCOJD                                                           
b03  C                   IF        Not %ERROR                                                       
     C                   EVAL      NDCIAS=S5CIAS                                                    
     C                   EVAL      NDARTI=S5ARTI                                                    
     C                   EVAL      NDMODE=S5MODE                                                    
     C                   EVAL      NDVARI=S5VARI                                                    
     C                   EVAL      NDTCOJ = ZXTCOJ                                                  
     C     KMSCOJC       SETLL     MSCOJD                                                           
     C     KMSCOJC       READE     MSCOJD                                                           
d04  C                   DOW       NOT %EOF(MSCOJD)                                                 
b05  C                   IF        NDBAJA <> '1'                                                    
     C                   EVAL      M5ARTI=NDCOMP                                                    
     C                   EVAL      M5VARI=NDVAR2                                                    
     C                   EVAL      M5MODE=NDMOD2                                                    
     C     KMSARTI00     CHAIN     MSARTI00                                                         
      * Valido Sobrestock                                                                           
     C                   EVAL      ZXCANT = NDCANT                                                  
     C                   EXSR      CS_SOBRST2                                                       
b06  C                   IF        T2VA06 = 1                                                       
     C                   LEAVE                                                                      
e06  C                   ENDIF                                                                      
e05  C                   ENDIF                                                                      
     C     KMSCOJC       READE     MSCOJD                                                           
e04  C                   ENDDO                                                                      
e03  C                   ENDIF                                                                      
     C                   CLOSE(E)  MSCOJD                                                           
x02  C                   ELSE                                                                       
      * NO Es Conjunto                                                                              
     C                   EVAL      M5ARTI=S5ARTI                                                    
     C                   EVAL      M5VARI=S5VARI                                                    
     C                   EVAL      M5MODE=S5MODE                                                    
     C     KMSARTI00     CHAIN     MSARTI00                                                         
      * Valido Sobrestock                                                                           
     C                   EXSR      CS_SOBRST2                                                       
e02  C                   ENDIF                                                                      
                                                                                                    
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar sobreestock del artículo                                                          
      **********************************************************************                        
     C     CS_SOBRST2    BEGSR                                                                      
                                                                                                    
02110C**                 EVAL      M5CIAS=S5CIAS                                                    
02110C**                 EVAL      M5ARTI=S5ARTI                                                    
02110C**                 EVAL      M5VARI=S5VARI                                                    
02110C**                 EVAL      M5MODE=S5MODE                                                    
02110C**   KMSARTI00     CHAIN     MSARTI00                                                         
02110C**                 IF        %FOUND(MSARTI00)                                                 
     C                   EVAL      ZXARTIX = M5ARTI                                                 
     C                   EVAL      ZXVARIX = M5VARI                                                 
     C                   EVAL      ZXMODEX = M5MODE                                                 
     C                   EVAL      Z1CANT = S5CANT - S5CANR - S5CANS                                
FQ726C                   SELECT                                                                     
FQ726C                   WHEN      T3SSTO = '1'                                                     
     C                   EVAL      ZXVSTK = 0                                                       
FQ726C                   WHEN      T3SSTO = '2'                                                     
FQ726C                   EVAL      ZXVSTK = 1                                                       
FQ726C                   ENDSL                                                                      
     C                   EXSR      CS_STCKPRO                                                       
b02  C                   IF        ZXSTPR = 0                                                       
     C                   EVAL      ZXLG05 = 0                                                       
     C                   EVAL      ZXVSTK = 0                                                       
     C                   EXSR      CS_STCKDEL                                                       
b03  C                   IF        ZXSTDL = 1                                                       
     C                   EVAL      T2VA06 = 1                                                       
FQ726C                   EVAL      T2LOGU = P7LOGS                                                  
     C                   EVAL      S5LOGE = P7LOGS                                                  
CR554c                   exsr      CS_set_s5lb2b                                                    
     C                   UPDATE    RCODEPE                                                          
e03  C                   ENDIF                                                                      
x02  C                   ELSE                                                                       
     C                   EVAL      T2VA06 = 1                                                       
e02  C                   ENDIF                                                                      
02110C**                 ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      *  Busqueda cantidades de stock pdte servir,fabricar,deposito...                              
      **********************************************************************                        
     C     CS_CANSTOK    BEGSR                                                                      
                                                                                                    
     C                   EVAL      @PEDATD=*DATE                                                    
     C                   EVAL      @PEDATH=*DATE                                                    
     C                   MOVE      @PEDATD       ZXDATD                                             
     C                   MOVE      @PEDATH       ZXDATH                                             
     C                   SUBDUR    1000  :*D     ZXDATD                                             
     C                   ADDDUR    1000  :*D     ZXDATH                                             
     C                   MOVE      ZXDATD        @PEDATD                                            
     C                   MOVE      ZXDATH        @PEDATH                                            
                                                                                                    
     C                   EVAL      @PECIAS=M1CIAS                                                   
     C                   EVAL      @PEARTI=M1ARTI                                                   
     C                   EVAL      @PEVARI=M1VARI                                                   
     C                   EVAL      @PEMODE=M1MODE                                                   
                                                                                                    
     C                   EVAL      M5CIAS=M1CIAS                                                    
     C                   EVAL      M5ARTI=M1ARTI                                                    
     C                   EVAL      M5VARI=M1VARI                                                    
     C                   EVAL      M5MODE=M1MODE                                                    
     C     KMSARTI00     CHAIN     MSARTI00                           81                            
                                                                                                    
      * Pendiente de servir                                                                         
     C                   EVAL      @PETISE=' '                                                      
     C                   CALL      'MM2600'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM      ZZDLGA        @PEDLGA                                            
     C                   PARM                    @PEARTI                                            
     C                   PARM                    @PEVARI                                            
     C                   PARM                    @PEMODE                                            
     C                   PARM                    @PETCOJ                                            
     C                   PARM                    @PEDATD                                            
     C                   PARM                    @PEDATH                                            
     C                   PARM                    @PECUST                                            
     C                   PARM      0             @PECANT                                            
     C                   PARM      0             @PECAN1                                            
     C                   PARM                    M1MAGA                                             
     C                   PARM                    @PETISE           4                                
     C                   PARM      '1'           @PERRO            1                                
     C                   EVAL      ZXCANS0 = @PECANT * ZXCANT                                       
                                                                                                    
      * Pendiente de traspasos depositos                                                            
     C                   EVAL      @PETISE=' '                                                      
     C                   CALL      'MM2604'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM      ZZDLGA        @PEDLGA                                            
     C                   PARM                    @PEARTI                                            
     C                   PARM                    @PEVARI                                            
     C                   PARM                    @PEMODE                                            
     C                   PARM                    @PETCOJ                                            
     C                   PARM                    @PEDATD                                            
     C                   PARM                    @PEDATH                                            
     C                   PARM      0             @PECANT                                            
     C                   PARM      0             @PECAN1                                            
     C                   PARM                    M1MAGA                                             
     C                   PARM                    @PETISE           4                                
     C                   PARM      *BLANKS       @PERRO            1                                
     C                   EVAL      ZXDEPO0 = @PECANT * ZXCANT                                       
                                                                                                    
      * Esto solo para empresas que utilizan nuestra produccion                                     
     C                   EVAL      @PECAN1=0                                                        
     C                   EVAL      @PECAN2=0                                                        
b01  C                   IF        ZZTCIA='1' OR ZZTCIA='2'                                         
     C                   EVAL      @PEDATD=*DATE                                                    
     C                   EVAL      @PEDATH=*DATE                                                    
     C                   MOVE      @PEDATD       ZXDATD                                             
     C                   MOVE      @PEDATH       ZXDATH                                             
     C                   SUBDUR    1000  :*D     ZXDATD                                             
     C                   ADDDUR    1000  :*D     ZXDATH                                             
     C                   MOVE      ZXDATD        @PEDATD                                            
     C                   MOVE      ZXDATH        @PEDATH                                            
      * Solo realizaré la búsqued en artículos susceptibles de ser utilizados en                    
      * es decir, que sean estructuras o componentes.                                               
     C     KMSARTI00     CHAIN     PMCAOR01                           81                            
b02  C                   IF        CHAIN=*ON                                                        
     C     KMSARTI00     CHAIN     PMCAOR08                           81                            
e02  C                   ENDIF                                                                      
                                                                                                    
      * Búsqueda de las necesidades a tener en cuenta en OF's                                       
     C                   EVAL      @PECAN1=0                                                        
     C                   EVAL      @PECAN2=0                                                        
     C     KMSARTI00     CHAIN     PMDEOR05                           81                            
b02  C                   IF        CHAIN=*OFF                                                       
      * Si MÑSNCC>='1', entonces (DOLL) se desea que se presente el                                 
      * material asignado                                                                           
     C                   EVAL      @PERRO=*BLANKS                                                   
b03  C**                 IF        MÑSNCC>='1'                                                      
     C**                 EVAL      @PERRO='A'                                                       
e03  C**                 ENDIF                                                                      
                                                                                                    
     C                   CALL      'MM2602'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM                    @PEARTI                                            
     C                   PARM                    @PEVARI                                            
     C                   PARM                    @PEMODE                                            
     C                   PARM                    @PEDATD                                            
     C                   PARM                    @PEDATH                                            
     C                   PARM      0             @PECAN1                                            
     C                   PARM      0             @PECAN2                                            
     C                   PARM                    M1MAGA                                             
     C                   PARM                    M5MAGD                                             
     C                   PARM                    @PERRO                                             
e02  C                   ENDIF                                                                      
e01  C                   ENDIF                                                                      
     C                   EVAL      ZXCANE0 = @PECAN2 * ZXCANT                                       
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar Stock en Trace                                                                    
      **********************************************************************                        
     C     CS_STCKTRA    BEGSR                                                                      
                                                                                                    
     C                   MOVEL     @PCIAS        PPCIAS                                             
     C                   EVAL      Z0CANT = S5CANT - S5CANR - S5CANS                                
     C                   EVAL      Z1CANT = S5CANT - S5CANR - S5CANS                                
     C                   EVAL      ZXARTDLGA = S5ARTI                                               
     C                   EVAL      ZXVARDLGA = S5VARI                                               
     C                   EVAL      ZXMODDLGA = S5MODE                                               
      * Si es artículo propio directamente Trace sin pasar por Productiva                           
     C                   EVAL      M5CIAS = S5CIAS                                                  
     C                   EVAL      M5ARTI = S5ARTI                                                  
     C                   EVAL      M5VARI = S5VARI                                                  
     C                   EVAL      M5MODE = S5MODE                                                  
     C     KMSARTI00     CHAIN     MSARTI00                                                         
b01  C                   IF        M5SIOL = '2'                                                     
     C                   EVAL      ZXARTTRAC = M5ARTI                                               
     C                   EVAL      ZXVARTRAC = M5VARI                                               
     C                   EVAL      ZXMODTRAC = M5MODE                                               
     C                   EVAL      Z2CANT = Z1CANT                                                  
     C                   EXSR      CS_STCK909                                                       
13070                                                                                               
13070 * si no hay stock en Trace busco en Delegaciones.                                             
13070C                   IF        T2VA07 = 1                                                       
13070C                   EVAL      ZXARTIX = S5ARTI                                                 
13070C                   EVAL      ZXVARIX = S5VARI                                                 
13070C                   EVAL      ZXMODEX = S5MODE                                                 
13070 * Delegación Propia                                                                           
02110C                   EVAL      ZXVSTK = 1                                                       
13070C                   EXSR      CS_STCKPRO                                                       
13070C                   IF        ZXSTPR = 1                                                       
13070C                   EVAL      T2VA07 = 1                                                       
13070C                   ELSE                                                                       
13070 * Delegaciones cercanas                                                                       
13070C                   EVAL      ZXLG05 = 1                                                       
13070C                   EVAL      ZXVSTK = 1                                                       
13070C                   EXSR      CS_STCKDEL                                                       
13070C                   IF        ZXSTDL = 1                                                       
13070C                   EVAL      T2VA07 = 1                                                       
13070C                   ENDIF                                                                      
13070C                   ENDIF                                                                      
13070C                   ENDIF                                                                      
13070                                                                                               
                                                                                                    
x01  C                   ELSE                                                                       
     C                   MOVEA     *BLANKS       SARVMCJT                                           
     C                   MOVEA     *BLANKS       SARPRCJT                                           
     C                   MOVEA     *BLANKS       SPRVRCJT                                           
     C                   MOVEA     *ZEROS        SCANTCJT                                           
      * Miramos si es Conjunto de Venta                                                             
     C                   EVAL      FileCojc_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/MSCOJC'                                           
     C                   OPEN (E)  MSCOJC                                                           
b02  C                   IF        Not %ERROR                                                       
     C                   EVAL      ZXTCOJ=' '                                                       
     C                   EVAL      NDCIAS=S5CIAS                                                    
     C                   EVAL      NDARTI=S5ARTI                                                    
     C                   EVAL      NDMODE=S5MODE                                                    
     C                   EVAL      NDVARI=S5VARI                                                    
     C                   EVAL      NDTCOJ='4'                                                       
     C     KMSCOJC       CHAIN     MSCOJC                                                           
b03  C                   IF        %FOUND(MSCOJC) AND NDBAJA<'1'                                    
      * Miramos si es Conjunto de Compra                                                            
     C                   EVAL      NDTCOJ='1'                                                       
     C     KMSCOJC       CHAIN     MSCOJC                                                           
b04  C                   IF        %FOUND(MSCOJC) AND NDBAJA<'1'                                    
      * Si es Conjunto de Ventas y de Compra No lo trataremos como Cjto                             
     C                   EVAL      ZXTCOJ=' '                                                       
x04  C                   ELSE                                                                       
      * Si es Conjunto de Ventas y No de Compra Si lo tratamos                                      
     C                   EVAL      ZXTCOJ='4'                                                       
e04  C                   ENDIF                                                                      
x03  C                   ELSE                                                                       
      * Si No es Conjunto de Venta , Pues no es Conjunto y punto                                    
     C                   EVAL      ZXTCOJ=' '                                                       
e03  C                   ENDIF                                                                      
     C                   CLOSE(E)  MSCOJC                                                           
      * Es Conjunto en Comercial                                                                    
b03  C                   IF        ZXTCOJ='4'                                                       
     C                   EVAL      FileCojd_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/MSCOJD'                                           
     C                   OPEN (E)  MSCOJD                                                           
b04  C                   IF        Not %ERROR                                                       
     C                   EVAL      NDCIAS=S5CIAS                                                    
     C                   EVAL      NDARTI=S5ARTI                                                    
     C                   EVAL      NDMODE=S5MODE                                                    
     C                   EVAL      NDVARI=S5VARI                                                    
     C                   EVAL      NDTCOJ = ZXTCOJ                                                  
     C     KMSCOJC       SETLL     MSCOJD                                                           
     C     KMSCOJC       READE     MSCOJD                                                           
d05  C                   DOW       NOT %EOF(MSCOJD)                                                 
b06  C                   IF        NDBAJA <> '1'                                                    
     C                   EVAL      M5ARTI=NDCOMP                                                    
     C                   EVAL      M5VARI=NDVAR2                                                    
     C                   EVAL      M5MODE=NDMOD2                                                    
     C     KMSARTI00     CHAIN     MSARTI00                                                         
b07  C                   IF        %FOUND(MSARTI00)                                                 
     C                   EVAL      ZXARTIX=M5ARTI                                                   
     C                   EVAL      ZXVARIX=M5VARI                                                   
     C                   EVAL      ZXMODEX=M5MODE                                                   
     C                   EVAL      ZKARVM=ZXARVMX                                                   
     C                   EXSR      CS_ARTEXIS                                                       
     C                   EVAL      ZXARVM=ZXARVMPRO                                                 
     C                   EVAL      ZXPRVR=M5PRVR                                                    
     C                   EVAL      Z1CANT = Z0CANT * NDCANT                                         
      * Guardo el Componente en la serie para tratarlo después                                      
      *   y asi poder cerrar el fichero MSCOJD usado tambíen después                                
     C                   EVAL      ZW=1                                                             
     C     *BLANKS       LOOKUP    SARVMCJT(ZW)                           81                        
     C                   MOVEL     ZKARVM        SARVMCJT(ZW)                                       
     C                   MOVEL     ZXARVMPRO     SARPRCJT(ZW)                                       
     C                   MOVEL     ZXPRVR        SPRVRCJT(ZW)                                       
     C                   Z-ADD     Z1CANT        SCANTCJT(ZW)                                       
e07  C                   ENDIF                                                                      
e06  C                   ENDIF                                                                      
     C     KMSCOJC       READE     MSCOJD                                                           
e05  C                   ENDDO                                                                      
e04  C                   ENDIF                                                                      
     C                   CLOSE(E)  MSCOJD                                                           
     C                   EXSR      CS_SERCONJ                                                       
x03  C                   ELSE                                                                       
      * NO Es Conjunto en Comercial                                                                 
     C                   EVAL      M5ARTI=S5ARTI                                                    
     C                   EVAL      M5VARI=S5VARI                                                    
     C                   EVAL      M5MODE=S5MODE                                                    
     C     KMSARTI00     CHAIN     MSARTI00                                                         
b04  C                   IF        %FOUND(MSARTI00)                                                 
     C                   EVAL      ZXARTIX=M5ARTI                                                   
     C                   EVAL      ZXVARIX=M5VARI                                                   
     C                   EVAL      ZXMODEX=M5MODE                                                   
     C                   EXSR      CS_ARTEXIS                                                       
     C                   EVAL      ZXARVM=ZXARVMPRO                                                 
     C                   EVAL      ZXPRVR=M5PRVR                                                    
      * Conjunto productiva                                                                         
     C                   EXSR      CS_CONJPRO                                                       
13070                                                                                               
13070 * si no hay stock en Trace busco en Delegaciones.                                             
13070C                   IF        T2VA07 = 1                                                       
13070C                   EVAL      ZXARTIX = S5ARTI                                                 
13070C                   EVAL      ZXVARIX = S5VARI                                                 
13070C                   EVAL      ZXMODEX = S5MODE                                                 
13070 * Delegación Propia                                                                           
02110C                   EVAL      ZXVSTK = 1                                                       
13070C                   EXSR      CS_STCKPRO                                                       
13070C                   IF        ZXSTPR = 1                                                       
13070C                   EVAL      T2VA07 = 1                                                       
13070C                   ELSE                                                                       
13070 * Delegaciones cercanas                                                                       
13070C                   EVAL      ZXLG05 = 1                                                       
13070C                   EVAL      ZXVSTK = 1                                                       
13070C                   EXSR      CS_STCKDEL                                                       
13070C                   IF        ZXSTDL = 1                                                       
13070C                   EVAL      T2VA07 = 1                                                       
13070C                   ENDIF                                                                      
13070C                   ENDIF                                                                      
13070C                   ENDIF                                                                      
13070                                                                                               
e04  C                   ENDIF                                                                      
                                                                                                    
e03  C                   ENDIF                                                                      
e02  C                   ENDIF                                                                      
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Leer Serie Conjunto Comercial Compras                                                       
      **********************************************************************                        
     C     CS_SERCONJ    BEGSR                                                                      
                                                                                                    
     C                   EVAL      ZW=1                                                             
     C     *BLANKS       LOOKUP    SARVMCJT(ZW)                           81                        
                                                                                                    
b01  C                   IF        ZW>1                                                             
     C                   EVAL      ZW=ZW-1                                                          
      * Leo Componentes Conjunto                                                                    
f02  C                   FOR       X=1 to ZW                                                        
     C                   MOVEL     SARVMCJT(X)   ZXARVMX                                            
     C                   MOVEL     SARPRCJT(X)   ZXARVMPRO                                          
     C                   MOVEL     SPRVRCJT(X)   ZXPRVR                                             
     C                   Z-ADD     SCANTCJT(X)   Z1CANT                                             
     C                   EVAL      ZXARTDLGA = ZXARTIX                                              
     C                   EVAL      ZXVARDLGA = ZXVARIX                                              
     C                   EVAL      ZXMODDLGA = ZXMODEX                                              
     C                   EXSR      CS_CONJPRO                                                       
13070C***                IF        T2VA07 = 0                                                       
13070C                   IF        T2VA07 = 1                                                       
     C                   LEAVE                                                                      
e03  C                   ENDIF                                                                      
e02  C                   ENDFOR                                                                     
13070                                                                                               
13070 * si no hay stock en Trace busco en Delegaciones.                                             
13070C                   IF        T2VA07 = 1                                                       
13070C                   FOR       X=1 to ZW                                                        
13070C                   MOVEL     SARVMCJT(X)   ZXARVMX                                            
13070 * Delegación Propia                                                                           
02110C                   EVAL      ZXVSTK = 1                                                       
13070C                   EXSR      CS_STCKPRO                                                       
13070C                   IF        ZXSTPR = 1                                                       
13070C                   EVAL      T2VA07 = 1                                                       
13070C                   ELSE                                                                       
13070 * Delegaciones cercanas                                                                       
13070C                   EVAL      ZXLG05 = 1                                                       
13070C                   EVAL      ZXVSTK = 1                                                       
13070C                   EXSR      CS_STCKDEL                                                       
13070C                   IF        ZXSTDL = 1                                                       
13070C                   EVAL      T2VA07 = 1                                                       
13070C                   ENDIF                                                                      
13070C                   ENDIF                                                                      
13070 * Si no hay stock del componente en Delg Propia ni cercanas                                   
13070 *       No miro mas componentes del Conjunto                                                  
13070C                   IF        ZXSTPR = 0 And ZXSTDL = 0                                        
13070C                   LEAVE                                                                      
13070C                   ENDIF                                                                      
13070C                   ENDFOR                                                                     
13070C                   ENDIF                                                                      
13070                                                                                               
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar si es Conjunto en Productiva                                                      
      **********************************************************************                        
     C     CS_CONJPRO    BEGSR                                                                      
                                                                                                    
     C                   EVAL      Z2CANT = Z1CANT                                                  
     C                   EVAL      ZXARVMX = ZXARVMPRO                                              
                                                                                                    
      * Busco Empresa Prodcutiva                                                                    
     C                   EVAL      U0CIAS = @PCIAS                                                  
     C                   EVAL      U0TENV = '5'                                                     
     C                   EVAL      U0CLP0 = ZXPRVR                                                  
     C                   EVAL      U0CLP2 = *BLANKS                                                 
     C     KUTCOM0       CHAIN     UTCOM0                                                           
b01  C                   IF        %FOUND(UTCOM0)                                                   
     C                   MOVEL     U0CIA1        ZXCIAD                                             
                                                                                                    
     C                   MOVEL     ZXCIAD        PPCIAS                                             
     C     KPMLIBL       CHAIN     PMLIBL                                                           
      * MOVEX                                                                                       
b02  C                   IF        %FOUND(PMLIBL) And PPMVXV = 'V'                                  
      * Buscar Compañía MOVEX                                                                       
     C                   EXSR      CS_CIASMVX                                                       
     C                   EXSR      CS_MVXLIBL                                                       
      * Busco Planta por defecto en la División                                                     
     C                   Eval      File_cmndiv = LIBLMVX + '/CMNDIV00'                              
     C                   OPEN (E)  CMNDIV00                                                         
b03  C                   IF        Not %ERROR                                                       
     C                   MOVEL     MXCONO        CCCONO                                             
     C                   MOVEL     MXDIVI        CCDIVI                                             
     C     KCMNDIV00     CHAIN     CMNDIV00                                                         
b04  C                   IF        %FOUND(CMNDIV00)                                                 
      * Busco Si es Conjunto                                                                        
     C                   Eval      File_mpdhed = LIBLMVX + '/MPDHED00'                              
     C                   OPEN (E)  MPDHED00                                                         
I0184C                   Eval      File_AQPEDI = LIBLAQA + '/AQPEDI00'                              
I0184C                   OPEN (E)  AQPEDI00                                                         
I0184C                   Eval      File_ZAQITN = LIBLAQA + '/ZAQITN00'                              
I0184C                   OPEN (E)  ZAQITN00                                                         
I0184C                   Eval      File_GMTABD = LIBLAQA + '/GMTABD01'                              
I0184C                   OPEN (E)  GMTABD01                                                         
I0184C                   Eval      File_MITFAC = LIBLMVX + '/MITFAC00'                              
I0184C                   OPEN (E)  MITFAC00                                                         
b05  C                   IF        Not %ERROR                                                       
I0184 *                                                                                             
I0184 *            Ver si estamos en una división Multiplanta                                       
I0184C                   MOVEL(P)  MXCONO        Z1CONO                                             
I0184C                   EVAL      Z1DIVI = MXDIVI                                                  
I0184C     KAQPEDI00     CHAIN     AQPEDI00                                                         
I0184C                   EVAL      ZXMULTIPLA = %FOUND(AQPEDI00)                                    
I0184C                                          AND  Z1L101 = '1'                                   
     C                   MOVEL     MXCONO        H_PHCONO                                           
I0184C**                 MOVEL     CCFACI        H_PHFACI                                           
     C                   MOVEL     ZXARVMPRO     H_PHPRNO                                           
I0184C                   EVAL      H_PHFACI = GET_FACI(MXDIVI:CCFACI:H_PHPRNO)                      
     C                   MOVEL     'KIT'         H_PHSTRT                                           
     C     KMPDHED00     CHAIN     MPDHED00                                                         
b06  C                   IF        %FOUND(MPDHED00) And                                             
     C                             H_PHSTAT >= '20' And H_PHSTAT < '90'                             
      * Si es Conjunto leo los Componentes                                                          
     C                   Eval      File_mpdmat = LIBLMVX + '/MPDMAT00'                              
     C                   OPEN (E)  MPDMAT00                                                         
b07  C                   IF        Not %ERROR                                                       
     C                   MOVEL     MXCONO        PMCONO                                             
I0184C**                 MOVEL     CCFACI        PMFACI                                             
     C                   MOVEL     ZXARVMPRO     PMPRNO                                             
I0184C                   EVAL      PMFACI = GET_FACI(MXDIVI:CCFACI:PMPRNO)                          
     C                   MOVEL     'KIT'         PMSTRT                                             
     C     KMPDMAT00     SETLL     MPDMAT00                                                         
     C     KMPDMAT00     READE     MPDMAT00                                                         
d08  C                   DOW       NOT %EOF(MPDMAT00)                                               
      * Para cada Componente miro si existe stock en Trace                                          
     C                   MOVEL     PMMTNO        ZXARTTRAC                                          
     C                   MOVEL     *BLANKS       ZXVARTRAC                                          
     C                   MOVEL     *BLANKS       ZXMODTRAC                                          
     C                   EVAL      Z2CANT = Z1CANT * PMCNQT                                         
     C                   EXSR      CS_STCK909                                                       
b09  C                   IF        T2VA07 = 1                                                       
     C                   LEAVE                                                                      
e09  C                   ENDIF                                                                      
     C     KMPDMAT00     READE     MPDMAT00                                                         
e08  C                   ENDDO                                                                      
e07  C                   ENDIF                                                                      
     C                   CLOSE(E)  MPDMAT00                                                         
x06  C                   ELSE                                                                       
      * Si No es Conjunto miro si existe stock en Trace                                             
     C                   EVAL      ZXARTTRAC = ZXARTIX                                              
     C                   EVAL      ZXVARTRAC = ZXVARIX                                              
     C                   EVAL      ZXMODTRAC = ZXMODEX                                              
     C                   EXSR      CS_STCK909                                                       
e06  C                   ENDIF                                                                      
e05  C                   ENDIF                                                                      
     C                   CLOSE(E)  MPDHED00                                                         
I0184C                   CLOSE(E)  AQPEDI00                                                         
I0184C                   CLOSE(E)  ZAQITN00                                                         
I0184C                   CLOSE(E)  GMTABD01                                                         
I0184C                   CLOSE(E)  MITFAC00                                                         
e04  C                   ENDIF                                                                      
e03  C                   ENDIF                                                                      
     C                   CLOSE(E)  CMNDIV00                                                         
x02  C                   ELSE                                                                       
      * AS400                                                                                       
      * Busco Si es Conjunto                                                                        
     C                   EVAL      FileCojc_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/MSCOJC'                                           
     C                   OPEN (E)  MSCOJC                                                           
b03  C                   IF        Not %ERROR                                                       
     C                   EVAL      NDCIAS = ZXCIAD                                                  
     C                   EVAL      NDARTI = ZXARTIX                                                 
     C                   EVAL      NDVARI = ZXVARIX                                                 
     C                   EVAL      NDMODE = ZXMODEX                                                 
     C                   EVAL      NDTCOJ = '4'                                                     
     C     KMSCOJC       CHAIN     MSCOJC                                                           
b04  C                   IF        %FOUND(MSCOJC) AND NDBAJA<'1'                                    
      * Si es Conjunto leo los Componentes                                                          
     C                   EVAL      FileCojd_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/MSCOJD'                                           
     C                   OPEN (E)  MSCOJD                                                           
b05  C                   IF        Not %ERROR                                                       
     C     KMSCOJC       SETLL     MSCOJD                                                           
     C     KMSCOJC       READE     MSCOJD                                                           
d06  C                   DOW       NOT %EOF(MSCOJD)                                                 
b07  C                   IF        NDBAJA <> '1'                                                    
      * Para cada Componente miro si existe stock en Trace                                          
     C                   EVAL      ZXARTTRAC = NDCOMP                                               
     C                   EVAL      ZXVARTRAC = NDVAR2                                               
     C                   EVAL      ZXMODTRAC = NDMOD2                                               
     C                   EVAL      Z2CANT = Z1CANT * NDCANT                                         
     C                   EXSR      CS_STCK909                                                       
b08  C                   IF        T2VA07 = 1                                                       
     C                   LEAVE                                                                      
e08  C                   ENDIF                                                                      
e07  C                   ENDIF                                                                      
     C     KMSCOJC       READE     MSCOJD                                                           
e06  C                   ENDDO                                                                      
e05  C                   ENDIF                                                                      
     C                   CLOSE(E)  MSCOJD                                                           
     C                   CLOSE(E)  MSCOJC                                                           
                                                                                                    
x04  C                   ELSE                                                                       
     C                   CLOSE(E)  MSCOJC                                                           
      * Si No es Conjunto miro si existe stock en Trace                                             
     C                   EVAL      ZXARTTRAC = ZXARTIX                                              
     C                   EVAL      ZXVARTRAC = ZXVARIX                                              
     C                   EVAL      ZXMODTRAC = ZXMODEX                                              
     C                   EXSR      CS_STCK909                                                       
e04  C                   ENDIF                                                                      
e03  C                   ENDIF                                                                      
e02  C                   ENDIF                                                                      
                                                                                                    
x01  C                   ELSE                                                                       
      * Si No encuentro equivalencia del Proveedor miro directamente Trace                          
     C                   EVAL      ZXARTTRAC = ZXARTIX                                              
     C                   EVAL      ZXVARTRAC = ZXVARIX                                              
     C                   EVAL      ZXMODTRAC = ZXMODEX                                              
     C                   EXSR      CS_STCK909                                                       
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar si el artículo existe en la productiva                                            
      **********************************************************************                        
     C     CS_ARTEXIS    BEGSR                                                                      
                                                                                                    
     C                   EVAL      ZXARTIX=M5ARTI                                                   
     C                   EVAL      ZXVARIX=M5VARI                                                   
     C                   EVAL      ZXMODEX=M5MODE                                                   
     C                   EVAL      ZXARVM=ZXARVMX                                                   
     C                   EVAL      ZXTCST=M5TCS1                                                    
     C                   EVAL      ZXARVP=*BLANKS                                                   
                                                                                                    
     C                   EVAL      C0CIAS=S5CIAS                                                    
     C                   EVAL      C0PRVR=M5PRVR                                                    
     C     KPUPROV       CHAIN     PUPROV                                                           
b01  C                   IF        %FOUND(PUPROV)                                                   
                                                                                                    
     C                   EVAL      C3CIAS=S5CIAS                                                    
     C                   EVAL      C3PRVR=M5PRVR                                                    
     C                   EVAL      C3ARVM=ZXARVM                                                    
     C     KPUPRP0       CHAIN     PUPRP0                                                           
b02  C                   IF        %FOUND(PUPRP0)                                                   
     C                   EVAL      ZXARVP=C3ARVP                                                    
     C                   EVAL      ZXTCST=C3TCST                                                    
b03  C                   IF        ZXTCST=*BLANKS                                                   
     C                   EVAL      ZXTCST=M5TCS1                                                    
e03  C                   ENDIF                                                                      
e02  C                   ENDIF                                                                      
                                                                                                    
b02  C                   IF        ZXARVP <> *BLANKS                                                
     C                   EVAL      ZXARVMPRO=ZXARVP                                                 
     C                   EXSR      CS_ARTEXI2                                                       
b03  C                   IF        ZXINCI = '005'                                                   
     C                   EVAL      ZXARVMPRO=ZXARVM                                                 
     C                   EXSR      CS_ARTEXI2                                                       
e03  C                   ENDIF                                                                      
x02  C                   ELSE                                                                       
     C                   EVAL      ZXARVMPRO=ZXARVM                                                 
     C                   EXSR      CS_ARTEXI2                                                       
e02  C                   ENDIF                                                                      
x01  C                   ELSE                                                                       
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar si el artículo existe en la productiva                                            
      **********************************************************************                        
     C     CS_ARTEXI2    BEGSR                                                                      
                                                                                                    
      * Busco Empresa Prodcutiva                                                                    
     C                   EVAL      U0CIAS = @PCIAS                                                  
     C                   EVAL      U0TENV = '5'                                                     
     C                   EVAL      U0CLP0 = M5PRVR                                                  
     C                   EVAL      U0CLP2 = *BLANKS                                                 
     C     KUTCOM0       CHAIN     UTCOM0                                                           
b01  C                   IF        %FOUND(UTCOM0)                                                   
     C                   MOVEL     U0CIA1        ZXCIAD                                             
                                                                                                    
     C                   EVAL      ZXINCI = '   '                                                   
     C                   EVAL      Q1CIAS = ZXCIAD                                                  
FQ942C                   EVAL      Q1ARVM = ZXARVMPRO                                               
FQ942C*    KGXEQAR       CHAIN     GXEQAR                                                           
      * Si el artículo no existe en GXEQAR buscamos en MSARTI Productiva                            
FQ942C*                  IF        Not %FOUND(GXEQAR)                                               
                                                                                                    
     C                   MOVEL     ZXCIAD        PPCIAS                                             
     C     KPMLIBL       CHAIN     PMLIBL                                                           
      * MOVEX                                                                                       
b03  C                   IF        %FOUND(PMLIBL) And PPMVXV = 'V'                                  
      * Buscar Compañía MOVEX                                                                       
     C                   EXSR      CS_CIASMVX                                                       
     C                   EXSR      CS_MVXLIBL                                                       
      * Abrir Ficheros MOVEX                                                                        
     C                   Eval      File_mitmas = LIBLMVX + '/MITMAS00'                              
     C                   OPEN (E)  MITMAS00                                                         
b04  C                   IF        Not %ERROR                                                       
     C                   MOVEL     MXCONO        MMCONO                                             
     C                   EVAL      MMITNO = M5ARTI                                                  
     C                   MOVEL     ZXARVMPRO     MMITNO                                             
     C     KMITMAS00     CHAIN     MITMAS00                                                         
b05  C                   IF        Not %FOUND(MITMAS00)                                             
FQ942C                             OR MMSTAT<>'20'                                                  
     C                   EVAL      ZXINCI = '005'                                                   
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
     C                   CLOSE(E)  MITMAS00                                                         
                                                                                                    
x03  C                   ELSE                                                                       
      * AS400                                                                                       
     C                   EVAL      Filearti_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/MSARTI'                                           
     C                   OPEN (E)  MSARTI                                                           
b04  C                   IF        Not %ERROR                                                       
     C                   EVAL      ZXARVMX = ZXARVMPRO                                              
     C                   EVAL      A_M5ARTI = ZXARTIX                                               
     C                   EVAL      A_M5VARI = ZXVARIX                                               
     C                   EVAL      A_M5MODE = ZXMODEX                                               
     C     KMSARTI       CHAIN     MSARTI                                                           
b05  C                   IF        Not %FOUND(MSARTI)                                               
FQ942C                             OR M5BAJA='1'                                                    
     C                   EVAL      ZXINCI = '005'                                                   
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
                                                                                                    
     C                   CLOSE(E)  MSARTI                                                           
                                                                                                    
e03  C                   ENDIF                                                                      
e02  C                   ENDIF                                                                      
FQ942C*                  ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar Stock en Trace                                                                    
      **********************************************************************                        
     C     CS_STCK909    BEGSR                                                                      
                                                                                                    
IT228 * Busco Stock en OL                                                                           
IT228C                   if        (%lookup(S5LOGE:T_logol)>0)                                      
IT228C                   EVAL      M0CIAS=S5CIAS                                                    
IT228C                   EVAL      M0LOGE=S5LOGE                                                    
IT228C     KMSALMA05     CHAIN     MSALMA05                                                         
IT228C                   IF        %FOUND AND M0BAJA<>'1'                                           
IT228C                   EVAL      @qmaga = M0MAGA                                                  
IT228C                   call      'MM1412'                                                         
IT228C                   PARM      S5cias        @qCIAS            3 0                              
IT228C                   PARM      ZXARTTRAC     @qARTI           15                                
IT228C                   PARM      ZXVARTRAC     @qVARI            3                                
IT228C                   PARM      ZXMODTRAC     @qMODE            3                                
IT228C                   PARM      0             @qSTOK           15 5                              
IT228C                   PARM      ' '           @qSERV            2                                
IT228C                   PARM                    @qmaga            5                                
IT228C                   EVAL      T2TDIS = @qSTOK                                                  
IT228C                   IF        Z2CANT <=@qSTOK                                                  
IT228C                   EVAL      T2VA07 = 0                                                       
IT228C                   ELSE                                                                       
IT228C                   EVAL      T2VA07 = 1                                                       
IT228C                   ENDIF                                                                      
IT228C                   ENDIF                                                                      
IT228 * Busco Stock en Trace                                                                        
IT228C*                  EVAL      M1CIAS = 909                                                     
IT228C*                  EVAL      M1ARTI = ZXARTTRAC                                               
IT228C*                  EVAL      M1VARI = ZXVARTRAC                                               
IT228C*                  EVAL      M1MODE = ZXMODTRAC                                               
IT228C*                  EVAL      M1MAGA = '01'                                                    
IT228C*                  EVAL      M1CALI = 'A'                                                     
IT228C*    KMSSTO909     CHAIN     MSSTO0909                                                        
IT228C*                  EVAL      ZXARTIX = ZXARTTRAC                                              
IT228C*                  EVAL      ZXVARIX = ZXVARTRAC                                              
IT228C*                  EVAL      ZXMODEX = ZXMODTRAC                                              
IT228C*                  EVAL      T2TART = ZXARVMX                                                 
IT228C*                  EVAL      T2TCAN = Z2CANT                                                  
IT228C*                  EVAL      T2TDIS = (M1SACT-M1SKRE-M1SKRP-M1SKR1-M1SKR2)                    
IT228C*                  IF        %FOUND(MSSTO0909) AND                                            
IT228C*                            Z2CANT <= (M1SACT-M1SKRE-M1SKRP                                  
IT228C*                                       -M1SKR1-M1SKR2)                                       
IT228C*                  EVAL      T2VA07 = 0                                                       
IT228C*                  ELSE                                                                       
IT228C*                  EVAL      T2VA07 = 1                                                       
      * si no hay stock en Trace busco en Delegaciones.                                             
13070C**                 EVAL      ZXARTIX=ZXARTDLGA                                                
13070C**                 EVAL      ZXVARIX=ZXVARDLGA                                                
13070C**                 EVAL      ZXMODEX=ZXMODDLGA                                                
13070C**                 EVAL      ZXVSTK = 1                                                       
      * Delegación Propia                                                                           
13070C**                 EXSR      CS_STCKPRO                                                       
13070C**                 IF        ZXSTPR = 1                                                       
13070C**                 EVAL      T2VA07 = 1                                                       
13070C**                 ENDIF                                                                      
13070C**                 IF        T2VA07 = 0                                                       
13070C**                 EVAL      ZXLG05 = 1                                                       
13070C**                 EVAL      ZXVSTK = 1                                                       
      * Delegaciones cercanas                                                                       
13070C**                 EXSR      CS_STCKDEL                                                       
13070C**                 IF        ZXSTDL = 1                                                       
13070C**                 EVAL      T2VA07 = 1                                                       
13070C**                 ENDIF                                                                      
13070C**                 ENDIF                                                                      
                                                                                                    
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar si hay stock suficiente en Delegación Propia                                      
      **********************************************************************                        
     C     CS_STCKPRO    BEGSR                                                                      
                                                                                                    
     C                   EVAL      ZXSTPR = 0                                                       
     C                   EVAL      ZXCANT = 1                                                       
      * De momento la linea será ED hasta que no encontremos stock                                  
     C                   EVAL      T2VA07 = 0                                                       
                                                                                                    
      * Logística asociada a la delegación                                                          
     C                   EVAL      P7CIAS=@PCIAS                                                    
     C                   EVAL      P7DLGA=@PDLGA                                                    
     C     KPMEMPR       CHAIN     PMEMPR                                                           
b03  C                   IF        %FOUND(PMEMPR)                                                   
FQ844C                             AND (P7AUTS=*BLANKS OR                                           
FQ844C                             T3OPL1=*BLANKS)                                                  
     C                   EVAL      MICIAS=P7CIAS                                                    
     C                   EVAL      MIDLGA=@PDLGA                                                    
     C                   EVAL      MILGCA=P7LOGS                                                    
     C     KMSLOAD       CHAIN     MSLOAD                                                           
     C     KMSLOAD       CHAIN     MSLOGI                                                           
b04  C                   IF        %FOUND(MSLOAD) AND %FOUND(MSLOGI)                                
     C                   EVAL      M0CIAS=S0CIAS                                                    
     C                   EVAL      M0LOGE=P7LOGS                                                    
     C     KMSALMA05     CHAIN     MSALMA05                                                         
b05  C                   IF        %FOUND(MSALMA05)                                                 
                                                                                                    
      * Busco Stock en el Almacén de la logística                                                   
     C                   EVAL      M1CIAS = S5CIAS                                                  
     C                   EVAL      M1ARTI = ZXARTIX                                                 
     C                   EVAL      M1VARI = ZXVARIX                                                 
     C                   EVAL      M1MODE = ZXMODEX                                                 
     C                   EVAL      M1MAGA = M0MAGA                                                  
     C                   EVAL      M1CALI = 'A'                                                     
     C     KMSSTO010     CHAIN     MSSTO01                                                          
b06  C                   IF        %FOUND(MSSTO01)                                                  
                                                                                                    
     C                   EVAL      ZXSTDD = 0                                                       
     C                   EVAL      ZXSTKA = 0                                                       
     C                   EVAL      ZXCANS0 = 0                                                      
     C                   EVAL      ZXCANE0 = 0                                                      
     C                   EVAL      ZXDEPO0 = 0                                                      
                                                                                                    
      * Solo tratamos si el almacén tiene stock                                                     
b07  C                   IF        M1SACT > 0                                                       
     C                   EVAL      ZXSTKA=M1SACT                                                    
                                                                                                    
      * Busqueda cantidades de stock pdte servir,fabricar,deposito...                               
     C                   EXSR      CS_CANSTOK                                                       
                                                                                                    
     C     KMSSTOK       CHAIN     MSSTOK                                                           
b08  C                   IF        %FOUND(MSSTOK)                                                   
      * Stock disponible                                                                            
     C                   EVAL      ZXSTDD=ZXSTKA-ZXCANS0-ZXCANE0                                    
b09  C                   IF        ZXDEPO0>0                                                        
     C                   EVAL      ZXSTDD=ZXSTDD-ZXDEPO0                                            
e09  C                   ENDIF                                                                      
      * Si stock disponible es mayor o igual a cantidad pedido No ED                                
     C                   EVAL      T2DART = ZXARVMX                                                 
     C                   EVAL      T2DCAN = Z1CANT                                                  
     C                   EVAL      T2DDIS = ZXSTDD                                                  
     C                   EVAL      T2DALM = M1MAGA                                                  
02110C**                 IF        Z1CANT <= ZXSTDD                                                 
02110C**                 EVAL      ZXSTPR = 1                                                       
02110C**                 ENDIF                                                                      
02110C                   IF        Z1CANT <= ZXSTDD And ZXVSTK = 1                                  
02110C                   EVAL      ZXSTPR = 1                                                       
02110C                   ENDIF                                                                      
02110C                   IF        M1SMAX<ZXSTDD And ZXVSTK = 0                                     
02110C                   IF        Z1CANT <= ZXSTDD                                                 
02110C                   EVAL      ZXSTPR = 1                                                       
02110C                   ENDIF                                                                      
02110C                   ENDIF                                                                      
e08  C                   ENDIF                                                                      
e07  C                   ENDIF                                                                      
e06  C                   ENDIF                                                                      
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
e03  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar si hay stock suficiente en alguna Delegación Cercana                              
      **********************************************************************                        
     C     CS_STCKDEL    BEGSR                                                                      
                                                                                                    
     C                   EVAL      ZXSTDL = 0                                                       
     C                   EVAL      ZXCANT = 1                                                       
      * De momento la linea será ED hasta que no encontremos stock                                  
     C                   EVAL      T2VA07 = 0                                                       
                                                                                                    
      * Busco en parámetros de Interdelegaciones,delegaciones cercanas                              
     C                   EVAL      XACIAS = S0CIAS                                                  
     C                   EVAL      XADLGA = S0DLGA                                                  
b01  C                   IF        ZXLG05 = 1                                                       
     C     KMSDLDL05     SETLL     MSDLDL05                                                         
     C     KMSDLDL05     READE     MSDLDL05                               82                        
x01  C                   ELSE                                                                       
     C     KMSDLDL05     SETLL     MSDLDL03                                                         
     C     KMSDLDL05     READE     MSDLDL03                               82                        
e01  C                   ENDIF                                                                      
d01  C                   DOW       EOF=*OFF                                                         
b02  C                   IF        (XAPRI2>'0' And ZXLG05 = 1)                                      
     C                             Or (XAPRIS>'0' And ZXLG05 = 0)                                   
                                                                                                    
      * Logística asociada a la delegación                                                          
     C                   EVAL      P7CIAS=S0CIAS                                                    
     C                   EVAL      P7DLGA=XADLG2                                                    
     C     KPMEMPR       CHAIN     PMEMPR                                                           
b03  C                   IF        %FOUND(PMEMPR)                                                   
     C                   EVAL      MICIAS=P7CIAS                                                    
     C                   EVAL      MIDLGA=XADLGA                                                    
     C                   EVAL      MILGCA=P7LOGS                                                    
     C     KMSLOAD       CHAIN     MSLOAD                                                           
     C     KMSLOAD       CHAIN     MSLOGI                                                           
b04  C                   IF        %FOUND(MSLOAD) AND %FOUND(MSLOGI)                                
     C                   EVAL      M0CIAS=S0CIAS                                                    
     C                   EVAL      M0LOGE=P7LOGS                                                    
     C     KMSALMA05     CHAIN     MSALMA05                                                         
b05  C                   IF        %FOUND(MSALMA05)                                                 
                                                                                                    
      * Busco Stock en el Almacén de la logística                                                   
     C                   EVAL      M1CIAS = S5CIAS                                                  
     C                   EVAL      M1ARTI = ZXARTIX                                                 
     C                   EVAL      M1VARI = ZXVARIX                                                 
     C                   EVAL      M1MODE = ZXMODEX                                                 
     C                   EVAL      M1MAGA = M0MAGA                                                  
     C                   EVAL      M1CALI = 'A'                                                     
     C     KMSSTO010     CHAIN     MSSTO01                                                          
b06  C                   IF        %FOUND(MSSTO01)                                                  
                                                                                                    
     C                   EVAL      ZXSTDD = 0                                                       
     C                   EVAL      ZXSTKA = 0                                                       
     C                   EVAL      ZXCANS0 = 0                                                      
     C                   EVAL      ZXCANE0 = 0                                                      
     C                   EVAL      ZXDEPO0 = 0                                                      
                                                                                                    
      * Solo tratamos si el almacén tiene stock                                                     
b07  C                   IF        M1SACT > 0                                                       
     C                   EVAL      ZXSTKA=M1SACT                                                    
                                                                                                    
      * Busqueda cantidades de stock pdte servir,fabricar,deposito...                               
     C                   EXSR      CS_CANSTOK                                                       
                                                                                                    
     C     KMSSTOK       CHAIN     MSSTOK                                                           
b08  C                   IF        %FOUND(MSSTOK)                                                   
      * Stock disponible                                                                            
     C                   EVAL      ZXSTDD=ZXSTKA-ZXCANS0-ZXCANE0                                    
b09  C                   IF        ZXDEPO0>0                                                        
     C                   EVAL      ZXSTDD=ZXSTDD-ZXDEPO0                                            
e09  C                   ENDIF                                                                      
      * Si stock disponible es mayor o igual a cantidad pedido No ED                                
     C                   EVAL      T2DART = ZXARVMX                                                 
     C                   EVAL      T2DCAN = Z1CANT                                                  
     C                   EVAL      T2DDIS = ZXSTDD                                                  
     C                   EVAL      T2DALM = M1MAGA                                                  
b09  C                   IF        Z1CANT <= ZXSTDD And ZXVSTK = 1                                  
     C                   EVAL      ZXSTDL = 1                                                       
     C                   LEAVE                                                                      
e09  C                   ENDIF                                                                      
b09  C                   IF        M1SMAX<ZXSTDD And ZXVSTK = 0                                     
b10  C                   IF        Z1CANT <= ZXSTDD                                                 
     C                   EVAL      ZXSTDL = 1                                                       
     C                   LEAVE                                                                      
e10  C                   ENDIF                                                                      
e09  C                   ENDIF                                                                      
e08  C                   ENDIF                                                                      
e07  C                   ENDIF                                                                      
e06  C                   ENDIF                                                                      
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
e03  C                   ENDIF                                                                      
e02  C                   ENDIF                                                                      
                                                                                                    
b02  C                   IF        ZXLG05 = 1                                                       
     C     KMSDLDL05     READE     MSDLDL05                               82                        
x02  C                   ELSE                                                                       
     C     KMSDLDL05     READE     MSDLDL03                               82                        
e02  C                   ENDIF                                                                      
e01  C                   ENDDO                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Validaciones para Alta ED (precio compra, artículo, etc...)                                 
      **********************************************************************                        
     C     CS_VALED51    BEGSR                                                                      
                                                                                                    
     C                   CALL      'ED0051'                                                         
     C                   PARM                    @PCIAS                                             
     C                   PARM                    @PDLGA                                             
     C                   PARM                    @PNPCO                                             
     C                   PARM                    @PTPED                                             
     C                   PARM                    @PDATP                                             
     C                   PARM                    @PNOPL                                             
     C                   PARM                    @PLINE                                             
FQ284C                   PARM      *BLANKS       @FDARV1                                            
FQ284C                   PARM      *BLANKS       @FDCOM2                                            
     C                   PARM      S5CUST        @PCUST                                             
     C                   PARM      S5TDI1        @PTDI1                                             
     C                   PARM      '403'         @PEDAU                                             
     C                   PARM      0             @PLOGI                                             
     C                   PARM      0             @PORIG                                             
     C                   PARM      1             @PINTE                                             
OL885C*                  PARM      ' '           @PERRO                                             
OL885C                   PARM      'D'           @PERRO                                             
     C                   PARM      *BLANKS       @PINCI                                             
                                                                                                    
b01  C                   IF        @PERRO <> ' '                                                    
     C*******            EVAL      T2VA08 = 1                                                       
     C                   EVAL      T2INCI = @PINCI                                                  
e01  C                   ENDIF                                                                      
b01  C                   IF        @PINCI = '003' OR                                                
     C                             @PINCI = '005'                                                   
CR528C                             OR @PINCI = '019'                                                
     C                   EVAL      T2VA08 = 1                                                       
e01  C                   ENDIF                                                                      
FQ942                                                                                               
FQ942C                   IF        @PINCI = '050'                                                   
FQ942C                   EVAL      T2CJTO = 1                                                       
FQ942C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * Calculo Importe línea pedido                               *                                
      *------------------------------------------------------------*                                
     C     CS_IMPORTE    BEGSR                                                                      
                                                                                                    
     C                   EVAL      ZXMONE2 = S5MONE                                                 
      * Tipo de IVA                                                                                 
     C                   EVAL      PECIAS=S5CIAS                                                    
     C                   EVAL      PECTAB='TIV2'                                                    
     C                   EVAL      PECLTA=*BLANKS                                                   
     C                   EVAL      PECLTA=S0TIV3                                                    
     C     KPMTABD       CHAIN     PMTABD                                                           
b01  C                   IF        %FOUND(PMTABD)                                                   
     C                   EVAL      ZXTIVC=PEBL61                                                    
     C                   EVAL      ZXBL65I=PEBL65                                                   
x01  C                   ELSE                                                                       
     C                   EVAL      ZXPABI=*BLANKS                                                   
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      XZAUXI=*ZEROS                                                    
     C                   EVAL      XZAUXI1=*ZEROS                                                   
     C                   EVAL      MBCIAS=S5CIAS                                                    
     C                   EVAL      MBMONE=ZXMONE2                                                   
ECOP * Ecotaxe                                                                                     
ECOP C                   EVAL      XZTAXE=0                                                         
ECOP C                   IF        S5ECOP<>*BLANKS                                                  
ECOP C                   CALL      'MN0398'                                                         
ECOP C                   PARM                    @PCIAS                                             
ECOP C                   PARM      S5ECOP        @PEECOP                                            
ECOP C                   PARM      S5DATP        @PEFLCD                                            
ECOP C                   PARM      0             @PETAXE                                            
ECOP C                   EVAL      XZTAXE=@PETAXE                                                   
ECOP C                   ENDIF                                                                      
      * Buscamos en Ajuste decimal                                                                  
                                                                                                    
     C     KMSDIV0       CHAIN     MSDIV0                                                           
b01  C                   IF        %FOUND(MSDIV0)                                                   
     C                   EVAL      XZDECI=MBDECI                                                    
     C                   EVAL      XZAJUD=MBAJUD                                                    
e01  C                   ENDIF                                                                      
                                                                                                    
      * Buscamos en PMUNAL UNIDADES ALTERNATIVAS                                                    
                                                                                                    
     C                   EVAL      XZCOFU=1                                                         
b01  C                   IF        S5UNIM<>S5UNDP                                                   
     C                   EVAL      XZCIAS=@PCIAS                                                    
     C                   EVAL      XZARTI=S5ARTI                                                    
     C                   EVAL      XZVARI=S5VARI                                                    
     C                   EVAL      XZMODE=S5MODE                                                    
     C                   EVAL      ZXCA10=S5CANT                                                    
     C                   EVAL      ZXCA11=S5CANT                                                    
     C                   EVAL      ZXUN10=S5UNIM                                                    
     C                   EVAL      ZXUN11=S5UNDP                                                    
     C* CAMBIO de unidades                                                                          
     C/COPY *LIBL/QSRDSRC,SRD021                                                                    
e01  C                   ENDIF                                                                      
                                                                                                    
      * Buscamos en CAMBIO MONEDA CABECERA DEL PEDIDO                                               
                                                                                                    
b01  C                   IF        ZXMONE2<>S5MONE                                                  
     C                   CALL      'MM2555'                                                         
     C                   PARM      S5CIAS        @PCIAS                                             
     C                   PARM      S5MONE        @PMON1                                             
     C                   PARM      ZXMONE2       @PMON2                                             
     C                   PARM      S5DATP        @PDATA                                             
     C                   PARM      S5NOPL        @PHORA                                             
     C                   PARM      0             @PCMCOCO                                           
     C                   PARM      0             @PCMCCCO                                           
     C                   PARM      *BLANKS       @PEERR                                             
     C                   EVAL      ZXCOCAMB=@PCMCCCO                                                
x01  C                   ELSE                                                                       
     C                   EVAL      ZXCOCAMB=1                                                       
e01  C                   ENDIF                                                                      
                                                                                                    
      * Buscamos en % de IVA                                                                        
     C                   EVAL      MVCIAS=S5CIAS                                                    
     C                   EVAL      MVTIVA=S5TIVA                                                    
     C                   EVAL      MVPABI=ZXPABI                                                    
     C                   EVAL      MVFLCD=@PDATP                                                    
     C     KMSIVAS       SETGT     MSIVAS                                                           
     C     KMSIVAS0      READPE    MSIVAS                                 83                        
s01  C                   SELECT                                                                     
     C                   WHEN      ZXTIVC=' '                                                       
     C                   EVAL      MVPIV2=*ZEROS                                                    
     C                   WHEN      ZXTIVC='0'                                                       
     C                   EVAL      MVPIV1=*ZEROS                                                    
     C                   EVAL      MVPIV2=*ZEROS                                                    
e01  C                   ENDSL                                                                      
                                                                                                    
      * Calculamos el precio de nueva linea o modificada                                            
     C                   EVAL      XZCANT=S5CANT                                                    
     C                   EVAL      XZPREC=S5PREC                                                    
     C                   EVAL      XZCADP=S5CADP                                                    
     C                   EVAL      XZDTO1=S5DTO1                                                    
     C                   EVAL      XZDTO2=S5DTO2                                                    
     C                   EVAL      XZDTO3=S5DTO3                                                    
     C                   EVAL      XZDTO4=S5DTO4                                                    
b01  C                   IF        XZDTO4=*ZEROS                                                    
     C                   EVAL      XZDTO4=@PDTOE                                                    
e01  C                   ENDIF                                                                      
ECOP C/COPY *LIBL/QSRDSRC,SRD022ECO                                                                 
ECOP C* AJUSTE Y DECIMALES                                                                          
ECOP C/COPY *LIBL/QSRDSRC,SRD001                                                                    
ECOP C                   Z-ADD     XZAUXI        ZXBIMPECO                                          
     C/COPY *LIBL/QSRDSRC,SRD022                                                                    
                                                                                                    
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
     C                   Z-ADD     XZAUXI        ZXBIMP                                             
ECOP C                   ADD       ZXBIMPECO     ZXBIMP                                             
      * Calculamos el IVA                                                                           
     C                   EVAL      XZAUXI=ZXBIMP*MVPIV1                                             
     C     XZAUXI        DIV(H)    100           XZAUXI                                             
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
     C                   Z-ADD     XZAUXI        ZXIIV1                                             
      * Calculamos el Recargo de equivalencia                                                       
     C                   EVAL      XZAUXI=ZXBIMP*MVPIV2                                             
     C     XZAUXI        DIV(H)    100           XZAUXI                                             
     C* AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
     C                   Z-ADD     XZAUXI        ZXIIV2                                             
                                                                                                    
      * Omitimos BASE o IVA segun tipo de IVA                                                       
                                                                                                    
b01  C                   IF        MVOMTB>='1'                                                      
     C                   EVAL      ZXBIMP=ZXBIMP-ZXBIMP                                             
e01  C                   ENDIF                                                                      
b01  C                   IF        MVOMTI>='1'                                                      
     C                   EVAL      ZXIIV1=ZXIIV1-ZXIIV1                                             
     C                   EVAL      ZXIIV2=ZXIIV2-ZXIIV2                                             
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Validaciones Importe lineas ED                                     *                        
      **********************************************************************                        
     C     CS_IMPLINE    BEGSR                                                                      
                                                                                                    
FQ710C*                  EVAL      XACIAS = @PCIAS                                                  
FQ710C*                  EVAL      XADLGA = @PDLGA                                                  
FQ710C*                  EVAL      XADLG2 = 'TRACE'                                                 
FQ710C*    KMSDLDL       CHAIN     MSDLDL                                                           
FQ710C*                  IF        %FOUND(MSDLDL)                                                   
FQ710C*                  EVAL      T2IMPM = XALII2                                                  
FQ710C                   EVAL      T2IMPM = T3LIMP                                                  
     C                   EVAL      T2IMED = ZXIMPO                                                  
FQ710C*                  IF        ZXIMPO < XALII2                                                  
FQ710C                   IF        ZXIMPO < T3LIMP                                                  
      * Actualizo fichero temporal                                                                  
     C                   EVAL      ZXVA09 = 1                                                       
     C                   EXSR      CS_FICTEMP                                                       
e02  C                   ENDIF                                                                      
FQ710C*                  ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Comprobar Pedido Completo                                          *                        
      **********************************************************************                        
     C     CS_PEDTOTA    BEGSR                                                                      
                                                                                                    
b01  C                   IF        ZXPEDT = 1 And S0ETOD = '1'                                      
      * Actualizo fichero temporal                                                                  
     C                   EVAL      ZXVA10 = 1                                                       
     C                   EXSR      CS_FICTEMP                                                       
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Actualizar fichero temporal                                                                 
      **********************************************************************                        
     C     CS_FICTEMP    BEGSR                                                                      
                                                                                                    
      * Leo Pedido en CODEPE                                                                        
     C     KED0050W      SETLL     ED0050W                                                          
     C     KED0050W      READE     ED0050W                                                          
d01  C                   DOW       NOT %EOF(ED0050W)                                                
     C                   EVAL      T2VA09 = ZXVA09                                                  
     C                   EVAL      T2VA10 = ZXVA10                                                  
C2510C                   IF        T2VA10 = 1                                                       
     C                   EVAL      T2ENTD = 0                                                       
C2510C                   ENDIF                                                                      
     C                   UPDATE    RED0050W                                                         
     C     KED0050W      READE     ED0050W                                                          
e01  C                   ENDDO                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Actualizar Marca ED en CODEPE TPE4='2'                                                      
      **********************************************************************                        
     C     CS_MARCAED    BEGSR                                                                      
                                                                                                    
      * Leo Pedido en CODEPE                                                                        
     C     KED0050W      SETLL     ED0050W                                                          
     C     KED0050W      READE     ED0050W                                                          
d01  C                   DOW       NOT %EOF(ED0050W)                                                
b02  C                   IF        T2ENTD = 1 And T2FORZ = 0                                        
     C                   EVAL      S5CIAS = T2CIAS                                                  
     C                   EVAL      S5DLGA = T2DLGA                                                  
     C                   EVAL      S5NPCO = T2NPCO                                                  
     C                   EVAL      S5TPED = T2TPED                                                  
     C                   EVAL      S5DATP = T2DATP                                                  
     C                   EVAL      S5NOPL = T2NOPL                                                  
     C                   EVAL      S5LINE = T2LINE                                                  
     C     KCODEPE0      CHAIN     CODEPE                                                           
b03  C                   IF        %FOUND(CODEPE)                                                   
CR554c                   if        not (s5lb2b <> *blank and s5tped ='25')                          
C2638C                   IF        S5STUL<>'5' AND S5CAPP=0                                         
     C                   EVAL      S5TPE4 = '2 '                                                    
C2638c                   ENDIF                                                                      
     C                   UPDATE    RCODEPE                                                          
CR554c                   endif                                                                      
e03  C                   ENDIF                                                                      
e02  C                   ENDIF                                                                      
     C     KED0050W      READE     ED0050W                                                          
e01  C                   ENDDO                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Buscar Puntos de Expedición                                                                 
      **********************************************************************                        
     C     CS_BUSPEXP    BEGSR                                                                      
                                                                                                    
      * Leo Pedido en CODEPE                                                                        
     C                   MOVEA     *BLANKS       SLOGISTI                                           
     C                   EVAL      S5CIAS = @PCIAS                                                  
     C                   EVAL      S5DLGA = @PDLGA                                                  
     C                   EVAL      S5NPCO = @PNPCO                                                  
     C                   EVAL      S5TPED = @PTPED                                                  
     C                   EVAL      S5DATP = @PDATP                                                  
     C                   EVAL      S5NOPL = @PNOPL                                                  
     C     KCODEPE       SETLL     CODEPE                                                           
     C     KCODEPE       READE(N)  CODEPE                                                           
d01  C                   DOW       NOT %EOF(CODEPE)                                                 
b02  C                   IF        S5TPE4 = '2'                                                     
     C                   EVAL      ZXLOGE = 'TRA'                                                   
e02  C                   ELSE                                                                       
     C                   EVAL      ZXLOGE = S5LOGE                                                  
e02  C                   ENDIF                                                                      
      * Busco la logística en la serie                                                              
     C                   EVAL      ZW=1                                                             
     C     ZXLOGE        LOOKUP    SLOGISTI(ZW)                           81                        
      * Si no existe grabo logística en la serie                                                    
b02  C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      ZW=1                                                             
     C     *BLANKS       LOOKUP    SLOGISTI(ZW)                           81                        
     C                   MOVEL     ZXLOGE        SLOGISTI(ZW)                                       
e02  C                   ENDIF                                                                      
                                                                                                    
     C     KCODEPE       READE(N)  CODEPE                                                           
e01  C                   ENDDO                                                                      
                                                                                                    
      * Puntos de expedición                                                                        
     C                   EVAL      ZW=1                                                             
     C     *BLANKS       LOOKUP    SLOGISTI(ZW)                           81                        
b01  C                   IF        ZW>1                                                             
     C                   EVAL      ZW=ZW-1                                                          
e01  C                   ENDIF                                                                      
                                                                                                    
      * Si los Puntos de Expedición superan la parametrización                                      
      *  cambio todo lo que no sea Entrega Directa a Delegación Propia                              
b01  C                   IF        ZW > T3PEXP                                                      
      * Logística asociada a la delegación                                                          
     C                   EVAL      P7CIAS=@PCIAS                                                    
     C                   EVAL      P7DLGA=@PDLGA                                                    
     C     KPMEMPR       CHAIN     PMEMPR                                                           
b02  C                   IF        %FOUND(PMEMPR)                                                   
C1686 * Se define un solo punto de expedición tal como se define                                    
C1686 * en el CR1686. Se define un punto de expedición y                                            
C1686 * si no lo cumple el material se quedará en la logística                                      
C1686 * de la delegación (o en su defecto en la forzada).                                           
C1686C                                                                                              
      * Leo Pedido en CODEPE                                                                        
     C                   EVAL      S5CIAS = @PCIAS                                                  
     C                   EVAL      S5DLGA = @PDLGA                                                  
     C                   EVAL      S5NPCO = @PNPCO                                                  
     C                   EVAL      S5TPED = @PTPED                                                  
     C                   EVAL      S5DATP = @PDATP                                                  
     C                   EVAL      S5NOPL = @PNOPL                                                  
     C     KCODEPE       SETLL     CODEPE                                                           
     C     KCODEPE       READE     CODEPE                                                           
     C                   DOW       NOT %EOF(CODEPE)                                                 
C1686C                   SELECT                                                                     
C1686 * + 1 PUNTO EXPEDICIÓN                                                                        
C1686C                   WHEN      T3PEXP>1                                                         
b04  C                   IF        S5TPE4 <> '2' And S5LOGE <> P7LOGS                               
FQ726C                   IF        T2LOGI = P7LOGS                                                  
FQ726C                   EVAL      T2LOGU = *BLANKS                                                 
FQ726C                   ELSE                                                                       
FQ726C                   EVAL      T2LOGU = P7LOGS                                                  
FQ726C                   ENDIF                                                                      
     C                   EVAL      S5LOGE = P7LOGS                                                  
C1686C                   IF        T3OPL1<>*BLANKS                                                  
C1686C                   EVAL      S5LOGE=T3OPL1                                                    
C1686C                   ELSE                                                                       
C1686C                   EVAL      S5LOGE=P7LOGS                                                    
C1686C                   ENDIF                                                                      
CR554c                   exsr      CS_set_s5lb2b                                                    
     C                   UPDATE    RCODEPE                                                          
e04  C                   ENDIF                                                                      
C1686 *   1 PUNTO EXPEDICIÓN                                                                        
C1686C                   WHEN      T3PEXP=1                                                         
C1686C                   IF        T3OPL1<>*BLANKS                                                  
C1686C                   EVAL      S5LOGE=T3OPL1                                                    
C1686C                   ELSE                                                                       
C1686C                   EVAL      S5LOGE=P7LOGS                                                    
C1686C                   ENDIF                                                                      
C1686C     KCODEPE0      CHAIN     ED0050W                                                          
C1686C                   EVAL      T2LOGU = S5LOGE                                                  
C1686C                   EVAL      T2ENTD= 0                                                        
C1686C                   EVAL      T2FORZ= 0                                                        
C1686C                   UPDATE    RED0050W                                                         
C1686C                   EVAL      S5TPE4= ' '                                                      
C1686c                   exsr      CS_set_s5lb2b                                                    
C1686C                   UPDATE    RCODEPE                                                          
C1686C                   ENDSL                                                                      
     C     KCODEPE       READE     CODEPE                                                           
e03  C                   ENDDO                                                                      
e02  C                   ENDIF                                                                      
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Recuperar Compañía de MOVEX                                                                 
      **********************************************************************                        
     C     CS_CIASMVX    BEGSR                                                                      
                                                                                                    
      *          Establecer Entorno de Trabajo Movex                                                
     C                   MOVEL     ZXCIAD        @PEDIVI                                            
     C                   CALL      'GX0150'                                                         
     C                   PARM                    @PEDIVI                                            
     C                   PARM      SDSUSR        @PEUSER                                            
     C                   PARM      *BLANKS       @PEVAL                                             
     C                   EVAL      ZXVAL=@PEVAL                                                     
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Recuperar Biblioteca de Movex                                                               
      **********************************************************************                        
     C     CS_MVXLIBL    BEGSR                                                                      
                                                                                                    
     C                   EVAL      LIBLMVX = *BLANKS                                                
                                                                                                    
s01  C                   SELECT                                                                     
     C                   WHEN      %SUBST(PPBIBL:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIBL:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIBL                                                 
     C                   WHEN      %SUBST(PPBIB1:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB1:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB1                                                 
     C                   WHEN      %SUBST(PPBIB2:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB2:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB2                                                 
     C                   WHEN      %SUBST(PPBIB3:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB3:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB3                                                 
     C                   WHEN      %SUBST(PPBIB4:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB4:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB4                                                 
     C                   WHEN      %SUBST(PPBIB5:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB5:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB5                                                 
     C                   WHEN      %SUBST(PPBIB6:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB6:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB6                                                 
     C                   WHEN      %SUBST(PPBIB7:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB7:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB7                                                 
     C                   WHEN      %SUBST(PPBIB8:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB8:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB8                                                 
     C                   WHEN      %SUBST(PPBIB9:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB9:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB9                                                 
     C                   WHEN      %SUBST(PPBI10:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI10:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI10                                                 
     C                   WHEN      %SUBST(PPBI11:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI11:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI11                                                 
     C                   WHEN      %SUBST(PPBI12:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI12:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI12                                                 
     C                   WHEN      %SUBST(PPBI13:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI13:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI13                                                 
     C                   WHEN      %SUBST(PPBI14:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI14:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI14                                                 
     C                   WHEN      %SUBST(PPBI15:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI15:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI15                                                 
     C                   WHEN      %SUBST(PPBI16:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI16:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI16                                                 
     C                   WHEN      %SUBST(PPBI17:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI17:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI17                                                 
     C                   WHEN      %SUBST(PPBI18:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI18:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI18                                                 
     C                   WHEN      %SUBST(PPBI19:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI19:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI19                                                 
     C                   WHEN      %SUBST(PPBI20:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI20:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI20                                                 
     C                   WHEN      %SUBST(PPBI21:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI21:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI21                                                 
     C                   WHEN      %SUBST(PPBI22:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI22:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI22                                                 
     C                   WHEN      %SUBST(PPBI23:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI23:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI23                                                 
     C                   WHEN      %SUBST(PPBI24:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI24:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI24                                                 
     C                   WHEN      %SUBST(PPBI25:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI25:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI25                                                 
     C                   OTHER                                                                      
     C                   EVAL      LIBLMVX = 'MVXJDTA'                                              
e01  C                   ENDSL                                                                      
                                                                                                    
I0184C                   EVAL      LIBLAQA = *BLANKS                                                
I0184                                                                                               
I0184C                   SELECT                                                                     
