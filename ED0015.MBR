      **************************************************************                                
      * Eliminar trazabilidad e Cabecera de pedido ventas          *                                
      * si corresponde                                             *                                
      *------------------------------------------------------------*                                
     C     CS_DELTRACAB  BEGSR                                                                      
      *                                                                                             
     C                   EVAL      *IN50=*OFF                                                       
     C                   EVAL      S5CIAS=@PCIAS                                                    
     C                   EVAL      S5DLGA=@PDLGA                                                    
     C                   EVAL      S5NPCO=@PNPCO                                                    
     C                   EVAL      S5TPED=@PTPED                                                    
     C                   EVAL      S5DATP=@PDATP                                                    
     C                   EVAL      S5NOPL=@PNOPL                                                    
     C                   EVAL      S5LINE=0                                                         
     C     KCODEPE       SETLL     CODEPE                                                           
     C     KCODEPE0      READE(N)  CODEPE                                                           
     C                   DOW       NOT %EOF(CODEPE)                                                 
     C                   IF        S5NP01<>*BLANKS                                                  
     C                   EVAL      *IN50=*ON                                                        
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
     C     KCODEPE0      READE(N)  CODEPE                                                           
     C                   ENDDO                                                                      
      *                                                                                             
     C                   IF        *IN50=*OFF                                                       
     C                   EVAL      S0CIAS=@PCIAS                                                    
     C                   EVAL      S0DLGA=@PDLGA                                                    
     C                   EVAL      S0NPCO=@PNPCO                                                    
     C                   EVAL      S0TPED=@PTPED                                                    
     C                   EVAL      S0DATP=@PDATP                                                    
     C                   EVAL      S0NOPL=@PNOPL                                                    
     C     KCOCAPE       CHAIN     COCAPE                                                           
     C                   IF        %FOUND(COCAPE)                                                   
     C                   EVAL      S0CI01=*BLANKS                                                   
     C                   EVAL      S0PR01=*BLANKS                                                   
     C                   EVAL      S0DL01=*BLANKS                                                   
     C                   EVAL      S0TP01=*BLANKS                                                   
     C                   EVAL      S0NP01=*BLANKS                                                   
     C                   EVAL      S0DA01=0                                                         
     C                   EVAL      S0NO01=0                                                         
     C                   UPDATE    RCOCAPE                                                          
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **************************************************************                                
      * Enviar cabecera de pedido cuando sean altas               *                                 
      *------------------------------------------------------------*                                
     C     CS_SNDALTCAB  BEGSR                                                                      
      *                                                                                             
     C                   EVAL      S5CIAS=@PCIAS                                                    
     C                   EVAL      S5DLGA=@PDLGA                                                    
     C                   EVAL      S5NPCO=@PNPCO                                                    
     C                   EVAL      S5TPED=@PTPED                                                    
     C                   EVAL      S5DATP=@PDATP                                                    
     C                   EVAL      S5NOPL=@PNOPL                                                    
     C                   EVAL      S5LINE=0                                                         
     C     KCODEPE       SETLL     CODEPE                                                           
     C     KCODEPE0      READE(N)  CODEPE                                                           
     C                   DOW       NOT %EOF(CODEPE)                                                 
      *                                                                                             
      * Si es entrega directa, miramos la/las líneas de compra                                      
      *                                                                                             
     C                   IF        S5TPE4='2'                                                       
      *                                                                                             
03050C**                 EVAL      T0CIAS=@PCIAS                                                    
03050C**                 EVAL      T0DLGA=@PDLGA                                                    
03050C**                 EVAL      T0NPCO=@PNPCO                                                    
03050C**                 EVAL      T0TPED=@PTPED                                                    
03050C**                 EVAL      T0DATP=@PDATP                                                    
03050C**                 EVAL      T0NOPL=@PNOPL                                                    
03050C**                 EVAL      T0LINE=@PLINE                                                    
03050C                   EVAL      T0CIAS=S5CIAS                                                    
03050C                   EVAL      T0DLGA=S5DLGA                                                    
03050C                   EVAL      T0NPCO=S5NPCO                                                    
03050C                   EVAL      T0TPED=S5TPED                                                    
03050C                   EVAL      T0DATP=S5DATP                                                    
03050C                   EVAL      T0NOPL=S5NOPL                                                    
03050C                   EVAL      T0LINE=S5LINE                                                    
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C     KEDTRLP00     READE     EDTRLP00                                                         
     C                   DOW       NOT %EOF(EDTRLP00)                                               
      *                                                                                             
      * Si el campo C0TOLI=*BLANKS quiere decir que no se ha enviado                                
      *                                                                                             
     C                   EVAL      C0CIAS=T0CIA1                                                    
     C                   EVAL      C0PRVR=T0PRVR                                                    
     C                   EVAL      C0DLGA=T0DLG1                                                    
     C                   EVAL      C0TPED=T0TPE1                                                    
     C                   EVAL      C0NPCO=T0NPC1                                                    
     C                   EVAL      C0DATP=T0DAT1                                                    
     C                   EVAL      C0NOPL=T0NOP1                                                    
     C     KPUCAPE       CHAIN(N)  PUCAPE                                                           
     C                   IF        %FOUND(PUCAPE) AND C0TOLI=*BLANKS                                
11050 *                                                                                             
11050 *  Activaremos el campo de CHEKSUM                                                            
11050 *                                                                                             
11050C                   EXSR      CS_CHKSUM                                                        
      *                                                                                             
11050C**                 EVAL      ZXOPC0='1'                                                       
     C                   EXSR      CS_SENDCAB                                                       
FQ604C                   EXSR      CS_SENDOBS                                                       
C1579 *                                                                                             
C1579 * Miramos si el pedido es de procedencia Poolweb                                              
C1579 *                                                                                             
C1579C                   EXSR      CS_POOLWEB                                                       
C1579                                                                                               
C1579 * Poolweb: Generación de fichero CSV con pedido compra a enviar.                              
C1579 * Movemos ' ' a @PEERRO para indicarle al PW0010 que el pedido                                
C1570 * viene de confirmación automática.                                                           
C1579 *                                                                                             
C1983C*Condicionar llamada a PW0011 Si no hay lineas sin precio                                     
C1983C* ZXPWP0=0                                                                                    
C1983c*                  if        %found(cocape) and zxpweb='1'                                    
C1983C                   if        %found(cocape) and zxpweb='1'                                    
C1983C                             AND ZXPWP0='0'                                                   
C1579C                   move      c0cias        @pcias1                                            
C1579C                   EVAL      @PEDLGA=C0DLGA                                                   
C1579C                   EVAL      @PENPCO=C0NPCO                                                   
C1579C                   EVAL      @PETPED=C0TPED                                                   
C1579C                   move      c0datp        @pdatp1                                            
C1579C                   move      c0nopl        @pnopl1                                            
C1579C                                                                                              
C1579C                   CALL      'PW0011CL'                                                       
C1579C                   PARM                    @PCIAS1                                            
C1579C                   PARM                    @PEDLGA                                            
C1579C                   PARM                    @PENPCO                                            
C1579C                   PARM                    @PETPED                                            
C1579C                   PARM                    @PDATP1                                            
C1579C                   PARM                    @PNOPL1                                            
C1579C                   PARM      ' '           @PEERRO                                            
C1579C                   endif                                                                      
C1579 *                                                                                             
      *                                                                                             
     C     KPUCAPE       CHAIN     PUCAPE                                                           
     C                   IF        %FOUND(PUCAPE) AND C0TOLI=*BLANKS                                
     C                   MOVE      ZXCHKS        C0TOLI                                             
C1983C*Si se han detectado precios a 0(ZXPWP0='1)cambiar status a '10'                              
C1983C                   IF        ZXPWP0='1' AND ZXPWEB='1'                                        
C1983C                   EVAL      C0STCO='10'                                                      
C1983C                   ENDIF                                                                      
     C                   UPDATE    RPUCAPE                                                          
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C     KEDTRLP00     READE     EDTRLP00                                                         
     C                   ENDDO                                                                      
      *                                                                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C     KCODEPE0      READE(N)  CODEPE                                                           
     C                   ENDDO                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **************************************************************                                
      * Incidencias en el pedido de compras                        *                                
      *------------------------------------------------------------*                                
     C     CS_INCICOMP   BEGSR                                                                      
      *                                                                                             
      * Comprobamos el fichero resultante del algoritmo porque                                      
      * si hay incidencias genero un e-mail y no confirmo el pedido                                 
      * de compras                                                                                  
      *                                                                                             
     C                   EVAL      ZXNOCONF=0                                                       
      *                                                                                             
     C                   EVAL      T2CIAS=@PCIAS                                                    
     C                   EVAL      T2DLGA=@PDLGA                                                    
     C                   EVAL      T2NPCO=@PNPCO                                                    
     C                   EVAL      T2TPED=@PTPED                                                    
     C                   EVAL      T2DATP=@PDATP                                                    
     C                   EVAL      T2NOPL=@PNOPL                                                    
     C                   EVAL      T2LINE=@PLINE                                                    
     C     KED0050W      CHAIN     ED0050W                                                          
     C                   IF        %FOUND(ED0050W)                                                  
     C                             AND T2ENTD=1 AND (T2INCI='002' OR                                
     C                             T2INCI='003' OR T2INCI='005')                                    
     C                   EVAL      ZXNOCONF=1                                                       
C1983**Si pedido PoolWeb no confirmar                                                               
C1983C                   IF        ZXPWEB='1'                                                       
C1983C                   EVAL      ZXNOCONF=0                                                       
C1983C                   ENDIF                                                                      
      *                                                                                             
15612C                   IF        ZXPRIVEZ='0'                                                     
15612                                                                                               
     C                   SELECT                                                                     
     C                   WHEN      T2INCI='002'                                                     
     C                   EVAL      @FDEDAU='022'                                                    
     C                   WHEN      T2INCI='003'                                                     
     C                   EVAL      @FDEDAU='023'                                                    
     C                   WHEN      T2INCI='005'                                                     
     C                   EVAL      @FDEDAU='024'                                                    
     C                   ENDSL                                                                      
      *                                                                                             
     C                   MOVEL(P)  T2DLGA        @FDDLGA                                            
     C                   MOVEL(P)  T2NPCO        @FDNPCO                                            
     C                   MOVEL(P)  T2TPED        @FDTPED                                            
      *                                                                                             
     C                   CALL      'ED0100'                                                         
     C                   PARM      T2CIAS        @FDCIAS                                            
     C                   PARM                    @FDDLGA                                            
     C                   PARM                    @FDNPCO                                            
     C                   PARM                    @FDTPED                                            
     C                   PARM      T2DATP        @FDDATP                                            
     C                   PARM      T2NOPL        @FDNOPL                                            
     C                   PARM      T2LINE        @FDLINE                                            
     C                   PARM                    @FDCIA2                                            
     C                   PARM                    @FDDLG2                                            
     C                   PARM                    @FDNPC2                                            
     C                   PARM                    @FDTPE2                                            
     C                   PARM                    @FDDAT2                                            
     C                   PARM                    @FDNOP2                                            
     C                   PARM                    @FDLIN2                                            
     C                   PARM      1             @FDLOGI                                            
     C                   PARM      0             @FDORIG                                            
     C                   PARM                    @FDEDAU                                            
     C                   PARM                    @FDERAV                                            
     C                   PARM                    @FDTEXT                                            
     C                   PARM                    @FDDATO                                            
     C                   PARM      1             @FDWAUD                                            
     C                   PARM      0             @FDCANT                                            
15612C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
FQ709 **************************************************************                                
FQ709 * COMMON SUBRUTINE (CS_) :                                   *                                
FQ709 * Recuperar CATERORIA ROTACIÓN CONSERVARLA PARA ANALISIS TCT *                                
FQ709 *           PER COMPRES                                      *                                
FQ709 *------------------------------------------------------------*                                
FQ709C     CS_BUSROTNEWC BEGSR                                                                      
FQ709 * BLANQUEAMOS VALORES A BUSCAR                                                                
FQ709C                   EVAL      C5CROT=*BLANKS                                                   
FQ709C                   EVAL      C5CROP=*BLANKS                                                   
FQ709C                   EVAL      C5CROTA=*BLANKS                                                  
FQ709C                   EVAL      C5CROTB=*BLANKS                                                  
FQ709C                   EVAL      C5CROTC=*BLANKS                                                  
FQ709C                                                                                              
FQ709C                   EVAL      @QCIAS=C5CIAS                                                    
FQ709C                   EVAL      @QDLGA=C5DLGA                                                    
FQ709C                   EVAL      @QLOGE=C5LOGE                                                    
FQ709C                   EVAL      @QARTI=C5ARTI                                                    
FQ709C                   EVAL      @QVARI=C5VARI                                                    
FQ709C                   EVAL      @QMODE=C5MODE                                                    
FQ709C                   EVAL      @QTCOJ=C5TCOJ                                                    
FQ709C                   EVAL      @QCROT=*BLANKS                                                   
FQ709C                   EVAL      @QCROTA=*BLANKS                                                  
FQ709C                   EVAL      @QCROTB=*BLANKS                                                  
FQ709C                   EVAL      @QCROTC=*BLANKS                                                  
FQ709                                                                                               
CR964                                                                                               
CR964C                   EVAL      @QLOFD=' '                                                       
CR964C                   IF        C5TPE4='2'                                                       
CR964C                   EVAL      @QLOFD='1'                                                       
CR964C                   ENDIF                                                                      
FQ709C                   CALL      'CO2755'                                                         
FQ709C                   PARM                    @QCIAS                                             
FQ709C                   PARM                    @QDLGA                                             
FQ709C                   PARM                    @QLOGE                                             
FQ709C                   PARM                    @QARTI                                             
FQ709C                   PARM                    @QVARI                                             
FQ709C                   PARM                    @QMODE                                             
FQ709C                   PARM                    @QTCOJ                                             
FQ709C                   PARM                    @QCROT                                             
FQ709C                   PARM                    @QCROTA                                            
FQ709C                   PARM                    @QCROTB                                            
FQ709C                   PARM                    @QCROTC                                            
CR964C                   PARM                    @QLOFD                                             
FQ709 *                                                                                             
FQ709C                   EVAL      C5CROT=%SUBST(@QCROT:1:1)                                        
FQ709C                   EVAL      C5CROP=%SUBST(@QCROT:2:1)                                        
FQ709 *                                                                                             
FQ709C                   IF        C5TCOJ='1'                                                       
FQ709C                   MOVE      @QCROTA       C5CROTA                                            
FQ709C                   MOVE      @QCROTB       C5CROTB                                            
FQ709C                   MOVE      @QCROTC       C5CROTC                                            
FQ709C                   ENDIF                                                                      
FQ709                                                                                               
FQ709C                   ENDSR                                                                      
      ******************************************************************                            
C1579 * MIRAMOS SI EL PEDIDO ES POOLWEB Y RECUPERAMOS EL PROVEEDOR                                  
C1579 **********************************************************************                        
C1579C     CS_POOLWEB    BEGSR                                                                      
C1579 *                                                                                             
C1579C                   eval      zxpweb='0'                                                       
C1579 *                                                                                             
F-2OL *_Nueva rutina para recuperar el proveedor del campo                                          
F-2OL *___________________(MSSTOK.M1PRVR), ___________________________                              
F-2OLC*OL187             exsr      SRrecu                                                           
OL187                    zxprvr=srrecu(s5arti:s5vari:s5mode);                                       
C1579 * Recuperamos el proveedor del artículo (si luego vemos que el                                
C1579 * pedido es de procedencia Poolweb, lo sustituiremos por el que                               
C1579 * tengamos definido en la tabla).                                                             
C1579 *                                                                                             
F-2OLc                   if        ZXPRVR = *blanks                                                 
C1579C                   eval      m5cias=s5cias                                                    
C1579C                   eval      m5arti=s5arti                                                    
C1579C                   eval      m5vari=s5vari                                                    
C1579C                   eval      m5mode=s5mode                                                    
C1579C     kmsarti00     chain     msarti00                                                         
C1579 *                                                                                             
C1579c*OL187             if        %found(msarti00)                                                 
OL187c                   if        %found(msarti00) AND ZXPRVR=*BLANKS                              
C1579c                   movel     m5prvr        zxprvr                                             
C1579c                   endif                                                                      
F-2OLc                   ENDIF                                                                      
C1579 *                                                                                             
C1579 * Para saber si es un pedido Poolweb,lo buscamos en la tabla                                  
C1579 * PWEB con la procedencia del pedido, y además nos dará cual                                  
C2579 * es el proveedor                                                                             
C1579 *                                                                                             
C1579C                   eval      s0cias=@pcias                                                    
C1579C                   eval      s0dlga=@pdlga                                                    
C1579C                   eval      s0npco=@pnpco                                                    
C1579C                   eval      s0tped=@ptped                                                    
C1579C                   eval      s0datp=@pdatp                                                    
C1579C                   eval      s0nopl=@pnopl                                                    
C1579C     kcocape       chain(n)  cocape                                                           
C1579 *                                                                                             
C1579 * Para saber si es un proveedor Poolweb,lo buscamos en la tabla                               
C1579 * PWEB con la procedencia del pedido.                                                         
C1579 *                                                                                             
C1579C                   if        %found(cocape)                                                   
C1579C                   eval      pecias=@pcias                                                    
C1579C                   eval      pectab='PWEB'                                                    
C1579C                   eval      peclta=s0pped                                                    
C1579C     kpmtabd       chain     pmtabd                                                           
C1579                                                                                               
C1579C                   if        %found(pmtabd)                                                   
C1579C                   eval      zxpweb='1'                                                       
C1579C                   movel     pedesc        zxprvr                                             
C1579C                   endif                                                                      
C1579                                                                                               
C1579C                   endif                                                                      
C1579                                                                                               
C1579C                   ENDSR                                                                      
C4137**************************************************************                                
C4137* Control excepciones                                        *                                
C4137**************************************************************                                
C4406c*C4137     cs_provstok   begsr                                                                
C4137*                                                                                             
C4406c*C4137             eval      t3cias = @pcias                                                  
C4406c*C4137             eval      t3dlga = @pdlga                                                  
C4406c*C4137     kedparm       chain     edparm                                                     
C4406c*C4137             if        %found(edparm) and t3alpr = '1' and                              
C4406c*C4137                       m0PRVR <> *BLANKS                                                
C4406c*C4137             eval      zxprvr_dom = m0prvr                                              
C4406c*C4137             eval      zxprvr     = m0prvr                                              
C4406c*C4137             endif                                                                      
C4137*                                                                                             
C4406c*C4137             endsr                                                                      
C4137**************************************************************                                
C4137* Control excepciones                                        *                                
C4137**************************************************************                                
C4137c     cs_eiexce     begsr                                                                      
C4137*                                                                                             
C4137c                   select                                                                     
C4137c                   when      zxexcepcion = 1                                                  
C4137c                   eval      z0file = 'ED0015'                                                
C4137c                   eval      z0cias = @pcias                                                  
C4137c                   eval      z0pais = 'FD'                                                    
C4137c                   eval      z0grp2 = 'OPCAL'                                                 
C4137c                   eval      z0cust = %subst(c9cfac: 1: 10)                                   
C4137c                   eval      z0camp = *blanks                                                 
C4137c     keiexce       chain     eiexce                                                           
C4137c                   if        %found(eiexce)                                                   
C4137c                   exsr      cs_tr0435                                                        
C4406c                   else                                                                       
C4406c                   clear                   c0edic                                             
C4406c                   clear                   c0fedi                                             
C4406c                   clear                   c0uedi                                             
C4137c                   endif                                                                      
C4137c                   endsl                                                                      
C4137*                                                                                             
C4137c                   endsr                                                                      
C4137**************************************************************                                
C4137* Valida si grabamos TR0435                                  *                                
C4137**************************************************************                                
C4137c     cs_tr0435     begsr                                                                      
C4137*                                                                                             
C4137c                   eval      c0edic = '1'                                                     
C4137c                   eval      c0fedi = %char(*date)                                            
C4137c                   eval      c0uedi = sdsusr                                                  
C4137c                   write     rtr0435                              55                          
C4137*                                                                                             
C4137c                   endsr                                                                      
I0200 ******************************************************************                            
I0200 * Buscamos si el país de la dirección de entrega es de exportación                            
I0200 **********************************************************************                        
I0200C     CS_EXPORT     BEGSR                                                                      
I0200 *                                                                                             
I0200C                   EVAL      ZXEXPORT=' '                                                     
I0200 *                                                                                             
I0200C                   EVAL      S2CIAS=S0CIAS                                                    
I0200C                   EVAL      S2DLGA=S0DLGA                                                    
I0200C                   EVAL      S2NPCO=S0NPCO                                                    
I0200C                   EVAL      S2TPED=S0TPED                                                    
I0200C                   EVAL      S2DATP=S0DATP                                                    
I0200C                   EVAL      S2NOPL=S0NOPL                                                    
I0200C                   EVAL      S2CDIR='1'                                                       
I0200C     KCODIPE       CHAIN     CODIPE                                                           
I0200C                   IF        %FOUND(CODIPE)                                                   
I0200C                   EVAL      S0CIAS=S2CIAS                                                    
I0200C                   EVAL      S0PAIS=S2PAIS                                                    
I0200C     KMSPAIS       CHAIN     MSPAIS                                                           
I0200C                   IF        %FOUND(MSPAIS)                                                   
I0200C                   IF        MEPCEE<>'1'                                                      
I0200C                   EVAL      ZXEXPORT='1'                                                     
I0200C                   ENDIF                                                                      
I0200C                   ENDIF                                                                      
I0200C                   ENDIF                                                                      
I0200 *                                                                                             
I0200C                   ENDSR                                                                      
      ******************************************************************                            
F-2OL *   Recuperar almacén a partir de la logística del pedido venta                               
F-2OL **********************************************************************                        
OL187C*    SRrecu        BEGSR                                                                      
OL187   dcl-proc SRrecu;                                                                            
OL187   dcl-pi *n like(m1prvr);                                                                     
OL187    parti like(s5arti);                                                                        
OL187    pvari like(s5vari);                                                                        
OL187    pmode like(s5mode);                                                                        
OL187   end-pi;                                                                                     
OL187   dcl-pr getenv pointer extproc('getenv');                                                    
OL187     *n pointer value options(*string:*trim);                                                  
OL187   end-pr;                                                                                     
OL187   dcl-s EnvValue like(s5loge) inz;                                                            
E7153   dcl-s MagaPedido like(m1maga) inz;                                                          
OL187                    gprop=*off;                                                                
                                                                                                    
F-2OLC                   eval      @pcias = s5cias                                                  
E7153 *F-2OLC                   eval      @palma = s5loge                                           
E7153                    EnvValue = s5loge;                                                         
F-2OLC                   eval      @ptipo = '1'                                                     
F-2OLC                   eval      @pdlga = s5dlga                                                  
OL187                                                                                               
OL187   // Si estem traient la línia d'ED i és un Kit hem de recuperar la logística que tenia       
OL187      if @PEDAU = '009' and s5tcoj = '4';                                                      
OL187        EnvValue = %str(getenv('ED0015_LOGOLD'));                                              
OL187        if EnvValue <> *blanks;                                                                
OL187          @palma = EnvValue;                                                                   
OL187        endif;                                                                                 
OL187      endif;                                                                                   
E7153                    chain (s5cias:EnvValue) msalma05;                                          
E7153                    if %found(msalma05);                                                       
E7153                      MagaPedido = m0maga;                                                     
E7153                    endif;                                                                     
E7153                    @palma = MagaPedido;                                                       
F-2OL *                                                                                             
F-2OLC                   CALL      'MM1411'                                                         
F-2OLC                   PARM                    @PCIAS                                             
F-2OLC                   PARM                    @PALMA                                             
F-2OLC                   PARM                    @PTIPO                                             
F-2OLC                   PARM                    @PDLGA                                             
F-2OLC                   PARM      *blanks       @PRESP                                             
F-2OL *                                                                                             
F-2OLC                   if        @PRESP <>*blanks                                                 
E7153                      m1maga = @PRESP;                                                         
E7153                    else;                                                                      
E7153                      m1maga = MagaPedido;                                                     
E7153                    endif;                                                                     
F-2OLC                                                                                              
F-2OLC                   EVAL      M5CIAS = S5CIAS                                                  
E7153 *F-2OLC                   EVAL      M1MAGA = @PRESP                                           
F-2OLC*OL187             EVAL      M1ARTI = S5ARTI                                                  
F-2OLC*OL187             EVAL      M1VARI = S5VARI                                                  
F-2OLC*OL187             EVAL      M1MODE = S5MODE                                                  
OL187C                   EVAL      M1ARTI = pARTI                                                   
OL187C                   EVAL      M1VARI = pVARI                                                   
OL187C                   EVAL      M1MODE = pMODE                                                   
F-2OL *                                                                                             
F-2OLc     KMSSTOK       CHAIN     MSSTOK                             90                            
F-2OLC                   IF        %FOUND                                                           
OL187                    if m1prop='1' or m1prop='2';                                               
OL187                      gprop =*on;                                                              
OL187                    endif;                                                                     
F-2OLC                   IF        m1prvr <> *blanks                                                
F-2OLC*                  movel     M1PRVR        ZXPRVR                                             
OL187                    return M1PRVR;                                                             
F-2OLC                   ENDIF                                                  ECSTK <= *ZEROS     
F-2OLC                   ENDIF                                                  ECSTK <= *ZEROS     
F-2OL * Acceder a MSSTOK con clave                                                                  
F-2OL *                                                                                             
OL187                                                                                               
OL187    // Si NO tenim M1PRVR informat cerquem en MSALMA                                           
OL187         chain (s5cias:m1maga) msalma;                                                         
OL187         if %found(msalma) and m0tal1='8' and m0prvr <> *blanks;                               
OL187           return m0prvr;                                                                      
OL187         endif;                                                                                
E7153 *F-2OLC                   endif                                                               
OL187                    return *blanks;                                                            
OL187   end-proc;                                                                                   
F-2OL **********************************************************************                        
F-2OLC*OL187             ENDSR                                                                      
      ******************************************************************                            
** CTDATA C                                                                                         
'                                                                                                   
