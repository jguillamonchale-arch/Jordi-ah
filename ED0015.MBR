      **********************************************************************                        
      * Rutina principal                                                                            
      **********************************************************************                        
      *                                                                                             
     C                   EVAL      S5CIAS=@PCIAS                                                    
     C                   EVAL      S5DLGA=@PDLGA                                                    
     C                   EVAL      S5NPCO=@PNPCO                                                    
     C                   EVAL      S5TPED=@PTPED                                                    
     C                   EVAL      S5DATP=@PDATP                                                    
     C                   EVAL      S5NOPL=@PNOPL                                                    
     C                   EVAL      S5LINE=@PLINE                                                    
     C                   EVAL      S0CIAS=@PCIAS                                                    
     C                   EVAL      S0DLGA=@PDLGA                                                    
     C                   EVAL      S0NPCO=@PNPCO                                                    
     C                   EVAL      S0TPED=@PTPED                                                    
     C                   EVAL      S0DATP=@PDATP                                                    
     C                   EVAL      S0NOPL=@PNOPL                                                    
03060C                   TIME                    ZXHORA                                             
      *                                                                                             
     C                   IF        @PFIN<>1                                                         
PD889C                   EVAL      ZXCONFIRMADO=' '                                                 
PD889C     KCOCAPE       CHAIN(N)  COCAPE                                                           
PD889C*C5442             IF        %FOUND AND S0STCO>='20'                                          
C5442C                   IF        %FOUND AND S0STCO>='2P'                                          
PD933C                   IF        ZXPECABE='1'                                                     
PD933C                   EVAL      ZXPEDCON=0                                                       
PD933C                   ELSE                                                                       
PD933C                   EVAL      ZXPEDCON=1                                                       
PD933C                   ENDIF                                                                      
PD889C                   EVAL      ZXCONFIRMADO='1'                                                 
PD889C                   ENDIF                                                                      
      *                                                                                             
      * Si nos llega 1 línea                                                                        
      *                                                                                             
     C                   IF        @PLINE<>0                                                        
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
     C                   IF        %FOUND(CODEPE)                                                   
     C                             AND S5TLIN<'1'                                                   
     C                             AND S5ARTI<>ZXARTPOR                                             
     C                   EXSR      CS_MAIN                                                          
15040 * Si nos llega 1 alta de linea de un pedido ya confirmado y                                   
15040 * hemos grabado cabecera porque es un nuevo proveedor envio                                   
15040 * TR0035                                                                                      
15040C                   IF        ZXMASL=1 And ZXNEWC=1                                            
11050C                   EVAL      ZXOPC0='1'                                                       
15040C                   EXSR      CS_SNDALTCAB                                                     
15040C                   ENDIF                                                                      
11050 *                                                                                             
11050 * Si nos llega 1 alta de linea de un pedido ya confirmado y                                   
11050 * aunque ya se grabó cabecera, se vuelve a enviar para actualizar                             
11050 * CHKSUM                                                                                      
11050C                   IF        ZXMASL=1 AND ZXNEWC=0                                            
11050C                   EVAL      ZXOPC0='2'                                                       
11050C                   EXSR      CS_SNDALTCAB                                                     
11050C                   ENDIF                                                                      
11050 *                                                                                             
     C                   ENDIF                                                                      
      *                                                                                             
      * Si nos llega sin línea hacemos todo el pedido                                               
      *                                                                                             
     C                   ELSE                                                                       
     C     KCODEPE       SETLL     CODEPE                                                           
     C     KCODEPE0      READE(N)  CODEPE                                                           
     C                   DOW       NOT %EOF(CODEPE)                                                 
     C                   IF        S5TLIN<'1'                                                       
     C                             AND S5ARTI<>ZXARTPOR                                             
     C                   EVAL      @PLINE=S5LINE                                                    
     C                   EXSR      CS_MAIN                                                          
     C                   ENDIF                                                                      
     C     KCODEPE0      READE(N)  CODEPE                                                           
     C                   ENDDO                                                                      
      *                                                                                             
     C                   ENDIF                                                                      
      *                                                                                             
      * Comprobar trazabilidad de la cabecera de Ventas                                             
      *                                                                                             
     C                   EXSR      CS_DELTRACAB                                                     
      *                                                                                             
      * Enviar las cabeceras de compra de todos los pedidos ED                                      
      * cuando ya tenga todas las líneas (@PFIN=1)                                                  
      *                                                                                             
     C                   ELSE                                                                       
In199C                   IF        @PEDAU<>'011'                                                    
11050C                   EVAL      ZXOPC0='1'                                                       
     C                   EXSR      CS_SNDALTCAB                                                     
In199C                   ENDIF                                                                      
     C                   ENDIF                                                                      
