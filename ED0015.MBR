      **********************************************************************                        
      * Dirección de envío directa cliente                                                          
      **********************************************************************                        
     C     CS_PUDIPE1    BEGSR                                                                      
      *                                                                                             
      * Tenemos una variable para controlar que sólo se envie una vez                               
      *                                                                                             
     C                   EVAL      S2CIAS=S0CIAS                                                    
     C                   EVAL      S2DLGA=S0DLGA                                                    
     C                   EVAL      S2NPCO=S0NPCO                                                    
     C                   EVAL      S2TPED=S0TPED                                                    
     C                   EVAL      S2DATP=S0DATP                                                    
     C                   EVAL      S2NOPL=S0NOPL                                                    
     C                   EVAL      S2CDIR='1'                                                       
     C     KCODIPE       CHAIN     CODIPE                                                           
     C                   IF        %FOUND(CODIPE)                                                   
      *                                                                                             
     C                   EVAL      S0CIAS=S2CIAS                                                    
     C                   EVAL      S0PAIS=S2PAIS                                                    
     C     KMSPAIS       CHAIN     MSPAIS                                                           
     C                   IF        %FOUND(MSPAIS)                                                   
      *                                                                                             
     C                   EVAL      C2CIAS=C0CIAS                                                    
     C                   EVAL      C2DLGA=C0DLGA                                                    
     C                   EVAL      C2NPCO=C0NPCO                                                    
     C                   EVAL      C2TPED=C0TPED                                                    
     C                   EVAL      C2DATP=C0DATP                                                    
     C                   EVAL      C2NOPL=C0NOPL                                                    
     C                   EVAL      C2CDIR='1'                                                       
     C     KPUDIPE       CHAIN     PUDIPE                                                           
      *                                                                                             
     C                   EVAL      C2TDVA='1'                                                       
     C                   EVAL      C2RAOS=S2RAOS                                                    
     C                   EVAL      C2RAO2=S2RAO2                                                    
     C                   EVAL      C2DPTO=S2DPTO                                                    
     C                   EVAL      C2DIRE=S2DIRE                                                    
     C                   EVAL      C2DIR2=S2DIR2                                                    
     C                   EVAL      C2POBL=S2POBL                                                    
     C                   EVAL      C2POST=S2POST                                                    
     C                   EVAL      C2TELE=S2TELE                                                    
     C                   EVAL      C2TEL2=S2TEL2                                                    
     C                   EVAL      C2TLEX=S2TLEX                                                    
     C                   EVAL      C2TFAX=S2TFAX                                                    
     C                   EVAL      C2EMAI=S2EMAI                                                    
     C                   EVAL      C2PAIS=S2PAIS                                                    
     C                   EVAL      C2PEGE=S2PEGE                                                    
     C                   EVAL      C2OB50=S2OB50                                                    
     C                   EVAL      C2OB51=S2OB51                                                    
     C                   EVAL      C2TTTA=S2TTTA                                                    
     C                   EVAL      C2EMAI=S2EMAI                                                    
      *                                                                                             
     C                   IF        MEPCEE='1'                                                       
     C                   EVAL      C2NIFF=S0NIFC                                                    
     C                   IF        C2NIFF=*BLANKS                                                   
     C                   EVAL      C2NIFF=S0NIFI                                                    
     C                   ENDIF                                                                      
     C                   ELSE                                                                       
     C                   EVAL      C2NIFF=S0NIFI                                                    
     C                   IF        C2NIFF=*BLANKS                                                   
     C                   EVAL      C2NIFF=S0NIFC                                                    
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        %FOUND(PUDIPE)                                                   
     C                   UPDATE    RPUDIPE                                                          
     C                   EVAL      ZXOPC0='2'                                                       
     C                   IF        @PEDAU='001' OR @PEDAU='002'                                     
     C                             OR @PEDAU='010'                                                  
     C                   EVAL      ZXOPC0='1'                                                       
     C                   ENDIF                                                                      
     C                   ELSE                                                                       
     C                   EVAL      C2EVOL=ZXEVOL                                                    
     C                   EVAL      C2EVPR=ZXEVPR                                                    
     C                   WRITE     RPUDIPE                                                          
     C                   EVAL      ZXOPC0='1'                                                       
     C                   ENDIF                                                                      
      *                                                                                             
     C                   EXSR      CS_SENDDIR                                                       
      *                                                                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **************************************************************                                
      * Grabacion observaciones                                    *                                
      *------------------------------------------------------------*                                
     C     CS_OBSERV     BEGSR                                                                      
      *                                                                                             
      * Grabo las observaciones del pedido de ventas si hay                                         
      *                                                                                             
     C                   EVAL      S0CIAS=S5CIAS                                                    
     C                   EVAL      S0DLGA=S5DLGA                                                    
     C                   EVAL      S0NPCO=S5NPCO                                                    
     C                   EVAL      S0TPED=S5TPED                                                    
     C                   EVAL      S0DATP=S5DATP                                                    
     C                   EVAL      S0NOPL=S5NOPL                                                    
     C                   EVAL      S0LINP=S5LINE                                                    
     C                   Z-ADD     0             ZXLINE            3 0                              
     C     KCOOBPE       SETLL     COOBPE                                                           
     C     KCOOBPE       READE     COOBPE                                                           
     C                   DOW       NOT %EOF(COOBPE)                                                 
      *                                                                                             
     C                   IF        S0T1OB=' ' OR S0T1OB='0' OR S0T1OB='4'                           
I0161C                             OR S0T1OB='1'                                                    
      *                                                                                             
     C                   EVAL      ZXLINE=ZXLINE+1                                                  
     C                   EVAL      C0LINE=ZXLINE                                                    
     C                   EVAL      C0CIAS=C5CIAS                                                    
     C                   EVAL      C0LINP=C5LINE                                                    
      *                                                                                             
     C                   EVAL      C0T1OB=S0T1OB                                                    
     C                   EVAL      C0T2OB=S0T2OB                                                    
     C                   EVAL      C0T3OB=S0T3OB                                                    
     C                   EVAL      C0IDIO=S0IDIO                                                    
     C                   EVAL      C0LINE=S0LINE                                                    
     C                   EVAL      C0MSGE=S0MSGE                                                    
     C                   EVAL      C0IDIB=S0IDIB                                                    
     C                   EVAL      C0DAT8=*DATE                                                     
     C                   TIME                    C0HORA                                             
     C                   EVAL      C0USUA=ZZUSUA                                                    
     C                   EVAL      C0PANT=SDSJOB                                                    
     C                   EVAL      C0TLI1=S0TLI1                                                    
     C                   EVAL      C0TLI2=S0TLI2                                                    
     C                   EVAL      C0TLI3=S0TLI3                                                    
     C                   EVAL      C0OB50=S0OB50                                                    
     C                   EVAL      C0MRCA=S0MRCA                                                    
     C                   EVAL      C0DAT1=C0DAT8                                                    
     C                   EVAL      C0EVOL=ZXEVOL                                                    
     C                   EVAL      C0EVPR=ZXEVPR                                                    
     C                   MOVEL     S5CIAS        C0CI02                                             
     C                   EVAL      C0DL02=S5DLGA                                                    
     C                   EVAL      C0NP02=S5NPCO                                                    
     C                   EVAL      C0TP02=S5TPED                                                    
     C                   EVAL      C0DA02=S5DATP                                                    
     C                   EVAL      C0NO02=S5NOPL                                                    
     C                   WRITE     RPUOBPE                                                          
FQ604C***                EVAL      ZXOPC0='1'                                                       
FQ604C***                EXSR      CS_SENDOBS                                                       
      *                                                                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C     KCOOBPE       READE     COOBPE                                                           
     C                   ENDDO                                                                      
      *                                                                                             
      * Ahora de artículo                                                                           
      *                                                                                             
     C     KMSOBAR       SETLL     MSOBAR                                                           
     C     KMSOBAR       READE     MSOBAR                                                           
     C                   DOW       NOT %EOF(MSOBAR)                                                 
      *                                                                                             
     C                   EVAL      C0CIAS=C5CIAS                                                    
     C                   EVAL      C0LINP=C5LINE                                                    
     C                   EVAL      C0LINE=M5LINE                                                    
     C     KPUOBPE       CHAIN     PUOBPE                                                           
     C                   IF        NOT %FOUND(PUOBPE) AND (M5T1OB=' ' OR                            
     C                             M5T1OB='0' OR M5T1OB='4')                                        
     C                   EVAL      C0T1OB=M5T1OB                                                    
     C                   EVAL      C0T2OB=M5T2OB                                                    
     C                   EVAL      C0T2OB=M5T3OB                                                    
     C                   EVAL      C0IDIB=M5IDIB                                                    
     C                   EVAL      C0OB50=M5OB50                                                    
     C                   EVAL      C0MSGE=M5MSGE                                                    
     C                   EVAL      C0DAT8=ZZDATS                                                    
     C                   IF        C0DAT8=0                                                         
     C                   EVAL      C0DAT8=*DATE                                                     
     C                   ENDIF                                                                      
     C                   TIME                    C0HORA                                             
     C                   EVAL      C0USUA=ZZUSUA                                                    
     C                   EVAL      C0PANT=SDSJOB                                                    
     C                   EVAL      C0IDIO=M5IDIO                                                    
     C                   EVAL      C0TLI1=M5TLI1                                                    
     C                   EVAL      C0TLI2=M5TLI2                                                    
     C                   EVAL      C0TLI3=M5TLI3                                                    
     C                   EVAL      C0MRCA=M5MRCA                                                    
     C                   EVAL      C0DAT1=C0DAT8                                                    
     C                   EVAL      C0EVOL=ZXEVOL                                                    
     C                   EVAL      C0EVPR=ZXEVPR                                                    
     C                   WRITE     RPUOBPE                                                          
FQ604C***                EVAL      ZXOPC0='1'                                                       
FQ604C***                EXSR      CS_SENDOBS                                                       
     C                   ENDIF                                                                      
      *                                                                                             
     C     KMSOBAR       READE     MSOBAR                                                           
     C                   ENDDO                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
FQ604 **************************************************************                                
FQ604 * Grabacion observaciones cabecera                           *                                
FQ604 *------------------------------------------------------------*                                
FQ604C     CS_OBSCAB     BEGSR                                                                      
FQ604 *                                                                                             
FQ604C                   Z-ADD     0             ZXLINE            3 0                              
FQ604 * Método de Entrega                                                                           
FQ604C                   IF        S0EDME<>' ' And S0EDME<>'0'                                      
FQ604C                   EVAL      C0IDIO=S0IDIO                                                    
FQ604C                   EVAL      C0LINP=0                                                         
FQ604C                   EVAL      ZXLINE=ZXLINE+1                                                  
FQ604C                   EVAL      C0LINE=ZXLINE                                                    
FQ604C     KPUOBPE       CHAIN     PUOBPE                                                           
FQ604C                   IF        NOT %FOUND(PUOBPE)                                               
FQ604C                   EVAL      PECTAB ='EDME'                                                   
FQ604C                   EVAL      PECLTA = S0EDME                                                  
FQ604C     KPMTAB2       CHAIN     PMTAB2                                                           
FQ604C                   IF        %FOUND(PMTAB2)                                                   
FQ604C                   MOVEL(P)  PEDESC        C0OB50                                             
FQ604C                   EVAL      C0T1OB=*BLANKS                                                   
FQ604C                   EVAL      C0T2OB=*BLANKS                                                   
FQ604C                   EVAL      C0T3OB=*BLANKS                                                   
FQ604C                   EVAL      C0IDIB=S0IDIB                                                    
FQ604C                   EVAL      C0MSGE=*BLANKS                                                   
FQ604C                   EVAL      C0DAT8=ZZDATS                                                    
FQ604C                   IF        C0DAT8=0                                                         
FQ604C                   EVAL      C0DAT8=*DATE                                                     
FQ604C                   ENDIF                                                                      
FQ604C                   TIME                    C0HORA                                             
FQ604C                   EVAL      C0USUA=ZZUSUA                                                    
FQ604C                   EVAL      C0PANT=SDSJOB                                                    
FQ604C                   EVAL      C0IDIO=S0IDIO                                                    
FQ604C                   EVAL      C0LINP=0                                                         
FQ604C                   EVAL      C0TLI1=*BLANKS                                                   
FQ604C                   EVAL      C0TLI2='1'                                                       
FQ604C                   EVAL      C0TLI3=*BLANKS                                                   
FQ604C                   EVAL      C0MRCA=*BLANKS                                                   
FQ604C                   EVAL      C0DAT1=C0DAT8                                                    
FQ604C                   MOVEL     S0CIAS        C0CI02                                             
FQ604C                   EVAL      C0DL02=S0DLGA                                                    
FQ604C                   EVAL      C0NP02=S0NPCO                                                    
FQ604C                   EVAL      C0TP02=S0TPED                                                    
FQ604C                   EVAL      C0DA02=S0DATP                                                    
FQ604C                   EVAL      C0NO02=S0NOPL                                                    
FQ604C                   EVAL      C0EVOL=ZXEVOL                                                    
FQ604C                   EVAL      C0EVPR=ZXEVPR                                                    
FQ604C                   WRITE     RPUOBPE                                                          
FQ604C                   ENDIF                                                                      
FQ604C                   ENDIF                                                                      
FQ604C                   ENDIF                                                                      
FQ604 *                                                                                             
FQ604 *                                                                                             
FQ604 * Grabo las observaciones del pedido de ventas si hay                                         
FQ604 *                                                                                             
FQ604C                   EVAL      S0CIAS=S5CIAS                                                    
FQ604C                   EVAL      S0DLGA=S5DLGA                                                    
FQ604C                   EVAL      S0NPCO=S5NPCO                                                    
FQ604C                   EVAL      S0TPED=S5TPED                                                    
FQ604C                   EVAL      S0DATP=S5DATP                                                    
FQ604C                   EVAL      S0NOPL=S5NOPL                                                    
FQ604C                   EVAL      S0LINP=0                                                         
FQ604C     KCOOBPE       SETLL     COOBPE                                                           
FQ604C     KCOOBPE       READE     COOBPE                                                           
FQ604C                   DOW       NOT %EOF(COOBPE)                                                 
FQ604 *                                                                                             
FQ604C                   IF        S0TLI2='1' Or S0TLI2='3'                                         
I0161C                             Or S0TLI2='2'                                                    
FQ604 *                                                                                             
FQ604C                   EVAL      ZXLINE=ZXLINE+1                                                  
FQ604C                   EVAL      C0LINE=ZXLINE                                                    
FQ604C                   EVAL      C0LINP=0                                                         
FQ604 *                                                                                             
FQ604C                   EVAL      C0T1OB=S0T1OB                                                    
FQ604C                   EVAL      C0T2OB=S0T2OB                                                    
FQ604C                   EVAL      C0T3OB=S0T3OB                                                    
FQ604C                   EVAL      C0IDIO=S0IDIO                                                    
FQ604C                   EVAL      C0MSGE=S0MSGE                                                    
FQ604C                   EVAL      C0IDIB=S0IDIB                                                    
FQ604C                   EVAL      C0DAT8=*DATE                                                     
FQ604C                   TIME                    C0HORA                                             
FQ604C                   EVAL      C0USUA=ZZUSUA                                                    
FQ604C                   EVAL      C0PANT=SDSJOB                                                    
FQ604C                   EVAL      C0TLI1=S0TLI1                                                    
FQ604C                   EVAL      C0TLI2=S0TLI2                                                    
FQ604C                   EVAL      C0TLI3=S0TLI3                                                    
FQ604C                   EVAL      C0OB50=S0OB50                                                    
FQ604C                   EVAL      C0MRCA=S0MRCA                                                    
FQ604C                   EVAL      C0DAT1=C0DAT8                                                    
FQ604C                   EVAL      C0EVOL=ZXEVOL                                                    
FQ604C                   EVAL      C0EVPR=ZXEVPR                                                    
FQ604C                   MOVEL     S0CIAS        C0CI02                                             
FQ604C                   EVAL      C0DL02=S0DLGA                                                    
FQ604C                   EVAL      C0NP02=S0NPCO                                                    
FQ604C                   EVAL      C0TP02=S0TPED                                                    
FQ604C                   EVAL      C0DA02=S0DATP                                                    
FQ604C                   EVAL      C0NO02=S0NOPL                                                    
FQ604C                   WRITE     RPUOBPE                                                          
FQ604 *                                                                                             
FQ604C                   ENDIF                                                                      
FQ604 *                                                                                             
FQ604C     KCOOBPE       READE     COOBPE                                                           
FQ604C                   ENDDO                                                                      
FQ604C                   ENDSR                                                                      
FQ604 **************************************************************                                
FQ604 * Eliminación Observaciones                                  *                                
FQ604 *------------------------------------------------------------*                                
FQ604C     CS_OBSDEL     BEGSR                                                                      
FQ604 *                                                                                             
07053C                   IF        C0LINP=0                                                         
FQ604C     KPUOBPE0      SETLL     PUOBPE                                                           
FQ604C     KPUOBPE0      READE     PUOBPE                                                           
07053C                   ELSE                                                                       
07053C     KPUOBPE1      SETLL     PUOBPE                                                           
07053C     KPUOBPE1      READE     PUOBPE                                                           
07053C                   ENDIF                                                                      
FQ604C                   DOW       NOT %EOF(PUOBPE)                                                 
FQ604C*07053             IF        C0TLI2='1' Or C0TLI2='3'                                         
FQ604C                   DELETE    RPUOBPE                                                          
FQ604C*07053             ENDIF                                                                      
07053C                   IF        C0LINP=0                                                         
FQ604C     KPUOBPE0      READE     PUOBPE                                                           
07053C                   ELSE                                                                       
07053C     KPUOBPE1      READE     PUOBPE                                                           
07053C                   ENDIF                                                                      
FQ604C                   ENDDO                                                                      
FQ604                                                                                               
FQ604C                   ENDSR                                                                      
      **********************************************************************                        
      * Datos generales para envío                                                                  
      **********************************************************************                        
     C     CS_SEND       BEGSR                                                                      
      *                                                                                             
     C                   EVAL      C0CIAS=C0CIAS                                                    
     C                   EVAL      C0PRVR=C0PRVR                                                    
     C     KPUPROV       CHAIN     PUPROV                                                           
      *                                                                                             
     C     KPUCAPE       CHAIN(N)  PUCAPE                                                           
      *                                                                                             
     C                   IF        ZZALOL<'1'                                                       
     C                   EVAL      MICIAS=C0CIAS                                                    
     C                   EVAL      MIDLGA=C0DLGA                                                    
     C                   EVAL      MILGCA=C0LOGE                                                    
     C     KMSLOGI       CHAIN     MSLOGI                                                           
     C                   IF        MIALOL='1'                                                       
     C                   EVAL      ZXEVR0=' '                                                       
     C                   EVAL      U0TENV='1'                                                       
     C                   ELSE                                                                       
     C                   EVAL      U0TENV='5'                                                       
     C                   EVAL      ZXEVR0='5'                                                       
     C                   ENDIF                                                                      
     C                   IF        ZZEPP1>='1' OR ZZEPP8>='1'                                       
     C                   EVAL      U0CIAS=C0CIAS                                                    
     C                   EVAL      U0CLP0=C0PRVR                                                    
      * El registro no debe ser baja ni puede estar desactivado y                                   
      * debe permitir traspaso automatico de pedidos                                                
     C     KUTCOM0       CHAIN     UTCOM0                                                           
     C                   IF        (%FOUND(UTCOM0) AND U0BAJA<='0' AND                              
     C                             U0ACTI<='0')AND (U0EPP1>='1')                                    
     C                   EVAL      ZXUTCOMU=1                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Envío de la cabecera del pedido                                                             
      **********************************************************************                        
     C     CS_SENDCAB    BEGSR                                                                      
      *                                                                                             
      * Datos para envío general                                                                    
      *                                                                                             
     C                   EXSR      CS_SEND                                                          
I0200 *                                                                                             
I0200 * Miramos si el pedido de cliente es de Export                                                
I0200 * (Utilizaremos el campo libre C0CCCA)                                                        
I0200C                   EXSR      CS_EXPORT                                                        
I0200C                   EVAL      C0CCCA=ZXEXPORT                                                  
I0200C                                                                                              
      *                                                                                             
     C                   IF        ZXUTCOMU=1 AND ZZALOL<'1'                                        
      *                                                                                             
     C                   EVAL      C0OPC0=ZXOPC0                                                    
     C                   EVAL      C0EVR0=ZXEVR0                                                    
     C                   EVAL      C0CPVE='0'                                                       
      *                                                                                             
     C                   EVAL      C0TENV=U0TENV                                                    
     C                   EVAL      C0DEST=U0DEST                                                    
     C                   EVAL      C0TDES=U0TDES                                                    
     C                   EVAL      C0CIDT=U0CIA1                                                    
     C                   EVAL      C0CLDT=U0CLP1                                                    
     C                   EVAL      C0USU0=SDSUSR                                                    
     C                   EVAL      C0PAN0=ZZPANT                                                    
     C                   EVAL      C0DAT0=ZZDATS                                                    
     C                   TIME                    ZXTIME                                             
     C                   MOVEL     ZXTIME        C0HOR0                                             
     C                   EVAL      C0PROG=SDSPGM                                                    
11050 ** Activaremos el campo de CHEKSUM                                                            
11050C**                 EXSR      CS_CHKSUM                                                        
11050C**                 EVAL      C0CHKS=ZXCHKS                                                    
      *                                                                                             
     C                   EVAL      *IN81=*ON                                                        
     C                   DOU       *IN80=*OFF                                                       
     C                   EVAL      C0HOR0=C0HOR0+1                                                  
     C                   IF        ZXNOCONF=0                                                       
31030C                             AND C0STCO>='2A'                                                 
11050C                   EVAL      C0CHKS=ZXCHKS                                                    
C4137*                                                                                             
C4137c                   eval      zxnograbar=*blanks                                               
C4137c                   eval      c9cias = c0cias                                                  
C4137c                   eval      c9prvr = c0prvr                                                  
C4137c     kpucedi       chain     pucedi                                                           
C4137c                   if        %found(pucedi) and c9eped = '1'                                  
C4137c                   eval      zxnograbar='N'                                                   
C4137c                   endif                                                                      
C4137*                                                                                             
C4137c                   if        zxnograbar=*blanks                                               
     C                   WRITE     RTR0035                              80                          
C4137c                   endif                                                                      
C4137c                   eval      zxnograbar=*blanks                                               
C4137*                                                                                             
C4137c                   clear                   c0edic                                             
C4137c                   clear                   c0fedi                                             
C4137c                   clear                   c0uedi                                             
C4137c                   clear                   zxexcepcion                                        
C4137*                                                                                             
     C                   ENDIF                                                                      
     C                   ENDDO                                                                      
      *                                                                                             
     C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Envío de la línea del pedido                                                                
      **********************************************************************                        
     C     CS_SENDDET    BEGSR                                                                      
      *                                                                                             
      * Datos para envío general si no es baja porque ya lo he determinado                          
      *                                                                                             
     C                   IF        @PEDAU<>'005' AND @PEDAU<>'009'                                  
     C                             AND @PEDAU<>'018'                                                
C2559C                             AND @PEDAU<>'051'                                                
     C                   EXSR      CS_SEND                                                          
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        ZXUTCOMU=1 AND ZZALOL<'1'                                        
      *                                                                                             
     C                   EVAL      C5OPC0=ZXOPC0                                                    
     C                   EVAL      C5EVR0=ZXEVR0                                                    
      *                                                                                             
     C                   EVAL      C5TENV=U0TENV                                                    
     C                   EVAL      C5DEST=U0DEST                                                    
     C                   EVAL      C5TDES=U0TDES                                                    
     C                   EVAL      C5CIDT=U0CIA1                                                    
     C                   EVAL      C5CLDT=U0CLP1                                                    
     C                   EVAL      C5CUSF=C0CUST                                                    
     C                   EVAL      C5USU0=SDSUSR                                                    
     C                   EVAL      C5PAN0=ZZPANT                                                    
     C                   EVAL      C5DAT0=ZZDATS                                                    
     C                   IF        C5OPC0='4' OR ZXMASL=1                                           
     C                   EVAL      C5ACHK='1'                                                       
     C                   ENDIF                                                                      
     C                   TIME                    ZXTIME                                             
     C                   MOVEL     ZXTIME        C5HOR0                                             
     C                   EVAL      C5PROG=SDSPGM                                                    
      *                                                                                             
     C                   EVAL      *IN81=*ON                                                        
     C                   DOU       *IN80=*OFF                                                       
     C                   EVAL      C5HOR0=C5HOR0+1                                                  
M345BC                   IF        ZXOPC0='9'                                                       
M345BC                   EVAL      C5HOR0=C5HOR0+68                                                 
M345BC                   ENDIF                                                                      
     C                   EVAL      C0CIAS=C5CIAS                                                    
     C                   EVAL      C0DLGA=C5DLGA                                                    
     C                   EVAL      C0NPCO=C5NPCO                                                    
     C                   EVAL      C0TPED=C5TPED                                                    
     C                   EVAL      C0DATP=C5DATP                                                    
     C                   EVAL      C0NOPL=C5NOPL                                                    
     C     KPUCAPE       CHAIN(N)  PUCAPE                                                           
     C                   IF        ZXNOCONF=0                                                       
31030C                             AND C0STCO>='2A'                                                 
C4137c                   eval      zxnograbar=*blanks                                               
C4137c                   eval      c9cias = c0cias                                                  
C4137c                   eval      c9prvr = c0prvr                                                  
C4137c     kpucedi       chain     pucedi                                                           
C4137c                   if        %found(pucedi) and c9eped = '1'                                  
C4137c                   eval      zxnograbar='N'                                                   
C4137c                   endif                                                                      
C4137*                                                                                             
C4137c                   if        zxnograbar=*blanks                                               
     C                   WRITE     RTR0036                              80                          
C4137c                   endif                                                                      
C4137c                   eval      zxnograbar=*blanks                                               
     C                   ENDIF                                                                      
     C                   ENDDO                                                                      
      *                                                                                             
     C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Envío de las observaciones del pedido                                                       
      **********************************************************************                        
     C     CS_SENDOBS    BEGSR                                                                      
      *                                                                                             
      * Datos para envío general                                                                    
      *                                                                                             
FQ604C                   IF        ZXOPC0<>'2'                                                      
     C                   EXSR      CS_SEND                                                          
      *                                                                                             
     C                   IF        ZXUTCOMU=1 AND ZZALOL<'1'                                        
      *                                                                                             
     C                   EVAL      C0OPC0=ZXOPC0                                                    
     C                   EVAL      C0EVR0=ZXEVR0                                                    
      *                                                                                             
     C                   EVAL      C0DL02=@PDLGA                                                    
     C                   EVAL      C0NP02=@PNPCO                                                    
     C                   EVAL      C0TP02=@PTPED                                                    
     C                   EVAL      C0DA02=@PDATP                                                    
     C                   EVAL      C0NO02=@PNOPL                                                    
      *                                                                                             
     C                   EVAL      C0TENV=U0TENV                                                    
     C                   EVAL      C0DEST=U0DEST                                                    
     C                   EVAL      C0TDES=U0TDES                                                    
     C                   EVAL      C0CIDT=U0CIA1                                                    
     C                   EVAL      C0CLDT=U0CLP1                                                    
     C                   EVAL      C0USU0=SDSUSR                                                    
     C                   EVAL      C0PAN0=ZZPANT                                                    
     C                   EVAL      C0DAT0=ZZDATS                                                    
     C                   TIME                    ZXTIME                                             
     C                   MOVEL     ZXTIME        C0HOR0                                             
     C                   EVAL      C0PROG=SDSPGM                                                    
      *                                                                                             
     C                   EVAL      *IN81=*ON                                                        
     C                   DOU       *IN80=*OFF                                                       
     C                   EVAL      C0HOR0=C0HOR0+1                                                  
     C     KPUCAPE       CHAIN(N)  PUCAPE                                                           
     C                   IF        ZXNOCONF=0                                                       
     C                             AND C0STCO>='20'                                                 
18060C*    KPUOBPE0      CHAIN(N)  PUOBPE                                                           
18060C     KPUOBPE0      SETLL     PUOBPE                                                           
18060C     KPUOBPE0      READE     PUOBPE                                                           
FQ604C                   DOW       NOT %EOF(PUOBPE)                                                 
C4137c                   eval      zxnograbar=*blanks                                               
C4137c                   eval      c9cias = c0cias                                                  
C4137c                   eval      c9prvr = c0prvr                                                  
C4137c     kpucedi       chain     pucedi                                                           
C4137c                   if        %found(pucedi) and c9eped = '1'                                  
C4137c                   eval      zxnograbar='N'                                                   
C4137c                   endif                                                                      
C4137*                                                                                             
C4137c                   if        zxnograbar=*blanks                                               
     C                   WRITE     RTR0037                              80                          
C4137c                   endif                                                                      
C4137c                   eval      zxnograbar=*blanks                                               
FQ604C     KPUOBPE0      READE(N)  PUOBPE                                                           
FQ604C                   ENDDO                                                                      
     C                   ENDIF                                                                      
     C                   ENDDO                                                                      
      *                                                                                             
     C                   ENDIF                                                                      
FQ604C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Envío de la dirección de entrega del pedido                                                 
      **********************************************************************                        
     C     CS_SENDDIR    BEGSR                                                                      
      *                                                                                             
      * Datos para envío general                                                                    
      *                                                                                             
     C                   EXSR      CS_SEND                                                          
      *                                                                                             
     C                   IF        ZXUTCOMU=1                                                       
      *                                                                                             
     C                   EVAL      C2OPC0=ZXOPC0                                                    
     C                   EVAL      C2EVR0=ZXEVR0                                                    
      *                                                                                             
     C                   EVAL      C2TENV=U0TENV                                                    
     C                   EVAL      C2DEST=U0DEST                                                    
     C                   EVAL      C2TDES=U0TDES                                                    
     C                   EVAL      C2CIDT=U0CIA1                                                    
     C                   EVAL      C2CLDT=U0CLP1                                                    
     C                   EVAL      C2USU0=SDSUSR                                                    
     C                   EVAL      C2PAN0=ZZPANT                                                    
     C                   EVAL      C2DAT0=ZZDATS                                                    
     C                   TIME                    ZXTIME                                             
     C                   MOVEL     ZXTIME        C2HOR0                                             
     C                   EVAL      C5PROG=SDSPGM                                                    
      *                                                                                             
     C                   EVAL      *IN81=*ON                                                        
     C                   DOU       *IN80=*OFF                                                       
     C                   EVAL      C2HOR0=C2HOR0+1                                                  
20040C                   IF        C2OPC0='4'                                                       
20040C                   EVAL      C2CIAS=C0CIAS                                                    
20040C                   EVAL      C2DLGA=C0DLGA                                                    
20040C                   EVAL      C2NPCO=C0NPCO                                                    
20040C                   EVAL      C2TPED=C0TPED                                                    
20040C                   EVAL      C2DATP=C0DATP                                                    
20040C                   EVAL      C2NOPL=C0NOPL                                                    
20040C                   EVAL      C2CDIR='1'                                                       
20040C     KPUDIPE       CHAIN     PUDIPE                                                           
20040C                   ELSE                                                                       
     C                   EXSR      CS_ENCRIP                                                        
     C                   EVAL      C0CIAS=C2CIAS                                                    
     C                   EVAL      C0DLGA=C2DLGA                                                    
     C                   EVAL      C0NPCO=C2NPCO                                                    
     C                   EVAL      C0TPED=C2TPED                                                    
     C                   EVAL      C0DATP=C2DATP                                                    
     C                   EVAL      C0NOPL=C2NOPL                                                    
     C     KPUCAPE       CHAIN(N)  PUCAPE                                                           
20040C                   ENDIF                                                                      
     C                   IF        ZXNOCONF=0                                                       
31030C                             AND C0STCO>='2A'                                                 
PD838C                   CLEAR                   ZXCDIR            1                                
PD838C                   EVAL      ZXCDIR=C2CDIR                                                    
      *                                                                                             
      * Para evitar enviar 2 veces al mismo proveedor                                               
      *                                                                                             
     C                   EVAL      *IN55=*OFF                                                       
Q0322C*    C0PRVR        LOOKUP    SPROV(1)                               55                        
Q0322C                   EVAL      ZXPR_PED=C0PRVR+C0NPCO                                           
Q0322C     ZXPR_PED      LOOKUP    SPR_PED(1)                             55                        
     C                   IF        *IN55=*OFF                                                       
     C                   IF        C2OPC0<>'1'                                                      
     C                   EVAL      C2CDIR='3'                                                       
     C                   ENDIF                                                                      
C4137c                                                                                              
C4137c                   eval      zxnograbar=*blanks                                               
C4137c                   eval      c9cias = c0cias                                                  
C4137c                   eval      c9prvr = c0prvr                                                  
C4137c     kpucedi       chain     pucedi                                                           
C4137c                   if        %found(pucedi) and c9eped = '1'                                  
C4137c                   eval      zxnograbar='N'                                                   
C4137c                   endif                                                                      
C4137*                                                                                             
C4137c                   if        zxnograbar=*blanks                                               
     C                   WRITE     RTR0038                              80                          
C4137c                   endif                                                                      
C4137c                   eval      zxnograbar=*blanks                                               
PD838 *                                                                                             
PD838C                   EVAL      Z1CIAS=T0CIA2                                                    
PD838C     KAQPEDI10     CHAIN     AQPEDI10                                                         
PD838C                   IF        %FOUND AND Z1L100='1'                                            
PD838C                   EVAL      C2HOR0=C2HOR0+1                                                  
PD838C                   EVAL      C2CDIR=ZXCDIR                                                    
C4137c                   eval      zxnograbar=*blanks                                               
C4137c                   eval      c9cias = c0cias                                                  
C4137c                   eval      c9prvr = c0prvr                                                  
C4137c     kpucedi       chain     pucedi                                                           
C4137c                   if        %found(pucedi) and c9eped = '1'                                  
C4137c                   eval      zxnograbar='N'                                                   
C4137c                   endif                                                                      
C4137*                                                                                             
C4137c                   if        zxnograbar=*blanks                                               
PD838C                   WRITE     RTR0038                              80                          
C4137c                   endif                                                                      
PD838C                   ENDIF                                                                      
PD838 *                                                                                             
     C                   EVAL      BP=BP+1                                                          
Q0322C*                  EVAL      SPROV(BP)=C0PRVR                                                 
Q0322C                   EVAL      SPR_PED(BP)=C0PRVR+C0NPCO                                        
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDIF                                                                      
     C                   ENDDO                                                                      
      *                                                                                             
     C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PARA CONVERTIR UNIDADES PEDIDO A UNIDADES STOCK  *                                
      **************************************************************                                
     C     CS_CNVUBS     BEGSR                                                                      
      *                                                                                             
     C                   EVAL      P6CIAS=@PCIAS                                                    
     C                   EVAL      XZAUXI=ZXAUXIBS                                                  
     C                   MOVE      ZXARTIBS      P6ARTI                                             
     C                   MOVE      ZXVARIBS      P6VARI                                             
     C                   MOVE      ZXMODEBS      P6MODE                                             
     C                   MOVE      ZXUNIMBS      P6UNIM                                             
     C                   MOVE      '0'           P6TCOF                                             
     C                   Z-ADD     0             P6COFA                                             
     C     KPMUNAL       CHAIN     PMUNAL                                                           
     C                   IF        P6TCOF<>'1'                                                      
     C                   MULT      P6COFA        XZAUXI                                             
     C                   ELSE                                                                       
     C                   IF        P6COFA<>0                                                        
     C                   DIV       P6COFA        XZAUXI                                             
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   MOVE      '0'           XZDECI                                             
     C                   MOVE      '0'           XZAJUD                                             
      * AJUSTE Y DECIMALES                                                                          
     C/COPY *LIBL/QSRDSRC,SRD001                                                                    
      * OBTENGO LA CANTIDAD EN UNIDAD BASICA DEL ARTICULO                                           
     C                   EVAL      ZXAUXIBS=XZAUXI                                                  
      *                                                                                             
     C                   ENDSR                                                                      
      ******************************************************************                            
      * Generación DEL PUCAIM                                                                       
      ******************************************************************                            
     C     CS_PUCAIM     BEGSR                                                                      
      *                                                                                             
IN240C                   MOVE      C5NPCO        ZXJNBR                                             
IN240C*                  MOVE      SDSJNBR       ZXJNBR                                             
     C                   MOVE      UDATE         ZXDATA                                             
03060C**                 TIME                    ZXHORA                                             
     C                   EVAL      ZXHORA=ZXHORA+1                                                  
      *                                                                                             
     C                   CLEAR                   Z1COMA                                             
     C     DSLDA         CAT(P)    Z1COMA:0      Z1COMA                                             
     C                   Z-ADD     86            JOLINE                                             
     C                   CALL      'PRD935'                                                         
     C                   PARM                    JOTRAT                                             
     C                   PARM                    JOLINE                                             
     C                   PARM                    Z1COMA                                             
     C                                                                                              
     C                   EVAL      X1CIAS=ZZCIAS                                                    
     C                   EVAL      X1DLGA=C5DLGA                                                    
     C                   EVAL      X1NPCO=C5NPCO                                                    
     C                   EVAL      X1DATP=C5DATP                                                    
     C                   EVAL      X1TPED=C5TPED                                                    
     C                   EVAL      X1NOPL=C5NOPL                                                    
     C                   CLEAR                   Z1COMA                                             
     C     PU2540        CAT       Z1COMA:0      Z1COMA                                             
     C                   EVAL      JOLINE=88                                                        
     C                   CALL      'PRD935'                                                         
     C                   PARM                    JOTRAT                                             
     C                   PARM                    JOLINE                                             
     C                   PARM                    Z1COMA                                             
      *                                                                                             
     C                   EVAL      @PEPRG2='PU2540    '                                             
      *                                                                                             
     C                   Z-ADD     150           ZXLOGC           15 5                              
     C                   MOVE      *BLANKS       ZXQCM2          150                                
     C                   MOVEL     'SBMJOB'      ZXQCM2                                             
     C     ZXQCM2        CAT       'CMD(':1      ZXQCM2                                             
     C     ZXQCM2        CAT       'CALL (':0    ZXQCM2                                             
     C     ZXQCM2        CAT       'PRDGJ8':0    ZXQCM2                                             
     C     ZXQCM2        CAT       'CL)':0       ZXQCM2                                             
     C     ZXQCM2        CAT       'PARM(':1     ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       JOTRAT:0      ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):1        ZXQCM2                                             
     C     ZXQCM2        CAT       @PEPRG2:0     ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):0        ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):1        ZXQCM2                                             
     C     ZXQCM2        CAT       C(1):1        ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
     C     ZXQCM2        CAT       'JOB(':1      ZXQCM2                                             
     C     ZXQCM2        CAT       @PEPRG2:0     ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
     C     ZXQCM2        CAT       'JOBQ(':1     ZXQCM2                                             
     C     ZXQCM2        CAT       ZZJOCC:0      ZXQCM2                                             
     C     ZXQCM2        CAT       ')':0         ZXQCM2                                             
     C                   CALL      'QCMDEXC'                                                        
     C                   PARM                    ZXQCM2                                             
     C                   PARM                    ZXLOGC                                             
      *                                                                                             
     C                   ENDSR                                                                      
      ******************************************************************                            
      * EVENTO de trazabilidad                                                                      
      ******************************************************************                            
     C     CS_TRAZAVTA   BEGSR                                                                      
      *                                                                                             
     C                   MOVEL(P)  S5DLGA        @FDDLGA                                            
     C                   MOVEL(P)  S5NPCO        @FDNPCO                                            
     C                   MOVEL(P)  S5TPED        @FDTPED                                            
      *                                                                                             
     C                   CALL      'ED0100'                                                         
     C                   PARM      S5CIAS        @FDCIAS                                            
     C                   PARM                    @FDDLGA                                            
     C                   PARM                    @FDNPCO                                            
     C                   PARM                    @FDTPED                                            
     C                   PARM      S5DATP        @FDDATP                                            
     C                   PARM      S5NOPL        @FDNOPL                                            
     C                   PARM      S5LINE        @FDLINE                                            
     C                   PARM                    @FDCIA2                                            
     C                   PARM                    @FDDLG2                                            
     C                   PARM                    @FDNPC2                                            
     C                   PARM                    @FDTPE2                                            
     C                   PARM                    @FDDAT2                                            
     C                   PARM                    @FDNOP2                                            
     C                   PARM                    @FDLIN2                                            
     C                   PARM      1             @FDLOGI                                            
     C                   PARM      0             @FDORIG                                            
     C                   PARM                    @FDEDAU                                            
     C                   PARM                    @FDERAV                                            
     C                   PARM                    @FDTEXT                                            
     C                   PARM                    @FDDATO                                            
     C                   PARM      1             @FDWAUD                                            
     C                   PARM      S5CANT        @FDCANT                                            
      *                                                                                             
     C                   ENDSR                                                                      
      ******************************************************************                            
      * Generación de la TRAZA de compras                                                           
      ******************************************************************                            
     C     CS_TRAZACOM   BEGSR                                                                      
      *                                                                                             
     C                   MOVEL(P)  C5DLGA        @FDDLGA                                            
     C                   MOVEL(P)  C5NPCO        @FDNPCO                                            
     C                   MOVEL(P)  C5TPED        @FDTPED                                            
      *                                                                                             
     C                   CALL      'ED0100'                                                         
     C                   PARM      C5CIAS        @FDCIAS                                            
     C                   PARM                    @FDDLGA                                            
     C                   PARM                    @FDNPCO                                            
     C                   PARM                    @FDTPED                                            
     C                   PARM      C5DATP        @FDDATP                                            
     C                   PARM      C5NOPL        @FDNOPL                                            
     C                   PARM      C5LINE        @FDLINE                                            
     C                   PARM                    @FDCIA2                                            
     C                   PARM                    @FDDLG2                                            
     C                   PARM                    @FDNPC2                                            
     C                   PARM                    @FDTPE2                                            
     C                   PARM                    @FDDAT2                                            
     C                   PARM                    @FDNOP2                                            
     C                   PARM                    @FDLIN2                                            
     C                   PARM      1             @FDLOGI                                            
     C                   PARM      1             @FDORIG                                            
     C                   PARM                    @FDEDAU                                            
     C                   PARM                    @FDERAV                                            
     C                   PARM                    @FDTEXT                                            
     C                   PARM                    @FDDATO                                            
     C                   PARM      1             @FDWAUD                                            
     C                   PARM      C5CANT        @FDCANT                                            
      *                                                                                             
      * Enviar el registro                                                                          
      *                                                                                             
     C                   SELECT                                                                     
     C                   WHEN      @FDEDAU='100'                                                    
     C                   EVAL      ZXOPC0='1'                                                       
     C                   WHEN      @FDEDAU='110'                                                    
     C                   EVAL      ZXOPC0='1'                                                       
     C                   WHEN      @FDEDAU='105'                                                    
     C                   EVAL      ZXOPC0='4'                                                       
     C                   WHEN      @FDEDAU='109'                                                    
     C                   EVAL      ZXOPC0='4'                                                       
     C                   WHEN      @FDEDAU='118'                                                    
     C                   EVAL      ZXOPC0='4'                                                       
C2559C                   WHEN      @FDEDAU='151'                                                    
C2559C                   EVAL      ZXOPC0='4'                                                       
     C                   WHEN      @FDEDAU='119'                                                    
14060 *Al reabrir una línea si no tiene cant. servida se debe volver                                
14060 *a crear en productiva, si tiene cant servida se debe modificar.                              
14060C                   IF        C5CANS=0                                                         
14060C                   EVAL      ZXOPC0='1'                                                       
14060C                   ELSE                                                                       
14060C                   EVAL      ZXOPC0='2'                                                       
14060C                   ENDIF                                                                      
     C                   OTHER                                                                      
     C                   EVAL      ZXOPC0='2'                                                       
     C                   ENDSL                                                                      
      *                                                                                             
In199C                   IF        @PEDAU<>'011'                                                    
M345B *                            AND @PEDAU<>'013'                                                
     C                   EXSR      CS_SENDDET                                                       
In199C                   ENDIF                                                                      
M345B * ENVIAMOS CAMBIOS DE COENVIO SOLO A LAS EMPRESAS INVICTUS                                    
M345B * LO DESACTIVO HASTA QUE NO NOS DEN EL OK                                                     
M345BC                   IF        @PEDAU='013'                                                     
M345BC*                  EVAL      Z1CIAS=T0CIA2                                                    
M345BC*    KAQPEDI10     CHAIN     AQPEDI10                                                         
M345BC*                  IF        %FOUND AND Z1L100='1'                                            
M345BC*                  EVAL      ZXOPC0='9'                                                       
M345BC*                  EXSR      CS_SENDDET                                                       
M345BC*                  ENDIF                                                                      
M345BC                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE CALCULO DE CHECKSUM                           *                                
      *------------------------------------------------------------*                                
     C     CS_CHKSUM     BEGSR                                                                      
     C                   EVAL      ZXCHKS=0                                                         
C1983C                   EVAL      ZXPWP0='0'                                                       
     C                   EVAL      C5CIAS=C0CIAS                                                    
     C                   EVAL      C5DLGA=C0DLGA                                                    
     C                   EVAL      C5TPED=C0TPED                                                    
     C                   EVAL      C5NPCO=C0NPCO                                                    
     C                   EVAL      C5DATP=C0DATP                                                    
     C                   EVAL      C5NOPL=C0NOPL                                                    
     C                   EVAL      C5LINE=0                                                         
     C     KPUDEPE       SETLL     PUDEPE                                                           
     C     KPUDEPEX      READE(N)  PUDEPE                                                           
     C                   DOW       NOT %EOF(PUDEPE)                                                 
     C                   EVAL      ZXCHKS=ZXCHKS+1                                                  
C1983C*Generar variable de precio=0                                                                 
C1983C                   IF        C5PREC=0                                                         
C1983C                   EVAL      ZXPWP0='1'                                                       
C1983C                   ENDIF                                                                      
     C     KPUDEPEX      READE(N)  PUDEPE                                                           
     C                   ENDDO                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * ENCRIPTADOR DE DIRECCIONES                                 *                                
      *------------------------------------------------------------*                                
     C     CS_ENCRIP     BEGSR                                                                      
      *                                                                                             
      * Se encriptan los Datos de la Dirección de Envío si la Empresa                               
      * lo tiene como Parámetro y si la Dirección es para Cliente Terceros                          
      * y el País Destino es de la CEE.                                                             
      *                                                                                             
      * Las empresas con ERP Movex tampoco se encriptan porque no las ven                           
      *                                                                                             
     C                   MOVEL(P)  C2CIDT        PPCIAS                                             
     C     PPCIAS        CHAIN     PMLIBL                                                           
     C                   IF        %FOUND(PMLIBL) AND PPMVXV<>'V'                                   
      *                                                                                             
     C                   IF        (ZZENCR='1' AND C0TPE4='2' AND C2CDIR='1')                       
     C                             OR (ZZENCR='1' AND C0EDET='1' AND C2CDIR='1')                    
      *                                                                                             
     C                   EVAL      MECIAS=C2CIAS                                                    
     C                   EVAL      MEPAIS=C2PAIS                                                    
     C     KMSPAIS       CHAIN     MSPAIS                                                           
     C                   IF        (%FOUND(MSPAIS) AND MEPCEE='1' AND                               
     C                              C0TPE4='2')                                                     
     C                             OR (C0EDET='1' AND C0TPE4<>'2')                                  
      *                                                                                             
     C                   IF        C2RAOS<>*BLANKS                                                  
     C                   EVAL      @PECADENA=*BLANKS                                                
     C                   EVAL      @PECADENA=C2RAOS                                                 
     C                   CALL      'UT2570'                                                         
     C                   PARM                    @PECADENA                                          
     C                   PARM      '1'           @PEACCION                                          
     C                   PARM      *BLANKS       @PEERROR                                           
     C                   IF        @PEERROR=*BLANKS                                                 
     C                   EVAL      C2RAOS=@PECADENA                                                 
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        C2RAO2<>*BLANKS                                                  
     C                   EVAL      @PECADENA=*BLANKS                                                
     C                   EVAL      @PECADENA=C2RAO2                                                 
     C                   CALL      'UT2570'                                                         
     C                   PARM                    @PECADENA                                          
     C                   PARM      '1'           @PEACCION                                          
     C                   PARM      *BLANKS       @PEERROR                                           
     C                   IF        @PEERROR=*BLANKS                                                 
     C                   EVAL      C2RAO2=@PECADENA                                                 
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        C2DIRE<>*BLANKS                                                  
     C                   EVAL      @PECADENA=*BLANKS                                                
     C                   EVAL      @PECADENA=C2DIRE                                                 
     C                   CALL      'UT2570'                                                         
     C                   PARM                    @PECADENA                                          
     C                   PARM      '1'           @PEACCION                                          
     C                   PARM      *BLANKS       @PEERROR                                           
     C                   IF        @PEERROR=*BLANKS                                                 
     C                   EVAL      C2DIRE=@PECADENA                                                 
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        C2DIR2<>*BLANKS                                                  
     C                   EVAL      @PECADENA=*BLANKS                                                
     C                   EVAL      @PECADENA=C2DIR2                                                 
     C                   CALL      'UT2570'                                                         
     C                   PARM                    @PECADENA                                          
     C                   PARM      '1'           @PEACCION                                          
     C                   PARM      *BLANKS       @PEERROR                                           
     C                   IF        @PEERROR=*BLANKS                                                 
     C                   EVAL      C2DIR2=@PECADENA                                                 
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        C2POBL<>*BLANKS                                                  
     C                   EVAL      @PECADENA=*BLANKS                                                
     C                   EVAL      @PECADENA=C2POBL                                                 
     C                   CALL      'UT2570'                                                         
     C                   PARM                    @PECADENA                                          
     C                   PARM      '1'           @PEACCION                                          
     C                   PARM      *BLANKS       @PEERROR                                           
     C                   IF        @PEERROR=*BLANKS                                                 
     C                   EVAL      C2POBL=@PECADENA                                                 
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        C2POST<>*BLANKS                                                  
     C                   EVAL      @PECADENA=*BLANKS                                                
     C                   EVAL      @PECADENA=C2POST                                                 
     C                   CALL      'UT2570'                                                         
     C                   PARM                    @PECADENA                                          
     C                   PARM      '1'           @PEACCION                                          
     C                   PARM      *BLANKS       @PEERROR                                           
     C                   IF        @PEERROR=*BLANKS                                                 
     C                   EVAL      C2POST=@PECADENA                                                 
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
FQ722C*                  IF        C2TELE<>*BLANKS                                                  
FQ722C*                  EVAL      @PECADENA=*BLANKS                                                
FQ722C*                  EVAL      @PECADENA=C2TELE                                                 
FQ722C*                  CALL      'UT2570'                                                         
FQ722C*                  PARM                    @PECADENA                                          
FQ722C*                  PARM      '1'           @PEACCION                                          
FQ722C*                  PARM      *BLANKS       @PEERROR                                           
FQ722C*                  IF        @PEERROR=*BLANKS                                                 
FQ722C*                  EVAL      C2TELE=@PECADENA                                                 
FQ722C*                  ENDIF                                                                      
FQ722C*                  ENDIF                                                                      
      *                                                                                             
FQ722C*                  IF        C2TEL2<>*BLANKS                                                  
