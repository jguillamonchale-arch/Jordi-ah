      * Entrada de parámetros                                                                       
      *                                                                                             
     C     *ENTRY        PLIST                                                                      
     C                   PARM                    @PCIAS                                             
     C                   PARM                    @PDLGA                                             
     C                   PARM                    @PNPCO                                             
     C                   PARM                    @PTPED                                             
     C                   PARM                    @PDATP                                             
     C                   PARM                    @PNOPL                                             
     C                   PARM                    @PLINE                                             
     C                   PARM                    @PEDAU                                             
     C                   PARM                    @PJOBT                                             
     C                   PARM                    @PFIN                                              
PD933C                   PARM                    @PCABE            1                                
PD933C                   IF        %PARMS>10                                                        
PD933C                   EVAL      ZXPECABE=     @PCABE                                             
PD933C                   ENDIF                                                                      
      *                                                                                             
      * @PFIN: 0 = No es la última línea del pedido de ventas                                       
      *        1 = Es la última línea del pedido de ventas                                          
      *        8 = Es una nueva línea en un ped.vta. ya confirmado ant.CO0181                       
      *                                                                                             
22716C** Comprobar si venimos de nuevo pedido o Adicción lineas                                     
22716C                   EVAL      ZXPEDCON=0                                                       
22716C                   IF        @PFIN=8                                                          
22716C                   EVAL      ZXPEDCON=1                                                       
22716C                   ENDIF                                                                      
     C                   Z-ADD     0             ZXMASL            1 0                              
     C                   IF        @PFIN=8                                                          
     C                   EVAL      @PFIN=0                                                          
     C                   EVAL      ZXMASL=1                                                         
     C                   ENDIF                                                                      
      *                                                                                             
      * ANTES DE NADA RECUPERO EL TIPO DE TRABAJO (INTERACTIVO O BATCH)                             
      * SI EL TRABAJO ES BATCH TRANSFORMO TODO LO MANUAL EN AUTOMATICO                              
      * '0' SIGNIFICA BATCH                                                                         
      * '1' SIGNIFICA INTERACTIVO                                                                   
      *                                                                                             
     C                   CALL      'RTVTIJ'                                                         
     C                   PARM      *BLANKS       @PTIPJ            1                                
      *                                                                                             
     C                   IF        @PTIPJ<='0'                                                      
     C                   CALL      'PRDGJ4CL'                                                       
     C                   ENDIF                                                                      
      *                                                                                             
      * Recuperación de la LDA (Interactiva o BATCH)                                                
      *                                                                                             
     C     *DTAARA       DEFINE    PURLDA        DSLDA                                              
     C                   IF        @PTIPJ>'0'                                                       
     C                   IN        DSLDA                                                            
     C                   ELSE                                                                       
     C     *LOCK         IN        DSLDA                                                            
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        @PTIPJ<='0'                                                      
     C                   EVAL      JOLINE=86                                                        
     C     KPMJOBC       CHAIN     PMJOBC                                                           
     C                   IF        %FOUND(PMJOBC)                                                   
     C     JODATO        CAT       DSLDA:0       DSLDA                                              
     C                   ENDIF                                                                      
     C                   OUT       DSLDA                                                            
     C                   ENDIF                                                                      
      *                                                                                             
      * Parámetros del Setup de entrada de pedidos de compra                                        
      *                                                                                             
     C                   EVAL      PICIAS=ZZCIAS                                                    
     C                   EVAL      PIPROG='PU0120   '                                               
     C                   EVAL      PIUSU1=ZZUSUA                                                    
     C     KPMSETP       CHAIN     PMSETP                                                           
     C                   CLEAR                   PU0120                                             
     C     PIDATR        CAT       PU0120:0      PU0120                                             
      *                                                                                             
      * Busqueda Cias OL                                                                            
      *                                                                                             
     C                   EVAL      PECIAS=ZZCIAS                                                    
     C                   EVAL      PECTAB='INOL'                                                    
     C                   EVAL      PECLTA='DESTSGA   '                                              
     C     KPMTAB2       CHAIN     PMTAB2                                                           
     C                   IF        %FOUND(PMTAB2)                                                   
     C                   EVAL      U1DEST=PEDESC                                                    
     C     U1DEST        CHAIN     UTDEST                                                           
     C                   IF        %FOUND(UTDEST) AND U1DSGA='1'                                    
     C                   EVAL      U0DEST=U1DEST                                                    
     C                   EVAL      U0TENV='9'                                                       
     C                   EVAL      U0CLP0=*BLANKS                                                   
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
      * Variable de envío General activada                                                          
      * Variable de envío a TRACE desactivada                                                       
      * Variable de envío a PRODUCTIVA activada                                                     
      *                                                                                             
     C                   EVAL      ZXEVR0=*BLANKS                                                   
     C                   EVAL      ZXEVOL='1'                                                       
     C                   EVAL      ZXEVPR='1'                                                       
      *                                                                                             
     C                   EVAL      @PECIAS=@PCIAS                                                   
     C                   EVAL      @FDEDAU=@PEDAU                                                   
      *                                                                                             
      * Guardo si tiene artículo de portes tipo APE                                                 
      *                                                                                             
     C                   EVAL      ZXARTPOR=*BLANKS                                                 
     C                   EVAL      PECIAS=@PCIAS                                                    
     C                   EVAL      PECTAB='PORT'                                                    
     C                   EVAL      PECLTA='ARTICULO'                                                
     C     KPMTABD       CHAIN     PMTABD                                                           
     C                   IF        %FOUND(PMTABD)                                                   
     C                   EVAL      ZXARTPOR=PEDESC                                                  
     C                   ENDIF                                                                      
