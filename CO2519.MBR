3003AC                   KFLD                    PIPROG                                             
3003AC                   KFLD                    PIUSU1                                             
      * RECUPERACIÓ DE LA LDA DE COMPRES                                                            
     C     *DTAARA       DEFINE    PURLDA        DSLDA                                              
     C                   IN        DSLDA                                                            
FQ284 *                                                                                             
FQ284C                   EVAL      ZEAMPL=ZZAMPL                                                    
FQ284 *                                                                                             
     C     *ENTRY        PLIST                                                                      
     C                   PARM                    @PCIAS                                             
     C                   PARM                    @PDLGA                                             
     C                   PARM                    @PNPCO                                             
     C                   PARM                    @PTPED                                             
     C                   PARM                    @PDATP                                             
     C                   PARM                    @PNOPL                                             
     C                   PARM                    @PERRO                                             
                                                                                                    
28099* BUSCAR PARAMETRO DIAS HORIZONTE PARA TRATAMIENTO NIVEL DE SERVICIO                          
28099C                   EVAL      ZXDIAS=*ZEROS                                                    
28099C                   EVAL      PECIAS=@PCIAS                                                    
28099C                   EVAL      PECTAB='NSER'                                                    
28099C                   EVAL      PECLTA='000'                                                     
11060C     KPMTABD       CHAIN(N)  PMTABD                                                           
28099C                   IF        %FOUND(PMTABD) AND PEBAJA<'1'                                    
28099C                   IF        %SUBST(PEDESC:1:3)<>'   '                                        
28099C                   EVAL      ZXDIAS=%INT(%SUBST(PEDESC:1:3))                                  
28099C                   ENDIF                                                                      
28099C                   ENDIF                                                                      
28099C*                                                                                             
3003A* Buscar setup de CO0120                                                                      
3003AC                   EVAL      PICIAS=@PCIAS                                                    
3003AC                   EVAL      PIPROG='CO0120'                                                  
3003AC                   EVAL      PIUSU1=ZZUSUA                                                    
3003AC     KMSSETP       CHAIN (N) PMSETP                             81                            
3003AC                   CLEAR                   CO0120                                             
3003AC     PIDATR        CAT       CO0120:0      CO0120                                             
3003A*                                                                                             
     C                   EVAL      PXFMD1=ZZFMD1                                                    
     C                   EVAL      ZXERRO=@PERRO                                                    
     C                   EVAL      ZXERR2=ZXERRO                                                    
     C                   EVAL      @PERRO=*BLANKS                                                   
     C                   EVAL      PECIAS=@PCIAS                                                    
     C                   EVAL      PECTAB='NPVE'                                                    
     C                   EVAL      PDCIAS=@PCIAS                                                    
     C                   EVAL      PDCTAB='NPVE'                                                    
     C                   MOVE      @PCIAS        ZXCIAS2                                            
     C                   EVAL      ZXDLGA2=@PDLGA                                                   
     C                   EVAL      ZXTPED2=@PTPED                                                   
     C                   EVAL      PECLTA=ZXCLTA                                                    
      * Guardo las clave original                                                                   
     C                   EVAL      ZXCIAS=@PCIAS                                                    
     C                   EVAL      ZXDLGA=@PDLGA                                                    
     C                   EVAL      ZXNPCO=@PNPCO                                                    
     C                   EVAL      ZXTPED=@PTPED                                                    
     C                   EVAL      ZXDATP=@PDATP                                                    
     C                   EVAL      ZXNOPL=@PNOPL                                                    
                                                                                                    
     C                   EVAL      ZXOPT1='CHK'                                                     
07060C***                IF        @PERRO>='1'                                                      
07060C                   IF        ZXERRO>='1'                                                      
     C     KCOCAPEX      CHAIN     COCAPE                             81                            
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      ZXOPT1='END'                                                     
     C                   ENDIF                                                                      
07060 *Validar que exista dirección de envío                                                        
14060C                   EXSR      FD_BASE                                                          
11060C                   IF        S0TPE4='2'                                                       
14060C                             AND @FDORIG=2                                                    
07060C                   EVAL      S2CIAS=@PCIAS                                                    
07060C                   EVAL      S2DLGA=@PDLGA                                                    
07060C                   EVAL      S2NPCO=@PNPCO                                                    
07060C                   EVAL      S2TPED=@PTPED                                                    
07060C                   EVAL      S2DATP=@PDATP                                                    
07060C                   EVAL      S2NOPL=@PNOPL                                                    
07060C                   EVAL      S2CDIR='3'                                                       
07060C     KCODIPE       CHAIN(N)  CODIPE                             81                            
07060C                   IF        CHAIN=*ON                                                        
07060C                   EVAL      ZXOPT1='END'                                                     
07060C                   ENDIF                                                                      
11060C                   ENDIF                                                                      
     C                   ENDIF                                                                      
MOVEX * ABRIMOS LOS FICHEROS DE CONTABILIDAD SI CORRESPONDE (ZZCTBP=' ')                            
MOVEXC*                  IF        ZZCTBP=' '                                                       
MOVEXC*                  OPEN      CNRAZSOC                                                         
MOVEXC*                  ENDIF                                                                      
                                                                                                    
FQ284C                   EXSR      CS_LOGOL                                                         
                                                                                                    
     C     TINZSR        ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CHECK. DEFINICIO DE TOTS ELS PARÀMETRES          *                                
      * GENERALS DEL PROGRAMA.                                     *                                
      *------------------------------------------------------------*                                
     C     SUBCHK        BEGSR                                                                      
                                                                                                    
     C                   EVAL      ZXOPT='UP1'                                                      
     C                   IF        ZXERR2='1'                                                       
     C                   EVAL      ZXOPT='UP2'                                                      
     C                   ENDIF                                                                      
     C     TSUBCHK       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA QUE CONTROLA ELS POSSIBLES ERRORS DE PROGRAMA    *                                
      *------------------------------------------------------------*                                
     C     CHKTABD       BEGSR                                                                      
                                                                                                    
     C                   EVAL      ERRGRL=*OFF                                                      
                                                                                                    
     C                   DOU       LCKRCD=*OFF                                                      
     C     KPMTABD       CHAIN     PMTABD                             8180                          
     C                   ENDDO                                                                      
     C                   IF        CHAIN=*ON OR PEBAJA=*ON                                PMTABD    
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TCHKTABD                                           
                                                                                                    
     C                   MOVEL     PEDESC        ZXNORT                                             
     C     ZXNODE        IFEQ      *BLANKS                                                          
     C                   MOVE      *ZEROS        ZXNODE                                             
     C                   MOVEL     UYEAR         ZXNODE                                             
     C                   ENDIF                                                                      
     C     ZXNOHA        IFEQ      *BLANKS                                                          
     C                   MOVE      *ALL'9'       ZXNOHA                                             
     C                   MOVEL     UYEAR         ZXNOHA                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXALPH=ZXNODE                                                    
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   EVAL      ZXNORD=PXNUM                                                     
      *                                                                                             
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXALPH=ZXNOHA                                                    
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   EVAL      ZXNORH=PXNUM                                                     
                                                                                                    
     C                   ADD       1             ZXNORD                                             
     C     ZXNORD        IFGT      ZXNORH                                                           
     C                   MOVE      '3'           @PERRO                                             
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TCHKTABD                                           
     C     TCHKTABD      ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA UPDATE                                           *                                
      *------------------------------------------------------------*                                
     C     SUBUP1        BEGSR                                                                      
      * Da nº a @PNPCO                                                                              
     C                   EVAL      ZXOPT='END'                                                      
     C                   IF        ZXERR2='2'                                                       
     C                   EVAL      ZXOPT='UP2'                                                      
     C                   ENDIF                                                                      
      * Si ya tiene nº de salida no continuo en esta subrutina                                      
     C                   IF        @PNPCO<>*BLANKS                                                  
     C                   GOTO      TFIN                                                             
     C                   ENDIF                                                                      
      *                                                                                             
      * @PERRO DE SALIDA:                                                                           
      * @PERRO='1' ==> NO SE HA ENCONTRADO TABLA O SON BAJA                                         
      * @PERRO='2' ==> Nº DE ORDEN YA EXISTE                                                        
      * @PERRO='3' ==> NO QUEDAN MAS NUMEROS PARA OTORGAR                                           
     C                   MOVE      ZXERRO        ZXINBA            1                                
     C     KPMTABL       CHAIN     PMTABL                             8180                          
     C                   IF        CHAIN=*ON                                          PMTABL        
     C                   MOVE      '1'           @PERRO                                             
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ELSE                                                                       
     C                   IF        PDBAJA=*ON                                                       
     C                   MOVE      '1'           @PERRO                                             
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TFIN                                               
      * 1º intento con todos los valores de parámetros CIAS+DLGA+TPED                               
     C                   EVAL      ZXCLTA1=*BLANKS                                                  
     C                   EXSR      CHKTABD                                                          
     C                   EVAL      ZXCLTA1=PECLTA                                                   
     C                   IF        ERRGRL=*OFF                                                      
     C                   GOTO      TFI9                                                             
     C                   ENDIF                                                                      
                                                                                                    
      * SI NO CONSEGUIMOS CON TODOS LOS CIAS+DLGA+TPED, se intenta según                            
      * CIAS+DLGA si DLGA ES<>*BLANKS                                                               
     C                   MOVE      *BLANKS       @PERRO                                             
     C                   EVAL      ZXCLTA2=*BLANKS                                                  
     C                   IF        @PDLGA<>*BLANKS                                                  
     C                   EVAL      ZXTPED2=*BLANKS                                                  
     C                   EVAL      PECLTA=ZXCLTA                                                    
     C                   IF        PECLTA<>ZXCLTA1                                                  
     C                   EXSR      CHKTABD                                                          
     C                   EVAL      ZXCLTA2=PECLTA                                                   
     C                   IF        ERRGRL=*OFF                                                      
     C                   GOTO      TFI9                                                             
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
      * SI NO CONSEGUIMOS CON CIAS+DLGA SE INTENTARA CON CIAS+TPED                                  
     C                   MOVE      *BLANKS       @PERRO                                             
     C                   EVAL      ZXCLTA3=*BLANKS                                                  
     C                   IF        @PTPED<>*BLANKS                                                  
     C                   EVAL      ZXDLGA2=*BLANKS                                                  
     C                   EVAL      ZXTPED2=@PTPED                                                   
     C                   EVAL      PECLTA=ZXCLTA                                                    
     C                   IF        PECLTA<>ZXCLTA1 AND PECLTA<>ZXCLTA2                              
     C                   EXSR      CHKTABD                                                          
     C                   EVAL      ZXCLTA3=PECLTA                                                   
     C                   IF        ERRGRL=*OFF                                                      
     C                   GOTO      TFI9                                                             
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
      * SI NO CONSEGUIMOS CON CIAS+TPED SE INTENTARA CON CIAS                                       
     C                   MOVE      *BLANKS       @PERRO                                             
     C                   EVAL      ZXDLGA2=*BLANKS                                                  
     C                   EVAL      ZXTPED2=*BLANKS                                                  
     C                   EVAL      PECLTA=ZXCLTA                                                    
     C                   IF        PECLTA<>ZXCLTA1 AND PECLTA<>ZXCLTA2                              
     C                             AND PECLTA<>ZXCLTA3                                              
     C                   EXSR      CHKTABD                                                          
     C                   IF        ERRGRL=*OFF                                                      
     C                   GOTO      TFI9                                                             
     C                   ENDIF                                                                      
     C                   ELSE                                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
      * Si llega hasta aquí es que no ha podido recoger nº                                          
     C                   IF        ERRGRL=*ON                                                       
     C                   MOVE      '1'           @PERRO                                             
     C                   GOTO      TFIN                                                             
     C                   ENDIF                                                                      
                                                                                                    
     C     TFI9          TAG                                                                        
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXNORD                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        ZXNODE                                             
      * Si el nº es menor de 9999 le pondremos ceros delante                                        
      * por similitud al traspaso realizado desde la antigua aplicación                             
     C                   IF        PXNUM<=9999                                                      
     C                   Z-ADD     PXNUM         ZXNODEN           5 0                              
     C                   MOVE      ZXNODEN       ZXNODE                                             
     C                   ENDIF                                                                      
                                                                                                    
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=ZXNORH                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                          CAMP NUMÈRIC        
     C                   PARM                    PXALPH                         CAMP ALFANUMÈRIC    
     C                   PARM                    PXFLDD                         Nº CARACT. VISUA    
     C                   PARM                    PXDCCD                         Nº DECIMALS         
     C                   PARM                    PXFMD1                         AJUST DECIMAL (.    
     C                   PARM                    PXEDTC                         CODI EDICIO(4,M,    
     C                   PARM                    PXNMER                         RETORN ERROR        
     C                   PARM                    PXTIPA                         TIPO AJUSTE (0,1    
     C                   MOVE      PXALPH        ZXNOHA                                             
                                                                                                    
     C                   MOVEA     ZXNODE        SSSNUME                                            
     C                   MOVE      *BLANKS       ZXNODE                                             
     C                   DO        10            ZX                                                 
     C                   IF        SSSNUME(ZX)<>*BLANKS                                             
     C                   MOVEA     SSSNUME(ZX)   ZXNODE                                             
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
     C                   ENDDO                                                                      
                                                                                                    
     C                   MOVEA     ZXNOHA        SSSNUME                                            
     C                   MOVE      *BLANKS       ZXNOHA                                             
     C                   DO        10            ZX                                                 
     C                   IF        SSSNUME(ZX)<>*BLANKS                                             
     C                   MOVEA     SSSNUME(ZX)   ZXNOHA                                             
     C                   LEAVE                                                                      
     C                   ENDIF                                                                      
     C                   ENDDO                                                                      
                                                                                                    
     C                   MOVEL     ZXNORT        PEDESC                                             
     C  N81              UPDATE    RPMTABD                                      *UPD PMTABD         
     C                   MOVEL     ZXNODE        @PNPCO                                             
      * Si el numerador contiene letras, entonces modifico                                          
     C                   IF        PEBL65<>*BLANKS                                                  
     C     PEBL65        CAT       @PNPCO:0      @PNPCO                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C     TFIN          TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT1='END'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C     TSUBUP1       ENDSR                                                                      
                                                                                                    
      **************************************************************                                
      * SUBRUTINA UPDATE                                           *                                
      *------------------------------------------------------------*                                
     C     SUBUP2        BEGSR                                                                      
     C* Aquí viene la actualización de COCAPE, CODEPE, estatus, CODIPE                              
     C* COPECO, COOBPE ,etc.                                                                        
     C                   EVAL      ZXOPT='END'                                                      
                                                                                                    
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      CHAIN     COCAPE                             8180                          
     C                   ENDDO                                                                      
                                                                                                    
     C                   MOVE      'R'           S0STCO                                             
     C                   IF        CHAIN=*OFF AND ZXERRO='1'                                        
     C                   EVAL      S0FLAN=*DATE                                                     
     C                   EVAL      S0STCO='20'                                                      
     C                   ENDIF                                                                      
01041C                   IF        CHAIN=*OFF AND                                                   
01041C                             S0FLAN>S0FREP                                                    
25051C                             AND S0C420<>'X'                                                  
01041C                   EVAL      S0FREP=S0FLAN                                                    
01041C                   ENDIF                                                                      
06B12C                   IF        S0STCO='20'                                                      
06B12C                   EXSR      MAXFRRE                                                          
06B12C                   ENDIF                                                                      
PGE21C                   EVAL      S0DAT8=*DATE                                                     
PGE21C                   TIME                    S0HORA                                             
PGE21C                   EVAL      S0USUA=SDSUSR                                                    
     C                   UPDATE    RCOCAPE                              80                          
C1997 *                                                                                             
C1997C                   EVAL      @PELINE=0                                                        
C1997C                   EVAL      @PEFILD='S0STCO'                                                 
C1997C                   EVAL      @PECAUD='CO09'                                                   
C1997C                   EVAL      @PEVAL1='10'                                                     
C1997C                   EVAL      @PEVAL2='20'                                                     
C1997C*                  EXSR      CS_UT2725                                                        
      * Actualización del resto de ficheros asociados al pedido                                     
     C                   IF        ZXERRO='2'                                                       
     C                   EXSR      CS_UPDATE                                                        
C1997C                   EXSR      CS_UT2725                                                        
FQ284 * Mirar si ED V2 y si es productiva para desencriptar dirección                               
FQ284C                   IF        ZDLIV2=1 AND @FDORIG=2                                           
FQ284C                             AND S0TPE4='2'                                                   
FQ284C                   EXSR      CS_DIREDV2                                                       
FQ284C                   ENDIF                                                                      
C0031 *                                                                                             
C0031 * Envío de Cartera Comercial a Trace                                                          
C0031 * (Si no es Pedido de Entrega Directa porque si es así, ya lo haré                            
C0031 * en el PU2660 y así tendré la Trazabilidad del Pedido de Compras)                            
C0031 *                                                                                             
C0031C*                  IF        S0TPE4<>'2' AND S0PPED<>'99'                                     
C0031C*                  CALL      'CO2697'                                                         
C0031C*                  PARM      S0CIAS        @PECIAS                                            
C0031C*                  PARM      S0DLGA        @PEDLGA                                            
C0031C*                  PARM      S0NPCO        @PENPCO                                            
C0031C*                  PARM      S0TPED        @PETPED                                            
C0031C*                  PARM      S0DATP        @PEDATP                                            
C0031C*                  PARM      S0NOPL        @PENOPL                                            
C0031C*                  PARM      *ZEROS        @PELINE                                            
C0031C*                  PARM      '1'           @PERRO                                             
C0031C*                  EVAL      @PERRO=*BLANKS                                                   
C0031C*                  ENDIF                                                                      
C0031 *                                                                                             
     C                   ENDIF                                                                      
     C     TSUBUP2       ENDSR                                                                      
      *                                                                                             
      **************************************************************                                
      * SUBRUTINA UPDATE                                           *                                
      *------------------------------------------------------------*                                
     C     CS_UPDATE     BEGSR                                                                      
FQ284C                   EVAL      ZXDECRIP=0                                                       
      * Cambio de nº de orden en detalle                                                            
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      CHAIN     CODEPE                             8180                          
     C                   ENDDO                                                                      
     C                   DOW       CHAIN=*OFF                                                       
28099C                   EXSR      CS_NIVELS                                                        
     C                   EVAL      S5NPCO=@PNPCO                                                    
01041C                   IF        CHAIN=*OFF AND                                                   
01041C                             S0FLAN>S5FREP                                                    
25051C***                          AND S0C420<>'X'                                                  
01041C                   EVAL      S5FREP=S0FLAN                                                    
01041C                   ENDIF                                                                      
PGE21C                   EVAL      S5DAT8=*DATE                                                     
PGE21C                   TIME                    S5HORA                                             
PGE21C                   EVAL      S5USUA=SDSUSR                                                    
     C                   UPDATE    RCODEPE                                                          
FQ284C                   IF        S5TPE4='2'                                                       
FQ284C                   EXSR      FD_LINVER2                                                       
FQ284C                   ENDIF                                                                      
FQ284 * Evento ED 202 Alta línea pedido CODEP2 EDI en productiva                                    
FQ284C                   IF        ZDLIV2=1 and @FDORIG=2                                           
FQ284C                   EVAL      @FDEDAU='215'                                                    
FQ284C                   EXSR      FD_CONTROL                                                       
FQ284 *                                                                                             
FQ284 * Si la logistica es propia, hay que desencriptar la dirección                                
FQ284 * de entrega para que se pueda servir cuando me autoricen                                     
FQ284 *                                                                                             
F-2OLC*FQ284             IF        S5LOGE<>ZXLOGOL                                                  
F-2OLc                   if        (%lookup(s5loge:T_logol)=0)                                      
FQ284C                   EVAL      ZXDECRIP=1                                                       
FQ284C                   ENDIF                                                                      
FQ284 *                                                                                             
FQ284C                   ENDIF                                                                      
      * ENLACE CON FICHERO DE ACUMULAR EL PDTE DE SERVIR                                            
     C                   EXSR      CS_MSPDTE                                                        
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      READE     CODEPE                               8081                        
     C                   ENDDO                                                                      
     C                   ENDDO                                                                      
      * Cambio de nº de orden en detalle CODEP2                                                     
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      CHAIN     CODEP2                             8180                          
     C                   ENDDO                                                                      
     C                   DOW       CHAIN=*OFF                                                       
     C                   EVAL      S5NPCO=@PNPCO                                                    
     C                   UPDATE    RCODEP2                                                          
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      READE     CODEP2                               8081                        
     C                   ENDDO                                                                      
     C                   ENDDO                                                                      
      * Cambio de nº de orden en GASTOS ADICIONALES                                                 
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      CHAIN     COGAPE                             8180                          
     C                   ENDDO                                                                      
     C                   DOW       CHAIN=*OFF                                                       
     C                   EVAL      VBNPCO=@PNPCO                                                    
     C                   UPDATE    RCOGAPE                                                          
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      READE     COGAPE                               8081                        
     C                   ENDDO                                                                      
     C                   ENDDO                                                                      
      * Cambio de nº de orden en observaciones                                                      
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      CHAIN     COOBPE                             8180                          
     C                   ENDDO                                                                      
     C                   DOW       CHAIN=*OFF                                                       
     C                   EVAL      S0NPCO=@PNPCO                                                    
     C                   UPDATE    RCOOBPE                                                          
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      READE     COOBPE                               8081                        
     C                   ENDDO                                                                      
     C                   ENDDO                                                                      
      * Cambio de nº de orden en direcciones                                                        
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      CHAIN     CODIPE                             8180                          
     C                   ENDDO                                                                      
     C                   DOW       CHAIN=*OFF                                                       
     C                   EVAL      S2NPCO=@PNPCO                                                    
     C                   UPDATE    RCODIPE                                                          
      *                                                                                             
     C                   IF        S2CDIR='1'                                                       
     C     KCOCLIN       CHAIN     COCLIN                             81                            
     C                   IF        CL_S0TCLI='9'                                                    
     C*                  EVAL      A0_EMPRESA=S0CIAS                                                
MOVEXC*                  IF        ZZCTBP=' '                                                       
MOVEXC*                  MOVE      S0CIAS        A0_EMPRESA                                         
MOVEXC*                  EVAL      A0_NOMPLA=S2RAOS                                                 
MOVEXC*                  IF        S0NIFI<>*BLANKS                                                  
MOVEXC*                  EVAL      A0_DNICIF=S0NIFI                                                 
MOVEXC*                  ELSE                                                                       
MOVEXC*                  EVAL      A0_DNICIF=S0NIFC                                                 
MOVEXC*                  ENDIF                                                                      
MOVEXC*    KCNRAZSOC     CHAIN     CNRAZSOC                           81                            
MOVEXC*                  IF        CHAIN=*ON                                                        
MOVEXC*                  WRITE     CNRAZS                                                           
MOVEXC*                  ENDIF                                                                      
MOVEXC*                  ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      READE     CODIPE                               8081                        
     C                   ENDDO                                                                      
     C                   ENDDO                                                                      
      * Cambio de nº de orden en cuentas contables                                                  
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      CHAIN     COPECO                             8180                          
     C                   ENDDO                                                                      
     C                   DOW       CHAIN=*OFF                                                       
     C                   EVAL      SUNPCO=@PNPCO                                                    
     C                   UPDATE    RCOPECO                                                          
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      READE     COPECO                               8081                        
     C                   ENDDO                                                                      
     C                   ENDDO                                                                      
                                                                                                    
      * Cambio de nº de orden de los importes                                                       
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      CHAIN     COCAIM                             8180                          
     C                   ENDDO                                                                      
     C                   DOW       CHAIN=*OFF                                                       
     C                   EVAL      SYNPCO=@PNPCO                                                    
     C                   UPDATE    RCOCAIM                                                          
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      READE     COCAIM                               8081                        
     C                   ENDDO                                                                      
     C                   ENDDO                                                                      
                                                                                                    
      * Cambio de nº de orden de compra en la cabecera de orden                                     
     C                   DOU       LCKRCD=*OFF                                                      
     C     KCOCAPEX      CHAIN     COCAPE                             8180                          
     C                   ENDDO                                                                      
     C                   EVAL      S0STCO='20'                                                      
     C                   EVAL      S0FLAN=*DATE                                                     
     C                   EVAL      S0NPCO=@PNPCO                                                    
01041C                   IF        CHAIN=*OFF AND                                                   
01041C                             S0FLAN>S0FREP                                                    
01041C                   EVAL      S0FREP=S0FLAN                                                    
01041C                   ENDIF                                                                      
     C                   IF        CHAIN=*OFF                                                       
06B12C                   IF        S0STCO='20'                                                      
06B12C                   EXSR      MAXFRRE                                                          
06B12C                   ENDIF                                                                      
PGE21C                   EVAL      S0DAT8=*DATE                                                     
PGE21C                   TIME                    S0HORA                                             
PGE21C                   EVAL      S0USUA=SDSUSR                                                    
     C                   UPDATE    RCOCAPE                                                          
     C                   ENDIF                                                                      
     C     UPDATET       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE ACUMULAR EN FICHERO MSPDTE                                                     
      *------------------------------------------------------------*                                
     C     CS_MSPDTE     BEGSR                                                                      
     C                   EVAL      ZXCANTZ=S5CANT                                                   
     C                   IF        S5CANC<>0                                                        
     C                   EVAL      ZXCANTZ=S5CANC                                                   
     C                   ENDIF                                                                      
     C                   EVAL      MICIAS=S5CIAS                                                    
     C                   EVAL      MIDLGA=S5DLGA                                                    
     C                   EVAL      MILGCA=S5LOGE                                                    
     C     KMSLOAD       CHAIN     MSLOAD                             81                            
     C                   CALL      'MM2605'                                                         
     C                   PARM      S5CIAS        @PECIAS                                            
     C                   PARM      MIMAGA        @PEMAGA                                            
     C                   PARM      S5ARTI        @PEARTI                                            
     C                   PARM      S5VARI        @PEVARI                                            
     C                   PARM      S5MODE        @PEMODE                                            
     C                   PARM      S5TCOJ        @PETCOJ                                            
     C                   PARM      ZXCANTZ       @PECANT                                            
     C                   PARM      S5UNIM        @PEUNIM                                            
     C                   PARM      '1'           @PETIPO                                            
     C                   PARM      *BLANKS       @PEERR                                             
                                                                                                    
     C                   ENDSR                                                                      
28099 **************************************************************                                
28099 * SUBRUTINA TRATAMIENTO PARA GESTION NIVEL DE SERVICIO       *                                
28099 **************************************************************                                
28099C     CS_NIVELS     BEGSR                                                                      
28099C*                                                                                             
28099C* 1) INICIALIZAR CAMPOS DE TRATAMIENTO NIVEL DE SERVICIO                                      
28099C*                                                                                             
28099C                   EVAL      S5SKDC=*BLANKS                                                   
28099C                   EVAL      S5SKDA=*BLANKS                                                   
28099C                   EVAL      S5SKNC=*BLANKS                                                   
28099C*                                                                                             
28099C* 2) SI NO HAY DIAS DE HORIZONTE, SALIR                                                       
28099C*                                                                                             
28099C                   IF        ZXDIAS<=0                                                        
28099C                   GOTO      NODIAS                                                           
28099C                   ENDIF                                                                      
28099C*                                                                                             
28099C* 3) ACCESO PARA SABER SI HAY DISPONIBILIDAD DE STOCK X EMPRESA                               
28099C*                                                                                             
28099C                   EVAL      S5SKDC='0'                                                       
28099C                   EVAL      S5SKDA='0'                                                       
28099C*                                                                                             
28099C                   EVAL      @NSCIAS=S5CIAS                                                   
28099C                   EVAL      @NSLOGE=*BLANKS                                                  
28099C                   EVAL      @NSARTI=S5ARTI                                                   
28099C                   EVAL      @NSVARI=S5VARI                                                   
28099C                   EVAL      @NSMODE=S5MODE                                                   
28099C                   EVAL      @NSTCOJ=S5TCOJ                                                   
28099C                   EVAL      @NSDLGA=S5DLGA                                                   
28099C                   EVAL      @NSNPCO=S5NPCO                                                   
28099C                   EVAL      @NSTPED=S5TPED                                                   
28099C                   EVAL      @NSDATP=S5DATP                                                   
28099C                   EVAL      @NSNOPL=S5NOPL                                                   
28099C                   EVAL      @NSLINE=S5LINE                                                   
28099C                   EVAL      @NSCANT=0                                                        
28099C                   EVAL      @NSUNIM=*BLANKS                                                  
28099C*                                                                                             
28099C                   CALL      'CO2677'                                                         
28099C                   PARM                    @NSCIAS                                            
28099C                   PARM                    @NSLOGE                                            
28099C                   PARM                    @NSARTI                                            
28099C                   PARM                    @NSVARI                                            
28099C                   PARM                    @NSMODE                                            
28099C                   PARM                    @NSTCOJ                                            
28099C                   PARM                    @NSDLGA                                            
28099C                   PARM                    @NSNPCO                                            
28099C                   PARM                    @NSTPED                                            
28099C                   PARM                    @NSDATP                                            
28099C                   PARM                    @NSNOPL                                            
28099C                   PARM                    @NSLINE                                            
28099C                   PARM                    @NSCANT                                            
28099C                   PARM                    @NSUNIM                                            
28099C*                                                                                             
28099c                   IF        @NSUNIM=S5UNIM                                                   
28099c                   eval      ZXCANT=S5CANT-S5CANS                                             
28099c                   else                                                                       
28099C                   EVAL      ZXUNID=S5CANT-S5CANS                                             
28099c                   exsr      CS_PMUNAL                                                        
28099C                   EVAL      ZXCANT=ZXUNIDS                                                   
28099c                   endif                                                                      
28099c*                                                                                             
28099c                   if        @nscant>=zxcant                                                  
28099C                   EVAL      S5SKDC='1'                                                       
28099c                   endif                                                                      
28099C*                                                                                             
28099C* 4) ACCESO PARA SABER SI HAY DISPONIBILIDAD DE STOCK X LOGISTICA                             
28099C*                                                                                             
28099C                   EVAL      @NSCIAS=S5CIAS                                                   
28099C                   EVAL      @NSLOGE=S5LOGE                                                   
28099C                   EVAL      @NSARTI=S5ARTI                                                   
28099C                   EVAL      @NSVARI=S5VARI                                                   
28099C                   EVAL      @NSMODE=S5MODE                                                   
28099C                   EVAL      @NSTCOJ=S5TCOJ                                                   
28099C                   EVAL      @NSDLGA=S5DLGA                                                   
28099C                   EVAL      @NSNPCO=S5NPCO                                                   
28099C                   EVAL      @NSTPED=S5TPED                                                   
28099C                   EVAL      @NSDATP=S5DATP                                                   
28099C                   EVAL      @NSNOPL=S5NOPL                                                   
28099C                   EVAL      @NSLINE=S5LINE                                                   
28099C                   EVAL      @NSCANT=0                                                        
28099C                   EVAL      @NSUNIM=*BLANKS                                                  
28099C*                                                                                             
28099C                   CALL      'CO2677'                                                         
28099C                   PARM                    @NSCIAS                                            
28099C                   PARM                    @NSLOGE                                            
28099C                   PARM                    @NSARTI                                            
28099C                   PARM                    @NSVARI                                            
28099C                   PARM                    @NSMODE                                            
28099C                   PARM                    @NSTCOJ                                            
28099C                   PARM                    @NSDLGA                                            
28099C                   PARM                    @NSNPCO                                            
28099C                   PARM                    @NSTPED                                            
28099C                   PARM                    @NSDATP                                            
28099C                   PARM                    @NSNOPL                                            
28099C                   PARM                    @NSLINE                                            
28099C                   PARM                    @NSCANT                                            
28099C                   PARM                    @NSUNIM                                            
28099C*                                                                                             
28099c                   IF        @NSUNIM=S5UNIM                                                   
28099c                   eval      ZXCANT=S5CANT-S5CANS                                             
28099c                   else                                                                       
28099C                   EVAL      ZXUNID=S5CANT-S5CANS                                             
28099c                   exsr      CS_PMUNAL                                                        
28099C                   EVAL      ZXCANT=ZXUNIDS                                                   
28099c                   endif                                                                      
28099c*                                                                                             
28099c                   if        @nscant>=zxcant                                                  
28099C                   EVAL      S5SKDA='1'                                                       
18129C                   EVAL      S5TPLA='0'                                                       
30914C                   IF        %TRIM(S5TPE4)='2'                                                
C2549C                             AND  S0PPED<>'99'                                                
30914C                   EVAL      S5TPLA='I'                                                       
30914C                   ENDIF                                                                      
28099c                   endif                                                                      
28099C*                                                                                             
28099C* 5) SI FECHA SOLICITADA ES > HOY + DIAS DE PARAMETRO NO SE MARCA COMO                        
28099C*    CALCULADO                                                                                
28099C*                                                                                             
28099C                   MOVEL     ZXDIAS        ZXDMRD            3 0                              
28099C                   MOVE      *DATE         ZXFEDUR                                            
28099C     ZXFEDUR       ADDDUR    ZXDMRD:*D     ZXFEDUR                                            
28099C                   MOVE      ZXFEDUR       ZXF30                                              
28099C*                                                                                             
DISPOC                   if        s5fREP<=zxf30                                                    
DISPOC*                  if        s5frrr<=zxf30                                                    
28099C                   EVAL      S5SKNC='1'                                                       
28099c                   endif                                                                      
28099C*                                                                                             
28099C     NODIAS        TAG                                                                        
28099C                   ENDSR                                                                      
28099*--------------------------------------------------------------------*                        
28099* SUBRUTINA CONVERSION DE UNIDADES                                   *                        
28099*--------------------------------------------------------------------*                        
28099C     CS_PMUNAL     BEGSR                                                                      
28099 *                                                                                             
28099C                   EVAL      ZXTCOF=*BLANKS                                                   
28099C                   EVAL      ZXCOFA=1                                                         
28099 *                                                                                             
28099c                   Eval      p6Cias = S5CIAS                                                  
28099c                   Eval      p6Arti = S5Arti                                                  
28099c                   Eval      p6Vari = S5Vari                                                  
28099c                   Eval      p6Mode = S5Mode                                                  
28099c                   Eval      p6Unim = S5UNIM                                                  
28099c     kpmunal       Chain     pmunal                                                           
28099c                   If        %Found(pmunal)                                                   
28099C                   EVAL      ZXTCOF=P6TCOF                                                    
28099C                   EVAL      ZXCOFA=P6COFA                                                    
28099c                   EndIf                                                                      
28099 *                                                                                             
28099c                   If        ZXTCOF = '1'                                                     
28099c                   Eval      ZXUNIDS = ZXUNID / ZXCoFa                                        
28099c                   Else                                                                       
28099c                   Eval      ZXUNIDS = ZXUNID * ZXCoFa                                        
28099c                   EndIf                                                                      
28099 *                                                                                             
28099C                   ENDSR                                                                      
FQ284 **************************************************************                                
FQ284 * SUBRUTINA PARA MIRAR SI LA LÍNEA ES DE ENTREGA DIRECTA V2  *                                
FQ284 **************************************************************                                
FQ284C     FD_LINVER2    BEGSR                                                                      
FQ284C                                                                                              
FQ284 * Determinar el tipo de empresa en la que estoy                                               
FQ284C                   SELECT                                                                     
FQ284 * Comercial                                                                                   
FQ284C                   WHEN      ZZALOL<'1' AND S0PPED<>'99'                                      
FQ284C                   EVAL      @FDORIG=0                                                        
FQ284 * Productiva                                                                                  
FQ284C                   WHEN      ZZALOL<'1' AND S0PPED='99'                                       
FQ284C                   EVAL      @FDORIG=2                                                        
FQ284 * Trace                                                                                       
FQ284C                   WHEN      ZZALOL='1'                                                       
FQ284C                   EVAL      @FDORIG=3                                                        
FQ284 *                                                                                             
FQ284C                   ENDSL                                                                      
FQ284 * Llamar a ED051 con auditoría 400 para saber si es línea ED V2                               
FQ284 * FDLOGI=1 para que mire por la clave de ped.compras comercial.                               
FQ284C                   MOVEL(P)  S5CI01        @FDCIAS                                            
FQ284C                   CALL      'ED0051'                                                         
FQ284C                   PARM                    @FDCIAS                                            
FQ284C                   PARM      S5DL01        @FDDLGA                                            
FQ284C                   PARM      S5NP01        @FDNPCO                                            
FQ284C                   PARM      S5TP01        @FDTPED                                            
FQ284C                   PARM      S5DA01        @FDDATP                                            
FQ284C                   PARM      S5NO01        @FDNOPL                                            
FQ284C                   PARM      S5LI01        @FDLINE                                            
FQ284C                   PARM      *BLANKS       @FDARV1                                            
FQ284C                   PARM      *BLANKS       @FDCOM2                                            
FQ284C                   PARM      *BLANKS       @FDCUST                                            
FQ284C                   PARM      *BLANKS       @FDTDI1                                            
FQ284C                   PARM      '400'         @FDEDAU                                            
FQ284C                   PARM      1             @FDLOGI                                            
FQ284C                   PARM                    @FDORIG                                            
FQ284C                   PARM      1             @FDINTE                                            
FQ284C                   PARM      *BLANKS       @FDERRO                                            
FQ284C                   PARM      *BLANKS       @FDINCI                                            
FQ284C                                                                                              
FQ284C                   IF        @FDERRO=*BLANKS                                                  
FQ284C                   EVAL      ZDLIV2=1                                                         
FQ284C                   ENDIF                                                                      
FQ284C                                                                                              
FQ284C                   ENDSR                                                                      
FQ284 **************************************************************                                
FQ284 * Control fluidra Direct                                     *                                
FQ284 **************************************************************                                
FQ284C     FD_CONTROL    BEGSR                                                                      
FQ284C                   EVAL      @FDERRO=*BLANKS                                                  
FQ284 *                                                                                             
FQ284 * Evento por determinar                                                                       
FQ284 *                                                                                             
FQ284C                   IF        @FDEDAU=*BLANKS                                                  
FQ284 *                                                                                             
FQ284 *  Evento determinado                                                                         
FQ284 *                                                                                             
FQ284C                   ELSE                                                                       
FQ284C                   SELECT                                                                     
FQ284 *Confirmación línea pedido                                                                    
FQ284C                   WHEN      @FDEDAU='215'                                                    
FQ284C                   EXSR      FD_EVENTO                                                        
FQ284C                   ENDSL                                                                      
FQ284C                   ENDIF                                                                      
FQ284 *                                                                                             
FQ284C                   ENDSR                                                                      
FQ284 **************************************************************                                
FQ284 * Eventos fluidra Direct                                     *                                
FQ284 **************************************************************                                
FQ284C     FD_EVENTO     BEGSR                                                                      
FQ284 *                                                                                             
FQ284 * Preparar parámetros según el evento y ejecutar                                              
FQ284 *                                                                                             
FQ284C                   SELECT                                                                     
FQ284 *                                                                                             
FQ284 *Confirmación línea pedido en CODEP2 via EDI                                                  
FQ284 *                                                                                             
FQ284C                   WHEN      @FDEDAU='215'                                                    
FQ284C                   MOVEL(P)  S5CI01        @FDCIAS                                            
FQ284C                   EVAL      @FDDLGA=S5DL01                                                   
FQ284C                   EVAL      @FDNPCO=S5NP01                                                   
FQ284C                   EVAL      @FDTPED=S5TP01                                                   
FQ284C                   EVAL      @FDDATP=S5DA01                                                   
FQ284C                   EVAL      @FDNOPL=S5NO01                                                   
FQ284C                   EVAL      @FDLINE=S5LI01                                                   
FQ284C                   EVAL      @FDCIA2=S5CIAS                                                   
FQ284C                   EVAL      @FDDLG2=S5DLGA                                                   
FQ284C                   EVAL      @FDNPC2=S5NPCO                                                   
FQ284C                   EVAL      @FDTPE2=S5TPED                                                   
FQ284C                   EVAL      @FDDAT2=S5DATP                                                   
FQ284C                   EVAL      @FDNOP2=S5NOPL                                                   
FQ284C                   EVAL      @FDLIN2=S5LINE                                                   
FQ284 *Lógico con clave pedido de compras en comercial                                              
FQ284C                   EVAL      @FDLOGI=1                                                        
FQ284C                   EVAL      @FDERAV=*BLANKS                                                  
FQ284C                   EVAL      @FDTEXT=*BLANKS                                                  
FQ284C                   EVAL      @FDDATO=*BLANKS                                                  
FQ284C                   EVAL      @FDWAUD=1                                                        
FQ284C                   EVAL      @FDCANT=S5CANT                                                   
FQ284                                                                                               
FQ284C                   ENDSL                                                                      
FQ284 *                                                                                             
FQ284 * Ejecutar                                                                                    
FQ284 *                                                                                             
FQ284C                   CALL      'ED0100'                                                         
FQ284C                   PARM                    @FDCIAS                                            
FQ284C                   PARM                    @FDDLGA                                            
FQ284C                   PARM                    @FDNPCO                                            
FQ284C                   PARM                    @FDTPED                                            
FQ284C                   PARM                    @FDDATP                                            
FQ284C                   PARM                    @FDNOPL                                            
FQ284C                   PARM                    @FDLINE                                            
FQ284C                   PARM                    @FDCIA2                                            
FQ284C                   PARM                    @FDDLG2                                            
FQ284C                   PARM                    @FDNPC2                                            
FQ284C                   PARM                    @FDTPE2                                            
FQ284C                   PARM                    @FDDAT2                                            
FQ284C                   PARM                    @FDNOP2                                            
FQ284C                   PARM                    @FDLIN2                                            
FQ284C                   PARM                    @FDLOGI                                            
FQ284C                   PARM                    @FDORIG                                            
FQ284C                   PARM                    @FDEDAU                                            
FQ284C                   PARM                    @FDERAV                                            
FQ284C                   PARM                    @FDTEXT                                            
FQ284C                   PARM                    @FDDATO                                            
FQ284C                   PARM                    @FDWAUD                                            
FQ284C                   PARM                    @FDCANT                                            
FQ284 *                                                                                             
FQ284C                   ENDSR                                                                      
FQ284 **************************************************************                                
FQ284 * Si la empresa actua como productiva y es ED V2 desencriptar*                                
FQ284 **************************************************************                                
FQ284C     CS_DIREDV2    BEGSR                                                                      
FQ284 *                                                                                             
FQ284 * Si la empresa actua como productiva mirar si el pedido                                      
FQ284 * contiene alguna línea de ED V2.                                                             
FQ284 * Si es así se desencriptará la dirección de envio tipo 3 y                                   
FQ284 * se guardará como tipo 1.                                                                    
FQ284 *                                                                                             
FQ284 * Variable que determina si la línea ED V2 permite cambio logística                           
FQ284C                   EVAL      ZDCLOG=0                                                         
FQ284 *                                                                                             
FQ284 * Determinar el tipo de empresa en la que estoy                                               
FQ284 *                                                                                             
FQ284C                   SELECT                                                                     
FQ284 * Comercial                                                                                   
FQ284C                   WHEN      ZZALOL<'1' AND S0PPED<>'99'                                      
FQ284C                   EVAL      @FDORIG=0                                                        
FQ284 * Productiva                                                                                  
FQ284C                   WHEN      ZZALOL<'1' AND S0PPED='99'                                       
FQ284C                   EVAL      @FDORIG=2                                                        
FQ284 * Trace                                                                                       
FQ284C                   WHEN      ZZALOL='1'                                                       
FQ284C                   EVAL      @FDORIG=3                                                        
FQ284 *                                                                                             
FQ284C                   ENDSL                                                                      
FQ284C                                                                                              
FQ284 *Solo si es productiva                                                                        
FQ284C                   IF        @FDORIG=2                                                        
FQ284 *                                                                                             
FQ284 * Llamar a ED051 con auditoría 222 para saber si el pedido                                    
FQ284 * contiene alguna línea que se permita                                                        
FQ284 * que sea entregable desde la logística propia de la productiva.                              
FQ284 * Usar @FDINTE=2  (mirar en pedido completo)                                                  
FQ284 * Usar @FDLOGI=2  Productiva                                                                  
FQ284C                   CALL      'ED0051'                                                         
FQ284C                   PARM      @PCIAS        @FDCIAS                                            
FQ284C                   PARM      @PDLGA        @FDDLGA                                            
FQ284C                   PARM      @PNPCO        @FDNPCO                                            
FQ284C                   PARM      @PTPED        @FDTPED                                            
FQ284C                   PARM      @PDATP        @FDDATP                                            
FQ284C                   PARM      @PNOPL        @FDNOPL                                            
FQ284C                   PARM      0             @FDLINE                                            
FQ284C                   PARM      *BLANKS       @FDARV1                                            
FQ284C                   PARM      *BLANKS       @FDCOM2                                            
FQ284C                   PARM      *BLANKS       @FDCUST                                            
FQ284C                   PARM      *BLANKS       @FDTDI1                                            
FQ284C                   PARM      '222'         @FDEDAU                                            
FQ284C                   PARM      2             @FDLOGI                                            
FQ284C                   PARM                    @FDORIG                                            
FQ284C                   PARM      2             @FDINTE                                            
FQ284C                   PARM      *BLANKS       @FDERRO                                            
FQ284C                   PARM      *BLANKS       @FDINCI                                            
FQ284C                                                                                              
FQ284C                   IF        @FDERRO=*BLANKS                                                  
FQ284C                   EVAL      ZDCLOG=1                                                         
FQ284C                   ENDIF                                                                      
FQ284C                                                                                              
FQ284C                   ENDIF                                                                      
FQ284C*Si la empresa actua como de productiva y el pedido tiene líneas                              
FQ284C*autorizadas a salir desde la logística de la productiva                                      
FQ284C*desencriptaré la dirección tipo 3 y la grabaré como tipo 1.                                  
FQ284C                   IF        @FDORIG=2 and (ZDCLOG=1                                          
FQ284C                             OR ZXDECRIP=1)                                                   
FQ284C                                                                                              
FQ284C                   EVAL      S2CIAS=@PCIAS                                                    
FQ284C                   EVAL      S2DLGA=@PDLGA                                                    
FQ284C                   EVAL      S2NPCO=@PNPCO                                                    
FQ284C                   EVAL      S2TPED=@PTPED                                                    
FQ284C                   EVAL      S2DATP=@PDATP                                                    
FQ284C                   EVAL      S2NOPL=@PNOPL                                                    
FQ284C                   EVAL      S2CDIR='3'                                                       
FQ284C     KCODIPE       CHAIN     CODIPE                                                           
FQ284C                   IF        %FOUND(CODIPE)                                                   
FQ284C                   EXSR      CS_DECRIP                                                        
14062C                   EXSR      CS_DECRI2                                                        
FQ284C                   EVAL      S2CDIR='1'                                                       
FQ284C     KCODIPE       CHAIN     CODIPE                                                           
FQ284C                   IF        %FOUND(CODIPE)                                                   
FQ284C                   EVAL      S2RAOS=WK_S2RAOS                                                 
FQ284C                   EVAL      S2RAO2=WK_S2RAO2                                                 
FQ284C                   EVAL      S2DPTO=WK_S2DPTO                                                 
FQ284C                   EVAL      S2DIRE=WK_S2DIRE                                                 
FQ284C                   EVAL      S2DIR2=WK_S2DIR2                                                 
FQ284C                   EVAL      S2POBL=WK_S2POBL                                                 
FQ284C                   EVAL      S2POST=WK_S2POST                                                 
FQ284C*FQ722             EVAL      S2TELE=WK_S2TELE                                                 
FQ284C*FQ722             EVAL      S2TEL2=WK_S2TEL2                                                 
FQ284C*FQ722             EVAL      S2TLEX=WK_S2TLEX                                                 
FQ284C*FQ722             EVAL      S2TFAX=WK_S2TFAX                                                 
FQ284C                   EVAL      S2EMAI=WK_S2EMAI                                                 
FQ284C                   EVAL      S2PAIS=WK_S2PAIS                                                 
FQ284C*FQ722             EVAL      S2PEGE=WK_S2PEGE                                                 
FQ284C                   EVAL      S2OB50=WK_S2OB50                                                 
FQ284C                   EVAL      S2OB51=WK_S2OB51                                                 
FQ284C                   EVAL      S2TDVA=WK_S2TDVA                                                 
FQ284C                   EVAL      S2NIFF=WK_S2NIFF                                                 
FQ284C                   UPDATE    RCODIPE                                                          
FQ284C                   ENDIF                                                                      
FQ284C                   ENDIF                                                                      
FQ284C                                                                                              
FQ284C                   ENDIF                                                                      
FQ284C*                                                                                             
FQ284C                   ENDSR                                                                      
