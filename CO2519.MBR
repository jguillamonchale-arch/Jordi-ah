3003A* Mirar si el usuario tiene activada la reserva automatica                                    
3003AC                   IF        MCRESE = '1'                                                     
3003AC                   EXSR      CS_RESERVA                                                       
3003AC                   ENDIF                                                                      
CR839* Si Empresa tiene PARM 'FD List.RoturaStock'=1 + es FD ->                                    
CR839*    Lanzar listado                                                                           
CR839C                   IF        ZEROFD='1'                                                       
CR839C                   IF        S0TPE4='2'                                                       
CR839C                             AND   S0STCO = '20'                                              
CR839C                   EXSR      CS_ROTURA                                                        
CR839C                   ENDIF                                                                      
CR839C                   ENDIF                                                                      
