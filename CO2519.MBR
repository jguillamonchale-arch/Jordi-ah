FQ284 **************************************************************                                
FQ284 * GUARDA LOGISTICA DEL OL                                    *                                
FQ284 *------------------------------------------------------------*                                
FQ284C     CS_LOGOL      BEGSR                                                                      
FQ284 *                                                                                             
F-2OLC*    @PCIAS        SETLL     MSALMA                                                           
F-2OLC*    @PCIAS        READE     MSALMA                                                           
F-2OLC*                  DOW       NOT %EOF(MSALMA)                                                 
F-2OLC*                  IF        M0TAL1='8' AND M0BAJA<>'1'                                       
F-2OLC*                  EVAL      ZXLOGOL=M0LOGS                                                   
F-2OLC*                  LEAVE                                                                      
F-2OLC*                  ENDIF                                                                      
F-2OLC*    @PCIAS        READE     MSALMA                                 84                        
F-2OLC*                  ENDDO                                                                      
F-2OL                                                                                               
F-2OLc                   open      msalma08                                                         
F-2OLc                   eval      i2 = *zero                                                       
F-2OLc                   eval      zztal1 = '8'                                                     
F-2OLc     Kalma08       setll     msalma08                                                         
F-2OLc     Kalma08       reade     msalma08                                                         
F-2OLc                   dow       not %eof(msalma08)                                               
F-2OLC                   if        m0tal1='8' and m0baja<>'1'                                       
F-2OLc                             and i2 < %elem(T_logol)                                          
F-2OLc                   eval      i2 += 1                                                          
F-2OLc                   eval      T_logol(i2) = m0logs                                             
F-2OLc                   endif                                                                      
F-2OLc     Kalma08       reade     msalma08                                                         
F-2OLc                   enddo                                                                      
F-2OLc                   close     msalma08                                                         
FQ284 *                                                                                             
FQ284C                   ENDSR                                                                      
14060 **************************************************************                                
14060 * CALCULA EMPRESA ORIGEN                                     *                                
14060 *------------------------------------------------------------*                                
14060C     FD_BASE       BEGSR                                                                      
14060 *                                                                                             
14060 * Determinar el tipo de empresa en la que estoy                                               
14060C                   SELECT                                                                     
14060 * Comercial                                                                                   
14060C                   WHEN      ZZALOL<'1' AND S0PPED<>'99'                                      
14060C                   EVAL      @FDORIG=0                                                        
14060 * Productiva                                                                                  
14060C                   WHEN      ZZALOL<'1' AND S0PPED='99'                                       
14060C                   EVAL      @FDORIG=2                                                        
14060 * Trace                                                                                       
14060C                   WHEN      ZZALOL='1'                                                       
14060C                   EVAL      @FDORIG=3                                                        
14060 *                                                                                             
14060C                   ENDSL                                                                      
14060 *                                                                                             
14060C                   ENDSR                                                                      
3003A* ==================================================================== *                      
3003A* Intentamos reservar el stock del pedido confirmado.                                         
3003A* ==================================================================== *                      
3003AC     CS_RESERVA    BEGSR                                                                      
3003AC                   MOVE      SDSJNBR       ZXJNBR                                             
3003AC                   MOVE      UDATE         ZXDATA                                             
3003AC                   TIME                    ZXHORA                                             
3003AC*  DATOS DE SELECCION                                                                         
3003AC                   CLEAR                   Z1COMA                                             
3003AC     DSLDA         CAT       Z1COMA:0      Z1COMA                                             
3003AC                   EVAL      JOLINE=86                                                        
3003AC                   CALL      'PRD935'                                                         
3003AC                   PARM                    JOTRAT                                             
3003AC                   PARM                    JOLINE                                             
3003AC                   PARM                    Z1COMA                                             
3003AC                   EVAL      X0CIAS=S0CIAS                                                    
3003AC                   EVAL      X0DLGA=S0DLGA                                                    
3003AC                   EVAL      X0NPCO=S0NPCO                                                    
3003AC                   EVAL      X0TPED=S0TPED                                                    
3003AC                   EVAL      X0DATP=S0DATP                                                    
3003AC                   EVAL      X0NOPL=S0NOPL                                                    
3003AC                   EVAL      X0LINE=0                                                         
3003AC                   EVAL      X0STCO=S0STCO                                                    
3003AC                   EVAL      X0IMPR='1'                                                       
3003A* Intenteremos reservar lo que podamos.                                                       
3003AC                   EVAL      X0RESE='0'                                                       
3003AC                   EVAL      X0CANR=0                                                         
3003A                                                                                               
3003AC                   CLEAR                   Z1COMA                                             
3003AC     CO2628        CAT       Z1COMA:0      Z1COMA                                             
3003AC                   EVAL      JOLINE=99                                                        
3003AC                   CALL      'PRD935'                                                         
3003AC                   PARM                    JOTRAT                                             
3003AC                   PARM                    JOLINE                                             
3003AC                   PARM                    Z1COMA                                             
3003A                                                                                               
3003AC                   EVAL      @PEPRG2='CO2628'                                                 
3003A * Sometiendo la reserva                                                                       
3003AC                   Z-ADD     100           ZXLOGC           15 5                              
3003AC                   MOVE      *BLANKS       ZXQCM2          150                                
3003AC                   MOVEL     'SBMJOB'      ZXQCM2                                             
3003AC     ZXQCM2        CAT       'CMD(':1      ZXQCM2                                             
3003AC     ZXQCM2        CAT       'CALL (':0    ZXQCM2                                             
3003AC     ZXQCM2        CAT       'PRDGJ8':0    ZXQCM2                                             
3003AC     ZXQCM2        CAT       'CL)':0       ZXQCM2                                             
3003AC     ZXQCM2        CAT       'PARM(':1     ZXQCM2                                             
3003AC     ZXQCM2        CAT       C:0           ZXQCM2                                             
3003AC     ZXQCM2        CAT       JOTRAT:0      ZXQCM2                                             
3003AC     ZXQCM2        CAT       C:0           ZXQCM2                                             
3003AC     ZXQCM2        CAT       C:1           ZXQCM2                                             
3003AC     ZXQCM2        CAT       @PEPRG2:0     ZXQCM2                                             
3003AC     ZXQCM2        CAT       C:0           ZXQCM2                                             
3003AC     ZXQCM2        CAT       C:1           ZXQCM2                                             
3003AC     ZXQCM2        CAT       C:1           ZXQCM2                                             
3003AC     ZXQCM2        CAT       ')':0         ZXQCM2                                             
3003AC     ZXQCM2        CAT       ')':0         ZXQCM2                                             
3003AC     ZXQCM2        CAT       'JOB(':1      ZXQCM2                                             
3003AC     ZXQCM2        CAT       @PEPRG2:0     ZXQCM2                                             
3003AC     ZXQCM2        CAT       ')':0         ZXQCM2                                             
3003AC     ZXQCM2        CAT       'JOBQ(':1     ZXQCM2                                             
3003AC     ZXQCM2        CAT       ZZJDIR:0      ZXQCM2                                             
3003AC     ZXQCM2        CAT       ')':0         ZXQCM2                                             
3003A                                                                                               
3003AC                   CALL      'QCMDEXC'                                                        
3003AC                   PARM                    ZXQCM2                                             
3003AC                   PARM                    ZXLOGC                                             
3003AC                   ENDSR                                                                      
14062 **************************************************************                                
14062 * DESENCRIPTADOR DE DIRECCIONES                              *                                
14062 *------------------------------------------------------------*                                
14062C     CS_DECRI2     BEGSR                                                                      
14062                                                                                               
14062 * Si nos devuelve todos los registros en blanco es que la                                     
14062 *dirección estaba desencriptada y debemos grabarla a tipo '1'                                 
14062 *para que se pueda aparecer en los listados de preparación de                                 
14062 *la compañia.                                                                                 
14062C                   IF        WK_S2RAOS=*BLANKS                                                
14062C                   EVAL      WK_S2RAOS=S2RAOS                                                 
14062C                   ENDIF                                                                      
14062C                   IF        WK_S2RAO2=*BLANKS                                                
14062C                   EVAL      WK_S2RAO2=S2RAO2                                                 
14062C                   ENDIF                                                                      
14062C                   IF        WK_S2DPTO=*BLANKS                                                
14062C                   EVAL      WK_S2DPTO=S2DPTO                                                 
14062C                   ENDIF                                                                      
14062C                   IF        WK_S2DIRE=*BLANKS                                                
14062C                   EVAL      WK_S2DIRE=S2DIRE                                                 
14062C                   ENDIF                                                                      
14062C                   IF        WK_S2DIR2=*BLANKS                                                
14062C                   EVAL      WK_S2DIR2=S2DIR2                                                 
14062C                   ENDIF                                                                      
14062C                   IF        WK_S2POBL=*BLANKS                                                
14062C                   EVAL      WK_S2POBL=S2POBL                                                 
14062C                   ENDIF                                                                      
14062C                   IF        WK_S2POST=*BLANKS                                                
14062C                   EVAL      WK_S2POST=S2POST                                                 
14062C                   ENDIF                                                                      
14062C*                  IF        WK_S2TELE=*BLANKS                                                
14062C*                  EVAL      WK_S2TELE=S2TELE                                                 
14062C*                  ENDIF                                                                      
14062C*                  IF        WK_S2TEL2=*BLANKS                                                
14062C*                  EVAL      WK_S2TEL2=S2TEL2                                                 
14062C*                  ENDIF                                                                      
14062C*                  IF        WK_S2TLEX=*BLANKS                                                
14062C*                  EVAL      WK_S2TLEX=S2TLEX                                                 
14062C*                  ENDIF                                                                      
14062C*                  IF        WK_S2TFAX=*BLANKS                                                
14062C*                  EVAL      WK_S2TFAX=S2TFAX                                                 
14062C*                  ENDIF                                                                      
14062C                   IF        WK_S2EMAI=*BLANKS                                                
14062C                   EVAL      WK_S2EMAI=S2EMAI                                                 
14062C                   ENDIF                                                                      
14062C                   IF        WK_S2PAIS=*BLANKS                                                
14062C                   EVAL      WK_S2PAIS=S2PAIS                                                 
14062C                   ENDIF                                                                      
14062C*                  IF        WK_S2PEGE=*BLANKS                                                
14062C*                  EVAL      WK_S2PEGE=S2PEGE                                                 
14062C*                  ENDIF                                                                      
14062C                   IF        WK_S2OB50=*BLANKS                                                
14062C                   EVAL      WK_S2OB50=S2OB50                                                 
14062C                   ENDIF                                                                      
14062C                   IF        WK_S2OB51=*BLANKS                                                
14062C                   EVAL      WK_S2OB51=S2OB51                                                 
14062C                   ENDIF                                                                      
14062C                   IF        WK_S2TDVA=*BLANKS                                                
14062C                   EVAL      WK_S2TDVA=S2TDVA                                                 
