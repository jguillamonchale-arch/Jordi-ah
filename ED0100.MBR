13040 **********************************************************************                        
13040 * Autorizar pedido excedido de riesgo en comercial                   *                        
13040 **********************************************************************                        
13040C     CS_COD025     BEGSR                                                                      
13040 *                                                                                             
13040 * Actualizo campos en registro de trazabilidad                                                
13040 *                                                                                             
13040C                   EVAL      S0CIAS=@PCIAS                                                    
13040C                   EVAL      S0DLGA=@PDLGA                                                    
13040C                   EVAL      S0NPCO=@PNPCO                                                    
13040C                   EVAL      S0TPED=@PTPED                                                    
13040C                   EVAL      S0DATP=@PDATP                                                    
13040C                   EVAL      S0NOPL=@PNOPL                                                    
13040C     KCOCAPE       SETLL     CODEPE                                                           
13040C     KCOCAPE       READE(N)  CODEPE                                                           
13040C                   DOW       NOT %EOF(CODEPE)                                                 
13040 *                                                                                             
13040 * Recupero la clave del pedido comercial y actualizo                                          
13040 *                                                                                             
13040C                   EVAL      ZXGRAU=0                                                         
13040C                   EVAL      T0CIAS=S5CIAS                                                    
13040C                   EVAL      T0DLGA=S5DLGA                                                    
13040C                   EVAL      T0NPCO=S5NPCO                                                    
13040C                   EVAL      T0TPED=S5TPED                                                    
13040C                   EVAL      T0DATP=S5DATP                                                    
13040C                   EVAL      T0NOPL=S5NOPL                                                    
13040C                   EVAL      T0LINE=S5LINE                                                    
13040C                   EVAL      T0ARV1=*BLANKS                                                   
13040C                   EVAL      T0COM2=*BLANKS                                                   
13040C     KEDTRLP00X    SETLL     EDTRLP00                                                         
13040C     KEDTRLP00     READE     EDTRLP00                                                         
13040C                   DOW       NOT %EOF(EDTRLP00)                                               
13040 *                                                                                             
13040 * Sólo actúo si tenía riesgo y ahora no lo tiene                                              
13040 *                                                                                             
13040C                   IF        T0RISK=1                                                         
13040C                   EVAL      S0CIAS=@PCIAS                                                    
13040C                   EVAL      S0DLGA=@PDLGA                                                    
13040C                   EVAL      S0NPCO=@PNPCO                                                    
13040C                   EVAL      S0TPED=@PTPED                                                    
13040C                   EVAL      S0DATP=@PDATP                                                    
13040C                   EVAL      S0NOPL=@PNOPL                                                    
13040C     KCOCAPE       CHAIN(N)  COCAPE                                                           
13040C                   IF        %FOUND(COCAPE)                                                   
13040C                             And (S0REXC<'1' Or S0RAUT='1')                                   
13040 *                                                                                             
13040C                   EVAL      T0DWRF=*DATE                                                     
24080C                   TIME                    T0HWRF                                             
C1350C                   EXSR      CS_DESBLQALB                                                     
C1350C*                  EVAL      T0RISK=0                                                         
13040C                   UPDATE    REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
13040 *                                                                                             
13040 * Auditoría sólo para la 1ª línea                                                             
13040 *                                                                                             
13040C                   IF        ZXGRAU=0                                                         
13040C                   EXSR      CS_UPD_EDTRAU                                                    
13040C                   EVAL      ZXGRAU=1                                                         
13040C                   ENDIF                                                                      
13040 *                                                                                             
13040C                   ENDIF                                                                      
13040C                   ENDIF                                                                      
13040 *                                                                                             
13040C     KEDTRLP00     READE     EDTRLP00                                                         
13040C                   ENDDO                                                                      
13040 *                                                                                             
13040 * Posible E-Mail con datos del pedido de ventas                                               
13040 *                                                                                             
13040C                   MOVEL(P)  T0CIAS        @EMCIAA                                            
13040C                   MOVEL(P)  T0DLGA        @EMDLGA                                            
13040C                   MOVEL(P)  T0CUST        @EMCODE                                            
13040C                   MOVEL(P)  T0NPCO        @EMNDOC                                            
13040C                   MOVE      T0DATP        @EMFDOC                                            
13040C                   MOVE      T0LINE        @EMLDOC                                            
13040 *                                                                                             
13040C     KCOCAPE       READE(N)  CODEPE                                                           
13040C                   ENDDO                                                                      
13040 *                                                                                             
13040C                   ENDSR                                                                      
