FQ726 * Busco empresa donde me encuentro                                                            
FQ726C                   EVAL      P7CIAS=@PCIAS                                                    
FQ726C                   EVAL      P7DLGA=@PDLGA                                                    
FQ726C     KPMEMPR       CHAIN     PMEMPR                                                           
                                                                                                    
12041 * Si viene el pedido a blancos salgo del programa                                             
12041C                   IF        @PCIAS=0 Or @PNPCO=*BLANKS                                       
12041C                   GOTO      FINPROG                                                          
12041C                   ENDIF                                                                      
      * Buscar código auditoría en PMTAB2                                                           
      *                                                                                             
FQ726 * Busco descripción error y lleno las series                                                  
FQ726C                   EVAL      NZCTAB='EDAU'                                                    
FQ726C                   EVAL      NZCLTA=@PEDAU                                                    
FQ726C                   EVAL      NZIDIO=P7IDIO                                                    
FQ726C     KMSTRG1       CHAIN     MSTRG1                                                           
FQ726C                   IF        %FOUND(MSTRG1)                                                   
FQ726C                   MOVEL(P)  NZDESC        ZXDESCAUD                                          
20514C                   EVAL      PECTAB='EDAU'                                                    
20514C                   EVAL      PECLTA=@PEDAU                                                    
20514C     KPMTAB2       CHAIN(N)  PMTAB2                             81                            
FQ726C                   ELSE                                                                       
     C                   EVAL      PECTAB='EDAU'                                                    
     C                   EVAL      PECLTA=@PEDAU                                                    
     C     KPMTAB2       CHAIN(N)  PMTAB2                             81                            
FQ726C                   IF        %FOUND(PMTAB2)                                                   
FQ726C                   MOVEL(P)  PEDESC        ZXDESCAUD                                          
FQ726C                   ELSE                                                                       
FQ726C                   MOVEL     *BLANKS       ZXDESCAUD                                          
FQ726C                   ENDIF                                                                      
FQ726C                   ENDIF                                                                      
      *                                                                                             
      *  Si @PTEXT es blanks se recupera el PEDESC de PMTAB2                                        
      *                                                                                             
     C                   IF        @PTEXT=*BLANKS                                                   
FQ726C**                 EVAL      @PTEXT=PEDESC                                                    
FQ726C                   EVAL      @PTEXT=ZXDESCAUD                                                 
     C                   ENDIF                                                                      
      *                                                                                             
      *  Guardo código de E-Mail asociado                                                           
      *                                                                                             
     C                   MOVEL(P)  PEBL65        @EMEVEN                                            
FQ726 * busco parámetros de la comercial                                                            
FQ726C                   EVAL      T3CIAS = @PCIAS                                                  
FQ726C                   EVAL      T3DLGA = @PDLGA                                                  
FQ726C     KEDPARM       CHAIN     EDPARM                                                           
