In192                                                                                               
In192C                   EVAL      ZXLIED=0                                                         
In192C                   EVAL      S0CIAS=@PCIAS                                                    
In192C                   EVAL      S0DLGA=@PDLGA                                                    
In192C                   EVAL      S0NPCO=@PNPCO                                                    
In192C                   EVAL      S0TPED=@PTPED                                                    
In192C                   EVAL      S0DATP=@PDATP                                                    
In192C                   EVAL      S0NOPL=@PNOPL                                                    
In192C     KCOCAPE       SETLL     CODEPE                                                           
In192C     KCOCAPE       READE(N)  CODEPE                                                           
In192C                   DOW       NOT %EOF(CODEPE)                                                 
In192C                   IF        S5TPE4='2'                                                       
In192C                   EVAL      ZXLIED=1                                                         
In192C                   ENDIF                                                                      
In192C     KCOCAPE       READE(N)  CODEPE                                                           
In192C                   ENDDO                                                                      
In192 * Si totes les línies son de EN actualitzem capçalera                                         
In192C                   IF        ZXLIED=0                                                         
In192C                   EVAL      S0CIAS=@PCIAS                                                    
In192C                   EVAL      S0DLGA=@PDLGA                                                    
In192C                   EVAL      S0NPCO=@PNPCO                                                    
In192C                   EVAL      S0TPED=@PTPED                                                    
In192C                   EVAL      S0DATP=@PDATP                                                    
In192C                   EVAL      S0NOPL=@PNOPL                                                    
In192C     KCOCAPE       CHAIN     COCAPE                                                           
In192C                   IF        %FOUND(COCAPE)                                                   
In192C                   EVAL      S0TPE4=' '                                                       
In192C                   UPDATE    RCOCAPE                                                          
In192C                   ENDIF                                                                      
In192C                   ENDIF                                                                      
14N12 * Reclamació GIC                                                                              
14N12C                   EVAL      S5CIAS=@PCIAS                                                    
