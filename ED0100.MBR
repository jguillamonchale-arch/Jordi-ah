      **********************************************************************                        
      * Proceso auditoría 001  Alta línea pedido comercial ED calculada    *                        
      **********************************************************************                        
     C     CS_COD001     BEGSR                                                                      
      *                                                                                             
      * Evento principal: graba el registro básico de una línea ED                                  
      *                                                                                             
      * Recupero datos para completar campos del registro                                           
      *                                                                                             
     C                   EVAL      S0CIAS=@PCIAS                                                    
     C                   EVAL      S0DLGA=@PDLGA                                                    
     C                   EVAL      S0NPCO=@PNPCO                                                    
     C                   EVAL      S0TPED=@PTPED                                                    
     C                   EVAL      S0DATP=@PDATP                                                    
     C                   EVAL      S0NOPL=@PNOPL                                                    
     C     KCOCAPE       CHAIN     COCAPE                                                           
     C                   IF        %FOUND(COCAPE)                                                   
     C                   EVAL      S5CIAS=@PCIAS                                                    
     C                   EVAL      S5DLGA=@PDLGA                                                    
     C                   EVAL      S5NPCO=@PNPCO                                                    
     C                   EVAL      S5TPED=@PTPED                                                    
     C                   EVAL      S5DATP=@PDATP                                                    
     C                   EVAL      S5NOPL=@PNOPL                                                    
     C                   EVAL      S5LINE=@PLINE                                                    
     C     KCODEPE       CHAIN     CODEPE                                                           
     C                   IF        %FOUND(CODEPE)                                                   
      *                                                                                             
     C                   CLEAR                   REDTRLP00                                          
     C                   EVAL      T0EDSN=1                                                         
     C                   MOVEL     'C'           T0EDFC                                             
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   MOVEL(P)  @PDLGA        T0DLGA                                             
     C                   MOVEL(P)  @PNPCO        T0NPCO                                             
     C                   MOVEL(P)  @PTPED        T0TPED                                             
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                   EVAL      T0DWR0=*DATE                                                     
     C                   TIME                    T0HWR0                                             
     C                   MOVEL(P)  SDSUSR        T0UWR0                                             
     C                   EVAL      T0DWRF=T0DWR0                                                    
     C                   EVAL      T0HWRF=T0HWR0                                                    
     C                   MOVEL(P)  '10'          T0EDST                                             
      *                                                                                             
     C                   EVAL      T0ARVM=S5ARTI+S5VARI+S5MODE                                      
     C                   EVAL      T0CANT=S5CANT                                                    
FQ710C                   EXSR      CS_IMPORTE                                                       
FQ710C                   EVAL(H)   T0IMPO=ZXBIMP                                                    
FQ710C                   EVAL      T0MONE=S5MONE                                                    
     C                   EVAL      T0CUST=S0CUST                                                    
     C                   EVAL      T0TDI1=S0TDI1                                                    
      * Grabar                                                                                      
     C                   EVAL      T0TREG=0                                                         
13040 * Si ya viene con riesgo excedido lo marco                                                    
13040C                   IF        S0REXC>='1' And S0RAUT<'1'                                       
13040C                   EVAL      T0RISK=1                                                         
13040C                   ELSE                                                                       
13040C                   EVAL      T0RISK=0                                                         
13040C                   ENDIF                                                                      
C1350C                   EXSR      CS_BLQALB                                                        
19050 * Si ya viene retenido lo marco                                                               
19050C                   IF        S5PHLD>='1'                                                      
19050C                   EVAL      T0PHLD=1                                                         
19050C                   ENDIF                                                                      
24080 * Fecha lanzamiento                                                                           
24080C                   EVAL      T0FLAN=S0FLAN                                                    
24080 * Se da el caso que el evento se dispara antes de upd a COCAPE al                             
24080 * hacer la opción 25.                                                                         
24080C                   IF        T0FLAN=0                                                         
24080C                   EVAL      T0FLAN=*DATE                                                     
24080C                   ENDIF                                                                      
24080 * Fecha solicitada cliente                                                                    
24080C                   EVAL      T0FREP=S5FREP                                                    
24080 * Datos coenvio                                                                               
NAP45* Si coenvio tipo 3, grabamos coenvío en blanco                                               
NAP45C                   IF        S0COEN='3'                                                       
NAP45C                   EVAL      S5NCOE=''                                                        
NAP45C                   EVAL      S5NCOI=''                                                        
NAP45C                   EVAL      S5NCOF=''                                                        
NAP45C                   ENDIF                                                                      
24080C                   EVAL      T0NCOE=S5NCOE                                                    
24080C                   EVAL      T0NCOI=S5NCOI                                                    
24080C                   EVAL      T0NCOF=S5NCOF                                                    
24080 * Descripción artículo                                                                        
24080C                   IF        S5DEAP <> ' '                                                    
24080C                   EVAL      T0DES1=S5DEAP                                                    
24080C                   ELSE                                                                       
24080C                   EVAL      T0DES1=S5DES1                                                    
24080C                   ENDIF                                                                      
24080 * Unidad medida y factores de conversión                                                      
24080C                   EVAL      T0UNIM=S5UNIM                                                    
24080C                   EXSR      CS_UNITS                                                         
24080 * Cantidad servida desde Delegación                                                           
24080C                   EXSR      CS_CANDLGA                                                       
FQ607 * Nº Incidencia web Trace                                                                     
FQ607C                   IF        S0INFD <> *BLANKS                                                
IT227C*FQ607             MOVEL     S0INFD        T0INFD                                             
FQ607C                   MOVEL     S5LINI        T0LINI                                             
FQ607C                   ENDIF                                                                      
14N12 * Reclamació GIC                                                                              
14N12C                   EVAL      ZXPEFD='1'                                                       
14N12C                   EXSR      CS_TRZGIC                                                        
20100 * Cargo Portes                                                                                
20100C                   EXSR      CS_CARGPORT                                                      
FQ726 * Miro si tiene parámetro logística si es para servir desde Productiva                        
FQ726C                   IF        T3LOGI='1'                                                       
FQ726C                   EXSR      CS_LOGISTI                                                       
FQ726C                   ENDIF                                                                      
      *Si el registro ya existe evitaré crealo de nuevo para evitar                                 
      *duplicados entre los códigos 001 y 002.                                                      
     C     KEDTRLP00     CHAIN     EDTRLP00                                                         
     C                   IF        NOT %FOUND(EDTRLP00)                                             
21050C                   WRITE     REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDIF                                                                      
      *                                                                                             
      * Actualizo datos del pedido                                                                  
      *                                                                                             
     C                   EVAL      S0TPE4='2'                                                       
     C                   UPDATE    RCOCAPE                                                          
     C                   EVAL      S5TPE4='2'                                                       
     C                   UPDATE    RCODEPE                                                          
      *                                                                                             
      * Auditoría                                                                                   
      *                                                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de venta                                                
      *                                                                                             
     C                   MOVEL(P)  T0CIAS        @EMCIAA                                            
     C                   MOVEL(P)  T0DLGA        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPCO        @EMNDOC                                            
     C                   MOVE      T0DATP        @EMFDOC                                            
     C                   MOVE      T0LINE        @EMLDOC                                            
      *                                                                                             
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 002  Alta línea pedido comercial ED forzada      *                        
      **********************************************************************                        
     C     CS_COD002     BEGSR                                                                      
      *                                                                                             
      * Evento principal: graba el registro básico de una línea ED                                  
      * No se graba auditoría                                                                       
      *                                                                                             
      * Recupero datos para completar campos del registro                                           
      *                                                                                             
     C                   EVAL      S0CIAS=@PCIAS                                                    
     C                   EVAL      S0DLGA=@PDLGA                                                    
     C                   EVAL      S0NPCO=@PNPCO                                                    
     C                   EVAL      S0TPED=@PTPED                                                    
     C                   EVAL      S0DATP=@PDATP                                                    
     C                   EVAL      S0NOPL=@PNOPL                                                    
     C     KCOCAPE       CHAIN     COCAPE                                                           
     C                   IF        %FOUND(COCAPE)                                                   
     C                   EVAL      S5CIAS=@PCIAS                                                    
     C                   EVAL      S5DLGA=@PDLGA                                                    
     C                   EVAL      S5NPCO=@PNPCO                                                    
     C                   EVAL      S5TPED=@PTPED                                                    
     C                   EVAL      S5DATP=@PDATP                                                    
     C                   EVAL      S5NOPL=@PNOPL                                                    
     C                   EVAL      S5LINE=@PLINE                                                    
     C     KCODEPE       CHAIN     CODEPE                                                           
     C                   IF        %FOUND(CODEPE)                                                   
      *                                                                                             
     C                   CLEAR                   REDTRLP00                                          
     C                   EVAL      T0EDSN=1                                                         
     C                   MOVEL     'F'           T0EDFC                                             
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   MOVEL(P)  @PDLGA        T0DLGA                                             
     C                   MOVEL(P)  @PNPCO        T0NPCO                                             
     C                   MOVEL(P)  @PTPED        T0TPED                                             
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                   EVAL      T0DWR0=*DATE                                                     
     C                   TIME                    T0HWR0                                             
     C                   MOVEL(P)  SDSUSR        T0UWR0                                             
     C                   EVAL      T0DWRF=T0DWR0                                                    
     C                   EVAL      T0HWRF=T0HWR0                                                    
     C                   MOVEL(P)  '10'          T0EDST                                             
      *                                                                                             
     C                   EVAL      T0ARVM=S5ARTI+S5VARI+S5MODE                                      
     C                   EVAL      T0CANT=S5CANT                                                    
FQ710C                   EXSR      CS_IMPORTE                                                       
FQ710C                   EVAL(H)   T0IMPO=ZXBIMP                                                    
FQ710C                   EVAL      T0MONE=S5MONE                                                    
     C                   EVAL      T0CUST=S0CUST                                                    
     C                   EVAL      T0TDI1=S0TDI1                                                    
13040 * Si ya viene con riesgo excedido lo marco                                                    
13040C                   IF        S0REXC>='1' And S0RAUT<'1'                                       
13040C                   EVAL      T0RISK=1                                                         
13040C                   ELSE                                                                       
13040C                   EVAL      T0RISK=0                                                         
13040C                   ENDIF                                                                      
C1350C                   EXSR      CS_BLQALB                                                        
19050 * Si ya viene retenido lo marco                                                               
19050C                   IF        S5PHLD>='1'                                                      
19050C                   EVAL      T0PHLD=1                                                         
19050C                   ENDIF                                                                      
24080 * Fecha lanzamiento                                                                           
24080C                   EVAL      T0FLAN=S0FLAN                                                    
24080 * Se da el caso que el evento se dispara antes de upd a COCAPE al                             
24080 * hacer la opción 25.                                                                         
24080C                   IF        T0FLAN=0                                                         
24080C                   EVAL      T0FLAN=*DATE                                                     
24080C                   ENDIF                                                                      
24080 * Fecha solicitada cliente                                                                    
24080C                   EVAL      T0FREP=S5FREP                                                    
24080 * Datos coenvio                                                                               
NAP45* Si coenvio tipo 3, grabamos coenvío en blanco                                               
NAP45C                   IF        S0COEN='3'                                                       
NAP45C                   EVAL      S5NCOE=''                                                        
NAP45C                   EVAL      S5NCOI=''                                                        
NAP45C                   EVAL      S5NCOF=''                                                        
NAP45C                   ENDIF                                                                      
24080C                   EVAL      T0NCOE=S5NCOE                                                    
24080C                   EVAL      T0NCOI=S5NCOI                                                    
24080C                   EVAL      T0NCOF=S5NCOF                                                    
24080 * Descripción artículo                                                                        
24080C                   IF        S5DEAP <> ' '                                                    
24080C                   EVAL      T0DES1=S5DEAP                                                    
24080C                   ELSE                                                                       
24080C                   EVAL      T0DES1=S5DES1                                                    
24080C                   ENDIF                                                                      
24080 * Unidad medida y factores de conversión                                                      
