     C                   ENDIF                                                                      
      *                                                                                             
     C     KEDTRLP00     READE     EDTRLP00                                                         
     C                   ENDDO                                                                      
      *                                                                                             
      * Posible E-Mail con datos del pedido de ventas                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIAS        @EMCIAA                                            
     C                   MOVEL(P)  T0DLGA        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPCO        @EMNDOC                                            
     C                   MOVE      T0DATP        @EMFDOC                                            
     C                   MOVE      T0LINE        @EMLDOC                                            
      *                                                                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Cerrar línea en pedido comercial                                   *                        
      **********************************************************************                        
     C     CS_COD018     BEGSR                                                                      
      *                                                                                             
      * Recupero la clave del pedido comercial y elimino todo                                       
      *                                                                                             
     C                   EVAL      ZXGRAU=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                   EVAL      T0ARV1=*BLANKS                                                   
     C                   EVAL      T0COM2=*BLANKS                                                   
      *                                                                                             
     C     KEDTRLP00X    SETLL     EDTRLP00                                                         
     C     KEDTRLP00     READE     EDTRLP00                                                         
     C                   DOW       NOT %EOF(EDTRLP00)                                               
      *                                                                                             
      * Si tiene compra asociada, dejo que sea el evento de                                         
      * compras el que haga la eliminación                                                          
      *                                                                                             
     C                   IF        T0ARV1=*BLANKS                                                   
     C                   EVAL      T0EDST='95'                                                      
     C                   EVAL      T0MODI=1                                                         
     C                   UPDATE    REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDIF                                                                      
      *                                                                                             
      * Auditoría                                                                                   
      *                                                                                             
     C                   IF        ZXGRAU=0                                                         
     C                   EXSR      CS_UPD_EDTRAU                                                    
     C                   EVAL      ZXGRAU=1                                                         
     C                   ENDIF                                                                      
      *                                                                                             
     C     KEDTRLP00     READE     EDTRLP00                                                         
     C                   ENDDO                                                                      
      *                                                                                             
      * En este caso cierro todas las auditorias relacionadas                                       
      *                                                                                             
     C                   CLEAR                   T1ARV1                                             
     C                   CLEAR                   T1COM2                                             
     C                   CLEAR                   T1EDAU                                             
     C                   CLEAR                   T1DATR                                             
     C                   CLEAR                   T1HORR                                             
     C                   CLEAR                   T1TMST                                             
     C     KEDTRAU00     SETLL     EDTRAU00                                                         
     C     KEDTRAU00X    READE     EDTRAU00                                                         
     C                   DOW       NOT %EOF(EDTRAU00)                                               
      *                                                                                             
      * Si tiene compra asociada, dejo que sea el evento de                                         
      * compras el que cierre                                                                       
      *                                                                                             
     C                   IF        T1ARV1=*BLANKS                                                   
     C                   EVAL      T1STUL='5'                                                       
     C                   UPDATE    REDTRAU00                                                        
     C                   ENDIF                                                                      
      *                                                                                             
     C     KEDTRAU00X    READE     EDTRAU00                                                         
     C                   ENDDO                                                                      
      *                                                                                             
      * Posible E-Mail con datos del pedido de ventas                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIAS        @EMCIAA                                            
     C                   MOVEL(P)  T0DLGA        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPCO        @EMNDOC                                            
     C                   MOVE      T0DATP        @EMFDOC                                            
     C                   MOVE      T0LINE        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Reabrir línea comercial                                                                     
      **********************************************************************                        
     C     CS_COD019     BEGSR                                                                      
      *                                                                                             
      * Reabrimos la línea simplemente cambiando el estado                                          
      *                                                                                             
     C                   EVAL      ZXGRAU=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                   EVAL      T0ARV1=*BLANKS                                                   
     C                   EVAL      T0COM2=*BLANKS                                                   
      *                                                                                             
     C     KEDTRLP00X    SETLL     EDTRLP00                                                         
     C     KEDTRLP00     READE     EDTRLP00                                                         
     C                   DOW       NOT %EOF(EDTRLP00)                                               
      *                                                                                             
     C                   EVAL      T0DWRF=T0DWR0                                                    
     C                   EVAL      T0HWRF=T0HWR0                                                    
     C                   EVAL      T0EDST='20'                                                      
     C                   EVAL      T0MODI=1                                                         
     C                   UPDATE    REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
      *                                                                                             
      * Auditoría                                                                                   
      *                                                                                             
     C                   IF        ZXGRAU=0                                                         
     C                   EXSR      CS_UPD_EDTRAU                                                    
     C                   EVAL      ZXGRAU=1                                                         
     C                   ENDIF                                                                      
      *                                                                                             
     C     KEDTRLP00     READE     EDTRLP00                                                         
     C                   ENDDO                                                                      
      *                                                                                             
      * Posible E-Mail con datos del pedido de venta                                                
      *                                                                                             
     C                   MOVEL(P)  T0CIAS        @EMCIAA                                            
     C                   MOVEL(P)  T0DLGA        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPCO        @EMNDOC                                            
     C                   MOVE      T0DATP        @EMFDOC                                            
     C                   MOVE      T0LINE        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Desautorizar ED productiva                                         *                        
      **********************************************************************                        
     C     CS_COD020     BEGSR                                                                      
      *                                                                                             
      * Actualizo campos en registro de trazabilidad                                                
      *                                                                                             
     C                   EVAL      S5CIAS=@PCIAS                                                    
     C                   EVAL      S5DLGA=@PDLGA                                                    
     C                   EVAL      S5NPCO=@PNPCO                                                    
     C                   EVAL      S5TPED=@PTPED                                                    
     C                   EVAL      S5DATP=@PDATP                                                    
     C                   EVAL      S5NOPL=@PNOPL                                                    
     C                   EVAL      S5LINE=@PLINE                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
     C                   IF        %FOUND(CODEPE)                                                   
      *                                                                                             
      * Recupero la clave del pedido comercial y actualizo                                          
      *                                                                                             
     C                   EVAL      ZXGRAU=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                   EVAL      T0ARV1=*BLANKS                                                   
     C                   EVAL      T0COM2=*BLANKS                                                   
     C     KEDTRLP00X    SETLL     EDTRLP00                                                         
     C     KEDTRLP00     READE     EDTRLP00                                                         
     C                   DOW       NOT %EOF(EDTRLP00)                                               
      *                                                                                             
     C                   EVAL      T0DWRF=*DATE                                                     
24080C                   TIME                    T0HWRF                                             
     C                   EVAL      T0EDDP=0                                                         
     C                   UPDATE    REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
      *                                                                                             
      * Auditoría sólo para la 1ª línea                                                             
      *                                                                                             
     C                   IF        ZXGRAU=0                                                         
     C                   EXSR      CS_UPD_EDTRAU                                                    
     C                   EVAL      ZXGRAU=1                                                         
     C                   ENDIF                                                                      
      *                                                                                             
     C     KEDTRLP00     READE     EDTRLP00                                                         
     C                   ENDDO                                                                      
      *                                                                                             
      * Posible E-Mail con datos del pedido de ventas                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIAS        @EMCIAA                                            
     C                   MOVEL(P)  T0DLGA        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPCO        @EMNDOC                                            
     C                   MOVE      T0DATP        @EMFDOC                                            
     C                   MOVE      T0LINE        @EMLDOC                                            
      *                                                                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Cancelar confirmación de pedido comercial                          *                        
      **********************************************************************                        
     C     CS_COD021     BEGSR                                                                      
      *                                                                                             
      * Sólo puedo enviar E-Mail ya que no hay trazabilidad                                         
      *                                                                                             
     C                   MOVEL(P)  T0CIAS        @EMCIAA                                            
     C                   MOVEL(P)  T0DLGA        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPCO        @EMNDOC                                            
     C                   MOVE      T0DATP        @EMFDOC                                            
     C                   MOVE      T0LINE        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * ED no creada porque falta precio de compra                         *                        
      **********************************************************************                        
     C     CS_COD022     BEGSR                                                                      
In214 *                                                                                             
In214 * Recupero la clave del pedido comercial y actualizo                                          
In214C                   EVAL      ZXGRAU=0                                                         
In214C                   EVAL      T0CIAS=@PCIAS                                                    
In214C                   EVAL      T0DLGA=@PDLGA                                                    
In214C                   EVAL      T0NPCO=@PNPCO                                                    
In214C                   EVAL      T0TPED=@PTPED                                                    
In214C                   EVAL      T0DATP=@PDATP                                                    
In214C                   EVAL      T0NOPL=@PNOPL                                                    
In214C                   EVAL      T0LINE=@PLINE                                                    
In214C                   EVAL      T0ARV1=*BLANKS                                                   
In214C                   EVAL      T0COM2=*BLANKS                                                   
In214C     KEDTRLP00X    SETLL     EDTRLP00                                                         
In214C     KEDTRLP00     READE(N)  EDTRLP00                                                         
In214C                   DOW       NOT %EOF(EDTRLP00)                                               
In214 *                                                                                             
In214 * Auditoría sólo para la 1ª línea                                                             
In214C                   IF        ZXGRAU=0                                                         
In214C                   EXSR      CS_UPD_EDTRAU                                                    
In214C                   EVAL      ZXGRAU=1                                                         
In214C                   ENDIF                                                                      
In214 *                                                                                             
