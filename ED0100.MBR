      **********************************************************************                        
      * Anular línea en pedido comercial                                   *                        
      **********************************************************************                        
     C     CS_COD005     BEGSR                                                                      
      *                                                                                             
      * Recupero la clave del pedido comercial y elimino todo                                       
      *                                                                                             
     C                   EVAL      ZXGRAU=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                   EVAL      T0ARV1=*BLANKS                                                   
     C                   EVAL      T0COM2=*BLANKS                                                   
      *                                                                                             
     C     KEDTRLP00X    SETLL     EDTRLP00                                                         
     C     KEDTRLP00     READE     EDTRLP00                                                         
     C                   DOW       NOT %EOF(EDTRLP00)                                               
      *                                                                                             
     C                   IF        T0ARV1=*BLANKS                                                   
15060C                             AND T0CANS=0                                                     
