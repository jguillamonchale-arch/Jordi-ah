     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Modificar cantidad (-) en pedido compra                            *                        
      **********************************************************************                        
     C     CS_COD107     BEGSR                                                                      
      *                                                                                             
      * Actualizo campos en registro de trazabilidad                                                
      *                                                                                             
     C                   EVAL      C5CIAS=@PCIAS                                                    
     C                   EVAL      C5DLGA=@PDLGA                                                    
     C                   EVAL      C5NPCO=@PNPCO                                                    
     C                   EVAL      C5TPED=@PTPED                                                    
     C                   EVAL      C5DATP=@PDATP                                                    
     C                   EVAL      C5NOPL=@PNOPL                                                    
     C                   EVAL      C5LINE=@PLINE                                                    
     C     KPUDEPE       CHAIN(N)  PUDEPE                                                           
     C                   IF        %FOUND(PUDEPE)                                                   
      *                                                                                             
      * Recupero la clave del pedido de compra                                                      
      *                                                                                             
     C                   EVAL      ZXGRAU=0                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C     KEDTRLP10     READE     EDTRLP10                                                         
     C                   DOW       NOT %EOF(EDTRLP10)                                               
      *                                                                                             
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
     C                   EVAL      T0CAN1=C5CANT                                                    
FQ710C                   EVAL      T0UNI1=C5UNIM                                                    
     C                   UPDATE    REDTRLP10                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
      *                                                                                             
      * Auditoría sólo para la 1ª línea                                                             
      *                                                                                             
     C                   IF        ZXGRAU=0                                                         
     C                   EXSR      CS_UPD_EDTRAU                                                    
     C                   EVAL      ZXGRAU=1                                                         
     C                   ENDIF                                                                      
      *                                                                                             
     C     KEDTRLP10     READE     EDTRLP10                                                         
     C                   ENDDO                                                                      
      *                                                                                             
      * Posible E-Mail con datos del pedido de compras                                              
      *                                                                                             
     C                   MOVEL(P)  T0CIA1        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG1        @EMDLGA                                            
     C                   MOVEL(P)  T0PRVR        @EMCODE                                            
     C                   MOVEL(P)  T0NPC1        @EMNDOC                                            
     C                   MOVE      T0DAT1        @EMFDOC                                            
     C                   MOVE      T0LIN1        @EMLDOC                                            
      *                                                                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Retener línea pedido compra                                        *                        
      **********************************************************************                        
     C     CS_COD108     BEGSR                                                                      
      *                                                                                             
      * Actualizo campos en registro de trazabilidad                                                
      *                                                                                             
     C                   EVAL      C5CIAS=@PCIAS                                                    
     C                   EVAL      C5DLGA=@PDLGA                                                    
     C                   EVAL      C5NPCO=@PNPCO                                                    
     C                   EVAL      C5TPED=@PTPED                                                    
     C                   EVAL      C5DATP=@PDATP                                                    
     C                   EVAL      C5NOPL=@PNOPL                                                    
     C                   EVAL      C5LINE=@PLINE                                                    
     C     KPUDEPE       CHAIN(N)  PUDEPE                                                           
     C                   IF        %FOUND(PUDEPE)                                                   
      *                                                                                             
      * Recupero la clave del pedido de compra                                                      
      *                                                                                             
     C                   EVAL      ZXGRAU=0                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C     KEDTRLP10     READE     EDTRLP10                                                         
     C                   DOW       NOT %EOF(EDTRLP10)                                               
      *                                                                                             
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
     C                   EVAL      T0PHLD=1                                                         
     C                   UPDATE    REDTRLP10                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
      *                                                                                             
      * Auditoría sólo para la 1ª línea                                                             
      *                                                                                             
     C                   IF        ZXGRAU=0                                                         
     C                   EXSR      CS_UPD_EDTRAU                                                    
     C                   EVAL      ZXGRAU=1                                                         
     C                   ENDIF                                                                      
      *                                                                                             
     C     KEDTRLP10     READE     EDTRLP10                                                         
     C                   ENDDO                                                                      
      *                                                                                             
      * Posible E-Mail con datos del pedido de compras                                              
      *                                                                                             
     C                   MOVEL(P)  T0CIA1        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG1        @EMDLGA                                            
     C                   MOVEL(P)  T0PRVR        @EMCODE                                            
     C                   MOVEL(P)  T0NPC1        @EMNDOC                                            
     C                   MOVE      T0DAT1        @EMFDOC                                            
     C                   MOVE      T0LIN1        @EMLDOC                                            
      *                                                                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Cambiar línea en compra ED -> EN                                   *                        
      **********************************************************************                        
     C     CS_COD109     BEGSR                                                                      
      *                                                                                             
      * Es como una anulación de línea                                                              
      * Recupero la clave del pedido de compra y actualizo                                          
      *                                                                                             
     C                   EVAL      ZXGRAU=0                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C     KEDTRLP10     READE     EDTRLP10                                                         
     C                   DOW       NOT %EOF(EDTRLP10)                                               
15060C                   IF        T0CANS=0                                                         
02060C                   WRITE     REDTRLX00                            80                          
11060C                   DOW       *IN80=*ON                                                        
02060C                   EVAL      T0HWR0 = T0HWR0+1                                                
02060C                   WRITE     REDTRLX00                            80                          
02060C                   ENDDO                                                                      
     C                   DELETE    REDTRLP10                                                        
15060C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        ZXGRAU=0                                                         
     C                   EXSR      CS_UPD_EDTRAU                                                    
     C                   EVAL      ZXGRAU=1                                                         
     C                   ENDIF                                                                      
      *                                                                                             
     C     KEDTRLP10     READE     EDTRLP10                                                         
     C                   ENDDO                                                                      
      *                                                                                             
      * En este caso cierro todas las auditorias relacionadas                                       
      *                                                                                             
     C     KEDTRLP00X    SETLL     EDTRAU00                                                         
     C     KEDTRLP00X    READE     EDTRAU00                                                         
     C                   DOW       NOT %EOF(EDTRAU00)                                               
02060C                   DOU       *IN80=*OFF                                                       
02060C                   EVAL      ZXTIM1 = %TIMESTAMP()                                            
02060C                   MOVEL     ZXTIM1        ZXTIMESTAMP                                        
02060C                   MOVEL     ZXTIMESTAMP   T1TMST                                             
02060C                   WRITE     REDTRAX00                            80                          
02060C                   ENDDO                                                                      
     C                   DELETE    REDTRAU00                                                        
     C     KEDTRLP00X    READE     EDTRAU00                                                         
     C                   ENDDO                                                                      
      *                                                                                             
      * Posible E-Mail con datos del pedido de compras                                              
      *                                                                                             
     C                   MOVEL(P)  T0CIA1        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG1        @EMDLGA                                            
     C                   MOVEL(P)  T0PRVR        @EMCODE                                            
     C                   MOVEL(P)  T0NPC1        @EMNDOC                                            
     C                   MOVE      T0DAT1        @EMFDOC                                            
     C                   MOVE      T0LIN1        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Cambiar línea en compra EN -> ED                                   *                        
      **********************************************************************                        
     C     CS_COD110     BEGSR                                                                      
      *                                                                                             
      * Recupero la clave del pedido de compras y luego el pedido de ventas                         
      *                                                                                             
     C                   EVAL      C0CIAS=@PCIAS                                                    
     C                   EVAL      C0DLGA=@PDLGA                                                    
     C                   EVAL      C0NPCO=@PNPCO                                                    
     C                   EVAL      C0TPED=@PTPED                                                    
     C                   EVAL      C0DATP=@PDATP                                                    
     C                   EVAL      C0NOPL=@PNOPL                                                    
     C     KPUCAPE       CHAIN     PUCAPE                                                           
     C                   IF        %FOUND(PUCAPE)                                                   
     C                   EVAL      C5CIAS=@PCIAS                                                    
     C                   EVAL      C5DLGA=@PDLGA                                                    
     C                   EVAL      C5NPCO=@PNPCO                                                    
     C                   EVAL      C5TPED=@PTPED                                                    
     C                   EVAL      C5DATP=@PDATP                                                    
     C                   EVAL      C5NOPL=@PNOPL                                                    
     C                   EVAL      C5LINE=@PLINE                                                    
     C     KPUDEPE       CHAIN     PUDEPE                                                           
     C                   IF        %FOUND(PUDEPE)                                                   
     C                   MOVEL     C5CIVE        S0CIAS                                             
     C                   EVAL      S0DLGA=C5DLVE                                                    
     C                   EVAL      S0NPCO=C5NPVE                                                    
     C                   EVAL      S0TPED=C5TPVE                                                    
     C                   EVAL      S0DATP=C5DAVE                                                    
     C                   EVAL      S0NOPL=C5NOVE                                                    
     C     KCOCAPE       CHAIN(N)  COCAPE                                                           
     C                   IF        %FOUND(COCAPE)                                                   
     C                   MOVEL     C5CIVE        S5CIAS                                             
     C                   EVAL      S5DLGA=C5DLVE                                                    
     C                   EVAL      S5NPCO=C5NPVE                                                    
     C                   EVAL      S5TPED=C5TPVE                                                    
     C                   EVAL      S5DATP=C5DAVE                                                    
     C                   EVAL      S5NOPL=C5NOVE                                                    
     C                   EVAL      S5LINE=C5LIVE                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
     C                   IF        %FOUND(CODEPE)                                                   
      *                                                                                             
      * Si es una entrega directa actuo                                                             
      *                                                                                             
     C                   IF        S5TPE4='2'                                                       
      *                                                                                             
      * Actualizo datos del pedido de compras                                                       
      *                                                                                             
     C                   EVAL      C0TPE4='2'                                                       
     C                   UPDATE    RPUCAPE                                                          
     C                   EVAL      C5TPE4='2'                                                       
     C                   UPDATE    RPUDEPE                                                          
      *                                                                                             
      * Actualizo datos del pedido de compras desde la 1ª línea original                            
      * si T0ARV1 Y T0COM2 aún están a *blanks                                                      
      *                                                                                             
     C                   EVAL      T0CIAS=S5CIAS                                                    
