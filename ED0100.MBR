24080C                   EXSR      CS_UNITS                                                         
24080 * Cantidad servida desde Delegación                                                           
24080C                   EXSR      CS_CANDLGA                                                       
FQ607 * Nº Incidencia web Trace                                                                     
FQ607C                   IF        S0INFD <> *BLANKS                                                
IT227C*FQ607             MOVEL     S0INFD        T0INFD                                             
FQ607C                   MOVEL     S5LINI        T0LINI                                             
FQ607C                   ENDIF                                                                      
14N12 * Reclamació GIC                                                                              
14N12C                   EVAL      ZXPEFD='1'                                                       
14N12C                   EXSR      CS_TRZGIC                                                        
20100 * Cargo Portes                                                                                
20100C                   EXSR      CS_CARGPORT                                                      
FQ726 * Miro si tiene parámetro logística si es para servir desde Productiva                        
FQ726C                   IF        T3LOGI='1'                                                       
FQ726C                   EXSR      CS_LOGISTI                                                       
FQ726C                   ENDIF                                                                      
      * Grabar                                                                                      
     C                   EVAL      T0TREG=0                                                         
      *Si el registro ya existe evitaré crealo de nuevo para evitar                                 
      *duplicados entre los códigos 001 y 002.                                                      
     C     KEDTRLP00     CHAIN     EDTRLP00                                                         
     C                   IF        NOT %FOUND(EDTRLP00)                                             
21050C                   WRITE     REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDIF                                                                      
      *                                                                                             
      * Actualizo datos del pedido (Ya deberían estar así)                                          
      *                                                                                             
     C                   EVAL      S0TPE4='2'                                                       
     C                   UPDATE    RCOCAPE                                                          
     C                   EVAL      S5TPE4='2'                                                       
     C                   UPDATE    RCODEPE                                                          
      *                                                                                             
      * Auditoría                                                                                   
      *                                                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de venta                                                
      *                                                                                             
     C                   MOVEL(P)  T0CIAS        @EMCIAA                                            
     C                   MOVEL(P)  T0DLGA        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPCO        @EMNDOC                                            
     C                   MOVE      T0DATP        @EMFDOC                                            
     C                   MOVE      T0LINE        @EMLDOC                                            
      *                                                                                             
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
