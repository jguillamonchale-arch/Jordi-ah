     C                   EVAL      C5DLGA=@PDLGA                                                    
     C                   EVAL      C5NPCO=@PNPCO                                                    
     C                   EVAL      C5TPED=@PTPED                                                    
     C                   EVAL      C5DATP=@PDATP                                                    
     C                   EVAL      C5NOPL=@PNOPL                                                    
     C                   EVAL      C5LINE=@PLINE                                                    
     C     KPUDEPE       CHAIN(N)  PUDEPE                                                           
     C                   IF        %FOUND(PUDEPE)                                                   
      *                                                                                             
      * Recupero la clave del pedido de compra                                                      
      *                                                                                             
     C                   EVAL      ZXGRAU=0                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C     KEDTRLP10     READE     EDTRLP10                                                         
     C                   DOW       NOT %EOF(EDTRLP10)                                               
      *                                                                                             
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
     C                   UPDATE    REDTRLP10                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
      *                                                                                             
      * Auditoría sólo para la 1ª línea                                                             
      *                                                                                             
     C                   IF        ZXGRAU=0                                                         
     C                   EXSR      CS_UPD_EDTRAU                                                    
     C                   EVAL      ZXGRAU=1                                                         
     C                   ENDIF                                                                      
      *                                                                                             
     C     KEDTRLP10     READE     EDTRLP10                                                         
     C                   ENDDO                                                                      
      *                                                                                             
      * Posible E-Mail con datos del pedido de compras                                              
      *                                                                                             
     C                   MOVEL(P)  T0CIA1        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG1        @EMDLGA                                            
     C                   MOVEL(P)  T0PRVR        @EMCODE                                            
     C                   MOVEL(P)  T0NPC1        @EMNDOC                                            
     C                   MOVE      T0DAT1        @EMFDOC                                            
     C                   MOVE      T0LIN1        @EMLDOC                                            
      *                                                                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
19050 **********************************************************************                        
19050 * DesRetener línea pedido compra                                     *                        
19050 **********************************************************************                        
19050C     CS_COD121     BEGSR                                                                      
19050 *                                                                                             
19050 * Actualizo campos en registro de trazabilidad                                                
19050 *                                                                                             
19050C                   EVAL      C5CIAS=@PCIAS                                                    
19050C                   EVAL      C5DLGA=@PDLGA                                                    
19050C                   EVAL      C5NPCO=@PNPCO                                                    
19050C                   EVAL      C5TPED=@PTPED                                                    
19050C                   EVAL      C5DATP=@PDATP                                                    
19050C                   EVAL      C5NOPL=@PNOPL                                                    
19050C                   EVAL      C5LINE=@PLINE                                                    
19050C     KPUDEPE       CHAIN(N)  PUDEPE                                                           
19050C                   IF        %FOUND(PUDEPE)                                                   
19050 *                                                                                             
19050 * Recupero la clave del pedido de compra                                                      
19050 *                                                                                             
19050C                   EVAL      ZXGRAU=0                                                         
19050C                   EVAL      T0CIA1=@PCIAS                                                    
19050C                   EVAL      T0DLG1=@PDLGA                                                    
19050C                   EVAL      T0NPC1=@PNPCO                                                    
19050C                   EVAL      T0TPE1=@PTPED                                                    
19050C                   EVAL      T0DAT1=@PDATP                                                    
19050C                   EVAL      T0NOP1=@PNOPL                                                    
19050C                   EVAL      T0LIN1=@PLINE                                                    
19050C     KEDTRLP10     SETLL     EDTRLP10                                                         
19050C     KEDTRLP10     READE     EDTRLP10                                                         
19050C                   DOW       NOT %EOF(EDTRLP10)                                               
19050 *                                                                                             
19050C                   EVAL      T0DWRF=*DATE                                                     
19050C                   TIME                    T0HWRF                                             
19050C                   EVAL      T0PHLD=0                                                         
19050C                   UPDATE    REDTRLP10                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
19050 *                                                                                             
19050 * Auditoría sólo para la 1ª línea                                                             
19050 *                                                                                             
19050C                   IF        ZXGRAU=0                                                         
19050C                   EXSR      CS_UPD_EDTRAU                                                    
19050C                   EVAL      ZXGRAU=1                                                         
19050C                   ENDIF                                                                      
19050 *                                                                                             
19050C     KEDTRLP10     READE     EDTRLP10                                                         
19050C                   ENDDO                                                                      
19050 *                                                                                             
19050 * Posible E-Mail con datos del pedido de compras                                              
19050 *                                                                                             
19050C                   MOVEL(P)  T0CIA1        @EMCIAA                                            
19050C                   MOVEL(P)  T0DLG1        @EMDLGA                                            
19050C                   MOVEL(P)  T0PRVR        @EMCODE                                            
19050C                   MOVEL(P)  T0NPC1        @EMNDOC                                            
19050C                   MOVE      T0DAT1        @EMFDOC                                            
19050C                   MOVE      T0LIN1        @EMLDOC                                            
19050 *                                                                                             
19050C                   ENDIF                                                                      
19050 *                                                                                             
19050C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 201  Alta línea pedido CODEPE en Productiva      *                        
      **********************************************************************                        
     C     CS_COD201     BEGSR                                                                      
      *                                                                                             
      * Recupero la clave del EDTRLP según el parámetro del lógico                                  
      *                                                                                             
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=1                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=2                                                         
     C                   EVAL      T0CIA2=@PCIAS                                                    
     C                   EVAL      T0DLG2=@PDLGA                                                    
     C                   EVAL      T0NPC2=@PNPCO                                                    
     C                   EVAL      T0TPE2=@PTPED                                                    
     C                   EVAL      T0DAT2=@PDATP                                                    
     C                   EVAL      T0NOP2=@PNOPL                                                    
     C                   EVAL      T0LIN2=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=3                                                         
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C                                                                                              
     C                   ENDSL                                                                      
     C                                                                                              
      *                                                                                             
      * Recupero datos del la línea del pedido en la productiva                                     
      *                                                                                             
     C                   EVAL      S5CIAS=@PCIA2                                                    
     C                   EVAL      S5DLGA=@PDLG2                                                    
     C                   EVAL      S5NPCO=@PNPC2                                                    
     C                   EVAL      S5TPED=@PTPE2                                                    
     C                   EVAL      S5DATP=@PDAT2                                                    
     C                   EVAL      S5NOPL=@PNOP2                                                    
     C                   EVAL      S5LINE=@PLIN2                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
     C                                                                                              
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
     C                                                                                              
     C                   EVAL      *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     SETLL     EDTRLP20                                                         
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C                   ENDSL                                                                      
     C                                                                                              
     C                   DOW       *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     READE     EDTRLP00                               82                        
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     READE     EDTRLP10                               82                        
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     READE     EDTRLP30                               82                        
     C                   ENDSL                                                                      
     C                                                                                              
     C                   IF        *IN82=*OFF                                                       
FDX01 *                                                                                             
FDX01 * Ahora se permiten conjuntos combinados, tenemos que despreciar los                          
FDX01 * componentes de material propio de la comercial y actualizar sólo                            
FDX01 * los que corresponden                                                                        
FDX01 *                                                                                             
FDX01C                   IF        T0PRVR<>*BLANKS                                                  
     C                                                                                              
      * Este evento es un alta de línea en empresa productiva.                                      
      * por tanto actualizo los campos:                                                             
     C                   EVAL      T0CIA2=@PCIA2                                                    
     C                   EVAL      T0DLG2=@PDLG2                                                    
     C                   EVAL      T0NPC2=@PNPC2                                                    
     C                   EVAL      T0TPE2=@PTPE2                                                    
     C                   EVAL      T0DAT2=@PDAT2                                                    
     C                   EVAL      T0NOP2=@PNOP2                                                    
     C                   EVAL      T0LIN2=@PLIN2                                                    
     C                   EVAL      T0ARV2=S5ARTI+S5VARI+S5MODE                                      
     C                   EVAL      T0COM2=*BLANKS                                                   
     C                   EVAL      T0CAN2=@PCANT                                                    
FQ710C                   EVAL      T0UNI2=S5UNIM                                                    
     C                   EVAL      T0CFC2=0                                                         
     C                   EVAL      T0CUS2=S5CUST                                                    
     C                   EVAL      T0DWR2=*DATE                                                     
     C                   TIME                    T0HWR2                                             
     C                   EVAL      T0UWR2=SDSUSR                                                    
     C                   EVAL      T0EDST='30'                                                      
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   UPDATE    REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=1                                                         
     C                   UPDATE    REDTRLP10                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=2                                                         
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=3                                                         
     C                   UPDATE    REDTRLP30                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDSL                                                                      
     C                                                                                              
FDX01C                   ENDIF                                                                      
FDX01 *                                                                                             
     C                   ENDIF                                                                      
     C                                                                                              
     C                   ENDDO                                                                      
     C                                                                                              
      *                                                                                             
      * Se quiere grabar registro de auditoría en EDTRAU?                                           
      *                                                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de compra                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
     C                   MOVE      T0DAT2        @EMFDOC                                            
     C                   MOVE      T0LIN2        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 202  Alta línea pedido CODEP2 en Productiva      *                        
      **********************************************************************                        
     C     CS_COD202     BEGSR                                                                      
      *                                                                                             
      * Recupero componente y línea del CODEP2 en DS desde PTEXT                                    
      *                                                                                             
     C                   EVAL      DSCODEP2=@PTEXT                                                  
      *                                                                                             
      * Recupero datos del la línea del pedido en la productiva                                     
      *                                                                                             
     C                   EVAL      S5CIAS=@PCIAS                                                    
     C                   EVAL      S5DLGA=@PDLGA                                                    
     C                   EVAL      S5NPCO=@PNPCO                                                    
     C                   EVAL      S5TPED=@PTPED                                                    
     C                   EVAL      S5DATP=@PDATP                                                    
     C                   EVAL      S5NOPL=@PNOPL                                                    
     C                   EVAL      S5LINE=@PLINE                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
     C                                                                                              
      *                                                                                             
      * Recupero datos del la línea del componente en la productiva                                 
      *                                                                                             
     C                   EVAL      C_S5CIAS=@PCIAS                                                  
     C                   EVAL      C_S5DLGA=@PDLGA                                                  
     C                   EVAL      C_S5NPCO=@PNPCO                                                  
     C                   EVAL      C_S5TPED=@PTPED                                                  
     C                   EVAL      C_S5DATP=@PDATP                                                  
     C                   EVAL      C_S5NOPL=@PNOPL                                                  
     C                   EVAL      C_S5LINE=@PLINE                                                  
     C                   MOVE      ZDLIN3        C_S5LIN3                                           
     C     KCODEP2       CHAIN(N)  CODEP2                                                           
      *                                                                                             
      * Recupero datos de la cabecera del pedido en la productiva                                   
      *                                                                                             
     C                   EVAL      S0CIAS=S5CIAS                                                    
     C                   EVAL      S0DLGA=S5DLGA                                                    
     C                   EVAL      S0NPCO=S5NPCO                                                    
     C                   EVAL      S0TPED=S5TPED                                                    
     C                   EVAL      S0DATP=S5DATP                                                    
     C                   EVAL      S0NOPL=S5NOPL                                                    
     C     KCOCAPE       CHAIN(N)  COCAPE                                                           
     C                                                                                              
      *                                                                                             
      * Calculo el estatus de la línea en la productiva                                             
      *                                                                                             
     C                   EVAL      ZXEDST=*BLANKS                                                   
     C                   IF        S0STCO>='20'                                                     
     C                   IF        S5CANR<>0                                                        
     C                   EVAL      ZXEDST='50'                                                      
     C                   ELSE                                                                       
     C                   EVAL      ZXEDST='40'                                                      
     C                   ENDIF                                                                      
     C                   ELSE                                                                       
     C                   EVAL      ZXEDST='30'                                                      
     C                   ENDIF                                                                      
      *                                                                                             
      * Recupero la clave del EDTRLP20 (productiva)                                                 
      *                                                                                             
     C                   EVAL      T0CIA2=@PCIAS                                                    
     C                   EVAL      T0DLG2=@PDLGA                                                    
     C                   EVAL      T0NPC2=@PNPCO                                                    
     C                   EVAL      T0TPE2=@PTPED                                                    
     C                   EVAL      T0DAT2=@PDATP                                                    
     C                   EVAL      T0NOP2=@PNOPL                                                    
     C                   EVAL      T0LIN2=@PLINE                                                    
     C                   EVAL      T0COM2=ZDCOMP+ZDVAR2+ZDMOD2                                      
      *                                                                                             
      * BUSCO el registro en archivo EDTRLP con el código de componente                             
      *                                                                                             
     C     KEDTRLP20X    CHAIN     EDTRLP20                                                         
      *Si no encuento el registro con código de componente significa que                            
      *tengo que buscarlo con componente *blanks                                                    
     C                   IF        NOT %FOUND(EDTRLP20)                                             
     C                   EVAL      T0COM2=*BLANKS                                                   
     C     KEDTRLP20X    CHAIN     EDTRLP20                                                         
      *Si lo encuentro con COMP=*blanks cambio el COMP y el coeficiente                             
     C                   IF        %FOUND(EDTRLP20)                                                 
     C                   EVAL      T0COM2=ZDCOMP+ZDVAR2+ZDMOD2                                      
     C                   EVAL      T0CFC2=(C_S5CA01/S5CANT)                                         
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
      *Actualizo estatus si es inferior a 50 o si era anulado                                       
     C                   if        (T0EDST<='50' or T0EDST='95') and                                
     C                             (ZXEDST<>*BLANKS)                                                
     C                   EVAL      T0EDST=ZXEDST                                                    
     C                   endif                                                                      
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
      *Si no lo encuentro tampoco blancos entonces lo tengo que crear                               
     C                   ELSE                                                                       
      *busco los datos con clave solo línea pedido productiva sin componente                        
     C     KEDTRLP20     CHAIN(N)  EDTRLP20                                                         
     C                   EVAL      T0COM2=ZDCOMP+ZDVAR2+ZDMOD2                                      
     C                   EVAL      T0CFC2=(C_S5CA01/S5CANT)                                         
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
      *Actualizo estatus si es inferior a 50 o si era anulado                                       
     C                   if        (T0EDST<='50' or T0EDST='95') and                                
     C                             (ZXEDST<>*BLANKS)                                                
     C                   EVAL      T0EDST=ZXEDST                                                    
     C                   endif                                                                      
     C                   EVAL      T0TREG=2                                                         
21050C                   WRITE     REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDIF                                                                      
      *Si lo encuentro como componente actualizo coeficiente por si acaso                           
     C                   ELSE                                                                       
     C                   EVAL      T0CFC2=(C_S5CA01/S5CANT)                                         
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
      *Actualizo estatus si es inferior a 50 o si era anulado                                       
     C                   if        (T0EDST<='50' or T0EDST='95') and                                
     C                             (ZXEDST<>*BLANKS)                                                
     C                   EVAL      T0EDST=ZXEDST                                                    
     C                   endif                                                                      
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDIF                                                                      
      *                                                                                             
      * Se quiere grabar registro de auditoría en EDTRAU?                                           
      *                                                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de compra                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
     C                   MOVE      T0DAT2        @EMFDOC                                            
     C                   MOVE      T0LIN2        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 205  Modi línea pedido CODEPE en Productiva      *                        
      **********************************************************************                        
     C     CS_COD205     BEGSR                                                                      
      *                                                                                             
      * Recupero la clave del EDTRLP según el parámetro del lógico                                  
      *                                                                                             
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=1                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=2                                                         
     C                   EVAL      T0CIA2=@PCIAS                                                    
     C                   EVAL      T0DLG2=@PDLGA                                                    
     C                   EVAL      T0NPC2=@PNPCO                                                    
     C                   EVAL      T0TPE2=@PTPED                                                    
     C                   EVAL      T0DAT2=@PDATP                                                    
     C                   EVAL      T0NOP2=@PNOPL                                                    
     C                   EVAL      T0LIN2=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=3                                                         
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C                                                                                              
     C                   ENDSL                                                                      
     C                                                                                              
      *                                                                                             
      * Recupero datos del la línea del pedido en la productiva                                     
      *                                                                                             
     C                   EVAL      S5CIAS=@PCIA2                                                    
     C                   EVAL      S5DLGA=@PDLG2                                                    
     C                   EVAL      S5NPCO=@PNPC2                                                    
     C                   EVAL      S5TPED=@PTPE2                                                    
     C                   EVAL      S5DATP=@PDAT2                                                    
     C                   EVAL      S5NOPL=@PNOP2                                                    
     C                   EVAL      S5LINE=@PLIN2                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
     C                                                                                              
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
     C                                                                                              
     C                   EVAL      *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     SETLL     EDTRLP20                                                         
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C                   ENDSL                                                                      
     C                                                                                              
     C                   DOW       *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     READE     EDTRLP00                               82                        
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     READE     EDTRLP10                               82                        
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     READE     EDTRLP30                               82                        
     C                   ENDSL                                                                      
     C                                                                                              
     C                   IF        *IN82=*OFF                                                       
     C                                                                                              
      * Este evento es una modificación de línea en empresa productiva.                             
      * por tanto actualizo los campos:                                                             
     C                   EVAL      T0CIA2=@PCIA2                                                    
     C                   EVAL      T0DLG2=@PDLG2                                                    
     C                   EVAL      T0NPC2=@PNPC2                                                    
     C                   EVAL      T0TPE2=@PTPE2                                                    
     C                   EVAL      T0DAT2=@PDAT2                                                    
     C                   EVAL      T0NOP2=@PNOP2                                                    
     C                   EVAL      T0LIN2=@PLIN2                                                    
     C                   EVAL      T0ARV2=S5ARTI+S5VARI+S5MODE                                      
     C                   EVAL      T0CAN2=@PCANT                                                    
FQ710C                   EVAL      T0UNI2=S5UNIM                                                    
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   UPDATE    REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=1                                                         
     C                   UPDATE    REDTRLP10                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=2                                                         
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=3                                                         
     C                   UPDATE    REDTRLP30                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDSL                                                                      
     C                                                                                              
     C                   ENDIF                                                                      
     C                                                                                              
     C                   ENDDO                                                                      
     C                                                                                              
      *                                                                                             
      * Se quiere grabar registro de auditoría en EDTRAU?                                           
      *                                                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de compra                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
     C                   MOVE      T0DAT2        @EMFDOC                                            
     C                   MOVE      T0LIN2        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 206  Modi línea pedido CODEP2 en Productiva      *                        
      **********************************************************************                        
     C     CS_COD206     BEGSR                                                                      
      *                                                                                             
      * Recupero componente y línea del CODEP2 en DS desde PTEXT                                    
      *                                                                                             
     C                   EVAL      DSCODEP2=@PTEXT                                                  
      *                                                                                             
      * Recupero datos del la línea del pedido en la productiva                                     
      *                                                                                             
     C                   EVAL      S5CIAS=@PCIAS                                                    
     C                   EVAL      S5DLGA=@PDLGA                                                    
     C                   EVAL      S5NPCO=@PNPCO                                                    
     C                   EVAL      S5TPED=@PTPED                                                    
     C                   EVAL      S5DATP=@PDATP                                                    
     C                   EVAL      S5NOPL=@PNOPL                                                    
     C                   EVAL      S5LINE=@PLINE                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
     C                                                                                              
      *                                                                                             
      * Recupero datos del la línea del componente en la productiva                                 
      *                                                                                             
     C                   EVAL      C_S5CIAS=@PCIAS                                                  
     C                   EVAL      C_S5DLGA=@PDLGA                                                  
     C                   EVAL      C_S5NPCO=@PNPCO                                                  
     C                   EVAL      C_S5TPED=@PTPED                                                  
     C                   EVAL      C_S5DATP=@PDATP                                                  
     C                   EVAL      C_S5NOPL=@PNOPL                                                  
     C                   EVAL      C_S5LINE=@PLINE                                                  
     C                   MOVE      ZDLIN3        C_S5LIN3                                           
     C     KCODEP2       CHAIN(N)  CODEP2                                                           
     C                                                                                              
      *                                                                                             
      * Recupero datos de la cabecera del pedido en la productiva                                   
      *                                                                                             
     C                   EVAL      S0CIAS=S5CIAS                                                    
     C                   EVAL      S0DLGA=S5DLGA                                                    
     C                   EVAL      S0NPCO=S5NPCO                                                    
     C                   EVAL      S0TPED=S5TPED                                                    
     C                   EVAL      S0DATP=S5DATP                                                    
     C                   EVAL      S0NOPL=S5NOPL                                                    
     C     KCOCAPE       CHAIN(N)  COCAPE                                                           
     C                                                                                              
      *                                                                                             
      * Calculo el estatus de la línea en la productiva                                             
      *                                                                                             
     C                   EVAL      ZXEDST=*BLANKS                                                   
     C                   IF        S0STCO>='20'                                                     
     C                   IF        S5CANR<>0                                                        
     C                   EVAL      ZXEDST='50'                                                      
     C                   ELSE                                                                       
     C                   EVAL      ZXEDST='40'                                                      
     C                   ENDIF                                                                      
     C                   ELSE                                                                       
     C                   EVAL      ZXEDST='30'                                                      
     C                   ENDIF                                                                      
      *                                                                                             
      * Recupero la clave del EDTRLP20 (productiva)                                                 
      *                                                                                             
     C                   EVAL      T0CIA2=@PCIAS                                                    
     C                   EVAL      T0DLG2=@PDLGA                                                    
     C                   EVAL      T0NPC2=@PNPCO                                                    
     C                   EVAL      T0TPE2=@PTPED                                                    
     C                   EVAL      T0DAT2=@PDATP                                                    
     C                   EVAL      T0NOP2=@PNOPL                                                    
     C                   EVAL      T0LIN2=@PLINE                                                    
     C                   EVAL      T0COM2=ZDCOMP+ZDVAR2+ZDMOD2                                      
      *                                                                                             
      * BUSCO el registro en archivo EDTRLP con el código de componente                             
      *                                                                                             
     C     KEDTRLP20X    CHAIN     EDTRLP20                                                         
      *Si no encuento el registro con código de componente significa que                            
      *tengo que buscarlo con componente *blanks                                                    
     C                   IF        NOT %FOUND(EDTRLP20)                                             
     C                   EVAL      T0COM2=*BLANKS                                                   
     C     KEDTRLP20X    CHAIN     EDTRLP20                                                         
      *Si lo encuentro con COMP=*blanks cambio el COMP y el coeficiente                             
     C                   IF        %FOUND(EDTRLP20)                                                 
     C                   EVAL      T0COM2=ZDCOMP+ZDVAR2+ZDMOD2                                      
     C                   EVAL      T0CFC2=(C_S5CA01/S5CANT)                                         
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
      *Actualizo estatus si es inferior a 50 o si era anulado                                       
     C                   if        (T0EDST<='50' or T0EDST='95') and                                
     C                             (ZXEDST<>*BLANKS)                                                
     C                   EVAL      T0EDST=ZXEDST                                                    
     C                   endif                                                                      
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
      *Si no lo encuentro tampoco blancos entonces lo tengo que crear                               
     C                   ELSE                                                                       
      *busco los datos con clave solo línea pedido productiva sin componente                        
     C     KEDTRLP20     CHAIN(N)  EDTRLP20                                                         
     C                   EVAL      T0COM2=ZDCOMP+ZDVAR2+ZDMOD2                                      
     C                   EVAL      T0CFC2=(C_S5CA01/S5CANT)                                         
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
      *Actualizo estatus si es inferior a 50 o si era anulado                                       
     C                   if        (T0EDST<='50' or T0EDST='95') and                                
     C                             (ZXEDST<>*BLANKS)                                                
     C                   EVAL      T0EDST=ZXEDST                                                    
     C                   endif                                                                      
     C                   EVAL      T0TREG=2                                                         
21050C                   WRITE     REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDIF                                                                      
      *Si lo encuentro como componente actualizo coeficiente por si acaso                           
     C                   ELSE                                                                       
     C                   EVAL      T0CFC2=(C_S5CA01/S5CANT)                                         
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
      *Actualizo estatus si es inferior a 50 o si era anulado                                       
     C                   if        (T0EDST<='50' or T0EDST='95') and                                
     C                             (ZXEDST<>*BLANKS)                                                
     C                   EVAL      T0EDST=ZXEDST                                                    
     C                   endif                                                                      
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDIF                                                                      
      *                                                                                             
      * Se quiere grabar registro de auditoría en EDTRAU?                                           
      *                                                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de compra                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
     C                   MOVE      T0DAT2        @EMFDOC                                            
     C                   MOVE      T0LIN2        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 210  Baja línea pedido CODEPE en Productiva      *                        
      **********************************************************************                        
     C     CS_COD210     BEGSR                                                                      
      *                                                                                             
      * Recupero la clave del EDTRLP según el parámetro del lógico                                  
      *                                                                                             
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=1                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=2                                                         
     C                   EVAL      T0CIA2=@PCIAS                                                    
     C                   EVAL      T0DLG2=@PDLGA                                                    
     C                   EVAL      T0NPC2=@PNPCO                                                    
     C                   EVAL      T0TPE2=@PTPED                                                    
     C                   EVAL      T0DAT2=@PDATP                                                    
     C                   EVAL      T0NOP2=@PNOPL                                                    
     C                   EVAL      T0LIN2=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=3                                                         
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C                                                                                              
     C                   ENDSL                                                                      
     C                                                                                              
     C                                                                                              
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
     C                                                                                              
     C                   EVAL      *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     SETLL     EDTRLP20                                                         
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C                   ENDSL                                                                      
     C                                                                                              
     C                   DOW       *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     READE     EDTRLP00                               82                        
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     READE     EDTRLP10                               82                        
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     READE     EDTRLP30                               82                        
     C                   ENDSL                                                                      
     C                                                                                              
     C                   IF        *IN82=*OFF                                                       
     C                                                                                              
      * Este evento es una baja de línea en empresa productiva.                                     
      * por tanto actualizo los campos:                                                             
     C                   EVAL      T0CIA2=@PCIA2                                                    
     C                   EVAL      T0DLG2=@PDLG2                                                    
     C                   EVAL      T0NPC2=@PNPC2                                                    
     C                   EVAL      T0TPE2=@PTPE2                                                    
     C                   EVAL      T0DAT2=@PDAT2                                                    
     C                   EVAL      T0NOP2=@PNOP2                                                    
     C                   EVAL      T0LIN2=@PLIN2                                                    
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
     C                   EVAL      T0EDST='95'                                                      
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   UPDATE    REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=1                                                         
     C                   UPDATE    REDTRLP10                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=2                                                         
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=3                                                         
     C                   UPDATE    REDTRLP30                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDSL                                                                      
     C                                                                                              
     C                   ENDIF                                                                      
     C                                                                                              
     C                   ENDDO                                                                      
     C                                                                                              
      *                                                                                             
      * Se quiere grabar registro de auditoría en EDTRAU?                                           
      *                                                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de compra                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
     C                   MOVE      T0DAT2        @EMFDOC                                            
     C                   MOVE      T0LIN2        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 211  Baja línea pedido CODEP2 en Productiva      *                        
      **********************************************************************                        
     C     CS_COD211     BEGSR                                                                      
      *                                                                                             
      * Recupero componente y línea del CODEP2 en DS desde PTEXT                                    
      *                                                                                             
     C                   EVAL      DSCODEP2=@PTEXT                                                  
      *                                                                                             
      * Recupero datos del la línea del pedido en la productiva                                     
      *                                                                                             
     C                   EVAL      S5CIAS=@PCIAS                                                    
     C                   EVAL      S5DLGA=@PDLGA                                                    
     C                   EVAL      S5NPCO=@PNPCO                                                    
     C                   EVAL      S5TPED=@PTPED                                                    
     C                   EVAL      S5DATP=@PDATP                                                    
     C                   EVAL      S5NOPL=@PNOPL                                                    
     C                   EVAL      S5LINE=@PLINE                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
     C                                                                                              
      *                                                                                             
      * Recupero datos del la línea del componente en la productiva                                 
      *                                                                                             
     C                   EVAL      C_S5CIAS=@PCIAS                                                  
     C                   EVAL      C_S5DLGA=@PDLGA                                                  
     C                   EVAL      C_S5NPCO=@PNPCO                                                  
     C                   EVAL      C_S5TPED=@PTPED                                                  
     C                   EVAL      C_S5DATP=@PDATP                                                  
     C                   EVAL      C_S5NOPL=@PNOPL                                                  
     C                   EVAL      C_S5LINE=@PLINE                                                  
     C                   MOVE      ZDLIN3        C_S5LIN3                                           
     C     KCODEP2       CHAIN(N)  CODEP2                                                           
     C                                                                                              
      *                                                                                             
      * Recupero la clave del EDTRLP20 (productiva)                                                 
      *                                                                                             
     C                   EVAL      T0CIA2=@PCIAS                                                    
     C                   EVAL      T0DLG2=@PDLGA                                                    
     C                   EVAL      T0NPC2=@PNPCO                                                    
     C                   EVAL      T0TPE2=@PTPED                                                    
     C                   EVAL      T0DAT2=@PDATP                                                    
     C                   EVAL      T0NOP2=@PNOPL                                                    
     C                   EVAL      T0LIN2=@PLINE                                                    
     C                   EVAL      T0COM2=ZDCOMP+ZDVAR2+ZDMOD2                                      
      *                                                                                             
      * BUSCO el registro en archivo EDTRLP con el código de componente                             
      *                                                                                             
     C     KEDTRLP20X    CHAIN     EDTRLP20                                                         
      *Si no encuento el registro con código de componente significa que                            
      *tengo que buscarlo con componente *blanks                                                    
     C                   IF        NOT %FOUND(EDTRLP20)                                             
     C                   EVAL      T0COM2=*BLANKS                                                   
     C     KEDTRLP20X    CHAIN     EDTRLP20                                                         
      *Si lo encuentro con COMP=*blanks cambio el COMP y el coeficiente                             
     C                   IF        %FOUND(EDTRLP20)                                                 
     C                   EVAL      T0COM2=ZDCOMP+ZDVAR2+ZDMOD2                                      
     C                   EVAL      T0CFC2=(C_S5CA01/S5CANT)                                         
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
     C                   EVAL      T0EDST='95'                                                      
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
      *Si no lo encuentro tampoco blancos entonces lo tengo que crear                               
     C                   ELSE                                                                       
      *busco los datos con clave solo línea pedido productiva sin componente                        
     C     KEDTRLP20     CHAIN(N)  EDTRLP20                                                         
     C                   EVAL      T0COM2=ZDCOMP+ZDVAR2+ZDMOD2                                      
     C                   EVAL      T0CFC2=(C_S5CA01/S5CANT)                                         
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
     C                   EVAL      T0EDST='95'                                                      
     C                   EVAL      T0TREG=2                                                         
21050C                   WRITE     REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDIF                                                                      
      *Si lo encuentro como componente actualizo coeficiente por si acaso                           
     C                   ELSE                                                                       
     C                   EVAL      T0CFC2=(C_S5CA01/S5CANT)                                         
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
     C                   EVAL      T0EDST='95'                                                      
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDIF                                                                      
      *                                                                                             
      * Se quiere grabar registro de auditoría en EDTRAU?                                           
      *                                                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de compra                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
     C                   MOVE      T0DAT2        @EMFDOC                                            
     C                   MOVE      T0LIN2        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 215 Confirmación línea pedido CODEPE en Productiva                        
      **********************************************************************                        
     C     CS_COD215     BEGSR                                                                      
      *                                                                                             
      * Recupero la clave del EDTRLP según el parámetro del lógico                                  
      *                                                                                             
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=1                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=2                                                         
     C                   EVAL      T0CIA2=@PCIAS                                                    
     C                   EVAL      T0DLG2=@PDLGA                                                    
     C                   EVAL      T0NPC2=@PNPCO                                                    
     C                   EVAL      T0TPE2=@PTPED                                                    
     C                   EVAL      T0DAT2=@PDATP                                                    
     C                   EVAL      T0NOP2=@PNOPL                                                    
     C                   EVAL      T0LIN2=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=3                                                         
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C                                                                                              
     C                   ENDSL                                                                      
     C                                                                                              
      *                                                                                             
      * Recupero datos del la línea del pedido en la productiva                                     
      *                                                                                             
     C                   EVAL      S5CIAS=@PCIA2                                                    
     C                   EVAL      S5DLGA=@PDLG2                                                    
     C                   EVAL      S5NPCO=@PNPC2                                                    
     C                   EVAL      S5TPED=@PTPE2                                                    
     C                   EVAL      S5DATP=@PDAT2                                                    
     C                   EVAL      S5NOPL=@PNOP2                                                    
     C                   EVAL      S5LINE=@PLIN2                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
     C                                                                                              
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
     C                                                                                              
     C                   EVAL      *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     SETLL     EDTRLP20                                                         
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C                   ENDSL                                                                      
     C                                                                                              
     C                   DOW       *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     READE     EDTRLP00                               82                        
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     READE     EDTRLP10                               82                        
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     READE     EDTRLP30                               82                        
