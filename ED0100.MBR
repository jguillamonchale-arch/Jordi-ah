     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C                   ENDSL                                                                      
     C                                                                                              
     C                   DOW       *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     READE     EDTRLP00                               82                        
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     READE     EDTRLP10                               82                        
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     READE     EDTRLP30                               82                        
     C                   ENDSL                                                                      
     C                                                                                              
     C                   ENDDO                                                                      
      *                                                                                             
      * Solo se grabará auditoría.                                                                  
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de compra                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
     C                   MOVE      T0DAT2        @EMFDOC                                            
     C                   MOVE      T0LIN2        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 224 Desautorizar contrapedido a la comercial                              
      **********************************************************************                        
     C     CS_COD224     BEGSR                                                                      
      *                                                                                             
      * Recupero la clave del EDTRLP según el parámetro del lógico                                  
      *                                                                                             
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=1                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=2                                                         
     C                   EVAL      T0CIA2=@PCIAS                                                    
     C                   EVAL      T0DLG2=@PDLGA                                                    
     C                   EVAL      T0NPC2=@PNPCO                                                    
     C                   EVAL      T0TPE2=@PTPED                                                    
     C                   EVAL      T0DAT2=@PDATP                                                    
     C                   EVAL      T0NOP2=@PNOPL                                                    
     C                   EVAL      T0LIN2=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=3                                                         
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C                                                                                              
     C                   ENDSL                                                                      
     C                                                                                              
      * Con este código de auditoría finalmente no se actualiza el                                  
      * archivo EDTRLP. Solo leo para recuperar valores para luego                                  
      * grabar auditoría.                                                                           
     C                                                                                              
     C                   EVAL      *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     SETLL     EDTRLP20                                                         
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C                   ENDSL                                                                      
     C                                                                                              
     C                   DOW       *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     READE     EDTRLP00                               82                        
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     READE     EDTRLP10                               82                        
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     READE     EDTRLP30                               82                        
     C                   ENDSL                                                                      
     C                                                                                              
     C                   ENDDO                                                                      
      *                                                                                             
      * Solo se grabará auditoría.                                                                  
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de compra                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
     C                   MOVE      T0DAT2        @EMFDOC                                            
     C                   MOVE      T0LIN2        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
24080 **********************************************************************                        
24080 * Proceso auditoría 227 Cambio fecha confirmada en productiva                                 
24080 **********************************************************************                        
24080C     CS_COD227     BEGSR                                                                      
24080 *                                                                                             
24080 * Recupero la clave del EDTRLP según el parámetro del lógico                                  
24080 *                                                                                             
24080C                   SELECT                                                                     
24080C                   WHEN      @PLOGI=0                                                         
24080C                   EVAL      T0CIAS=@PCIAS                                                    
24080C                   EVAL      T0DLGA=@PDLGA                                                    
24080C                   EVAL      T0NPCO=@PNPCO                                                    
24080C                   EVAL      T0TPED=@PTPED                                                    
24080C                   EVAL      T0DATP=@PDATP                                                    
24080C                   EVAL      T0NOPL=@PNOPL                                                    
24080C                   EVAL      T0LINE=@PLINE                                                    
24080C                                                                                              
24080C                   WHEN      @PLOGI=1                                                         
24080C                   EVAL      T0CIA1=@PCIAS                                                    
24080C                   EVAL      T0DLG1=@PDLGA                                                    
24080C                   EVAL      T0NPC1=@PNPCO                                                    
24080C                   EVAL      T0TPE1=@PTPED                                                    
24080C                   EVAL      T0DAT1=@PDATP                                                    
24080C                   EVAL      T0NOP1=@PNOPL                                                    
24080C                   EVAL      T0LIN1=@PLINE                                                    
24080C                                                                                              
24080C                   WHEN      @PLOGI=2                                                         
24080C                   EVAL      T0CIA2=@PCIAS                                                    
24080C                   EVAL      T0DLG2=@PDLGA                                                    
24080C                   EVAL      T0NPC2=@PNPCO                                                    
24080C                   EVAL      T0TPE2=@PTPED                                                    
24080C                   EVAL      T0DAT2=@PDATP                                                    
24080C                   EVAL      T0NOP2=@PNOPL                                                    
24080C                   EVAL      T0LIN2=@PLINE                                                    
24080C                                                                                              
24080C                   WHEN      @PLOGI=3                                                         
24080C                   EVAL      T0CIA3=@PCIAS                                                    
24080C                   EVAL      T0DLG3=@PDLGA                                                    
24080C                   EVAL      T0NPC3=@PNPCO                                                    
24080C                   EVAL      T0TPE3=@PTPED                                                    
24080C                   EVAL      T0DAT3=@PDATP                                                    
24080C                   EVAL      T0NOP3=@PNOPL                                                    
24080C                   EVAL      T0LIN3=@PLINE                                                    
24080C                                                                                              
24080C                   ENDSL                                                                      
24080C                                                                                              
24080 * Con este código de auditoría actualizo el campo T0FRRE  del                                 
24080 * archivo EDTRLP.                                                                             
24080C                                                                                              
24080C                   EVAL      *IN82=*OFF                                                       
24080C                                                                                              
24080C                   SELECT                                                                     
24080C                   WHEN      @PLOGI=0                                                         
24080C     KEDTRLP00     SETLL     EDTRLP00                                                         
24080C                   WHEN      @PLOGI=1                                                         
24080C     KEDTRLP10     SETLL     EDTRLP10                                                         
24080C                   WHEN      @PLOGI=2                                                         
24080C     KEDTRLP20     SETLL     EDTRLP20                                                         
24080C                   WHEN      @PLOGI=3                                                         
24080C     KEDTRLP30     SETLL     EDTRLP30                                                         
24080C                   ENDSL                                                                      
24080C                                                                                              
24080C                   DOW       *IN82=*OFF                                                       
24080C                                                                                              
24080C                   SELECT                                                                     
24080C                   WHEN      @PLOGI=0                                                         
24080C     KEDTRLP00     READE     EDTRLP00                               82                        
24080C                   WHEN      @PLOGI=1                                                         
24080C     KEDTRLP10     READE     EDTRLP10                               82                        
24080C                   WHEN      @PLOGI=2                                                         
24080C     KEDTRLP20     READE     EDTRLP20                               82                        
24080C                   WHEN      @PLOGI=3                                                         
24080C     KEDTRLP30     READE     EDTRLP30                               82                        
24080C                   ENDSL                                                                      
24080C                                                                                              
24080C                   IF        *IN82=*OFF                                                       
24080C                                                                                              
24080C                   EVAL      T0DWRF=*DATE                                                     
24080C                   TIME                    T0HWRF                                             
24080C                   MOVEL     @PTEXT        T0FRRE                                             
24080C                                                                                              
24080C                   SELECT                                                                     
24080C                   WHEN      @PLOGI=0                                                         
24080C                   UPDATE    REDTRLP00                            83                          
24080C   83              EXSR      CS_EDTRLD                                                        
24080C                   WHEN      @PLOGI=1                                                         
24080C                   UPDATE    REDTRLP10                            83                          
24080C   83              EXSR      CS_EDTRLD                                                        
24080C                   WHEN      @PLOGI=2                                                         
24080C                   UPDATE    REDTRLP20                            83                          
24080C   83              EXSR      CS_EDTRLD                                                        
24080C                   WHEN      @PLOGI=3                                                         
24080C                   UPDATE    REDTRLP30                            83                          
24080C   83              EXSR      CS_EDTRLD                                                        
24080C                   ENDSL                                                                      
24080C                                                                                              
24080C                   ENDIF                                                                      
24080C                                                                                              
24080C                   ENDDO                                                                      
24080 *                                                                                             
24080 * Solo se grabará auditoría.                                                                  
24080C                   EXSR      CS_UPD_EDTRAU                                                    
24080 *                                                                                             
24080 * Posible E-Mail con datos del pedido de compra                                               
24080 *                                                                                             
24080C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
24080C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
24080C                   MOVEL(P)  T0CUST        @EMCODE                                            
24080C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
24080C                   MOVE      T0DAT2        @EMFDOC                                            
24080C                   MOVE      T0LIN2        @EMLDOC                                            
24080 *                                                                                             
24080C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 230 Creación albarán X-DOCK.                                              
      **********************************************************************                        
     C     CS_COD230     BEGSR                                                                      
      *                                                                                             
      * Recupero la clave del EDTRLP según el parámetro del lógico                                  
      *                                                                                             
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=1                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=2                                                         
     C                   EVAL      T0CIA2=@PCIAS                                                    
     C                   EVAL      T0DLG2=@PDLGA                                                    
     C                   EVAL      T0NPC2=@PNPCO                                                    
     C                   EVAL      T0TPE2=@PTPED                                                    
     C                   EVAL      T0DAT2=@PDATP                                                    
     C                   EVAL      T0NOP2=@PNOPL                                                    
     C                   EVAL      T0LIN2=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=3                                                         
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C                                                                                              
     C                   ENDSL                                                                      
     C                                                                                              
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
     C                                                                                              
     C                   EVAL      *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     SETLL     EDTRLP20                                                         
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C                   ENDSL                                                                      
     C                                                                                              
     C                   DOW       *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     READE     EDTRLP00                               82                        
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     READE     EDTRLP10                               82                        
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     READE     EDTRLP30                               82                        
     C                   ENDSL                                                                      
     C                                                                                              
     C                   IF        *IN82=*OFF                                                       
     C                                                                                              
      * Este evento es la creación de un albarán X-DOCK.                                            
      * por tanto actualizo los campos:                                                             
     C                   EVAL      T0XDOC=1                                                         
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   UPDATE    REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=1                                                         
     C                   UPDATE    REDTRLP10                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=2                                                         
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=3                                                         
     C                   UPDATE    REDTRLP30                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDSL                                                                      
     C                                                                                              
     C                   ENDIF                                                                      
     C                                                                                              
     C                   ENDDO                                                                      
     C                                                                                              
      *                                                                                             
      * Se quiere grabar registro de auditoría en EDTRAU?                                           
      *                                                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de compra                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
     C                   MOVE      T0DAT2        @EMFDOC                                            
     C                   MOVE      T0LIN2        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 231 Creación albarán normal.                                              
      **********************************************************************                        
     C     CS_COD231     BEGSR                                                                      
      *                                                                                             
      * Recupero la clave del EDTRLP según el parámetro del lógico                                  
      *                                                                                             
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=1                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=2                                                         
     C                   EVAL      T0CIA2=@PCIAS                                                    
     C                   EVAL      T0DLG2=@PDLGA                                                    
     C                   EVAL      T0NPC2=@PNPCO                                                    
     C                   EVAL      T0TPE2=@PTPED                                                    
     C                   EVAL      T0DAT2=@PDATP                                                    
     C                   EVAL      T0NOP2=@PNOPL                                                    
     C                   EVAL      T0LIN2=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=3                                                         
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C                                                                                              
     C                   ENDSL                                                                      
     C                                                                                              
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
     C                                                                                              
     C                   EVAL      *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     SETLL     EDTRLP20                                                         
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C                   ENDSL                                                                      
     C                                                                                              
     C                   DOW       *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     READE     EDTRLP00                               82                        
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     READE     EDTRLP10                               82                        
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     READE     EDTRLP30                               82                        
     C                   ENDSL                                                                      
     C                                                                                              
     C                   IF        *IN82=*OFF                                                       
     C                                                                                              
      *                                                                                             
      * Recupero datos del la línea del pedido en la productiva                                     
      *                                                                                             
     C                   EVAL      S5CIAS=T0CIA2                                                    
     C                   EVAL      S5DLGA=T0DLG2                                                    
     C                   EVAL      S5NPCO=T0NPC2                                                    
     C                   EVAL      S5TPED=T0TPE2                                                    
     C                   EVAL      S5DATP=T0DAT2                                                    
     C                   EVAL      S5NOPL=T0NOP2                                                    
     C                   EVAL      S5LINE=T0LIN2                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
      * Este evento es la creación de un albarán normal.                                            
      * por tanto actualizo los campos:                                                             
     C                   EVAL      T0CANS=T0CANS + @PCANT                                           
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
      *estatus servido parcial o total                                                              
     C                   IF        (S5CANS+@PCANT) >= S5CANT                                        
     C                   EVAL      T0EDST='80'                                                      
     C                   ELSE                                                                       
     C                   EVAL      T0EDST='75'                                                      
     C                   ENDIF                                                                      
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   UPDATE    REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=1                                                         
     C                   UPDATE    REDTRLP10                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=2                                                         
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=3                                                         
     C                   UPDATE    REDTRLP30                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDSL                                                                      
     C                                                                                              
     C                   ENDIF                                                                      
     C                                                                                              
     C                   ENDDO                                                                      
     C                                                                                              
      *                                                                                             
      * Se quiere grabar registro de auditoría en EDTRAU?                                           
      *                                                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de compra                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
     C                   MOVE      T0DAT2        @EMFDOC                                            
     C                   MOVE      T0LIN2        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 251 Errores en pedido en Productiva                                       
      **********************************************************************                        
     C     CS_COD251     BEGSR                                                                      
      *                                                                                             
      *                                                                                             
      * Recupero la clave del EDTRLP según el parámetro del lógico                                  
      *                                                                                             
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=1                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=2                                                         
     C                   EVAL      T0CIA2=@PCIAS                                                    
     C                   EVAL      T0DLG2=@PDLGA                                                    
     C                   EVAL      T0NPC2=@PNPCO                                                    
     C                   EVAL      T0TPE2=@PTPED                                                    
     C                   EVAL      T0DAT2=@PDATP                                                    
     C                   EVAL      T0NOP2=@PNOPL                                                    
     C                   EVAL      T0LIN2=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=3                                                         
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C                                                                                              
     C                   ENDSL                                                                      
     C                                                                                              
      * Con este código de auditoría finalmente no se actualiza el                                  
      * archivo EDTRLP. Solo leo para recuperar valores para luego                                  
      * grabar auditoría.                                                                           
     C                                                                                              
     C                   EVAL      *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     SETLL     EDTRLP20                                                         
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C                   ENDSL                                                                      
     C                                                                                              
     C                   DOW       *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     READE     EDTRLP00                               82                        
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     READE     EDTRLP10                               82                        
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     READE     EDTRLP30                               82                        
     C                   ENDSL                                                                      
     C                                                                                              
     C                   ENDDO                                                                      
      *                                                                                             
      * Buscar código error en tabla EDER                                                           
      *                                                                                             
     C                   EVAL      PECTAB='EDER'                                                    
     C                   EVAL      PECLTA=@PERAV                                                    
     C     KPMTAB2       CHAIN(N)  PMTAB2                                                           
     C                   IF        %FOUND(PMTAB2)                                                   
      *Si existe código email específico para error lo recupero                                     
     C                   IF        PEBL65<>*BLANKS                                                  
     C                   MOVEL(P)  PEBL65        @EMEVEN                                            
     C                   ENDIF                                                                      
      *Recuperar descripción error                                                                  
FQ726C**                 EVAL      @PTEXT=PEDESC                                                    
FQ726C                   EVAL      @PTEXT=ZXDESCAUD                                                 
     C                   ENDIF                                                                      
      *                                                                                             
      * Volver a Buscar código auditoría en PMTAB2                                                  
      *                                                                                             
     C                   EVAL      PECTAB='EDAU'                                                    
     C                   EVAL      PECLTA=@PEDAU                                                    
     C     KPMTAB2       CHAIN(N)  PMTAB2                             81                            
      *                                                                                             
      * Solo se grabará auditoría.                                                                  
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de compra                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
     C                   MOVE      T0DAT2        @EMFDOC                                            
     C                   MOVE      T0LIN2        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 260 Avísos en pedido en Productiva                                        
      **********************************************************************                        
     C     CS_COD260     BEGSR                                                                      
      *                                                                                             
      *                                                                                             
      * Recupero la clave del EDTRLP según el parámetro del lógico                                  
      *                                                                                             
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=1                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=2                                                         
     C                   EVAL      T0CIA2=@PCIAS                                                    
     C                   EVAL      T0DLG2=@PDLGA                                                    
     C                   EVAL      T0NPC2=@PNPCO                                                    
     C                   EVAL      T0TPE2=@PTPED                                                    
     C                   EVAL      T0DAT2=@PDATP                                                    
     C                   EVAL      T0NOP2=@PNOPL                                                    
     C                   EVAL      T0LIN2=@PLINE                                                    
     C                                                                                              
     C                   WHEN      @PLOGI=3                                                         
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C                                                                                              
     C                   ENDSL                                                                      
     C                                                                                              
      * Con este código de auditoría finalmente no se actualiza el                                  
      * archivo EDTRLP. Solo leo para recuperar valores para luego                                  
      * grabar auditoría.                                                                           
     C                                                                                              
     C                   EVAL      *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     SETLL     EDTRLP20                                                         
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C                   ENDSL                                                                      
     C                                                                                              
     C                   DOW       *IN82=*OFF                                                       
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     READE     EDTRLP00                               82                        
     C                   WHEN      @PLOGI=1                                                         
     C     KEDTRLP10     READE     EDTRLP10                               82                        
     C                   WHEN      @PLOGI=2                                                         
     C     KEDTRLP20     READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI=3                                                         
     C     KEDTRLP30     READE     EDTRLP30                               82                        
     C                   ENDSL                                                                      
     C                                                                                              
     C                   ENDDO                                                                      
      *                                                                                             
      * Buscar código avíso en tabla EDAV                                                           
      *                                                                                             
     C                   EVAL      PECTAB='EDAV'                                                    
     C                   EVAL      PECLTA=@PERAV                                                    
     C     KPMTAB2       CHAIN(N)  PMTAB2                                                           
     C                   IF        %FOUND(PMTAB2)                                                   
      *Si existe código email específico para avíso lo recupero                                     
     C                   IF        PEBL65<>*BLANKS                                                  
     C                   MOVEL(P)  PEBL65        @EMEVEN                                            
     C                   ENDIF                                                                      
      *Recuperar descripción avíso                                                                  
FQ726C**                 EVAL      @PTEXT=PEDESC                                                    
FQ726C                   EVAL      @PTEXT=ZXDESCAUD                                                 
     C                   ENDIF                                                                      
      *                                                                                             
      * Volver a Buscar código auditoría en PMTAB2                                                  
      *                                                                                             
     C                   EVAL      PECTAB='EDAU'                                                    
     C                   EVAL      PECLTA=@PEDAU                                                    
     C     KPMTAB2       CHAIN(N)  PMTAB2                             81                            
      *                                                                                             
      * Solo se grabará auditoría.                                                                  
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de compra                                               
      *                                                                                             
     C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
     C                   MOVEL(P)  T0CUST        @EMCODE                                            
     C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
     C                   MOVE      T0DAT2        @EMFDOC                                            
     C                   MOVE      T0LIN2        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 301/302 Reserva/Desreserva TRACE                 *                        
      **********************************************************************                        
     C     CS_COD301     BEGSR                                                                      
                                                                                                    
      * Recupero datos del la línea del pedido en Trace                                             
     C                   EVAL      S5CIAS=@PCIA2                                                    
     C                   EVAL      S5DLGA=@PDLG2                                                    
     C                   EVAL      S5NPCO=@PNPC2                                                    
     C                   EVAL      S5TPED=@PTPE2                                                    
     C                   EVAL      S5DATP=@PDAT2                                                    
     C                   EVAL      S5NOPL=@PNOP2                                                    
     C                   EVAL      S5LINE=@PLIN2                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
b01  C                   IF        %FOUND(CODEPE)                                                   
                                                                                                    
      * Busco Trazabilidad X-DOC en COXDOC                                                          
b02  C                   IF        S5CCPP='1'                                                       
     C                   EVAL      TKCIAS=S5CIAS                                                    
     C                   EVAL      TKDLGA=S5DLGA                                                    
     C                   EVAL      TKNPCO=S5NPCO                                                    
     C                   EVAL      TKTPED=S5TPED                                                    
     C                   EVAL      TKDATP=S5DATP                                                    
     C                   EVAL      TKNOPL=S5NOPL                                                    
     C                   EVAL      TKLINE=S5LINE                                                    
     C     KCOXDOC       SETLL     COXDOC                                                           
     C     KCOXDOC       READE     COXDOC                                                           
e02  C                   ENDIF                                                                      
     C                                                                                              
      * Si no es X-DOC o es X-DOC tipo antiguo sin COXDOC                                           
b02  C                   IF        S5CCPP<>'1' Or                                                   
     C                             (S5CCPP='1' And %EOF(COXDOC))                                    
      * Recupero la clave del EDTRLP según el parámetro del lógico                                  
s03  C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                   WHEN      @PLOGI=2                                                         
     C                   EVAL      T0CIA2=@PCIAS                                                    
     C                   EVAL      T0DLG2=@PDLGA                                                    
     C                   EVAL      T0NPC2=@PNPCO                                                    
     C                   EVAL      T0TPE2=@PTPED                                                    
     C                   EVAL      T0DAT2=@PDATP                                                    
     C                   EVAL      T0NOP2=@PNOPL                                                    
     C                   EVAL      T0LIN2=@PLINE                                                    
e03  C                   ENDSL                                                                      
     C                                                                                              
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
s03  C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     CHAIN     EDTRLP00                           81                            
10051C                   IF        *IN81=*OFF And T0ARV1<>*BLANKS                                   
10051C                   EVAL      T0ARV1=S5ARTI+S5VARI+S5MODE                                      
10051C     KEDTRLP00Z    CHAIN     EDTRLP00                           81                            
10051C                   ENDIF                                                                      
     C                   WHEN      @PLOGI=2                                                         
b04  C                   IF        S5TACC = '1'                                                     
     C                   EVAL      T0COM2=S5ARTI+S5VARI+S5MODE                                      
x04  C                   ELSE                                                                       
     C                   EVAL      T0COM2=*BLANKS                                                   
e04  C                   ENDIF                                                                      
     C     KEDTRLP20X    CHAIN     EDTRLP20                           81                            
e03  C                   ENDSL                                                                      
     C                                                                                              
b03  C                   IF        *IN81=*OFF                                                       
      * Actualizo campos de Trace                                                                   
     C                   EVAL      ZXCANT = S5CANT                                                  
FQ710C                   EVAL      ZXUNIM = S5UNIM                                                  
     C                   EXSR      CS_TRAUPD                                                        
s04  C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   UPDATE    REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   WHEN      @PLOGI=2                                                         
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
e04  C                   ENDSL                                                                      
e03  C                   ENDIF                                                                      
     C                                                                                              
      * Actualizo Cantidades en Registro de Tipo 0                                                  
     C                   EVAL      ZYCANT = @PCANT                                                  
     C                   EXSR      CS_CANTID                                                        
     C                                                                                              
x02  C                   ELSE                                                                       
      * Es X-DOC                                                                                    
     C                   EVAL      ZXNP03=*BLANKS                                                   
     C                   EVAL      ZXLI03=*ZEROS                                                    
d03  C                   DOW       NOT %EOF(COXDOC)                                                 
     C                                                                                              
b04  C                   IF        TKNP03<>ZXNP03 Or TKLI03<>ZXLI03                                 
     C                   EVAL      ZXNP03=TKNP03                                                    
     C                   EVAL      ZXLI03=TKLI03                                                    
     C                   EVAL      ZXCANT=0                                                         
e04  C                   ENDIF                                                                      
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
     C                   MOVEL     TKCI03        T0CIA2                                             
     C                   EVAL      T0DLG2=TKDL03                                                    
     C                   EVAL      T0NPC2=TKNP03                                                    
     C                   EVAL      T0TPE2=TKTP03                                                    
     C                   EVAL      T0DAT2=TKDA03                                                    
     C                   EVAL      T0NOP2=TKNO03                                                    
     C                   EVAL      T0LIN2=TKLI03                                                    
      * El X-Doc es de un Conjunto ?                                                                
b04  C                   IF        TKARCO<>*BLANKS                                                  
     C                   EVAL      T0COM2=TKARTI+TKVARI+TKMODE                                      
x04  C                   ELSE                                                                       
     C                   EVAL      T0COM2=*BLANKS                                                   
e04  C                   ENDIF                                                                      
     C     KEDTRLP20X    CHAIN     EDTRLP20                                                         
b04  C                   IF        %FOUND(EDTRLP20)                                                 
      * Busco si existe el X-doc con el pedido de Trace                                             
     C                   EVAL      T0NPC3=@PNPC2                                                    
     C                   EVAL      T0LIN3=@PLIN2                                                    
     C     KEDTRLP20F    CHAIN     EDTRLP20                                                         
b05  C                   IF        %FOUND(EDTRLP20)                                                 
      * Actualizo campos de Trace                                                                   
     C                   EVAL      ZXCANT=ZXCANT+TKCANT                                             
FQ710C                   EVAL      ZXUNIM=TKUNIM                                                    
     C                   EXSR      CS_TRAUPD                                                        
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
x05  C                   ELSE                                                                       
      * Busco si existe el registro a blancos                                                       
     C                   EVAL      T0NPC3=*BLANKS                                                   
     C                   EVAL      T0LIN3=0                                                         
     C     KEDTRLP20F    CHAIN     EDTRLP20                                                         
b06  C                   IF        %FOUND(EDTRLP20)                                                 
      * Actualizo campos de Trace                                                                   
     C                   EVAL      ZXCANT=ZXCANT+TKCANT                                             
FQ710C                   EVAL      ZXUNIM=TKUNIM                                                    
     C                   EXSR      CS_TRAUPD                                                        
     C                   UPDATE    REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
x06  C                   ELSE                                                                       
      * Añado Nuevo registro EDTRLP tipo 3                                                          
     C                   EVAL      ZXCANT = TKCANT                                                  
FQ710C                   EVAL      ZXUNIM = TKUNIM                                                  
     C                   EXSR      CS_TRAADD                                                        
21050C                   WRITE     REDTRLP20                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
e06  C                   ENDIF                                                                      
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
                                                                                                    
      * Actualizo Cantidades en Registro de Tipo 0                                                  
     C                   EVAL      ZYCANT = TKCANT                                                  
     C                   EXSR      CS_CANTID                                                        
                                                                                                    
     C     KCOXDOC       READE     COXDOC                                                           
e03  C                   ENDDO                                                                      
     C                                                                                              
e02  C                   ENDIF                                                                      
                                                                                                    
      * Actualizar archivo de auditoría                                                             
      * Recupero el registro original por si lo he perdido en CS_CANTID                             
     C                   EVAL      S5CIAS=@PCIA2                                                    
     C                   EVAL      S5DLGA=@PDLG2                                                    
     C                   EVAL      S5NPCO=@PNPC2                                                    
     C                   EVAL      S5TPED=@PTPE2                                                    
     C                   EVAL      S5DATP=@PDAT2                                                    
     C                   EVAL      S5NOPL=@PNOP2                                                    
     C                   EVAL      S5LINE=@PLIN2                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
b02  C                   IF        %FOUND(CODEPE)                                                   
s03  C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C     KEDTRLP00     CHAIN     EDTRLP00                           81                            
10051C                   IF        *IN81=*OFF And T0ARV1<>*BLANKS                                   
10051C                   EVAL      T0ARV1=S5ARTI+S5VARI+S5MODE                                      
10051C     KEDTRLP00Z    CHAIN     EDTRLP00                           81                            
10051C                   ENDIF                                                                      
     C                   WHEN      @PLOGI=2                                                         
b04  C                   IF        S5TACC = '1'                                                     
     C                   EVAL      T0COM2=S5ARTI+S5VARI+S5MODE                                      
x04  C                   ELSE                                                                       
     C                   EVAL      T0COM2=*BLANKS                                                   
e04  C                   ENDIF                                                                      
     C     KEDTRLP20X    CHAIN     EDTRLP20                           81                            
e03  C                   ENDSL                                                                      
e02  C                   ENDIF                                                                      
                                                                                                    
     C                   EXSR      CS_UPD_EDTRAU                                                    
                                                                                                    
e01  C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 303/304 Preparación/Despreparación Trace                                  
      **********************************************************************                        
     C     CS_COD303     BEGSR                                                                      
                                                                                                    
      * Recupero datos del la línea del pedido en Trace                                             
     C                   EVAL      S5CIAS=@PCIA2                                                    
     C                   EVAL      S5DLGA=@PDLG2                                                    
     C                   EVAL      S5NPCO=@PNPC2                                                    
     C                   EVAL      S5TPED=@PTPE2                                                    
     C                   EVAL      S5DATP=@PDAT2                                                    
     C                   EVAL      S5NOPL=@PNOP2                                                    
     C                   EVAL      S5LINE=@PLIN2                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
b01  C                   IF        %FOUND(CODEPE)                                                   
                                                                                                    
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C     KEDTRLP30     READE     EDTRLP30                                                         
d02  C                   DOW       NOT %EOF(EDTRLP30)                                               
                                                                                                    
      * Actualizo campos de Trace                                                                   
     C                   EXSR      CS_TRAUPD                                                        
     C                   UPDATE    REDTRLP30                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
                                                                                                    
     C     KEDTRLP30     READE     EDTRLP30                                                         
e02  C                   ENDDO                                                                      
                                                                                                    
      * Actualizo Cantidades en Registro de Tipo 0 si es depreparación                              
     C                   IF        @PEDAU = '304'                                                   
     C                   EVAL      ZYCANT = @PCANT                                                  
     C                   EXSR      CS_CANTID                                                        
      * Recupero el registro original por si lo he perdido en CS_CANTID                             
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C     KEDTRLP30     READE(N)  EDTRLP30                                                         
     C                   ENDIF                                                                      
      * Actualizar archivo de auditoría                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
                                                                                                    
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 305/306 Confirmación/Anulación Prepara.Trace                              
      **********************************************************************                        
     C     CS_COD305     BEGSR                                                                      
                                                                                                    
      * busco preparación en Trace                                                                  
     C                   EVAL      SACIAS=@PCIA2                                                    
     C                   EVAL      SATNPE=' '                                                       
     C                   EVAL      SADLGA=@PDLG2                                                    
     C                   EVAL      SANPCO=@PNPC2                                                    
     C                   EVAL      SATPED=@PTPE2                                                    
     C                   EVAL      SADATP=@PDAT2                                                    
     C                   EVAL      SANOPL=@PNOP2                                                    
     C                   EVAL      SALINE=@PLIN2                                                    
     C                   MOVEL     @PTEXT        SANPRP                                             
     C     KCOAPRP01     CHAIN     COAPR101                                                         
b01  C                   IF        Not %FOUND(COAPR101)                                             
     C     KCOAPRP01     CHAIN     COAPRP01                                                         
e01  C                   ENDIF                                                                      
b01  C                   IF        %FOUND(COAPRP01) Or %FOUND(COAPR101)                             
                                                                                                    
      * Recupero datos del la línea del pedido en Trace                                             
     C                   EVAL      S5CIAS=@PCIA2                                                    
     C                   EVAL      S5DLGA=@PDLG2                                                    
     C                   EVAL      S5NPCO=@PNPC2                                                    
     C                   EVAL      S5TPED=@PTPE2                                                    
     C                   EVAL      S5DATP=@PDAT2                                                    
     C                   EVAL      S5NOPL=@PNOP2                                                    
     C                   EVAL      S5LINE=@PLIN2                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
b02  C                   IF        %FOUND(CODEPE)                                                   
                                                                                                    
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C     KEDTRLP30     READE     EDTRLP30                                                         
d03  C                   DOW       NOT %EOF(EDTRLP30)                                               
                                                                                                    
      * Actualizo campos de Trace                                                                   
     C                   EXSR      CS_TRAUPD                                                        
     C                   UPDATE    REDTRLP30                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
                                                                                                    
     C     KEDTRLP30     READE     EDTRLP30                                                         
e03  C                   ENDDO                                                                      
                                                                                                    
      * Busco Trazabilidad X-DOC en COXDOC                                                          
b03  C                   IF        S5CCPP='1'                                                       
     C                   EVAL      TKCIAS=S5CIAS                                                    
     C                   EVAL      TKDLGA=S5DLGA                                                    
     C                   EVAL      TKNPCO=S5NPCO                                                    
     C                   EVAL      TKTPED=S5TPED                                                    
     C                   EVAL      TKDATP=S5DATP                                                    
     C                   EVAL      TKNOPL=S5NOPL                                                    
     C                   EVAL      TKLINE=S5LINE                                                    
     C     KCOXDOC       SETLL     COXDOC                                                           
     C     KCOXDOC       READE     COXDOC                                                           
e03  C                   ENDIF                                                                      
     C                                                                                              
      * Si no es X-DOC o es X-DOC tipo antiguo sin COXDOC                                           
b03  C                   IF        S5CCPP<>'1' Or                                                   
     C                             (S5CCPP='1' And %EOF(COXDOC))                                    
      * Actualizo Cantidades es Registro de Tipo 0                                                  
     C                   EVAL      ZYCANT = @PCANT                                                  
     C                   EXSR      CS_CANTID                                                        
x03  C                   ELSE                                                                       
      * Es X-DOC                                                                                    
d04  C                   DOW       NOT %EOF(COXDOC)                                                 
     C                                                                                              
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
     C                   MOVEL     TKCI03        T0CIA2                                             
     C                   EVAL      T0DLG2=TKDL03                                                    
     C                   EVAL      T0NPC2=TKNP03                                                    
     C                   EVAL      T0TPE2=TKTP03                                                    
     C                   EVAL      T0DAT2=TKDA03                                                    
     C                   EVAL      T0NOP2=TKNO03                                                    
     C                   EVAL      T0LIN2=TKLI03                                                    
      * El X-Doc es de un Conjunto ?                                                                
b05  C                   IF        TKARCO<>*BLANKS                                                  
     C                   EVAL      T0COM2=TKARTI+TKVARI+TKMODE                                      
x05  C                   ELSE                                                                       
     C                   EVAL      T0COM2=*BLANKS                                                   
e05  C                   ENDIF                                                                      
     C     KEDTRLP20X    CHAIN(N)  EDTRLP20                                                         
b05  C                   IF        %FOUND(EDTRLP20)                                                 
      * Actualizo Cantidades en Registro de Tipo 0                                                  
     C                   EVAL      ZYCANT = TKCANT                                                  
     C                   EXSR      CS_CANTID                                                        
e05  C                   ENDIF                                                                      
                                                                                                    
     C     KCOXDOC       READE     COXDOC                                                           
e04  C                   ENDDO                                                                      
     C                                                                                              
e03  C                   ENDIF                                                                      
                                                                                                    
      * Recupero el registro original por si lo he perdido en CS_CANTID                             
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C     KEDTRLP30     READE(N)  EDTRLP30                                                         
                                                                                                    
      * Muevo valores a campo de Texto                                                              
     C                   EVAL      @PTEXT=*BLANKS                                                   
     C                   EVAL      ZDNPRP=SANPRP                                                    
     C                   EVAL      ZDEMBQ=SAEMBQ                                                    
     C                   EVAL      ZDXSGA=SAXSGA                                                    
     C                   MOVEL     SALSGA        ZDLSGA                                             
     C                   EVAL      @PTEXT=DSTEXT                                                    
     C                                                                                              
      * Actualizar archivo de auditoría                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
e02  C                   ENDIF                                                                      
                                                                                                    
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 307 Expedición desde Trace. Crean Albarán                                 
      **********************************************************************                        
     C     CS_COD307     BEGSR                                                                      
                                                                                                    
      * busco preparación en Trace                                                                  
     C                   EVAL      SACIAS=@PCIA2                                                    
     C                   EVAL      SATNPE=' '                                                       
     C                   EVAL      SADLGA=@PDLG2                                                    
     C                   EVAL      SANPCO=@PNPC2                                                    
     C                   EVAL      SATPED=@PTPE2                                                    
     C                   EVAL      SADATP=@PDAT2                                                    
     C                   EVAL      SANOPL=@PNOP2                                                    
     C                   EVAL      SALINE=@PLIN2                                                    
     C                   EVAL      SANPRP=%SUBST(@PTEXT:17:10)                                      
     C     KCOAPRP01     CHAIN     COAPR101                                                         
b01  C                   IF        Not %FOUND(COAPR101)                                             
     C     KCOAPRP01     CHAIN     COAPRP01                                                         
e01  C                   ENDIF                                                                      
b01  C                   IF        %FOUND(COAPRP01) Or %FOUND(COAPR101)                             
                                                                                                    
      * Recupero datos de la línea del pedido en Trace                                              
     C                   EVAL      S5CIAS=@PCIA2                                                    
     C                   EVAL      S5DLGA=@PDLG2                                                    
     C                   EVAL      S5NPCO=@PNPC2                                                    
     C                   EVAL      S5TPED=@PTPE2                                                    
     C                   EVAL      S5DATP=@PDAT2                                                    
     C                   EVAL      S5NOPL=@PNOP2                                                    
     C                   EVAL      S5LINE=@PLIN2                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
b02  C                   IF        %FOUND(CODEPE)                                                   
                                                                                                    
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C     KEDTRLP30     READE     EDTRLP30                                                         
d03  C                   DOW       NOT %EOF(EDTRLP30)                                               
                                                                                                    
      * Actualizo campos de Trace                                                                   
     C                   EXSR      CS_TRAUPD                                                        
     C                   UPDATE    REDTRLP30                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
                                                                                                    
     C     KEDTRLP30     READE     EDTRLP30                                                         
e03  C                   ENDDO                                                                      
                                                                                                    
      * Busco Trazabilidad X-DOC en COXDOC                                                          
b03  C                   IF        S5CCPP='1'                                                       
     C                   EVAL      TKCIAS=S5CIAS                                                    
     C                   EVAL      TKDLGA=S5DLGA                                                    
     C                   EVAL      TKNPCO=S5NPCO                                                    
     C                   EVAL      TKTPED=S5TPED                                                    
     C                   EVAL      TKDATP=S5DATP                                                    
     C                   EVAL      TKNOPL=S5NOPL                                                    
     C                   EVAL      TKLINE=S5LINE                                                    
     C     KCOXDOC       SETLL     COXDOC                                                           
     C     KCOXDOC       READE     COXDOC                                                           
e03  C                   ENDIF                                                                      
     C                                                                                              
      * Si no es X-DOC o es X-DOC tipo antiguo sin COXDOC                                           
b03  C                   IF        S5CCPP<>'1' Or                                                   
     C                             (S5CCPP='1' And %EOF(COXDOC))                                    
      * Actualizo Cantidades es Registro de Tipo 0                                                  
     C                   EVAL      ZYCANT = @PCANT                                                  
     C                   EXSR      CS_CANTID                                                        
x03  C                   ELSE                                                                       
      * Es X-DOC                                                                                    
d04  C                   DOW       NOT %EOF(COXDOC)                                                 
     C                                                                                              
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
     C                   MOVEL     TKCI03        T0CIA2                                             
     C                   EVAL      T0DLG2=TKDL03                                                    
     C                   EVAL      T0NPC2=TKNP03                                                    
     C                   EVAL      T0TPE2=TKTP03                                                    
     C                   EVAL      T0DAT2=TKDA03                                                    
     C                   EVAL      T0NOP2=TKNO03                                                    
     C                   EVAL      T0LIN2=TKLI03                                                    
      * El X-Doc es de un Conjunto ?                                                                
b05  C                   IF        TKARCO<>*BLANKS                                                  
     C                   EVAL      T0COM2=TKARTI+TKVARI+TKMODE                                      
x05  C                   ELSE                                                                       
     C                   EVAL      T0COM2=*BLANKS                                                   
e05  C                   ENDIF                                                                      
     C     KEDTRLP20X    CHAIN(N)  EDTRLP20                                                         
b05  C                   IF        %FOUND(EDTRLP20)                                                 
      * Actualizo Cantidades en Registro de Tipo 0                                                  
     C                   EVAL      ZYCANT = TKCANT                                                  
     C                   EXSR      CS_CANTID                                                        
e05  C                   ENDIF                                                                      
                                                                                                    
     C     KCOXDOC       READE     COXDOC                                                           
e04  C                   ENDDO                                                                      
     C                                                                                              
e03  C                   ENDIF                                                                      
                                                                                                    
      * Recupero el registro original por si lo he perdido en CS_CANTID                             
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C     KEDTRLP30     READE(N)  EDTRLP30                                                         
                                                                                                    
      * Actualizar archivo de auditoría                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
e02  C                   ENDIF                                                                      
                                                                                                    
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 308 Salida Camión desde Trace                                             
      **********************************************************************                        
     C     CS_COD308     BEGSR                                                                      
                                                                                                    
      * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
     C                   EVAL      T0CIA3=@PCIAS                                                    
     C                   EVAL      T0DLG3=@PDLGA                                                    
     C                   EVAL      T0NPC3=@PNPCO                                                    
     C                   EVAL      T0TPE3=@PTPED                                                    
     C                   EVAL      T0DAT3=@PDATP                                                    
     C                   EVAL      T0NOP3=@PNOPL                                                    
     C                   EVAL      T0LIN3=@PLINE                                                    
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C     KEDTRLP30     READE     EDTRLP30                                                         
b01  C                   IF        NOT %EOF(EDTRLP30)                                               
      * Actualizar archivo de auditoría                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
C1579 **********************************************************************                        
C1579 * Proceso auditoría 500 Creación albarán Poolweb                                              
C1579 **********************************************************************                        
C1579C     CS_COD500     BEGSR                                                                      
C1579 *                                                                                             
C1579 * Recupero la clave del EDTRLP según el parámetro del lógico                                  
C1579 *                                                                                             
C1579C                   SELECT                                                                     
C1579C                   WHEN      @PLOGI=0                                                         
C1579C                   EVAL      T0CIAS=@PCIAS                                                    
C1579C                   EVAL      T0DLGA=@PDLGA                                                    
C1579C                   EVAL      T0NPCO=@PNPCO                                                    
C1579C                   EVAL      T0TPED=@PTPED                                                    
C1579C                   EVAL      T0DATP=@PDATP                                                    
C1579C                   EVAL      T0NOPL=@PNOPL                                                    
C1579C                   EVAL      T0LINE=@PLINE                                                    
C1579C                                                                                              
C1579C                   WHEN      @PLOGI=1                                                         
C1579C                   EVAL      T0CIA1=@PCIAS                                                    
C1579C                   EVAL      T0DLG1=@PDLGA                                                    
C1579C                   EVAL      T0NPC1=@PNPCO                                                    
C1579C                   EVAL      T0TPE1=@PTPED                                                    
C1579C                   EVAL      T0DAT1=@PDATP                                                    
C1579C                   EVAL      T0NOP1=@PNOPL                                                    
C1579C                   EVAL      T0LIN1=@PLINE                                                    
C1579C                                                                                              
C1579C                   WHEN      @PLOGI=2                                                         
C1579C                   EVAL      T0CIA2=@PCIAS                                                    
C1579C                   EVAL      T0DLG2=@PDLGA                                                    
C1579C                   EVAL      T0NPC2=@PNPCO                                                    
C1579C                   EVAL      T0TPE2=@PTPED                                                    
C1579C                   EVAL      T0DAT2=@PDATP                                                    
C1579C                   EVAL      T0NOP2=@PNOPL                                                    
C1579C                   EVAL      T0LIN2=@PLINE                                                    
C1579C                                                                                              
C1579C                   WHEN      @PLOGI=3                                                         
C1579C                   EVAL      T0CIA3=@PCIAS                                                    
C1579C                   EVAL      T0DLG3=@PDLGA                                                    
C1579C                   EVAL      T0NPC3=@PNPCO                                                    
C1579C                   EVAL      T0TPE3=@PTPED                                                    
C1579C                   EVAL      T0DAT3=@PDATP                                                    
C1579C                   EVAL      T0NOP3=@PNOPL                                                    
C1579C                   EVAL      T0LIN3=@PLINE                                                    
C1579C                                                                                              
C1579C                   ENDSL                                                                      
C1579C                                                                                              
C1579 * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
C1579C                                                                                              
C1579C                   EVAL      *IN82=*OFF                                                       
C1579C                                                                                              
C1579C                   SELECT                                                                     
C1579C                   WHEN      @PLOGI=0                                                         
C1579C     KEDTRLP00     SETLL     EDTRLP00                                                         
C1579C                   WHEN      @PLOGI=1                                                         
C1579C     KEDTRLP10     SETLL     EDTRLP10                                                         
C1579C                   WHEN      @PLOGI=2                                                         
C1579C     KEDTRLP20     SETLL     EDTRLP20                                                         
C1579C                   WHEN      @PLOGI=3                                                         
C1579C     KEDTRLP30     SETLL     EDTRLP30                                                         
C1579C                   ENDSL                                                                      
C1579C                                                                                              
C1579C                   DOW       *IN82=*OFF                                                       
C1579C                                                                                              
C1579C                   SELECT                                                                     
C1579C                   WHEN      @PLOGI=0                                                         
C1579C     KEDTRLP00     READE     EDTRLP00                               82                        
C1579C                   WHEN      @PLOGI=1                                                         
C1579C     KEDTRLP10     READE     EDTRLP10                               82                        
C1579C                   WHEN      @PLOGI=2                                                         
C1579C     KEDTRLP20     READE     EDTRLP20                               82                        
C1579C                   WHEN      @PLOGI=3                                                         
C1579C     KEDTRLP30     READE     EDTRLP30                               82                        
C1579C                   ENDSL                                                                      
C1579C                                                                                              
C1579C                   IF        *IN82=*OFF                                                       
C1579C                                                                                              
C1579 *                                                                                             
C1579 * Recupero datos del la línea del pedido de compras                                           
C1579 *                                                                                             
C1579C                   EVAL      C5CIAS=T0CIA1                                                    
C1579C                   EVAL      C5DLGA=T0DLG1                                                    
C1579C                   EVAL      C5NPCO=T0NPC1                                                    
C1579C                   EVAL      C5TPED=T0TPE1                                                    
C1579C                   EVAL      C5DATP=T0DAT1                                                    
C1579C                   EVAL      C5NOPL=T0NOP1                                                    
C1579C                   EVAL      C5LINE=T0LIN1                                                    
C1579C     KPUDEPE       CHAIN(N)  PUDEPE                                                           
C1579 * Este evento es la creación de un albarán normal.                                            
C1579 * por tanto actualizo los campos:                                                             
C1579C                   EVAL      T0CANS=T0CANS + @PCANT                                           
C1579C                   EVAL      T0DWRF=*DATE                                                     
C1579C                   TIME                    T0HWRF                                             
C1579 *estatus servido parcial o total                                                              
C1579C                   IF        (C5CANS+@PCANT) >= C5CANT                                        
C1579C                   EVAL      T0EDST='80'                                                      
C1579C                   ELSE                                                                       
C1579C                   EVAL      T0EDST='75'                                                      
C1579C                   ENDIF                                                                      
C1579C                                                                                              
C1579C                   SELECT                                                                     
C1579C                   WHEN      @PLOGI=0                                                         
C1579C                   UPDATE    REDTRLP00                            83                          
C1579C   83              EXSR      CS_EDTRLD                                                        
C1579C                   WHEN      @PLOGI=1                                                         
C1579C                   UPDATE    REDTRLP10                            83                          
C1579C   83              EXSR      CS_EDTRLD                                                        
C1579C                   WHEN      @PLOGI=2                                                         
C1579C                   UPDATE    REDTRLP20                            83                          
C1579C   83              EXSR      CS_EDTRLD                                                        
C1579C                   WHEN      @PLOGI=3                                                         
C1579C                   UPDATE    REDTRLP30                            83                          
C1579C   83              EXSR      CS_EDTRLD                                                        
C1579C                   ENDSL                                                                      
C1579C                                                                                              
C1579C                   ENDIF                                                                      
C1579C                                                                                              
C1579C                   ENDDO                                                                      
C1579C                                                                                              
C1579 *                                                                                             
C1579 * Se quiere grabar registro de auditoría en EDTRAU?                                           
C1579 *                                                                                             
C1579C                   EXSR      CS_UPD_EDTRAU                                                    
C1579 *                                                                                             
C1579 * Posible E-Mail con datos del pedido de compra                                               
C1579 *                                                                                             
C1579C                   MOVEL(P)  T0CIA1        @EMCIAA                                            
C1579C                   MOVEL(P)  T0DLG1        @EMDLGA                                            
C1579C                   MOVEL(P)  T0PRVR        @EMCODE                                            
C1579C                   MOVEL(P)  T0NPC1        @EMNDOC                                            
C1579C                   MOVE      T0DAT1        @EMFDOC                                            
C1579C                   MOVE      T0LIN1        @EMLDOC                                            
C1579 *                                                                                             
C1579C                   ENDSR                                                                      
C1544 **********************************************************************                        
C1544 * Proceso auditoría 309 Salida Camión desde Trace a Consolidador                              
C1544 **********************************************************************                        
C1544C     CS_COD309     BEGSR                                                                      
C1544 * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
C1544C                   EVAL      T0CIA3=@PCIAS                                                    
C1544C                   EVAL      T0DLG3=@PDLGA                                                    
C1544C                   EVAL      T0NPC3=@PNPCO                                                    
C1544C                   EVAL      T0TPE3=@PTPED                                                    
C1544C                   EVAL      T0DAT3=@PDATP                                                    
C1544C                   EVAL      T0NOP3=@PNOPL                                                    
C1544C                   EVAL      T0LIN3=@PLINE                                                    
C1544C     KEDTRLP30     SETLL     EDTRLP30                                                         
C1544C     KEDTRLP30     READE     EDTRLP30                                                         
C1544C                   IF        NOT %EOF(EDTRLP30)                                               
C1544 * Actualizar archivo de auditoría                                                             
C1544C                   EXSR      CS_UPD_EDTRAU                                                    
C1544C                   ENDIF                                                                      
C1544C                   ENDSR                                                                      
      **********************************************************************                        
      * Añadir registro Tipo Trace                                                                  
      **********************************************************************                        
     C     CS_TRAADD     BEGSR                                                                      
                                                                                                    
     C                   EVAL      T0TREG=3                                                         
     C                   EVAL      T0CIA3=@PCIA2                                                    
     C                   EVAL      T0DLG3=@PDLG2                                                    
     C                   EVAL      T0NPC3=@PNPC2                                                    
     C                   EVAL      T0TPE3=@PTPE2                                                    
     C                   EVAL      T0DAT3=@PDAT2                                                    
     C                   EVAL      T0NOP3=@PNOP2                                                    
     C                   EVAL      T0LIN3=@PLIN2                                                    
     C                   EVAL      T0CAN3=ZXCANT                                                    
FQ710C                   EVAL      T0UNI3=ZXUNIM                                                    
     C                   EVAL      T0DWR3=*DATE                                                     
     C                   TIME                    T0HWR3                                             
     C                   EVAL      T0UWR3=SDSUSR                                                    
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
     C                   EVAL      T0CANT=0                                                         
FQ710C                   EVAL      T0IMPO=0                                                         
     C                   EVAL      T0CANR=0                                                         
     C                   EVAL      T0CANP=0                                                         
     C                   EVAL      T0CANS=0                                                         
     C                   EVAL      T0CAN1=0                                                         
     C                   EVAL      T0CAN2=0                                                         
      * Cálculo Status en Trace                                                                     
     C                   EXSR      CS_CALSTS                                                        
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Actualizar registro Tipo Trace                                                              
      **********************************************************************                        
     C     CS_TRAUPD     BEGSR                                                                      
                                                                                                    
s01  C                   SELECT                                                                     
                                                                                                    
     C                   WHEN      @PEDAU = '301' Or @PEDAU = '302'                                 
     C                   EVAL      T0CIA3=@PCIA2                                                    
     C                   EVAL      T0DLG3=@PDLG2                                                    
     C                   EVAL      T0NPC3=@PNPC2                                                    
     C                   EVAL      T0TPE3=@PTPE2                                                    
     C                   EVAL      T0DAT3=@PDAT2                                                    
     C                   EVAL      T0NOP3=@PNOP2                                                    
     C                   EVAL      T0LIN3=@PLIN2                                                    
     C                   EVAL      T0CAN3=ZXCANT                                                    
FQ710C                   EVAL      T0UNI3=ZXUNIM                                                    
In193C                   IF        @PEDAU = '301'                                                   
In193C                   EVAL      T0DWR3=*DATE                                                     
In193C                   TIME                    T0HWR3                                             
In193C                   EVAL      T0UWR3=SDSUSR                                                    
28100C                   IF        T0XDOC = 1                                                       
28100C                   EVAL      T0FURE=*DATE                                                     
28100C                   ENDIF                                                                      
In193C                   ENDIF                                                                      
C2185 *                                                                                             
C2185 * Actualizar datos TRACE en EDITRC                                                            
C2185 *                                                                                             
C2185C                   EXSR      CS_EDITRC                                                        
                                                                                                    
     C                   WHEN      @PEDAU = '303'                                                   
     C                   EVAL      T0STCP='10'                                                      
                                                                                                    
     C                   WHEN      @PEDAU = '304'                                                   
     C                   EVAL      T0STCP='  '                                                      
     C                   EVAL      T0STLP=' '                                                       
                                                                                                    
     C                   WHEN      @PEDAU = '305'                                                   
     C                   EVAL      T0STCP='20'                                                      
                                                                                                    
     C                   WHEN      @PEDAU = '306' And S5MPRP='1'                                    
     C                   EVAL      T0STCP='10'                                                      
                                                                                                    
     C                   WHEN      @PEDAU = '306' And S5MPRP=' '                                    
     C                   EVAL      T0STCP='  '                                                      
                                                                                                    
     C                   WHEN      @PEDAU = '307'                                                   
     C                   EVAL      T0STLP=SASTUL                                                    
                                                                                                    
e01  C                   ENDSL                                                                      
                                                                                                    
In193C**                 EVAL      T0DWR3=*DATE                                                     
In193C**                 TIME                    T0HWR3                                             
In193C**                 EVAL      T0UWR3=SDSUSR                                                    
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
      * Cálculo Status en Trace                                                                     
     C                   EXSR      CS_CALSTS                                                        
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Actualizo Cantidades en Registro de Tipo 0                                                  
      **********************************************************************                        
     C     CS_CANTID     BEGSR                                                                      
                                                                                                    
      * Si la línea que hemos actualizado es de conjunto divido por                                 
      * el coeficiente                                                                              
s01  C                   SELECT                                                                     
     C                   WHEN      T0CFC1 > 0                                                       
C3477C*                  EVAL      ZYCANT = ZYCANT / T0CFC1                                         
     C                   WHEN      T0CFC2 > 0                                                       
C3477C*                  EVAL      ZYCANT = ZYCANT / T0CFC2                                         
e01  C                   ENDSL                                                                      
      * Leo todos los registros de la línea del pedido en Comercial                                 
     C                   EVAL      ZXCOM1 = 0                                                       
     C                   EVAL      ZXCOM2 = 0                                                       
02070C                   SELECT                                                                     
02070C                   WHEN      @PEDAU = '302'                                                   
02070C                   EVAL      ZXEDST = '50'                                                    
02070C                   WHEN      @PEDAU = '301' Or @PEDAU = '306'                                 
02070C                   EVAL      ZXEDST = '60'                                                    
02070C                   WHEN      @PEDAU = '305'                                                   
02070C                   EVAL      ZXEDST = '70'                                                    
02070C                   WHEN      @PEDAU = '307'                                                   
02070C                   EVAL      ZXEDST = '80'                                                    
02070C                   ENDSL                                                                      
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C     KEDTRLP00     READE(N)  EDTRLP00                                                         
d01  C                   DOW       NOT %EOF(EDTRLP00)                                               
      * Calculo el numero de componentes si hay conjunto                                            
s02  C                   SELECT                                                                     
     C                   WHEN      T0CFC1 > 0                                                       
     C                   EVAL      ZXCOM1 = ZXCOM1+1                                                
     C                   WHEN      T0CFC2 > 0                                                       
     C                   EVAL      ZXCOM2 = ZXCOM2+1                                                
e02  C                   ENDSL                                                                      
02070C                   SELECT                                                                     
02070C                   WHEN      @PEDAU = '301' Or @PEDAU = '307'                                 
02070C                   IF        T0EDST < ZXEDST                                                  
02070C                   EVAL      ZXEDST = T0EDST                                                  
02070C                   ENDIF                                                                      
02070C                   WHEN      @PEDAU = '305'                                                   
02070C                   IF        T0STCP < '20'                                                    
02070C                   EVAL      ZXEDST = '60'                                                    
02070C                   ENDIF                                                                      
02070C                   WHEN      @PEDAU = '302' Or @PEDAU = '306'                                 
02070C                   IF        T0EDST > ZXEDST                                                  
02070C                   EVAL      ZXEDST = T0EDST                                                  
02070C                   ENDIF                                                                      
02070C                   ENDSL                                                                      
     C     KEDTRLP00     READE(N)  EDTRLP00                                                         
e01  C                   ENDDO                                                                      
      * Al final divido la cantidad total por el numero de Componentes                              
s01  C                   SELECT                                                                     
     C                   WHEN      ZXCOM1 > 0                                                       
C3477C*                  EVAL      ZYCANT = ZYCANT/ZXCOM1                                           
     C                   WHEN      ZXCOM2 > 0                                                       
C3477C*                  EVAL      ZYCANT = ZYCANT/ZXCOM2                                           
     C                   OTHER                                                                      
e01  C                   ENDSL                                                                      
                                                                                                    
      * Actualizo Registro Tipo 0                                                                   
C3477*                                                                                             
C3477C*    KEDTRLP00     SETLL     EDTRLP00                                                         
C3477C*    KEDTRLP00     READE     EDTRLP00                                                         
C3477C*d01  C                   DOW       NOT %EOF(EDTRLP00)                                        
C3477C*b02  C                   IF        T0TREG = 0                                                
C3477*                                                                                             
C3477c                   eval      t0cia3 = s5cias                                                  
C3477c                   eval      t0dlg3 = s5dlga                                                  
C3477c                   eval      t0npc3 = s5npco                                                  
C3477c                   eval      t0tpe3 = s5tped                                                  
C3477c                   eval      t0dat3 = s5datp                                                  
C3477c                   eval      t0nop3 = s5nopl                                                  
C3477c                   eval      t0lin3 = s5line                                                  
C3477*                                                                                             
C3477C     kedtrlp30     setll     edtrlp30                                                         
C3477C     kedtrlp30     reade     edtrlp30                                                         
C3477C                   dow       not %eof(edtrlp30)                                               
C3477*                                                                                             
s03  C                   SELECT                                                                     
     C                   WHEN      @PEDAU = '301'                                                   
02070C*                  IF        ZXEDST = '60' And (ZXCOM1>0 Or ZXCOM2>0)                         
02070C*                  EVAL(H)   T0CANR = %dech((T0CANR+ZYCANT):5:4)                              
02070C*                  ELSE                                                                       
02070C                   EVAL(H)   T0CANR = T0CANR + ZYCANT                                         
02070C*                  ENDIF                                                                      
     C                   WHEN      @PEDAU = '302'                                                   
02070C*                  IF        ZXEDST = '50' And (ZXCOM1>0 Or ZXCOM2>0)                         
02070C*                  EVAL(H)   T0CANR = %dech((T0CANR-ZYCANT):5:4)                              
02070C*                  ELSE                                                                       
02070C                   EVAL(H)   T0CANR = T0CANR - ZYCANT                                         
02070C*                  ENDIF                                                                      
     C                   IF        T0CANR < 0                                                       
     C                   EVAL      T0CANR = 0                                                       
     C                   ENDIF                                                                      
     C                   WHEN      @PEDAU = '305'                                                   
02070C*                  IF        ZXEDST = '70' And (ZXCOM1>0 Or ZXCOM2>0)                         
02070C*                  EVAL(H)   T0CANP = %dech((T0CANP+ZYCANT):5:4)                              
02070C*                  ELSE                                                                       
02070C                   EVAL(H)   T0CANP = T0CANP + ZYCANT                                         
02070C*                  ENDIF                                                                      
     C                   WHEN      @PEDAU = '306'                                                   
In185C                             Or @PEDAU = '304'                                                
02070C*                  IF        ZXEDST = '60' And (ZXCOM1>0 Or ZXCOM2>0)                         
02070C*                  EVAL(H)   T0CANP = %dech((T0CANP-ZYCANT):5:4)                              
02070C*                  ELSE                                                                       
02070C                   EVAL(H)   T0CANP = T0CANP - ZYCANT                                         
02070C*                  ENDIF                                                                      
     C                   IF        T0CANP < 0                                                       
     C                   EVAL      T0CANP = 0                                                       
     C                   ENDIF                                                                      
     C                   WHEN      @PEDAU = '307'                                                   
02070C*                  IF        ZXEDST = '80' And (ZXCOM1>0 Or ZXCOM2>0)                         
02070C*                  EVAL(H)   T0CANS = %dech((T0CANS+ZYCANT):5:4)                              
02070C*                  EVAL(H)   T0CANP = %dech((T0CANP-ZYCANT):5:4)                              
02070C*                  EVAL(H)   T0CANR = %dech((T0CANR-ZYCANT):5:4)                              
02070C*                  ELSE                                                                       
In193C**                 EVAL(H)   T0CANS = T0CANS + ZYCANT                                         
In193C                   IF        T0COFA > 0 And T0UNIM <> T0UNI3                                  
C3477C*In193C                   IF        T0TCOF = '0'                                              
C3477C*In193C                   EVAL(H)   T0CANS = T0CANS + (ZYCANT * T0COFA)                       
C3477C*In193C                   ELSE                                                                
C3477C*In193C                   EVAL(H)   T0CANS = T0CANS + (ZYCANT / T0COFA)                       
C3477C*In193C                   ENDIF                                                               
In193C                   ELSE                                                                       
In193C                   EVAL(H)   T0CANS = T0CANS + ZYCANT                                         
In193C                   ENDIF                                                                      
02070C                   EVAL(H)   T0CANP = T0CANP - ZYCANT                                         
02070C                   EVAL(H)   T0CANR = T0CANR - ZYCANT                                         
02070C*                  ENDIF                                                                      
02070C                   IF        T0CANS > 0 And T0CANT <> T0CANS                                  
02070C                   EVAL      T0EDST='75'                                                      
02070C                   ENDIF                                                                      
02070C                   IF        T0CANT = T0CANS                                                  
02070C                   EVAL      T0EDST='80'                                                      
02070C                   ENDIF                                                                      
02070C                   IF        T0STLP = '5'                                                     
02070C                   EVAL      T0STCP='  '                                                      
02070C                   ENDIF                                                                      
     C                   IF        T0CANP < 0                                                       
     C                   EVAL      T0CANP = 0                                                       
     C                   ENDIF                                                                      
     C                   IF        T0CANR < 0                                                       
     C                   EVAL      T0CANR = 0                                                       
     C                   ENDIF                                                                      
e03  C                   ENDSL                                                                      
C3477*                                                                                             
C3477C*                  UPDATE    REDTRLP00                            83                          
C3477C*21050C   83              EXSR      CS_EDTRLD                                                 
C3477C*e02  C                   ENDIF                                                               
C3477C*    KEDTRLP00     READE     EDTRLP00                                                         
C3477*                                                                                             
C3477c                   update    redtrlp30                            83                          
C3477c   83              exsr      cs_edtrld                                                        
C3477c     kedtrlp30     reade     edtrlp30                                                         
C3477*                                                                                             
e01  C                   ENDDO                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Cálculo Status en Trace                                                                     
      **********************************************************************                        
     C     CS_CALSTS     BEGSR                                                                      
                                                                                                    
     C                   EVAL      ZXCANR = 0                                                       
     C                   EVAL      ZXCANS = 0                                                       
                                                                                                    
s01  C                   SELECT                                                                     
     C                   WHEN      @PEDAU = '301'                                                   
     C                   EVAL      ZXCANR = (S5CANR + @PCANT)                                       
b02  C                   IF        ZXCANR > S5CANT                                                  
     C                   EVAL      ZXCANR = S5CANT                                                  
e02  C                   ENDIF                                                                      
     C                   EVAL      ZXCANS = S5CANS                                                  
     C                   WHEN      @PEDAU = '302'                                                   
     C                   EVAL      ZXCANR = (S5CANR - @PCANT)                                       
b02  C                   IF        ZXCANR < 0                                                       
     C                   EVAL      ZXCANR = 0                                                       
e02  C                   ENDIF                                                                      
     C                   EVAL      ZXCANS = S5CANS                                                  
     C                   WHEN      @PEDAU = '303' Or @PEDAU = '304'                                 
     C                             Or @PEDAU = '305' Or @PEDAU = '306'                              
     C                   EVAL      ZXCANR = S5CANR                                                  
     C                   EVAL      ZXCANS = S5CANS                                                  
     C                   WHEN      @PEDAU = '307'                                                   
     C                   EVAL      ZXCANR = S5CANR                                                  
     C                   EVAL      ZXCANS = (S5CANS + @PCANT)                                       
e01  C                   ENDSL                                                                      
                                                                                                    
s01  C                   SELECT                                                                     
     C                   WHEN      (ZXCANS>0 And S5CANT=ZXCANS                                      
     C                             And T0TREG<>0)                                                   
     C                             Or (ZXCANS>0 And S5CANT=ZXCANS                                   
02070C                             And T0TREG=0 And T0CANS+ZXCANS>=T0CANT)                          
     C                   EVAL      T0EDST='80'                                                      
     C                   EVAL      T0STCP='  '                                                      
     C                   WHEN      (ZXCANS>0 And S5CANT>ZXCANS                                      
     C                             And T0TREG<>0)                                                   
     C                             Or (ZXCANS>0 And S5CANT>ZXCANS                                   
     C                             And T0TREG=0 And T0CANS+ZXCANS<T0CANT)                           
     C                   EVAL      T0EDST='75'                                                      
02070C                   IF        T0STLP = '5' And @PEDAU = '307'                                  
02070C                   EVAL      T0STCP='  '                                                      
02070C                   ENDIF                                                                      
     C                   WHEN      ZXCANS=0 And S5CANT=S5CAPP                                       
     C                   EVAL      T0EDST='70'                                                      
     C                   WHEN      ZXCANS=0 And S5CAPP>0 And S5CANT>S5CAPP                          
     C                   EVAL      T0EDST='65'                                                      
     C                   WHEN      ZXCANS=0 And S5CAPP=0 And S5CANT=ZXCANR                          
     C                   EVAL      T0EDST='60'                                                      
     C                   WHEN      ZXCANS=0 And S5CAPP=0 And                                        
     C                             ZXCANR>0 And S5CANT>ZXCANR                                       
     C                   EVAL      T0EDST='55'                                                      
C2616C                   WHEN      ZXCANS=0 And S5CAPP=0 And ZXCANR=0                               
C2280C                             And T0EDST<'70'                                                  
C2616C                   EVAL      T0EDST='50'                                                      
e01  C                   ENDSL                                                                      
                                                                                                    
     C                   ENDSR                                                                      
24080 **********************************************************************                        
24080 * Unitats de Mesura                                                                           
24080 **********************************************************************                        
24080C     CS_UNITS      BEGSR                                                                      
24080                                                                                               
24080 * Per defecte                                                                                 
24080C                   EVAL      T0COFA=1                                                         
24080C                   EVAL      T0TCOF='0'                                                       
24080C                   EVAL      T0DECI=0                                                         
24080                                                                                               
24080 * Ara mirem si existeix alguna conversió unitats contra OL                                    
24080C                   EVAL      P6CIAS=S5CIAS                                                    
24080C                   EVAL      P6ARTI=S5ARTI                                                    
24080C                   EVAL      P6VARI=S5VARI                                                    
24080C                   EVAL      P6MODE=S5MODE                                                    
24080C     KPMUNAL       SETLL     PMUNAL                                                           
24080C     KPMUNAL       READE     PMUNAL                                                           
24080C                   DOW       NOT %EOF(PMUNAL)                                                 
24080C                   IF        P6UNOL='1'                                                       
24080C                   EVAL      T0COFA=P6COFA                                                    
24080C                   EVAL      T0TCOF=P6TCOF                                                    
24080C                   EVAL      T0DECI=P6DECI                                                    
24080C                   ENDIF                                                                      
24080C     KPMUNAL       READE     PMUNAL                                                           
24080C                   ENDDO                                                                      
24080                                                                                               
24080C                   ENDSR                                                                      
24080 **********************************************************************                        
24080 * Quantitat Servida des de Delegació                                                          
24080 **********************************************************************                        
24080C     CS_CANDLGA    BEGSR                                                                      
24080                                                                                               
24080C                   EVAL      T0CAND=0                                                         
24080 * Primer miro si ha ha albarans al històric                                                   
24080C                   EVAL      CECIAS=S5CIAS                                                    
24080C                   EVAL      CECUST=S5CUST                                                    
24080C                   EVAL      CENPCO=S5NPCO                                                    
24080C                   EVAL      CETPED=S5TPED                                                    
24080C                   EVAL      CEDATP=S5DATP                                                    
24080C                   EVAL      CENOPL=S5NOPL                                                    
24080C                   EVAL      CELINE=S5LINE                                                    
24080C     KCOALBD10     SETLL     COHALD10                                                         
24080C     KCOALBD10     READE     COHALD10                                                         
24080C                   DOW       NOT %EOF(COHALD10)                                               
24080C                   IF        %SUBST(CEALBA:1:2)<>'OD'                                         
24080C                             And %SUBST(CEALBA:1:2)<>'ED'                                     
24080C                   EVAL      T0CAND=T0CAND+CECANS                                             
24080C                   ENDIF                                                                      
24080C     KCOALBD10     READE     COHALD10                                                         
24080C                   ENDDO                                                                      
24080                                                                                               
24080 * Ara miro si ha ha albarans                                                                  
24080C                   EVAL      CECIAS=S5CIAS                                                    
24080C                   EVAL      CECUST=S5CUST                                                    
24080C                   EVAL      CENPCO=S5NPCO                                                    
24080C                   EVAL      CETPED=S5TPED                                                    
24080C                   EVAL      CEDATP=S5DATP                                                    
24080C                   EVAL      CENOPL=S5NOPL                                                    
24080C                   EVAL      CELINE=S5LINE                                                    
24080C     KCOALBD10     SETLL     COALBD10                                                         
24080C     KCOALBD10     READE     COALBD10                                                         
24080C                   DOW       NOT %EOF(COALBD10)                                               
24080C                   IF        %SUBST(CEALBA:1:2)<>'OD'                                         
24080C                   EVAL      T0CAND=T0CAND+CECANS                                             
24080C                   ENDIF                                                                      
24080C     KCOALBD10     READE     COALBD10                                                         
24080C                   ENDDO                                                                      
24080                                                                                               
24080C                   ENDSR                                                                      
FQ710 **************************************************************                                
FQ710 * Calculo Importe unitario de la linea de pedido             *                                
FQ710 *------------------------------------------------------------*                                
FQ710C     CS_IMPORTE    BEGSR                                                                      
FQ710                                                                                               
FQ710C                   EVAL      ZXMONE2 = S5MONE                                                 
FQ710 * Tipo de IVA                                                                                 
FQ710C                   EVAL      P_PECIAS=S5CIAS                                                  
FQ710C                   EVAL      P_PECTAB='TIV2'                                                  
FQ710C                   EVAL      P_PECLTA=*BLANKS                                                 
FQ710C                   EVAL      P_PECLTA=S0TIV3                                                  
FQ710C     KPMTABD       CHAIN     PMTABD                                                           
FQ710C                   IF        %FOUND(PMTABD)                                                   
FQ710C                   EVAL      ZXTIVC=P_PEBL61                                                  
FQ710C                   EVAL      ZXBL65I=P_PEBL65                                                 
FQ710C                   ELSE                                                                       
FQ710C                   EVAL      ZXPABI=*BLANKS                                                   
FQ710C                   ENDIF                                                                      
FQ710                                                                                               
FQ710C                   EVAL      XZAUXI=*ZEROS                                                    
FQ710C                   EVAL      XZAUXI1=*ZEROS                                                   
FQ710C                   EVAL      MBCIAS=S5CIAS                                                    
FQ710C                   EVAL      MBMONE=ZXMONE2                                                   
FQ710 * Ecotaxe                                                                                     
FQ710C                   EVAL      XZTAXE=0                                                         
FQ710C                   IF        S5ECOP<>*BLANKS                                                  
FQ710C                   CALL      'MN0398'                                                         
FQ710C                   PARM                    @PCIAS                                             
FQ710C                   PARM      S5ECOP        @PEECOP                                            
FQ710C                   PARM      S5DATP        @PEFLCD                                            
FQ710C                   PARM      0             @PETAXE                                            
FQ710C                   EVAL      XZTAXE=@PETAXE                                                   
FQ710C                   ENDIF                                                                      
FQ710 * Buscamos en Ajuste decimal                                                                  
FQ710                                                                                               
FQ710C     KMSDIV0       CHAIN     MSDIV0                                                           
FQ710C                   IF        %FOUND(MSDIV0)                                                   
FQ710C                   EVAL      XZDECI=MBDECI                                                    
FQ710C                   EVAL      XZAJUD=MBAJUD                                                    
FQ710C                   ENDIF                                                                      
FQ710                                                                                               
FQ710 * Buscamos en PMUNAL UNIDADES ALTERNATIVAS                                                    
FQ710                                                                                               
FQ710C                   EVAL      XZCOFU=1                                                         
FQ710C                   IF        S5UNIM<>S5UNDP                                                   
FQ710C                   EVAL      XZCIAS=@PCIAS                                                    
FQ710C                   EVAL      XZARTI=S5ARTI                                                    
FQ710C                   EVAL      XZVARI=S5VARI                                                    
FQ710C                   EVAL      XZMODE=S5MODE                                                    
FQ710C                   EVAL      ZXCA10=1                                                         
FQ710C                   EVAL      ZXCA11=1                                                         
FQ710C                   EVAL      ZXUN10=S5UNIM                                                    
FQ710C                   EVAL      ZXUN11=S5UNDP                                                    
FQ710C* CAMBIO de unidades                                                                          
FQ710C/COPY *LIBL/QSRDSRC,SRD021                                                                    
FQ710C                   ENDIF                                                                      
FQ710                                                                                               
FQ710 * Buscamos en CAMBIO MONEDA CABECERA DEL PEDIDO                                               
FQ710                                                                                               
FQ710C                   IF        ZXMONE2<>S5MONE                                                  
FQ710C                   CALL      'MM2555'                                                         
FQ710C                   PARM      S5CIAS        @PCIAS                                             
FQ710C                   PARM      S5MONE        @PMON1                                             
FQ710C                   PARM      ZXMONE2       @PMON2                                             
FQ710C                   PARM      S5DATP        @PDATA                                             
FQ710C                   PARM      S5NOPL        @PHORA                                             
FQ710C                   PARM      0             @PCMCOCO                                           
FQ710C                   PARM      0             @PCMCCCO                                           
FQ710C                   PARM      *BLANKS       @PEERR                                             
FQ710C                   EVAL      ZXCOCAMB=@PCMCCCO                                                
FQ710C                   ELSE                                                                       
FQ710C                   EVAL      ZXCOCAMB=1                                                       
FQ710C                   ENDIF                                                                      
FQ710                                                                                               
FQ710 * Buscamos en % de IVA                                                                        
FQ710C                   EVAL      MVCIAS=S5CIAS                                                    
FQ710C                   EVAL      MVTIVA=S5TIVA                                                    
FQ710C                   EVAL      MVPABI=ZXPABI                                                    
FQ710C                   EVAL      MVFLCD=@PDATP                                                    
FQ710C     KMSIVAS       SETGT     MSIVAS                                                           
FQ710C     KMSIVAS0      READPE    MSIVAS                                 83                        
FQ710C                   SELECT                                                                     
FQ710C                   WHEN      ZXTIVC=' '                                                       
FQ710C                   EVAL      MVPIV2=*ZEROS                                                    
FQ710C                   WHEN      ZXTIVC='0'                                                       
FQ710C                   EVAL      MVPIV1=*ZEROS                                                    
FQ710C                   EVAL      MVPIV2=*ZEROS                                                    
FQ710C                   ENDSL                                                                      
FQ710                                                                                               
FQ710 * Calculamos el precio de nueva linea o modificada                                            
FQ710C                   EVAL      XZCANT=1                                                         
FQ710C                   EVAL      XZPREC=S5PREC                                                    
FQ710C                   EVAL      XZCADP=S5CADP                                                    
FQ710C                   EVAL      XZDTO1=S5DTO1                                                    
FQ710C                   EVAL      XZDTO2=S5DTO2                                                    
FQ710C                   EVAL      XZDTO3=S5DTO3                                                    
FQ710C                   EVAL      XZDTO4=S5DTO4                                                    
FQ710C                   IF        XZDTO4=*ZEROS                                                    
FQ710C                   EVAL      XZDTO4=@PDTOE                                                    
FQ710C                   ENDIF                                                                      
FQ710C/COPY *LIBL/QSRDSRC,SRD022ECO                                                                 
FQ710C* AJUSTE Y DECIMALES                                                                          
FQ710C/COPY *LIBL/QSRDSRC,SRD001                                                                    
FQ710C                   Z-ADD     XZAUXI        ZXBIMPECO                                          
FQ710C/COPY *LIBL/QSRDSRC,SRD022                                                                    
FQ710                                                                                               
FQ710C* AJUSTE Y DECIMALES                                                                          
FQ710C/COPY *LIBL/QSRDSRC,SRD001                                                                    
FQ710C                   Z-ADD     XZAUXI        ZXBIMP                                             
FQ710C                   ADD       ZXBIMPECO     ZXBIMP                                             
FQ710 * Calculamos el IVA                                                                           
FQ710C                   EVAL      XZAUXI=ZXBIMP*MVPIV1                                             
FQ710C     XZAUXI        DIV(H)    100           XZAUXI                                             
FQ710C* AJUSTE Y DECIMALES                                                                          
FQ710C/COPY *LIBL/QSRDSRC,SRD001                                                                    
FQ710C                   Z-ADD     XZAUXI        ZXIIV1                                             
FQ710 * Calculamos el Recargo de equivalencia                                                       
FQ710C                   EVAL      XZAUXI=ZXBIMP*MVPIV2                                             
FQ710C     XZAUXI        DIV(H)    100           XZAUXI                                             
FQ710C* AJUSTE Y DECIMALES                                                                          
FQ710C/COPY *LIBL/QSRDSRC,SRD001                                                                    
FQ710C                   Z-ADD     XZAUXI        ZXIIV2                                             
FQ710                                                                                               
FQ710 * Omitimos BASE o IVA segun tipo de IVA                                                       
FQ710                                                                                               
FQ710C                   IF        MVOMTB>='1'                                                      
FQ710C                   EVAL      ZXBIMP=ZXBIMP-ZXBIMP                                             
FQ710C                   ENDIF                                                                      
FQ710C                   IF        MVOMTI>='1'                                                      
FQ710C                   EVAL      ZXIIV1=ZXIIV1-ZXIIV1                                             
FQ710C                   EVAL      ZXIIV2=ZXIIV2-ZXIIV2                                             
FQ710C                   ENDIF                                                                      
FQ710                                                                                               
FQ710C                   ENDSR                                                                      
20100 **************************************************************                                
20100 * Cargo Portes                                               *                                
20100 *------------------------------------------------------------*                                
20100C     CS_CARGPORT   BEGSR                                                                      
20100                                                                                               
20100C                   EVAL      T0PORT = 0                                                       
20100C                   EVAL      P_PECIAS=@PCIAS                                                  
20100C                   EVAL      P_PECTAB='PORT'                                                  
20100C                   EVAL      P_PECLTA='ARTICULO'                                              
20100C     KPMTABD       CHAIN     PMTABD                                                           
20100C                   IF        %FOUND(PMTABD)                                                   
20100C                   EVAL      ZXART_PORTES = P_PEDESC                                          
20100C                   ELSE                                                                       
20100C                   EVAL      ZXART_PORTES = *BLANKS                                           
20100C                   ENDIF                                                                      
20100                                                                                               
20100 * Detall Comandes Comercial                                                                   
20100C                   IF        ZXART_PORTES <> *BLANKS                                          
20100                                                                                               
20100C     KCOCAPE       SETLL     CODEPE                                                           
20100C     KCOCAPE       READE     CODEPE                                                           
20100C                   DOW       NOT %EOF(CODEPE)                                                 
20100C                   IF        S5ARTI = ZXART_PORTES                                            
20100C                             And S5STUL<'1'                                                   
20100C                   EVAL      T0PORT = 1                                                       
20100C                   ENDIF                                                                      
20100C     KCOCAPE       READE     CODEPE                                                           
20100C                   ENDDO                                                                      
20100                                                                                               
20100 * Recupero registre CODEPE                                                                    
20100C                   EVAL      S5CIAS=@PCIAS                                                    
20100C                   EVAL      S5DLGA=@PDLGA                                                    
20100C                   EVAL      S5NPCO=@PNPCO                                                    
20100C                   EVAL      S5TPED=@PTPED                                                    
20100C                   EVAL      S5DATP=@PDATP                                                    
20100C                   EVAL      S5NOPL=@PNOPL                                                    
20100C                   EVAL      S5LINE=@PLINE                                                    
20100C     KCODEPE       CHAIN     CODEPE                                                           
20100                                                                                               
20100C                   ENDIF                                                                      
20100                                                                                               
20100C                   ENDSR                                                                      
FQ726 **********************************************************************                        
FQ726 * Comprobar logísticas para servir desde productiva                                           
FQ726 **********************************************************************                        
FQ726C     CS_LOGISTI    BEGSR                                                                      
FQ726                                                                                               
FQ726 * Miro la logística de la linea del pedido                                                    
FQ726C                   EVAL      MICIAS=S5CIAS                                                    
FQ726C                   EVAL      MIDLGA=S5DLGA                                                    
FQ726C                   EVAL      MILGCA=S5LOGE                                                    
FQ726C     KMSLOGI       CHAIN     MSLOGI                                                           
FQ726 * Si es una logistica que va por Entrega Directa y no es OL                                   
FQ726C                   IF        %FOUND(MSLOGI) And MIMI01='1'                                    
FQ726C                             And MIALOL<>'1'                                                  
FQ726C                   EVAL      T0EDDP = 1                                                       
FQ726C                   ENDIF                                                                      
FQ726                                                                                               
FQ726C                   ENDSR                                                                      
      **********************************************************************                        
      * Rutina que graba registro en EDTRAU                                *                        
      **********************************************************************                        
     C     CS_UPD_EDTRAU BEGSR                                                                      
      *                                                                                             
      * Se quiere grabar registro de auditoría en EDTRAU?                                           
      *                                                                                             
     C                   IF        @PWAUD=1                                                         
      * TIMESTAMP                                                                                   
     C*                  EVAL      ZXTIM1 = %TIMESTAMP()                                            
     C*                  MOVEL     ZXTIM1        ZXTIMESTAMP                                        
     C*                  MOVEL     ZXTIMESTAMP   T1TMST                                             
      *                                                                                             
     C                   EVAL      T1CIAS=T0CIAS                                                    
     C                   EVAL      T1DLGA=T0DLGA                                                    
     C                   EVAL      T1NPCO=T0NPCO                                                    
     C                   EVAL      T1TPED=T0TPED                                                    
     C                   EVAL      T1DATP=T0DATP                                                    
     C                   EVAL      T1NOPL=T0NOPL                                                    
     C                   EVAL      T1LINE=T0LINE                                                    
     C                   EVAL      T1ARVM=T0ARVM                                                    
     C                   EVAL      T1ARV1=T0ARV1                                                    
     C                   EVAL      T1COM2=T0COM2                                                    
     C                   EVAL      T1ARV2=T0ARV2                                                    
     C                   EVAL      T1EDAU=@PEDAU                                                    
FQ726C**                 EVAL      T1EDAD=PEDESC                                                    
FQ726C                   EVAL      T1EDAD=ZXDESCAUD                                                 
     C                   EVAL      T1DATR=*DATE                                                     
     C                   TIME                    T1HORR                                             
     C                   EVAL      T1USER=SDSUSR                                                    
     C                   EVAL      T1JOBR=SDSJOB                                                    
     C                   EVAL      T1CANT=@PCANT                                                    
     C                   EVAL      T1EDER=*BLANKS                                                   
     C                   EVAL      T1EDAV=@PERAV                                                    
      *Selecciono si es error o avíso                                                               
     C                   SELECT                                                                     
      *Error                                                                                        
     C                   WHEN      @PEDAU='251'                                                     
     C                   EVAL      T1EDER=@PERAV                                                    
     C                   EVAL      T1EDAV=*BLANKS                                                   
      *Avíso                                                                                        
     C                   WHEN      @PEDAU='260'                                                     
     C                   EVAL      T1EDER=*BLANKS                                                   
     C                   EVAL      T1EDAV=@PERAV                                                    
     C                   ENDSL                                                                      
     C                   EVAL      T1TEXT=@PTEXT                                                    
     C                   EVAL      T1DATO=@PDATO                                                    
     C                   EVAL      T1PGMR=PEBL62                                                    
     C                   EVAL      T1STUL='0'                                                       
      *                                                                                             
      * Todos los eventos de eliminación de una línea de ED                                         
      * se graban directamente en el fichero de eliminaciones                                       
      * sino, en el fichero de ED gestionadas                                                       
      *                                                                                             
     C                   IF        @PEDAU='005' OR @PEDAU='009'                                     
     C                             OR @PEDAU='105' OR @PEDAU='109'                                  
     C                   DOU       *IN80=*OFF                                                       
     C                   EVAL      ZXTIM1 = %TIMESTAMP()                                            
     C                   MOVEL     ZXTIM1        ZXTIMESTAMP                                        
     C                   MOVEL     ZXTIMESTAMP   T1TMST                                             
     C                   WRITE     REDTRAX00                            80                          
     C                   ENDDO                                                                      
     C                   ELSE                                                                       
     C                   DOU       *IN80=*OFF                                                       
     C                   EVAL      ZXTIM1 = %TIMESTAMP()                                            
     C                   MOVEL     ZXTIM1        ZXTIMESTAMP                                        
     C                   MOVEL     ZXTIMESTAMP   T1TMST                                             
     C                   WRITE     REDTRAU00                            80                          
     C                   ENDDO                                                                      
     C                   ENDIF                                                                      
     C                                                                                              
     C                   ENDIF                                                                      
     C                                                                                              
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Procesa Posible E-Mail asociado                                            *                
      **********************************************************************                        
     C     CS_EMAIL      BEGSR                                                                      
      *                                                                                             
     C                   MOVE      '1'           @EMTENV                                            
     C                   MOVE      *BLANKS       @EMJOBN                                            
     C                   MOVE      *BLANKS       @EMEEMA                                            
     C                   MOVE      *BLANKS       @EMREMA                                            
     C                   MOVE      *BLANKS       @EMPGRE                                            
      *                                                                                             
     C                   EVAL      ZXQCMG=*BLANKS                                                   
     C                   EVAL      ZXQCMG='SBMJOB CMD(CALL ED0530'+                                 
     C                             ' PARM('+C(1)+@EMJOBN+C(1)+                                      
     C                             ' '+C(1)+@EMPGRE+C(1)+                                           
     C                             ' '+C(1)+@EMCIAA+C(1)+                                           
     C                             ' '+C(1)+@EMDLGA+C(1)+                                           
     C                             ' '+C(1)+@EMEVEN+C(1)+                                           
     C                             ' '+C(1)+@EMTENV+C(1)+                                           
     C                             ' '+C(1)+@EMCODE+C(1)+                                           
     C                             ' '+C(1)+@EMNDOC+C(1)+                                           
     C                             ' '+C(1)+@EMFDOC+C(1)+                                           
     C                             ' '+C(1)+@EMLDOC+C(1)+                                           
     C                             ' '+C(1)+@EMEEMA+C(1)+                                           
     C                             ' '+C(1)+@EMREMA+C(1)+'))'+                                      
     C                             ' JOBQ(*LIBL/QFACDIG) JOB(ED0530)'                               
      *                                                                                             
     C                   CALL      'QCMDEXC'                                                        
     C                   PARM                    ZXQCMG                                             
     C                   PARM                    ZXLOGG                                             
      *                                                                                             
     C                   ENDSR                                                                      
21050 **********************************************************************                        
21050 * AUDITO REGISTROS DE CLAVES DUPLICADAS EN EDTRLP                            *                
21050 **********************************************************************                        
21050C     CS_EDTRLD     BEGSR                                                                      
21050 *                                                                                             
21050C                   WRITE     REDTRLD                              80                          
21050 *                                                                                             
21050C                   ENDSR                                                                      
14N12 **************************************************************                                
14N12 * Traçabilitat GIC                                           *                                
14N12 **************************************************************                                
14N12C     CS_TRZGIC     BEGSR                                                                      
14N12 *                                                                                             
14N12 * Traçabilitat Comanda                                                                        
14N12C                   EVAL      DS3TIPO='3'                                                      
14N12C                   MOVEL     S5CIAS        DS3CIAS                                            
14N12C                   EVAL      DS3DLGA=S5DLGA                                                   
14N12C                   EVAL      DS3NPCO=S5NPCO                                                   
14N12C                   EVAL      DS3TPED=S5TPED                                                   
14N12C                   MOVEL     S5DATP        DS3DATP                                            
14N12C                   MOVEL     S5NOPL        DS3NOPL                                            
14N12C                   MOVEL     S5LINE        DS3LINE                                            
14N12C                   EVAL      DS3BLAN=*BLANKS                                                  
14N12                                                                                               
14N12 * Cerco si la comanda es del GIC                                 n                            
14N12C                   EVAL      V7CIAS=S5CIAS                                                    
14N12C                   EVAL      V7TRZD=DSTRZD3                                                   
14N12C     KPVDEVI05     CHAIN     PVDEVI05                                                         
14N12C                   IF        %Found(PVDEVI05)                                                 
14N12                                                                                               
14N12 * Actualitzo línia reclamació GIC                                n                            
14N12C                   EVAL      V1NDE2=V7NDE2                                                    
14N12C                   EVAL      V1LIN2=V7LIN2                                                    
14N12C     KPVDEVD10     SETLL     PVDEVD10                                                         
14N12C     KPVDEVD10     READE     PVDEVD10                                                         
14N12C                   DOW       NOT %EOF(PVDEVD10)                                               
14N12C                   EVAL      V1PEFD=ZXPEFD                                                    
14N12C                   EVAL      V1AMPL=X1AMPL                                                    
14N12C                   UPDATE    RPVDEVD                                                          
14N12C     KPVDEVD10     READE     PVDEVD10                                                         
14N12C                   ENDDO                                                                      
14N12                                                                                               
14N12C                   EVAL      T0NDE2=V1NDE2                                                    
14N12C                   EVAL      T0LIR2=V1LIN2                                                    
14N12                                                                                               
14N12C                   ENDIF                                                                      
14N12                                                                                               
14N12C                   ENDSR                                                                      
C1328 **********************************************************************                        
C1328 * Campo de Autorización Entrega Directa Desde Productiva             *                        
C1328 **********************************************************************                        
C1328C     CS_EDDP       BEGSR                                                                      
C1328 *                                                                                             
C1328c                   eval      U_C0CIAS=@PCIAS                                                  
C1328c                   eval      U_C0PRVR=C0PRVR                                                  
C1328c     KPUPROV       CHAIN     PUPROV                                                           
C1328c                   if        %found                                                           
C1328c                             and U_C0EDDP='1'                                                 
C1328c                   move      U_C0EDDP      T0EDDP                                             
C1328c                   endif                                                                      
C1328 *                                                                                             
C1328C                   ENDSR                                                                      
C1350 **************************************************************                                
C1350 * Bloqueo albaranes                                          *                                
C1350 **************************************************************                                
C1350C     CS_BLQALB     BEGSR                                                                      
C1350 *                                                                                             
C2501C                   MOVEL     S0CIAS        ZXCIAS                                             
C2501C                   EVAL      FileCoclin= 'PURLIBF' + ZXCIAS +                                 
C2501C                                          '/COCLIN'                                           
C2501C                   OPEN (E)  COCLIN                                                           
C2501C                   IF        Not %ERROR                                                       
C1350C                   IF        T0RISK<>1                                                        
C1350C     KCOCLIN       CHAIN     COCLIN                                                           
13614C*                  IF        L_S0BABB='1'                                                     
13614C                   IF        L_S0BABB>='1'                                                    
C1350C                   EVAL      T0RISK=2                                                         
C1350C                   ENDIF                                                                      
C1350C                   ENDIF                                                                      
C2501C                   ENDIF                                                                      
C2501C                   CLOSE(E)  COCLIN                                                           
C1350                                                                                               
C1350C                   ENDSR                                                                      
C1350 **************************************************************                                
C1350 * Desbloqueo albaranes                                       *                                
C1350 **************************************************************                                
C1350C     CS_DESBLQALB  BEGSR                                                                      
C1350 *                                                                                             
C2501C                   MOVEL     S0CIAS        ZXCIAS                                             
C2501C                   EVAL      FileCoclin= 'PURLIBF' + ZXCIAS +                                 
C2501C                                          '/COCLIN'                                           
C2501C                   OPEN (E)  COCLIN                                                           
C2501C                   IF        Not %ERROR                                                       
C1350C                   IF        T0RISK<>0                                                        
C1350C     KCOCLIN       CHAIN     COCLIN                                                           
13614C*                  IF        L_S0BABB='1'                                                     
13614C                   IF        L_S0BABB>='1'                                                    
C1350C                   EVAL      T0RISK=2                                                         
C1350C                   ELSE                                                                       
C1350C                   EVAL      T0RISK=0                                                         
C1350C                   ENDIF                                                                      
C1350C                   ENDIF                                                                      
C2501C                   ENDIF                                                                      
C2501C                   CLOSE(E)  COCLIN                                                           
C1350                                                                                               
C1350C                   ENDSR                                                                      
C2185 **************************************************************                                
C2185 * Actualizar datos de TRACE en EDITRC                        *                                
C2185 **************************************************************                                
C2185C     CS_EDITRC     BEGSR                                                                      
C2185 *                                                                                             
C2185 * Buscamos todos los registros del pedido de la comercial en EDITRC                           
C2185 * y los actualizamos con los datos del pedido de TRACE                                        
C2185 *                                                                                             
C2501C                   EVAL      ZXEDITRC='0'                                                     
C2185C                   EVAL      T5CIAS=T0CIAS                                                    
C2185C                   EVAL      T5DLGA=T0DLGA                                                    
C2185C                   EVAL      T5NPCO=T0NPCO                                                    
C2185C                   EVAL      T5TPED=T0TPED                                                    
C2185C                   EVAL      T5DATP=T0DATP                                                    
C2185C                   EVAL      T5NOPL=T0NOPL                                                    
C2185C                   EVAL      T5LINE=T0LINE                                                    
C2185C     KEDITRC       SETLL     EDITRC                                                           
C2185C     KEDITRC       READE     EDITRC                                 83                        
C2185C                   DOW       NOT %EOF(EDITRC)                                                 
C2501C                   EVAL      ZXEDITRC='1'                                                     
C2185C                   EXSR      CS_UPD_EDITRC                                                    
C2185C     KEDITRC       READE     EDITRC                                 83                        
C2185C                   ENDDO                                                                      
C2185 *                                                                                             
C2501 * Si el pedido ha entrado manualmente y no via EDI mediante el                                
C2501 * EDIORD4 o el EDIORD6 lo grabamos ahora como un pedido normal                                
C2501 * sin localizaciones                                                                          
C2501 *                                                                                             
C2501C                   IF        ZXEDITRC='0'                                                     
C2501C                   EXSR      CS_GRA_EDITRC                                                    
C2501C                   ENDIF                                                                      
C2501 *                                                                                             
C2185C                   ENDSR                                                                      
C2185 **************************************************************                                
C2185 * Actualizar datos de TRACE en EDITRC                        *                                
C2185 **************************************************************                                
C2185C     CS_UPD_EDITRC BEGSR                                                                      
C2185 *                                                                                             
C2185 *  Reserva en TRACE (asignamos el pedido de TRACE)                                            
C2185 *                                                                                             
C2185C                   IF        @PEDAU='301'                                                     
C2185C                   EVAL      T5CIA3=T0CIA3                                                    
C2185C                   EVAL      T5DLG3=T0DLG3                                                    
C2185C                   EVAL      T5NPC3=T0NPC3                                                    
C2185C                   EVAL      T5TPE3=T0TPE3                                                    
C2185C                   EVAL      T5DAT3=T0DAT3                                                    
C2185C                   EVAL      T5NOP3=T0NOP3                                                    
C2185C                   EVAL      T5LIN3=T0LIN3                                                    
C2185C                   ENDIF                                                                      
C2185 *                                                                                             
C2185 *  Desreserva en TRACE (desasignamos el pedido de TRACE)                                      
C2185 *                                                                                             
C2185C                   IF        @PEDAU='302'                                                     
C2185C                   EVAL      T5CIA3=*ZEROS                                                    
C2185C                   EVAL      T5DLG3=*BLANKS                                                   
C2185C                   EVAL      T5NPC3=*BLANKS                                                   
C2185C                   EVAL      T5TPE3=*BLANKS                                                   
C2185C                   EVAL      T5DAT3=*ZEROS                                                    
C2185C                   EVAL      T5NOP3=*ZEROS                                                    
C2185C                   EVAL      T5LIN3=*ZEROS                                                    
C2185C                   ENDIF                                                                      
C2185 *                                                                                             
C2185C                   UPDATE    REDITRC                              83                          
C2185 *                                                                                             
C2185C                   ENDSR                                                                      
C2185 **************************************************************                                
C2501 * Grabar datos del pedido en EDITRC                          *                                
C2501 **************************************************************                                
C2501C     CS_GRA_EDITRC BEGSR                                                                      
R2185C                   CLEAR                   REDITRC                                            
C2501 *                                                                                             
C2501 * Datos de localización (no hay)                                                              
C2501 *                                                                                             
C2501C                   EVAL      T5CLA1=*BLANKS                                                   
C2501C                   EVAL      T5CLA2=*BLANKS                                                   
C2501C                   EVAL      T5CLA3=*BLANKS                                                   
C2501C                   EVAL      T5LLOC=*BLANKS                                                   
C2501C***                EVAL      T5CANT=*ZEROS                                                    
C2501C                   EVAL      T5DATE=*BLANKS                                                   
C2501C                   EVAL      T5DATU=*BLANKS                                                   
C2501 *                                                                                             
C2501 * Datos de CODEPE (desde EDTRLP)                                                              
C2501 *                                                                                             
C2501C                   EVAL      T5CIAS=T0CIAS                                                    
C2501C                   EVAL      T5DLGA=T0DLGA                                                    
C2501C                   EVAL      T5NPCO=T0NPCO                                                    
C2501C                   EVAL      T5TPED=T0TPED                                                    
C2501C                   EVAL      T5DATP=T0DATP                                                    
C2501C                   EVAL      T5NOPL=T0NOPL                                                    
C2501C                   EVAL      T5LINE=T0LINE                                                    
C2501C                   EVAL      T5CANT=T0CANT                                                    
C2501C                   EVAL      T5ARVP=T0ARVM                                                    
C2501C                   EVAL      T5CUST=T0CUST                                                    
C2501 *                                                                                             
C2501 * Datos de COCEDI (Sucursal y Dpto)                                                           
C2501 *                                                                                             
C2501C                   MOVEL     T0CIAS        ZXCIAS                                             
C2501C                   EVAL      FileCocedi= 'PURLIBF' + ZXCIAS +                                 
C2501C                                          '/COCEDI'                                           
C2501C                   OPEN (E)  COCEDI                                                           
C2501C                   IF        Not %ERROR                                                       
C2501C                   EVAL      ED_S0CIAS=T0CIAS                                                 
C2501C                   EVAL      ED_S0CUST=T0CUST                                                 
C2501C     KCOCEDI       CHAIN     COCEDI                             81                            
C2501C                   IF        %FOUND(COCEDI)                                                   
C2501*                  EVAL      T5SUCU=ED_S0SUCU                                                 
C2501C                   IF        T5SUCU=' '                                                       
C2501C                   EVAL      T5SUCU=ED_S0RECE                                                 
C2501C                   ENDIF                                                                      
C2501C                   EVAL      T5SUCD=ED_S0SUCD                                                 
C2501C                   ENDIF                                                                      
C2501C                   ENDIF                                                                      
C2501C                   CLOSE(E)  COCEDI                                                           
C2501 *                                                                                             
C2501 * Datos de CODIPR (Dirección de entrega) (desde EDTRLP)                                       
C2501 *                                                                                             
C2501C                   MOVEL     T0CIAS        ZXCIAS                                             
C2501C                   EVAL      FileCodipr= 'PURLIBF' + ZXCIAS +                                 
C2501C                                          '/CODIPR'                                           
C2501C                   OPEN (E)  CODIPR                                                           
C2501C                   IF        Not %ERROR                                                       
C2501C                   EVAL      S2CIAS=T0CIAS                                                    
C2501C                   EVAL      S2CUST=T0CUST                                                    
C2501C                   EVAL      S2TDIR=T0TDI1                                                    
C2501C     KCODIPR       CHAIN     CODIPR                             81                            
C2501C                   IF        %FOUND(CODIPR)                                                   
C2501C                   EVAL      T5RAOS=S2RAOS                                                    
C2501C                   EVAL      T5RAO2=S2RAO2                                                    
C2501C                   EVAL      T5DPTO=S2DPTO                                                    
C2501C                   EVAL      T5DIRE=S2DIRE                                                    
C2501C                   EVAL      T5DIR2=S2DIR2                                                    
C2501C                   EVAL      T5POBL=S2POBL                                                    
C2501C                   EVAL      T5POST=S2POST                                                    
C2501C                   EVAL      T5PAIS=S2PAIS                                                    
C2501C                   EVAL      T5ETES=S2ETES                                                    
C2501C                   ELSE                                                                       
C2501C                   EVAL      T5RAOS=*BLANKS                                                   
C2501C                   EVAL      T5RAO2=*BLANKS                                                   
C2501C                   EVAL      T5DPTO=*BLANKS                                                   
C2501C                   EVAL      T5DIRE=*BLANKS                                                   
C2501C                   EVAL      T5DIR2=*BLANKS                                                   
C2501C                   EVAL      T5POBL=*BLANKS                                                   
C2501C                   EVAL      T5POST=*BLANKS                                                   
C2501C                   EVAL      T5PAIS=*BLANKS                                                   
C2501C                   EVAL      T5ETES=*BLANKS                                                   
C2501C                   ENDIF                                                                      
C2501 *                                                                                             
C2501 * Si la marca de imprimir etiquetas especiales de CODIPR=b ó '0'                              
C2501 * movemos la que tiene el cliente en COCLIN.L_S0ETES                                          
C2501 *                                                                                             
C2501C                   MOVEL     T0CIAS        ZXCIAS                                             
C2501C                   EVAL      FileCoclin= 'PURLIBF' + ZXCIAS +                                 
C2501C                                          '/COCLIN'                                           
C2501C                   OPEN (E)  COCLIN                                                           
C2501C                   IF        Not %ERROR                                                       
C2501C                   IF        S2ETES=*BLANKS OR S2ETES='0'                                     
C2501C                   EVAL      S0CIAS=T0CIAS                                                    
C2501C                   EVAL      S0CUST=T0CUST                                                    
C2501C     KCOCLIN       CHAIN     COCLIN                                                           
C2501C                   EVAL      T5ETES=L_S0ETES                                                  
C2501C                   ENDIF                                                                      
C2501C                   ENDIF                                                                      
C2501C                   CLOSE(E)  COCLIN                                                           
C2501 *                                                                                             
C2501C                   ENDIF                                                                      
C2501C                   CLOSE(E)  CODIPR                                                           
C2501 *                                                                                             
C2501 * Como el pedido no tiene EDIHPE (LOCLPED) quiere decir que el                                
C2501 * pedido no tiene localizaciones y por tanto no es consolidado                                
C2501 *                                                                                             
C2501C                   EVAL      T5MCON='0'                                                       
C2501 *                                                                                             
C2501 *  Reserva en TRACE (asignamos el pedido de TRACE)                                            
C2501 *                                                                                             
C2501C                   EVAL      T5CIA3=T0CIA3                                                    
C2501C                   EVAL      T5DLG3=T0DLG3                                                    
C2501C                   EVAL      T5NPC3=T0NPC3                                                    
C2501C                   EVAL      T5TPE3=T0TPE3                                                    
C2501C                   EVAL      T5DAT3=T0DAT3                                                    
C2501C                   EVAL      T5NOP3=T0NOP3                                                    
C2501C                   EVAL      T5LIN3=T0LIN3                                                    
C2501 *                                                                                             
C2501 * Buscamos la referencia del pedido de la comercial (S5REFE)                                  
C2501 *                                                                                             
C2501C                   MOVEL     T0CIAS        ZXCIAS                                             
C2501C                   EVAL      FileCodepe26= 'PURLIBF' + ZXCIAS +                               
C2501C                                          '/CODEPE26'                                         
C2501C                   OPEN (E)  CODEPE26                                                         
C2501C                   IF        Not %ERROR                                                       
C2501C                   EVAL      DP_S5CIAS=T0CIAS                                                 
C2501C                   EVAL      DP_S5DLGA=T0DLGA                                                 
C2501C                   EVAL      DP_S5NPCO=T0NPCO                                                 
C2501C                   EVAL      DP_S5TPED=T0TPED                                                 
C2501C                   EVAL      DP_S5DATP=T0DATP                                                 
C2501C                   EVAL      DP_S5NOPL=T0NOPL                                                 
C2501C     KCODEPE26     CHAIN     CODEPE26                                                         
C2501C                   IF        %FOUND(CODEPE26)                                                 
C2501C                   EVAL      T5REFE=DP_S5REFE                                                 
C2501C                   ENDIF                                                                      
C2501C                   ENDIF                                                                      
C2501C                   CLOSE(E)  CODEPE26                                                         
C2501 *                                                                                             
C2501 * Si es conjunto desdoblamos el registro y grabamos uno por cada                              
C2501 * componente de MSCOJD                                                                        
C2501 *                                                                                             
C2501C                   EVAL      T5COMP=*BLANKS                                                   
C2501C                   EVAL      T5LIN2=0                                                         
C2501C                   EVAL      T5CANS=0                                                         
C2501 *                                                                                             
C2501C                   EVAL      NDCIAS=T0CIAS                                                    
C2501C                   EVAL      NDARTI=%SUBST(T0ARVM:1:15)                                       
C2501C                   EVAL      NDVARI=%SUBST(T0ARVM:16:3)                                       
C2501C                   EVAL      NDMODE=%SUBST(T0ARVM:19:3)                                       
C2501C                   EVAL      NDTCOJ='4'                                                       
C2501C     KMSCOJC       CHAIN     MSCOJC                             83                            
C2501C                   IF        %FOUND(MSCOJC) AND NDBAJA<'1'                                    
C2501C     KMSCOJD0      SETLL     MSCOJD                                                           
C2501C     KMSCOJD0      READE     MSCOJD                                 83                        
C2501C                   DOW       NOT %EOF(MSCOJD)                                                 
C2501C                   IF        NDBAJA<'1'                                                       
C2501C                   EVAL      T5COMP=NDCOMP+NDVAR2+NDMOD2                                      
C2501C                   EVAL      T5LIN2+=1                                                        
C2501C                   EVAL      T5CANS=T5CANT*NDCANT                                             
C2501C                   WRITE     REDITRC                                                          
C2501C                   ENDIF                                                                      
C2501C     KMSCOJD0      READE     MSCOJD                                 83                        
C2501C                   ENDDO                                                                      
C2501 *                                                                                             
C2501C                   ELSE                                                                       
C2501 *                                                                                             
C2501 * Si no es conjunto no desdoblamos el registro                                                
C2501 *                                                                                             
C2501C                   WRITE     REDITRC                                                          
C2501C                   ENDIF                                                                      
C2501 *                                                                                             
C2501C                   ENDSR                                                                      
C2501 **************************************************************                                
C2684 * Proceso auditoría 232 eliminación X-doc                                                     
C2684 **********************************************************************                        
C2684C     CS_COD232     BEGSR                                                                      
C2684 *                                                                                             
C2684 * Recupero la clave del EDTRLP según el parámetro del lógico                                  
C2684 *                                                                                             
C2684C                   SELECT                                                                     
C2684C                   WHEN      @PLOGI=0                                                         
C2684C                   EVAL      T0CIAS=@PCIAS                                                    
C2684C                   EVAL      T0DLGA=@PDLGA                                                    
C2684C                   EVAL      T0NPCO=@PNPCO                                                    
C2684C                   EVAL      T0TPED=@PTPED                                                    
C2684C                   EVAL      T0DATP=@PDATP                                                    
C2684C                   EVAL      T0NOPL=@PNOPL                                                    
C2684C                   EVAL      T0LINE=@PLINE                                                    
C2684C                                                                                              
C2684C                   WHEN      @PLOGI=1                                                         
C2684C                   EVAL      T0CIA1=@PCIAS                                                    
C2684C                   EVAL      T0DLG1=@PDLGA                                                    
C2684C                   EVAL      T0NPC1=@PNPCO                                                    
C2684C                   EVAL      T0TPE1=@PTPED                                                    
C2684C                   EVAL      T0DAT1=@PDATP                                                    
C2684C                   EVAL      T0NOP1=@PNOPL                                                    
C2684C                   EVAL      T0LIN1=@PLINE                                                    
C2684C                                                                                              
C2684C                   WHEN      @PLOGI=2                                                         
C2684C                   EVAL      T0CIA2=@PCIAS                                                    
C2684C                   EVAL      T0DLG2=@PDLGA                                                    
C2684C                   EVAL      T0NPC2=@PNPCO                                                    
C2684C                   EVAL      T0TPE2=@PTPED                                                    
C2684C                   EVAL      T0DAT2=@PDATP                                                    
C2684C                   EVAL      T0NOP2=@PNOPL                                                    
C2684C                   EVAL      T0LIN2=@PLINE                                                    
C2684C                                                                                              
C2684C                   WHEN      @PLOGI=3                                                         
C2684C                   EVAL      T0CIA3=@PCIAS                                                    
C2684C                   EVAL      T0DLG3=@PDLGA                                                    
C2684C                   EVAL      T0NPC3=@PNPCO                                                    
C2684C                   EVAL      T0TPE3=@PTPED                                                    
C2684C                   EVAL      T0DAT3=@PDATP                                                    
C2684C                   EVAL      T0NOP3=@PNOPL                                                    
C2684C                   EVAL      T0LIN3=@PLINE                                                    
C2684C                                                                                              
C2684C                   ENDSL                                                                      
C2684C                                                                                              
C2684 * Leo archivo de trazabilidad y actualizo los campos correspondientes                         
C2684C                                                                                              
C2684C                   EVAL      *IN82=*OFF                                                       
C2684C                                                                                              
C2684C                   SELECT                                                                     
C2684C                   WHEN      @PLOGI=0                                                         
C2684C     KEDTRLP00     SETLL     EDTRLP00                                                         
C2684C                   WHEN      @PLOGI=1                                                         
C2684C     KEDTRLP10     SETLL     EDTRLP10                                                         
C2684C                   WHEN      @PLOGI=2                                                         
C2684C     KEDTRLP20     SETLL     EDTRLP20                                                         
C2684C                   WHEN      @PLOGI=3                                                         
C2684C     KEDTRLP30     SETLL     EDTRLP30                                                         
C2684C                   ENDSL                                                                      
C2684C                                                                                              
C2684C                   DOW       *IN82=*OFF                                                       
C2684C                                                                                              
C2684C                   SELECT                                                                     
C2684C                   WHEN      @PLOGI=0                                                         
C2684C     KEDTRLP00     READE     EDTRLP00                               82                        
C2684C                   WHEN      @PLOGI=1                                                         
C2684C     KEDTRLP10     READE     EDTRLP10                               82                        
C2684C                   WHEN      @PLOGI=2                                                         
C2684C     KEDTRLP20     READE     EDTRLP20                               82                        
C2684C                   WHEN      @PLOGI=3                                                         
C2684C     KEDTRLP30     READE     EDTRLP30                               82                        
C2684C                   ENDSL                                                                      
C2684C                                                                                              
C2684C                   IF        *IN82=*OFF                                                       
C2684C                                                                                              
C2684 * Este evento es la creación de un albarán X-DOCK.                                            
C2684 * por tanto actualizo los campos:                                                             
C2684C                   EVAL      T0XDOC=0                                                         
C2684C                   EVAL      T0DWRF=*DATE                                                     
C2684C                   TIME                    T0HWRF                                             
C2684C                                                                                              
C2684C                   SELECT                                                                     
C2684C                   WHEN      @PLOGI=0                                                         
C2684C                   UPDATE    REDTRLP00                            83                          
C2684C   83              EXSR      CS_EDTRLD                                                        
C2684C                   WHEN      @PLOGI=1                                                         
C2684C                   UPDATE    REDTRLP10                            83                          
C2684C   83              EXSR      CS_EDTRLD                                                        
C2684C                   WHEN      @PLOGI=2                                                         
C2684C                   UPDATE    REDTRLP20                            83                          
C2684C   83              EXSR      CS_EDTRLD                                                        
C2684C                   WHEN      @PLOGI=3                                                         
C2684C                   UPDATE    REDTRLP30                            83                          
C2684C   83              EXSR      CS_EDTRLD                                                        
C2684C                   ENDSL                                                                      
C2684C                                                                                              
C2684C                   ENDIF                                                                      
C2684C                                                                                              
C2684C                   ENDDO                                                                      
C2684C                                                                                              
C2684 *                                                                                             
C2684 * Se quiere grabar registro de auditoría en EDTRAU?                                           
C2684 *                                                                                             
C2684C                   EXSR      CS_UPD_EDTRAU                                                    
C2684 *                                                                                             
C2684 * Posible E-Mail con datos del pedido de compra                                               
C2684 *                                                                                             
C2684C                   MOVEL(P)  T0CIA2        @EMCIAA                                            
C2684C                   MOVEL(P)  T0DLG2        @EMDLGA                                            
C2684C                   MOVEL(P)  T0CUST        @EMCODE                                            
C2684C                   MOVEL(P)  T0NPC2        @EMNDOC                                            
C2684C                   MOVE      T0DAT2        @EMFDOC                                            
C2684C                   MOVE      T0LIN2        @EMLDOC                                            
C2684 *                                                                                             
C2684C                   ENDSR                                                                      
IT228 **********************************************************************                        
IT228C     CS_EXCEPM3    BEGSR                                                                      
IT228C                                                                                              
IT228C                   EVAL      C3CIAS = T0CIAS                                                  
IT228C                   EVAL      C3PRVR = T0PRVR                                                  
IT228C                   EVAL      C3ARVM = T0ARV1                                                  
IT228C     KPUPRP0       CHAIN     PUPRP0                                                           
IT228 *                                                                                             
IT228C                   IF        %FOUND AND C3ARVP<>*BLANKS                                       
IT228C                   EVAL      @PEARVP = C3ARVP                                                 
IT228C                   ELSE                                                   %FOUND(PUPRP0)      
IT228C                   EVAL      @PEARVP = T0ARV1                                                 
IT228C                   ENDIF                                                  %FOUND(PUPRP0)      
IT228 * Obtener almacén de servicio                                                                 
IT228 *                                                                                             
IT228C                   IF        M5SIOL<>'2'                                                      
IT228C                   EVAL      P_PECIAS=C5CIAS                                                  
IT228C                   EVAL      P_PECTAB='INO2'                                                  
IT228C                   EVAL      P_PECLTA='MAGV'+C5LOGE                                           
IT228C     KPMTABD       CHAIN     PMTABD                                                           
IT228C                   IF        %FOUND(PMTABD)                                                   
IT228C                   EVAL      @PEALMA=P_PEDESC                                                 
IT228C                   ELSE                                                                       
IT228C                   EVAL      @PEALMA=C5LOGE                                                   
IT228C                   ENDIF                                                                      
IT228C                   ELSE                                                                       
IT228C                   EVAL      @PEALMA=C5LOGE                                                   
IT228C                   ENDIF                                                                      
IT228C                   CALL      'MM1411'                                                         
IT228C                   PARM                    C5CIAS                                             
IT228C                   PARM                    @PEALMA                                            
IT228C                   PARM      '2'           @PETIPO                                            
IT228C                   PARM                    C5DLGA                                             
IT228C                   PARM                    @PERESP                                            
IT228 *                                                                                             
IT228C                   IF        @PERESP <> *BLANKS                                               
IT228C                   EVAL      @PEAlm1= @PERESP                                                 
IT228C                   ELSE                                                                       
IT228C                   EVAL      @PEAlm1 = C5loge                                                 
IT228C                   ENDIF                                                                      
IT228 *                                                                                             
IT228C                   CALL      'ED2530'                                                         
IT228C                   PARM                    T0CIAS                                             
IT228C                   PARM                    T0PRVR                                             
IT228C                   PARM                    @PEARVP                                            
IT228C                   PARM                    @PEALM1                                            
IT228C                   PARM                    @PEALM2                                            
IT228C                   PARM                    @PEINFO                                            
IT228 *                                                                                             
IT228C                   IF        @PEINFO='A' OR @PEINFO='P'                                       
IT228C                   EVAL      %SUBST(T0INFD:9:1) = '*'                                         
IT228 *                                                                                             
IT228C                   ENDIF                                                  %FOUND(EDTRLP10)    
IT228 *                                                                                             
IT228C                   ENDSR                                                                      
IT228 **********************************************************************                        
PG615 **************************************************************                                
PG615 *                                                                                             
PG615 *------------------------------------------------------------*                                
PG615C     LLAMA1413     BEGSR                                                                      
PG615                                                                                               
PG615c                   eval      iCnt=*zero                                                       
PG615 * 1er.- Validar si aquesta comanda M3 ja l'hem processat                                      
PG615c                   if        iLnpc2>*zero                                                     
PG615c                   eval      iCnt=%lookup(t0npc2:T_npc2:1:iLnpc2)                             
PG615c                   endif                                                                      
PG615c                   if        iCnt=*zero                                                       
PG615 * 2on.- NO l'hem processat, guardem comanda M3                                                
PG615c                   eval      iLnpc2 += 1                                                      
PG615c                   eval      T_npc2(iLnpc2)=t0npc2                                            
PG615 * 3er.- Actualitzem COCAPE                                                                    
PG615C                   eval      S0CIAS=T0CIAS                                                    
PG615C                   eval      S0DLGA=T0DLGA                                                    
PG615C                   eval      S0NPCO=T0NPCO                                                    
PG615C                   eval      S0TPED=T0TPED                                                    
PG615C                   eval      S0DATP=T0DATP                                                    
PG615C                   eval      S0NOPL=T0NOPL                                                    
PG615C     KCOCAPE       chain     cocape                                                           
E7394c                   if        %found(cocape)                                                   
PG615c                   select                                                                     
PG615c                   when      T0RISK = 2                                                       
PG615c                   eval      S0REXC = '1'                                                     
PG615c                   when      T0RISK = 0                                                       
PG615c                   eval      S0REXC = '0'                                                     
PG615c                   endsl                                                                      
PG615C                   update    rcocape                                                          
PG615 *                                                                                             
PG615 * 3er.- Llençar alineació amb M3                                                              
PG615c                   eval      bkcias = t0cias                                                  
PG615c                   eval      bkdlga = t0dlga                                                  
PG615c                   eval      bknpco = t0npco                                                  
PG615c                   eval      bktped = t0tped                                                  
PG615c                   eval      bkdatp = t0datp                                                  
PG615c                   eval      bknopl = t0nopl                                                  
PG615c                   eval      Tlin(1)= t0line                                                  
PG615c                   eval      pPointer = %addr(dsMM1413)                                       
PG615 *                                                                                             
PG615c                   call      'MM1413'                                                         
PG615c                   parm                    pPointer                                           
E7394c                   endif                                                  %found(cocape)      
PG615 *                                                                                             
PG615c                   endif                                                                      
PG615C                   ENDSR                                                                      
PG615 **********************************************************************                        
** CTDATA C                                                                                         
'                                                                                                   
