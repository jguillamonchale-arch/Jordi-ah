      **********************************************************************                        
      * Cambiar línea en comercial ED -> EN                                *                        
      **********************************************************************                        
     C     CS_COD009     BEGSR                                                                      
      *                                                                                             
      * Es como una anulación de línea                                                              
      * Recupero la clave del pedido comercial y elimino                                            
      *                                                                                             
     C                   EVAL      ZXGRAU=0                                                         
     C                   EVAL      T0CIAS=@PCIAS                                                    
     C                   EVAL      T0DLGA=@PDLGA                                                    
     C                   EVAL      T0NPCO=@PNPCO                                                    
     C                   EVAL      T0TPED=@PTPED                                                    
     C                   EVAL      T0DATP=@PDATP                                                    
     C                   EVAL      T0NOPL=@PNOPL                                                    
     C                   EVAL      T0LINE=@PLINE                                                    
     C                   EVAL      T0ARV1=*BLANKS                                                   
     C                   EVAL      T0COM2=*BLANKS                                                   
     C     KEDTRLP00X    SETLL     EDTRLP00                                                         
     C     KEDTRLP00     READE     EDTRLP00                                                         
     C                   DOW       NOT %EOF(EDTRLP00)                                               
      *                                                                                             
      * Si tiene compra asociada, dejo que sea el evento de                                         
      * compras el que haga la eliminación                                                          
      *                                                                                             
     C                   IF        T0ARV1=*BLANKS                                                   
15060C                             AND T0CANS=0                                                     
02060C                   WRITE     REDTRLX00                            80                          
11060C                   DOW       *IN80=*ON                                                        
02060C                   EVAL      T0HWR0 = T0HWR0+1                                                
02060C                   WRITE     REDTRLX00                            80                          
02060C                   ENDDO                                                                      
     C                   DELETE    REDTRLP00                                                        
     C                   ENDIF                                                                      
