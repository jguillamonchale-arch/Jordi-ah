19050C     KEDTRLP00     READE     EDTRLP00                                                         
19050C                   ENDDO                                                                      
19050 *                                                                                             
19050 * Posible E-Mail con datos del pedido de ventas                                               
19050 *                                                                                             
19050C                   MOVEL(P)  T0CIAS        @EMCIAA                                            
19050C                   MOVEL(P)  T0DLGA        @EMDLGA                                            
19050C                   MOVEL(P)  T0CUST        @EMCODE                                            
19050C                   MOVEL(P)  T0NPCO        @EMNDOC                                            
19050C                   MOVE      T0DATP        @EMFDOC                                            
19050C                   MOVE      T0LINE        @EMLDOC                                            
19050 *                                                                                             
19050C                   ENDIF                                                                      
19050 *                                                                                             
19050C                   ENDSR                                                                      
FQ607 **********************************************************************                        
FQ607 * Alta reclamación incidencia web                                    *                        
FQ607 **********************************************************************                        
FQ607C     CS_COD028     BEGSR                                                                      
FQ607 *                                                                                             
FQ607 * Actualizo campos en registro de trazabilidad                                                
FQ607 *                                                                                             
FQ607C                   EVAL      T4CIAS=@PCIAS                                                    
FQ607C                   EVAL      T4DLGA=@PDLGA                                                    
FQ607C                   EVAL      T4NPCO=@PNPCO                                                    
FQ607C                   EVAL      T4TPED=@PTPED                                                    
FQ607C                   EVAL      T4DATP=@PDATP                                                    
FQ607C                   EVAL      T4NOPL=@PNOPL                                                    
FQ607C                   EVAL      T4LINE=@PLINE                                                    
FQ607C     KEDINCI30     CHAIN     EDINCI30                                                         
FQ607C                   IF        %FOUND(EDINCI30)                                                 
FQ607 *                                                                                             
FQ607 * Recupero la clave del pedido comercial y actualizo                                          
FQ607 *                                                                                             
FQ607C                   EVAL      ZXGRAU=0                                                         
FQ607C                   EVAL      T0CIAS=@PCIAS                                                    
FQ607C                   EVAL      T0DLGA=@PDLGA                                                    
FQ607C                   EVAL      T0NPCO=@PNPCO                                                    
FQ607C                   EVAL      T0TPED=@PTPED                                                    
FQ607C                   EVAL      T0DATP=@PDATP                                                    
FQ607C                   EVAL      T0NOPL=@PNOPL                                                    
FQ607C                   EVAL      T0LINE=@PLINE                                                    
FQ607C                   EVAL      T0ARV1=*BLANKS                                                   
FQ607C                   EVAL      T0COM2=*BLANKS                                                   
FQ607C     KEDTRLP00X    SETLL     EDTRLP00                                                         
FQ607C     KEDTRLP00     READE     EDTRLP00                                                         
FQ607C                   DOW       NOT %EOF(EDTRLP00)                                               
FQ607                                                                                               
FQ607C                   EVAL      T0DWRF=*DATE                                                     
FQ607C                   TIME                    T0HWRF                                             
FQ607C                   MOVEL     T4NDE2        T0NDE2                                             
FQ607C                   EVAL      T0LIR2=T4LIR2                                                    
FQ607C                   UPDATE    REDTRLP00                            83                          
FQ607C   83              EXSR      CS_EDTRLD                                                        
FQ607 *                                                                                             
FQ607 * Auditoría sólo para la 1ª línea                                                             
FQ607 *                                                                                             
FQ607C                   IF        ZXGRAU=0                                                         
FQ607C                   EXSR      CS_UPD_EDTRAU                                                    
FQ607C                   EVAL      ZXGRAU=1                                                         
FQ607C                   ENDIF                                                                      
FQ607 *                                                                                             
FQ607C     KEDTRLP00     READE     EDTRLP00                                                         
FQ607C                   ENDDO                                                                      
FQ607 *                                                                                             
FQ607 * Posible E-Mail con datos del pedido de ventas                                               
FQ607 *                                                                                             
FQ607C                   MOVEL(P)  T0CIAS        @EMCIAA                                            
FQ607C                   MOVEL(P)  T0DLGA        @EMDLGA                                            
FQ607C                   MOVEL(P)  T0CUST        @EMCODE                                            
FQ607C                   MOVEL(P)  T0NPCO        @EMNDOC                                            
FQ607C                   MOVE      T0DATP        @EMFDOC                                            
FQ607C                   MOVE      T0LINE        @EMLDOC                                            
FQ607 *                                                                                             
FQ607C                   ENDIF                                                                      
FQ607 *                                                                                             
FQ607C                   ENDSR                                                                      
FQ710 **********************************************************************                        
FQ710 * Forzar Preparación aunque no llegue al mínimo por expedición       *                        
FQ710 **********************************************************************                        
FQ710C     CS_COD029     BEGSR                                                                      
FQ710 *                                                                                             
FQ710 * Recupero la clave del pedido comercial y actualizo                                          
FQ710 *                                                                                             
FQ710C                   EVAL      ZXGRAU=0                                                         
FQ710C                   EVAL      T0CIAS=@PCIAS                                                    
FQ710C                   EVAL      T0DLGA=@PDLGA                                                    
FQ710C                   EVAL      T0NPCO=@PNPCO                                                    
FQ710C                   EVAL      T0TPED=@PTPED                                                    
FQ710C                   EVAL      T0DATP=@PDATP                                                    
FQ710C                   EVAL      T0NOPL=@PNOPL                                                    
FQ710C                   EVAL      T0LINE=@PLINE                                                    
FQ710C                   EVAL      T0ARV1=*BLANKS                                                   
FQ710C                   EVAL      T0COM2=*BLANKS                                                   
FQ710C     KEDTRLP00X    SETLL     EDTRLP00                                                         
FQ710C     KEDTRLP00     READE     EDTRLP00                                                         
FQ710C                   DOW       NOT %EOF(EDTRLP00)                                               
FQ710 *                                                                                             
FQ710C                   EVAL      T0DWRF=*DATE                                                     
FQ710C                   TIME                    T0HWRF                                             
FQ710C                   SELECT                                                                     
FQ710C                   WHEN      @PEDAU ='029'                                                    
FQ710C                   EVAL      T0FOPR=1                                                         
FQ710C                   WHEN      @PEDAU ='030'                                                    
FQ710C                   EVAL      T0FOPR=0                                                         
FQ710C                   ENDSL                                                                      
FQ710C                   UPDATE    REDTRLP00                                                        
FQ710 *                                                                                             
FQ710 * Auditoría sólo para la 1ª línea                                                             
FQ710 *                                                                                             
FQ710C                   IF        ZXGRAU=0                                                         
FQ710C                   EXSR      CS_UPD_EDTRAU                                                    
FQ710C                   EVAL      ZXGRAU=1                                                         
FQ710C                   ENDIF                                                                      
FQ710 *                                                                                             
FQ710C     KEDTRLP00     READE     EDTRLP00                                                         
FQ710C                   ENDDO                                                                      
FQ710 *                                                                                             
FQ710 * Posible E-Mail con datos del pedido de ventas                                               
FQ710 *                                                                                             
FQ710C                   MOVEL(P)  T0CIAS        @EMCIAA                                            
FQ710C                   MOVEL(P)  T0DLGA        @EMDLGA                                            
FQ710C                   MOVEL(P)  T0CUST        @EMCODE                                            
FQ710C                   MOVEL(P)  T0NPCO        @EMNDOC                                            
FQ710C                   MOVE      T0DATP        @EMFDOC                                            
FQ710C                   MOVE      T0LINE        @EMLDOC                                            
FQ710 *                                                                                             
FQ710C                   ENDSR                                                                      
20100 **********************************************************************                        
20100 * Reserva/Desreserva Cial Material Propio                            *                        
20100 **********************************************************************                        
20100C     CS_COD031     BEGSR                                                                      
20100 *                                                                                             
20100 * Recupero la clave del pedido comercial y actualizo                                          
20100 *                                                                                             
20100C                   EVAL      ZXGRAU=0                                                         
20100C                   EVAL      T0CIAS=@PCIAS                                                    
20100C                   EVAL      T0DLGA=@PDLGA                                                    
20100C                   EVAL      T0NPCO=@PNPCO                                                    
20100C                   EVAL      T0TPED=@PTPED                                                    
20100C                   EVAL      T0DATP=@PDATP                                                    
20100C                   EVAL      T0NOPL=@PNOPL                                                    
20100C                   EVAL      T0LINE=@PLINE                                                    
20100C                   EVAL      T0ARV1=*BLANKS                                                   
20100C                   EVAL      T0COM2=*BLANKS                                                   
20100C     KEDTRLP00X    SETLL     EDTRLP00                                                         
20100C     KEDTRLP00     READE     EDTRLP00                                                         
20100C                   DOW       NOT %EOF(EDTRLP00)                                               
FDX01 *                                                                                             
FDX01 * Ahora se permiten conjuntos combinados (SIOL=2 y SIOL<>2) por lo                            
FDX01 * que hay que comprobar que sean SIOL=2 para tratar                                           
FDX01 *                                                                                             
FDX01C                   EVAL      M5CIAS=T0CIAS                                                    
FDX01C                   EVAL      M5ARTI=%SUBST(T0ARV1:1:15)                                       
FDX01C                   EVAL      M5VARI=%SUBST(T0ARV1:16:3)                                       
FDX01C                   EVAL      M5MODE=%SUBST(T0ARV1:19:3)                                       
FDX01C     KMSARTI00     CHAIN     MSARTI00                                                         
FDX01C                   IF        %FOUND(MSARTI00) AND M5SIOL='2'                                  
20100 *                                                                                             
20100C                   EVAL      T0DWRF=*DATE                                                     
20100C                   TIME                    T0HWRF                                             
20100C                   IF        @PEDAU ='031'                                                    
20100C                   EVAL      T0FURE=*DATE                                                     
20100C                   ENDIF                                                                      
10051C*                  EVAL      T0EDST='50'                                                      
20100C                   UPDATE    REDTRLP00                                                        
20100 *                                                                                             
20100 * Auditoría sólo para la 1ª línea                                                             
20100 *                                                                                             
20100C                   IF        ZXGRAU=0                                                         
20100C                   EXSR      CS_UPD_EDTRAU                                                    
20100C                   EVAL      ZXGRAU=1                                                         
20100C                   ENDIF                                                                      
FDX01 *                                                                                             
FDX01C                   ENDIF                                                                      
20100 *                                                                                             
20100C     KEDTRLP00     READE     EDTRLP00                                                         
20100C                   ENDDO                                                                      
20100 *                                                                                             
20100 * Posible E-Mail con datos del pedido de ventas                                               
20100 *                                                                                             
20100C                   MOVEL(P)  T0CIAS        @EMCIAA                                            
20100C                   MOVEL(P)  T0DLGA        @EMDLGA                                            
20100C                   MOVEL(P)  T0CUST        @EMCODE                                            
20100C                   MOVEL(P)  T0NPCO        @EMNDOC                                            
20100C                   MOVE      T0DATP        @EMFDOC                                            
20100C                   MOVE      T0LINE        @EMLDOC                                            
20100 *                                                                                             
10051 *                                                                                             
10051 * Si es conjunto de venta y soy propietario SIOL='2' creo un nuevo                            
10051 * registro por cada componente del conjunto. Leo CODEP2                                       
10051 *                                                                                             
10051C                   EVAL      C_S5CIAS=@PCIAS                                                  
10051C                   EVAL      C_S5DLGA=@PDLGA                                                  
10051C                   EVAL      C_S5NPCO=@PNPCO                                                  
10051C                   EVAL      C_S5TPED=@PTPED                                                  
10051C                   EVAL      C_S5DATP=@PDATP                                                  
10051C                   EVAL      C_S5NOPL=@PNOPL                                                  
10051C                   EVAL      C_S5LINE=@PLINE                                                  
10051C     KCODEP20      SETLL     CODEP2                                                           
10051C     KCODEP20      READE     CODEP2                                                           
10051C                   DOW       NOT %EOF(CODEP2)                                                 
FDX01 *                                                                                             
FDX01 * Ahora se permiten conjuntos combinados (SIOL=2 y SIOL<>2) por lo                            
FDX01 * que hay que comprobar que sean SIOL=2 para tratar                                           
FDX01 *                                                                                             
FDX01C                   EVAL      M5CIAS=C_S5CIAS                                                  
FDX01C                   EVAL      M5ARTI=C_S5COMP                                                  
FDX01C                   EVAL      M5VARI=C_S5VAR2                                                  
FDX01C                   EVAL      M5MODE=C_S5MOD2                                                  
FDX01C     KMSARTI00     CHAIN     MSARTI00                                                         
FDX01C                   IF        %FOUND(MSARTI00) AND M5SIOL='2'                                  
FDX01 *                                                                                             
10051                                                                                               
10051C                   EVAL      T0ARV1=C_S5COMP+C_S5VAR2+C_S5MOD2                                
10051C     KEDTRLP00Z    CHAIN     EDTRLP00                                                         
10051C                   IF        %FOUND(EDTRLP00)                                                 
10051C                   Z-ADD     C_S5CA04      T0CFC1                                             
10051C                   UPDATE    REDTRLP00                            83                          
10051C                   ELSE                                                                       
10051C                   EVAL      T0ARV1=*BLANKS                                                   
10051C     KEDTRLP00Z    CHAIN     EDTRLP00                                                         
10051C                   IF        %FOUND(EDTRLP00)                                                 
10051C                   EVAL      T0ARV1=C_S5COMP+C_S5VAR2+C_S5MOD2                                
10051C                   Z-ADD     C_S5CA04      T0CFC1                                             
10051C                   UPDATE    REDTRLP00                            83                          
10051C                   ELSE                                                                       
10051C                   EVAL      T0ARV1=C_S5COMP+C_S5VAR2+C_S5MOD2                                
10051C                   EVAL      T0TREG=1                                                         
10051C                   Z-ADD     C_S5CA04      T0CFC1                                             
10051C                   EVAL      T0EDST='50'                                                      
FDX01 *                                                                                             
FDX01C                   EVAL      T0PRVR=*BLANKS                                                   
FDX01C                   EVAL      T0CIA1=0                                                         
FDX01C                   EVAL      T0DLG1=*BLANKS                                                   
FDX01C                   EVAL      T0NPC1=*BLANKS                                                   
FDX01C                   EVAL      T0TPE1=*BLANKS                                                   
FDX01C                   EVAL      T0DAT1=0                                                         
FDX01C                   EVAL      T0NOP1=0                                                         
FDX01C                   EVAL      T0LIN1=0                                                         
FDX01C                   EVAL      T0CAN1=0                                                         
FDX01C                   EVAL      T0UNI1=*BLANKS                                                   
FDX01C                   EVAL      T0CIA2=0                                                         
FDX01C                   EVAL      T0DLG2=*BLANKS                                                   
FDX01C                   EVAL      T0NPC2=*BLANKS                                                   
FDX01C                   EVAL      T0TPE2=*BLANKS                                                   
FDX01C                   EVAL      T0DAT2=0                                                         
FDX01C                   EVAL      T0NOP2=0                                                         
FDX01C                   EVAL      T0LIN2=0                                                         
FDX01C                   EVAL      T0ARV2=*BLANKS                                                   
FDX01C                   EVAL      T0COM2=*BLANKS                                                   
FDX01C                   EVAL      T0CAN2=0                                                         
FDX01C                   EVAL      T0UNI2=*BLANKS                                                   
FDX01C                   EVAL      T0CFC2=0                                                         
FDX01C                   EVAL      T0CUS2=*BLANKS                                                   
FDX01C                   EVAL      T0DWR2=0                                                         
FDX01C                   EVAL      T0HWR2=0                                                         
FDX01C                   EVAL      T0CIA3=0                                                         
FDX01C                   EVAL      T0DLG3=*BLANKS                                                   
FDX01C                   EVAL      T0NPC3=*BLANKS                                                   
FDX01C                   EVAL      T0TPE3=*BLANKS                                                   
FDX01C                   EVAL      T0DAT3=0                                                         
FDX01C                   EVAL      T0NOP3=0                                                         
FDX01C                   EVAL      T0LIN3=0                                                         
FDX01C                   EVAL      T0CAN3=0                                                         
FDX01C                   EVAL      T0UNI3=*BLANKS                                                   
FDX01C                   EVAL      T0DWR3=0                                                         
FDX01C                   EVAL      T0HWR3=0                                                         
FDX01 *                                                                                             
10051C                   WRITE     REDTRLP00                            83                          
10051C   83              EXSR      CS_EDTRLD                                                        
FDX01 *                                                                                             
FDX01 * Auditoría sólo para la 1ª línea                                                             
FDX01 *                                                                                             
FDX01C                   IF        ZXGRAU=0 AND NOT *IN83                                           
FDX01C                   EXSR      CS_UPD_EDTRAU                                                    
FDX01C                   EVAL      ZXGRAU=1                                                         
FDX01C                   ENDIF                                                                      
FDX01 *                                                                                             
10051C                   ENDIF                                                                      
10051C                   ENDIF                                                                      
10051                                                                                               
FDX01C                   ENDIF                                                                      
FDX01 *                                                                                             
10051C     KCODEP20      READE     CODEP2                                                           
10051C                   ENDDO                                                                      
10051 *                                                                                             
20100C                   ENDSR                                                                      
C1350 **********************************************************************                        
C1350 * Proceso auditoría 033  Bloqueo de albaranes FD desde comercial     *                        
C1350 **********************************************************************                        
C1350C     CS_COD033     BEGSR                                                                      
C1350 *                                                                                             
C1350C                   EVAL      T0CIAS=@PCIAS                                                    
C1350C                   EVAL      T0CUST=@PNPCO                                                    
C1350C     KEDTRLP40     SETLL     EDTRLP40                                                         
C1350C     KEDTRLP40     READE     EDTRLP40                                                         
C1350C                   DOW       NOT %EOF(EDTRLP40)                                               
C1350C                   IF        T0EDST<'80' AND                                                  
C1350C                             T0RISK=0                                                         
C1350C                   EVAL      T0RISK=2                                                         
C1350C                   UPDATE    REDTRLP40                                                        
PG615                                                                                               
PG615 ** Nueva llamada a pgm CO2880 para modificar riesgo de pedidos                                
PG615C                   EXSR      LLAMA1413                                                        
PG615                                                                                               
C1350C                   EXSR      CS_UPD_EDTRAU                                                    
C1350C                   ENDIF                                                                      
C1350C     KEDTRLP40     READE     EDTRLP40                                                         
C1350C                   ENDDO                                                                      
C1350 *                                                                                             
C1350C                   ENDSR                                                                      
C1350 **********************************************************************                        
C1350 * Proceso auditoría 034  Desbloqueo albaranes FD desde comercial     *                        
C1350 **********************************************************************                        
C1350C     CS_COD034     BEGSR                                                                      
C1350 *                                                                                             
C1350C                   EVAL      T0CIAS=@PCIAS                                                    
C1350C                   EVAL      T0CUST=@PNPCO                                                    
C1350C     KEDTRLP40     SETLL     EDTRLP40                                                         
C1350C     KEDTRLP40     READE     EDTRLP40                                                         
C1350C                   DOW       NOT %EOF(EDTRLP40)                                               
C1350C                   IF        T0EDST<'80' AND                                                  
C1350C                             T0RISK=2                                                         
C1350C                   EVAL      T0RISK=0                                                         
C1350C                   UPDATE    REDTRLP40                                                        
PG615                                                                                               
PG615 ** Nueva llamada a pgm CO2880 para modificar riesgo de pedidos                                
PG615C                   EXSR      LLAMA1413                                                        
PG615                                                                                               
C1350C                   EXSR      CS_UPD_EDTRAU                                                    
C1350C                   ENDIF                                                                      
C1350C     KEDTRLP40     READE     EDTRLP40                                                         
C1350C                   ENDDO                                                                      
C1350 *                                                                                             
C1350C                   ENDSR                                                                      
67007 *****************************************************************************                 
67007 * Actualizar linea campo excedido riesgo en pedido comercial a largo plazo  *                 
67007 *****************************************************************************                 
67007C     CS_COD053     BEGSR                                                                      
67007 *                                                                                             
67007 * Actualizo campos en registro de trazabilidad                                                
67007 *                                                                                             
67007C                   EVAL      S0CIAS=@PCIAS                                                    
67007C                   EVAL      S0DLGA=@PDLGA                                                    
67007C                   EVAL      S0NPCO=@PNPCO                                                    
67007C                   EVAL      S0TPED=@PTPED                                                    
67007C                   EVAL      S0DATP=@PDATP                                                    
67007C                   EVAL      S0NOPL=@PNOPL                                                    
67007 *                                                                                             
67007C     KCOCAPE       SETLL     CODEPE                                                           
67007C     KCOCAPE       READE(N)  CODEPE                                                           
67007C                   DOW       NOT %EOF(CODEPE)                                                 
67007 *                                                                                             
67007 * Recupero la clave del pedido comercial y actualizo                                          
67007 *                                                                                             
67007C                   EVAL      ZXGRAU=0                                                         
67007C                   EVAL      T0CIAS=S5CIAS                                                    
67007C                   EVAL      T0DLGA=S5DLGA                                                    
67007C                   EVAL      T0NPCO=S5NPCO                                                    
67007C                   EVAL      T0TPED=S5TPED                                                    
67007C                   EVAL      T0DATP=S5DATP                                                    
67007C                   EVAL      T0NOPL=S5NOPL                                                    
67007C                   EVAL      T0LINE=S5LINE                                                    
67007C                   EVAL      T0ARV1=*BLANKS                                                   
67007C                   EVAL      T0COM2=*BLANKS                                                   
67007 *                                                                                             
67007C     KEDTRLP00X    SETLL     EDTRLP00                                                         
67007C     KEDTRLP00     READE     EDTRLP00                                                         
67007C                   DOW       NOT %EOF(EDTRLP00)                                               
67007 *                                                                                             
67007 * Trata las líneas con riesgo excedido en EDTRLP                                              
67007 *                                                                                             
67007C                   if        t0risk > 0                                                       
67007 *                                                                                             
67007C                   EVAL      S0CIAS=@PCIAS                                                    
67007C                   EVAL      S0DLGA=@PDLGA                                                    
67007C                   EVAL      S0NPCO=@PNPCO                                                    
67007C                   EVAL      S0TPED=@PTPED                                                    
67007C                   EVAL      S0DATP=@PDATP                                                    
67007C                   EVAL      S0NOPL=@PNOPL                                                    
67007 *                                                                                             
67007C     KCOCAPE       CHAIN(N)  COCAPE                                                           
67007C                   IF        %FOUND(COCAPE)                                                   
67007 *                                                                                             
67007 * Sólo actúo si retenido financiero es largo plazo y riesgo excedido                          
67007 * y autorización riesgo de COCAPE están a blanco                                              
67007 *                                                                                             
67007C                   IF        s0phld >= '3' and s0rexc = ' '                                   
67007C                                           and s0raut = ' '                                   
67007 *                                                                                             
67007C                   EVAL      T0DWRF=*DATE                                                     
67007C                   TIME                    T0HWRF                                             
67007C                   EVAL      T0RISK=0                                                         
67007C                   UPDATE    REDTRLP00                                                        
67007 *                                                                                             
67007 * Auditoría sólo para la 1ª línea                                                             
67007 *                                                                                             
67007C                   IF        ZXGRAU=0                                                         
67007C                   EXSR      CS_UPD_EDTRAU                                                    
67007C                   EVAL      ZXGRAU=1                                                         
67007C                   ENDIF                                                                      
67007 *                                                                                             
67007C                   ENDIF                                                                      
67007 *                                                                                             
67007C                   ENDIF                                                                      
67007 *                                                                                             
67007C                   ENDIF                                                                      
67007 *                                                                                             
67007C     KEDTRLP00     READE     EDTRLP00                                                         
67007C                   ENDDO                                                                      
67007 *                                                                                             
67007C     KCOCAPE       READE(N)  CODEPE                                                           
67007C                   ENDDO                                                                      
67007 *                                                                                             
67007C                   ENDSR                                                                      
      **********************************************************************                        
      * Proceso auditoría 100  Alta línea pedido ED en compras             *                        
      **********************************************************************                        
     C     CS_COD100     BEGSR                                                                      
      *                                                                                             
      * Recupero la clave del pedido de compras y luego el pedido de ventas                         
      *                                                                                             
     C                   EVAL      C0CIAS=@PCIAS                                                    
     C                   EVAL      C0DLGA=@PDLGA                                                    
     C                   EVAL      C0NPCO=@PNPCO                                                    
     C                   EVAL      C0TPED=@PTPED                                                    
     C                   EVAL      C0DATP=@PDATP                                                    
     C                   EVAL      C0NOPL=@PNOPL                                                    
     C     KPUCAPE       CHAIN     PUCAPE                                                           
     C                   IF        %FOUND(PUCAPE)                                                   
     C                   EVAL      C5CIAS=@PCIAS                                                    
     C                   EVAL      C5DLGA=@PDLGA                                                    
     C                   EVAL      C5NPCO=@PNPCO                                                    
     C                   EVAL      C5TPED=@PTPED                                                    
     C                   EVAL      C5DATP=@PDATP                                                    
     C                   EVAL      C5NOPL=@PNOPL                                                    
     C                   EVAL      C5LINE=@PLINE                                                    
     C     KPUDEPE       CHAIN     PUDEPE                                                           
     C                   IF        %FOUND(PUDEPE)                                                   
     C                   MOVEL     C5CIVE        S0CIAS                                             
     C                   EVAL      S0DLGA=C5DLVE                                                    
     C                   EVAL      S0NPCO=C5NPVE                                                    
     C                   EVAL      S0TPED=C5TPVE                                                    
     C                   EVAL      S0DATP=C5DAVE                                                    
     C                   EVAL      S0NOPL=C5NOVE                                                    
     C     KCOCAPE       CHAIN(N)  COCAPE                                                           
     C                   IF        %FOUND(COCAPE)                                                   
     C                   MOVEL     C5CIVE        S5CIAS                                             
     C                   EVAL      S5DLGA=C5DLVE                                                    
     C                   EVAL      S5NPCO=C5NPVE                                                    
     C                   EVAL      S5TPED=C5TPVE                                                    
     C                   EVAL      S5DATP=C5DAVE                                                    
     C                   EVAL      S5NOPL=C5NOVE                                                    
     C                   EVAL      S5LINE=C5LIVE                                                    
     C     KCODEPE       CHAIN(N)  CODEPE                                                           
     C                   IF        %FOUND(CODEPE)                                                   
      *                                                                                             
      * Si es una entrega directa actuo                                                             
      *                                                                                             
     C                   IF        S5TPE4='2'                                                       
      *                                                                                             
      * Actualizo datos del pedido de compras                                                       
      *                                                                                             
     C                   EVAL      C0TPE4='2'                                                       
     C                   UPDATE    RPUCAPE                                                          
     C                   EVAL      C5TPE4='2'                                                       
     C                   UPDATE    RPUDEPE                                                          
      *                                                                                             
      * Actualizo datos del pedido de compras desde la 1ª línea original                            
      * si T0ARV1 Y T0COM2 aún están a *blanks                                                      
      *                                                                                             
     C                   EVAL      T0CIAS=S5CIAS                                                    
     C                   EVAL      T0DLGA=S5DLGA                                                    
     C                   EVAL      T0NPCO=S5NPCO                                                    
     C                   EVAL      T0TPED=S5TPED                                                    
     C                   EVAL      T0DATP=S5DATP                                                    
     C                   EVAL      T0NOPL=S5NOPL                                                    
     C                   EVAL      T0LINE=S5LINE                                                    
      *                                                                                             
      * Recupero algunos valores de la 1º línea                                                     
      *                                                                                             
     C                   CLEAR                   ZGARVM                                             
     C                   CLEAR                   ZGCANT                                             
     C                   CLEAR                   ZGCUST                                             
     C                   CLEAR                   ZGTDI1                                             
     C                   CLEAR                   ZGDWR0                                             
     C                   CLEAR                   ZGHWR0                                             
     C                   CLEAR                   ZGUWR0                                             
     C     KEDTRLP00     CHAIN     EDTRLP00                                                         
     C                   IF        %FOUND(EDTRLP00)                                                 
     C                   EVAL      ZGARVM=T0ARVM                                                    
     C                   EVAL      ZGCANT=T0CANT                                                    
     C                   EVAL      ZGCUST=T0CUST                                                    
     C                   EVAL      ZGTDI1=T0TDI1                                                    
     C                   EVAL      ZGDWR0=T0DWR0                                                    
     C                   EVAL      ZGHWR0=T0HWR0                                                    
     C                   EVAL      ZGUWR0=T0UWR0                                                    
     C                   ENDIF                                                                      
      *                                                                                             
      * Compruebo si aún no tiene trazabilidad de compras                                           
      *                                                                                             
     C                   CLEAR                   T0ARV1                                             
     C                   CLEAR                   T0COM2                                             
     C     KEDTRLP00X    CHAIN     EDTRLP00                                                         
      *                                                                                             
     C                   EVAL      T0CIA1=C5CIAS                                                    
     C                   EVAL      T0DLG1=C5DLGA                                                    
     C                   EVAL      T0NPC1=C5NPCO                                                    
     C                   EVAL      T0TPE1=C5TPED                                                    
     C                   EVAL      T0DAT1=C5DATP                                                    
     C                   EVAL      T0NOP1=C5NOPL                                                    
     C                   EVAL      T0LIN1=C5LINE                                                    
     C                   EVAL      ZXARVM=C5ARTI+C5VARI+C5MODE                                      
     C                   MOVEL(P)  ZXARVM        T0ARV1                                             
     C                   MOVEL(P)  '20'          T0EDST                                             
     C                   EVAL      T0CAN1=C5CANT                                                    
FQ710C                   EVAL      T0UNI1=C5UNIM                                                    
     C                   EVAL      T0PRVR=C0PRVR                                                    
C1328c                   exsr      CS_EDDP                                                          
     C                   EVAL      T0DWR1=*DATE                                                     
     C                   TIME                    T0HWR1                                             
     C                   MOVEL(P)  SDSUSR        T0UWR1                                             
     C                   EVAL      T0DWRF=T0DWR1                                                    
     C                   EVAL      T0HWRF=T0HWR1                                                    
IT228C                   IF        P7EDOM='1'                                                       
IT228C                   EXSR      CS_EXCEPM3                                                       
IT228C                   ENDIF                                                                      
      *                                                                                             
      * Si es conjunto de venta hay que Extraer el coeficiente                                      
      * del componente                                                                              
      *                                                                                             
     C                   EVAL      T0CFC1=0                                                         
     C                   IF        S5TCOJ<>*BLANKS                                                  
     C                   EVAL      NDCIAS=S5CIAS                                                    
     C                   EVAL      NDARTI=S5ARTI                                                    
     C                   EVAL      NDVARI=S5VARI                                                    
     C                   EVAL      NDMODE=S5MODE                                                    
     C                   EVAL      NDTCOJ=S5TCOJ                                                    
     C                   EVAL      NDCOMP=C5ARTI                                                    
     C                   EVAL      NDVAR2=C5VARI                                                    
     C                   EVAL      NDMOD2=C5MODE                                                    
     C                   EVAL      NDTCO2=C5TCOJ                                                    
     C     KMSCOJD       CHAIN     MSCOJD                                                           
     C                   IF        %FOUND(MSCOJD)                                                   
     C                             AND NDBAJA<>'1'                                                  
     C                   EVAL      T0CFC1=NDCANT                                                    
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
     C                   IF        %FOUND(EDTRLP00)                                                 
     C                   UPDATE    REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ELSE                                                                       
     C                   EVAL      T0ARVM=ZGARVM                                                    
     C                   EVAL      T0CANT=ZGCANT                                                    
     C                   EVAL      T0CUST=ZGCUST                                                    
     C                   EVAL      T0TDI1=ZGTDI1                                                    
     C                   EVAL      T0DWR0=ZGDWR0                                                    
     C                   EVAL      T0HWR0=ZGHWR0                                                    
     C                   EVAL      T0UWR0=ZGUWR0                                                    
     C                   EVAL      T0UWR0=ZGUWR0                                                    
     C                   EVAL      T0TREG=1                                                         
21050C                   WRITE     REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
     C                   ENDIF                                                                      
      *                                                                                             
     C                   EXSR      CS_UPD_EDTRAU                                                    
      *                                                                                             
      * Posible E-Mail con datos del pedido de compras                                              
      *                                                                                             
     C                   MOVEL(P)  T0CIA1        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG1        @EMDLGA                                            
     C                   MOVEL(P)  T0PRVR        @EMCODE                                            
     C                   MOVEL(P)  T0NPC1        @EMNDOC                                            
     C                   MOVE      T0DAT1        @EMFDOC                                            
     C                   MOVE      T0LIN1        @EMLDOC                                            
      *                                                                                             
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
      * Sino es entrega directa libera registro (Sólo aquí)                                         
      *                                                                                             
     C                   ELSE                                                                       
     C                   UNLOCK    PUCAPE                                                           
     C                   UNLOCK    PUDEPE                                                           
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Anular línea en pedido de Compra                                   *                        
      **********************************************************************                        
     C     CS_COD105     BEGSR                                                                      
      *                                                                                             
      * Recupero la clave del pedido de compra                                                      
      *                                                                                             
     C                   EVAL      ZXGRAU=0                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C     KEDTRLP10     READE     EDTRLP10                                                         
     C                   DOW       NOT %EOF(EDTRLP10)                                               
      *                                                                                             
15060C                   IF        T0CANS=0                                                         
02060C                   WRITE     REDTRLX00                            80                          
11060C                   DOW       *IN80=*ON                                                        
02060C                   EVAL      T0HWR0 = T0HWR0+1                                                
02060C                   WRITE     REDTRLX00                            80                          
02060C                   ENDDO                                                                      
     C                   DELETE    REDTRLP10                                                        
15060C                   ENDIF                                                                      
      *                                                                                             
      * Auditoría sólo para la 1ª línea                                                             
      *                                                                                             
     C                   IF        ZXGRAU=0                                                         
     C                   EXSR      CS_UPD_EDTRAU                                                    
     C                   EVAL      ZXGRAU=1                                                         
     C                   ENDIF                                                                      
      *                                                                                             
     C     KEDTRLP10     READE     EDTRLP10                                                         
     C                   ENDDO                                                                      
      *                                                                                             
      * En este caso cierro todas las auditorias relacionadas                                       
      *                                                                                             
     C     KEDTRLP00X    SETLL     EDTRAU00                                                         
     C     KEDTRLP00X    READE     EDTRAU00                                                         
     C                   DOW       NOT %EOF(EDTRAU00)                                               
02060C                   DOU       *IN80=*OFF                                                       
02060C                   EVAL      ZXTIM1 = %TIMESTAMP()                                            
02060C                   MOVEL     ZXTIM1        ZXTIMESTAMP                                        
02060C                   MOVEL     ZXTIMESTAMP   T1TMST                                             
02060C                   WRITE     REDTRAX00                            80                          
02060C                   ENDDO                                                                      
     C                   DELETE    REDTRAU00                                                        
     C     KEDTRLP00X    READE     EDTRAU00                                                         
     C                   ENDDO                                                                      
      *                                                                                             
      * Posible E-Mail con datos del pedido de compras                                              
      *                                                                                             
     C                   MOVEL(P)  T0CIA1        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG1        @EMDLGA                                            
     C                   MOVEL(P)  T0PRVR        @EMCODE                                            
     C                   MOVEL(P)  T0NPC1        @EMNDOC                                            
     C                   MOVE      T0DAT1        @EMFDOC                                            
     C                   MOVE      T0LIN1        @EMLDOC                                            
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Modificar cantidad (+) en pedido compra                            *                        
      **********************************************************************                        
     C     CS_COD106     BEGSR                                                                      
      *                                                                                             
      * Actualizo campos en registro de trazabilidad                                                
      *                                                                                             
     C                   EVAL      C5CIAS=@PCIAS                                                    
     C                   EVAL      C5DLGA=@PDLGA                                                    
     C                   EVAL      C5NPCO=@PNPCO                                                    
     C                   EVAL      C5TPED=@PTPED                                                    
     C                   EVAL      C5DATP=@PDATP                                                    
     C                   EVAL      C5NOPL=@PNOPL                                                    
     C                   EVAL      C5LINE=@PLINE                                                    
     C     KPUDEPE       CHAIN(N)  PUDEPE                                                           
     C                   IF        %FOUND(PUDEPE)                                                   
      *                                                                                             
      * Recupero la clave del pedido de compra                                                      
      *                                                                                             
     C                   EVAL      ZXGRAU=0                                                         
     C                   EVAL      T0CIA1=@PCIAS                                                    
     C                   EVAL      T0DLG1=@PDLGA                                                    
     C                   EVAL      T0NPC1=@PNPCO                                                    
     C                   EVAL      T0TPE1=@PTPED                                                    
     C                   EVAL      T0DAT1=@PDATP                                                    
     C                   EVAL      T0NOP1=@PNOPL                                                    
     C                   EVAL      T0LIN1=@PLINE                                                    
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C     KEDTRLP10     READE     EDTRLP10                                                         
     C                   DOW       NOT %EOF(EDTRLP10)                                               
      *                                                                                             
     C                   EVAL      T0DWRF=*DATE                                                     
     C                   TIME                    T0HWRF                                             
     C                   EVAL      T0CAN1=C5CANT                                                    
FQ710C                   EVAL      T0UNI1=C5UNIM                                                    
     C                   UPDATE    REDTRLP10                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
      *                                                                                             
      * Auditoría sólo para la 1ª línea                                                             
      *                                                                                             
     C                   IF        ZXGRAU=0                                                         
     C                   EXSR      CS_UPD_EDTRAU                                                    
     C                   EVAL      ZXGRAU=1                                                         
     C                   ENDIF                                                                      
      *                                                                                             
     C     KEDTRLP10     READE     EDTRLP10                                                         
     C                   ENDDO                                                                      
      *                                                                                             
      * Posible E-Mail con datos del pedido de compras                                              
      *                                                                                             
     C                   MOVEL(P)  T0CIA1        @EMCIAA                                            
     C                   MOVEL(P)  T0DLG1        @EMDLGA                                            
     C                   MOVEL(P)  T0PRVR        @EMCODE                                            
     C                   MOVEL(P)  T0NPC1        @EMNDOC                                            
     C                   MOVE      T0DAT1        @EMFDOC                                            
     C                   MOVE      T0LIN1        @EMLDOC                                            
