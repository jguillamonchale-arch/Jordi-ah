C2280 ***                if        (T0EDST<='50' or T0EDST='95')                                    
C2280C                   if        T0EDST<='50'                                                     
     C                   EVAL      T0EDST='40'                                                      
     C                   endif                                                                      
     C                                                                                              
     C                   SELECT                                                                     
     C                   WHEN      @PLOGI=0                                                         
     C                   UPDATE    REDTRLP00                            83                          
21050C   83              EXSR      CS_EDTRLD                                                        
