C1078 **************************************************************                                
C1078 * COMMON SUBRUTINE (CS_) :                                  *                                 
C1078 * CONTAR LINEAS A PREPARAR                                   *                                
C1078 *------------------------------------------------------------*                                
C1078C     CS_CONTLIN    BEGSR                                                                      
C1078C                                                                                              
C1078 *                                                                                             
C1078C*                  EVAL      ZXDIAS=T5HORZ                                                    
C1078C*                  IF        ZXDIAS=0                                                         
C1078C*                  EVAL      ZXDIAS=999                                                       
C1078C*                  ENDIF                                                                      
C1078 *                                                                                             
C1078C*                  MOVE      *DATE         ZXFISO                                             
C1078C*                  ADDDUR    ZXDIAS:*D     ZXFISO                                             
C1078C*                  MOVE      ZXFISO        ZXFMAX                                             
C1078 *                                                                                             
C1078C*                  EVAL      T5MLIA=0                                                         
C1078C*    @PCIAS        SETLL     COCAPEA8                                                         
C1078C*    @PCIAS        READE     COCAPEA8                                                         
C1078C*                  DOW       NOT%EOF                                                          
C1078C*                  IF        (S0TPE4<>'2')                                                    
C1078C*                  EVAL      S5CIAS=S0CIAS                                                    
C1078C*                  EVAL      S5DLGA=S0DLGA                                                    
C1078C*                  EVAL      S5NPCO=S0NPCO                                                    
C1078C*                  EVAL      S5TPED=S0TPED                                                    
C1078C*                  EVAL      S5DATP=S0DATP                                                    
C1078C*                  EVAL      S5NOPL=S0NOPL                                                    
C1078C*    KCODEPE       SETLL     CODEPE                                                           
C1078C*    KCODEPE       READE     CODEPE                                                           
C1078C*                  DOW       NOT%EOF                                                          
C1078C*                  IF        M0LOGE=S5LOGE AND S5STUL<'5'                                     
C1078C*                            AND ZXFMAX>S5FREP                                                
C1078C*                  EVAL      T5MLIA=T5MLIA+1                                                  
C1078C*                  ENDIF                                                                      
C1078C*    KCODEPE       READE     CODEPE                                                           
C1078C*                  ENDDO                                                                      
C1078C*                  ENDIF                                                                      
C1078C*    @PCIAS        READE     COCAPEA8                                                         
C1078C*                  ENDDO                                                                      
C1078C                   ENDSR                                                                      
C1078C                                                                                              
C1078C                                                                                              
C1078 **************************************************************                                
C1078 * COMMON SUBRUTINE (CS_) :                                  *                                 
C1078 * CONTAR LINEAS A PREPARAR                                   *                                
C1078 *------------------------------------------------------------*                                
C1078C     CS_REDFLUIDRA BEGSR                                                                      
C1078 *                                                                                             
C1078C                   EVAL      G1CIAO=M0CIAS                                                    
C1078C                   MOVE      M0MAGA        G1MAGO                                             
C1078C                   MOVE      M1ARTI        G1ARTO                                             
C1078C                   MOVE      M1VARI        G1VARO                                             
C1078C                   MOVE      M1MODE        G1MODO                                             
C1078C                   MOVE      'A'           G1CALO                                             
C1078C     KGXSTO0       SETLL     GXSTO02                                                          
C1078C     KGXSTO0       READE     GXSTO02                                                          
C1078C                   DOW       NOT%EOF                                                          
C1078C                   DELETE    RGXSTO0                                                          
C1078C     KGXSTO0       READE     GXSTO02                                                          
C1078C                   ENDDO                                                                      
C1078 *                                                                                             
C1078C                   IF        P5ARFLU='1'                                                      
C1078C                   EVAL      M1CIAS=M0CIAS                                                    
C1078C                   EVAL      M1MAGA=M0MAGA                                                    
C1078C     KMSSTO0       SETLL     MSSTO0                                                           
C1078C     KMSSTO0       READE     MSSTO0                                                           
C1078C                   DOW       NOT%EOF                                                          
C1078                                                                                               
C1078C                   EVAL      M5CIAS=M1CIAS                                                    
C1078C                   EVAL      M5ARTI=M1ARTI                                                    
C1078C                   EVAL      M5VARI=M1VARI                                                    
C1078C                   EVAL      M5MODE=M1MODE                                                    
C1078C     KMSARTI00     CHAIN     MSARTI00                                                         
C1078C                   IF        %FOUND AND M5BAJA<>'1' AND                                       
C1078C                             M5PPV2<'1'                                                       
C1078C                   EVAL      S3CIAS=M5CIAS                                                    
C1078C                   EVAL      S3ARVM=M5ARTI+M5VARI+M5MODE                                      
C1078C                   EVAL      P3CIAR=M5CIAS                                                    
C1078C                   EVAL      P3ARVL=M5ARTI+M5VARI+M5MODE                                      
C1078C     KGMPRO303     CHAIN(N)  GMPRO303                                                         
C1078C     KCOCLP007     CHAIN(N)  COCLP007                                                         
C1078C                   IF        %FOUND(GMPRO303)                                                 
     C                             OR %FOUND(COCLP007)                                              
C1078C                                                                                              
C1078C     KMSSTOK       CHAIN     MSSTOK                                                           
C1078C                   IF        M1SMIN<M1SACT AND                                                
C1078C                             M1SACT>0  AND M1CALI='A'                                         
C1078C                   EVAL      ZXSDIS = M1SACT-M1SKRE-M1SKRP-M1SKR1-M1SKR2                      
C1078 * QUITAMOS EL VALOR                                                                           
C1078C                   IF        T5PMFD<>0                                                        
C2557C*C1078             EVAL      ZXSDIS=ZXSDIS-((T5PMFD/100)*ZXSDIS)                              
C2557C                   EVAL      ZXSDIS=ZXSDIS-((T5PMFD/100)*M1SMIN)                              
C1078C                   ENDIF                                                                      
C1078C                                                                                              
C1078C                   IF        T5DIFD<>0                                                        
C1078C                   EVAL      ZXSDIS=((T5DIFD/100)*ZXSDIS)                                     
C1078C                   ENDIF                                                                      
C1078C                                                                                              
C1078C                   IF        ZXSDIS>0                                                         
C1078C                   EVAL      G1CIAS=M0CIAS                                                    
C1078C                   MOVEL(P)  M0MAGA        G1MAGA                                             
C1078C                   MOVEL(P)  M1ARTI        G1ARTI                                             
C1078C                   MOVEL(P)  M1VARI        G1VARI                                             
C1078C                   MOVEL(P)  M1MODE        G1MODE                                             
C1078C                   MOVEL(P)  M1CALI        G1CALI                                             
C1078C                   EVAL      G1CIAO=M0CIAS                                                    
C1078C                   MOVEL(P)  M0MAGA        G1MAGO                                             
C1078C                   MOVEL(P)  M1ARTI        G1ARTO                                             
C1078C                   MOVEL(P)  M1VARI        G1VARO                                             
C1078C                   MOVEL(P)  M1MODE        G1MODO                                             
C1078C                   MOVEL(P)  M1CALI        G1CALO                                             
C1078C                   EVAL      G1SACT=ZXSDIS                                                    
C1078C                   EVAL      G1SKRE=0                                                         
C1078C                   EVAL      G1SKRP=0                                                         
C1078C                   EVAL      G1SKR1=0                                                         
C1078C                   EVAL      G1SKR2=0                                                         
C1078C                   EVAL      G1ARES=P3ARES                                                    
C1078C                   MOVE      *DATE         G1DAT1                                             
C1078C                   MOVE      *DATE         G1DAT8                                             
C1078C                   MOVEL(P)  SDSUSR        G1USUA                                             
C1078C                   MOVEL(P)  SDSJOB        G1PANT                                             
C1078C                   WRITE     RGXSTO0                                                          
C1078C                   ENDIF                                                                      
C1078 *                                                                                             
C1078                                                                                               
C1078C                   ENDIF                                                                      
C1078C                   ENDIF                                                                      
C1078C                   ENDIF                                                                      
C1078C     KMSSTO0       READE     MSSTO0                                                           
C1078C                   ENDDO                                                                      
C1078C                   CALL      'DO0055'                                                         
C1078C                   PARM      @PCIAS        @PECIAS                                            
C1078C                   PARM      @PMAGA        @PEMAGA                                            
C1078C                   PARM      *BLANKS       @PEOPCI                                            
C1078C                   PARM      *BLANKS       @PERRO                                             
C1078C                   ENDIF                                                                      
C1078C                   ENDSR                                                                      
C1078 **************************************************************                                
C1078 * COMMON SUBRUTINE (CS_) :                                  *                                 
C1078 * CREAR LOGÍSTICAS                                           *                                
C1078 *------------------------------------------------------------*                                
C1078C     CS_CRTLOG     BEGSR                                                                      
C1078C                   EVAL      F_M0CIAS=M0CIAS                                                  
C1078C                   EVAL      F_M0LOGE=P2ALOGE                                                 
C1078C     KMSALMA05     CHAIN     MSALMA05                                                         
C1078C                   IF        NOT%FOUND                                                        
C1078C                   EXFMT     W02                                                              
C1078C                   IF        CREATE='1'  OR                                                   
C1078C                             CMD10='1'                                                        
C1078C     @PCIAS        SETLL     PMEMPR                                                           
C1078C     @PCIAS        READE     PMEMPR                                                           
C1078C                   DOW       NOT%EOF                                                          
C1078C                   IF        ((CREATE='1' AND P7DLGA=M0DLGA) OR                               
C1078C                             CMD10='1')                                                       
C1078C                   EVAL      XL_MICIAS=M0CIAS                                                 
C1078C                   EVAL      XL_MIDLGA=P7DLGA                                                 
C1078C                   EVAL      XL_MILGCA=P2ALOGE                                                
C1078C     KMSLOAD       CHAIN     MSLOAD                                                           
C1078C                   IF        NOT%FOUND                                                        
C1078C                   EVAL      XL_MICIAS=M0CIAS                                                 
C1078C                   EVAL      XL_MIDLGA=P7DLGA                                                 
C1078C                   EVAL      XL_MILGCA=P2ALOGE                                                
C1078C                   EVAL      XL_MIPRIO='001'                                                  
C1078C                   EVAL      XL_MIMI05=*BLANKS                                                
C1078C                   EVAL      XL_MIMI06=*BLANKS                                                
C1078C                   EVAL      XL_MIMI20=*BLANKS                                                
C1078C                   EVAL      XL_MIMI21=*BLANKS                                                
C1078C                   EVAL      XL_MIMAGA=P2AMAGA                                                
C1078C                   EVAL      XL_MICPRI=*BLANKS                                                
C1078C                   EVAL      XL_MIZUBC=*BLANKS                                                
C1078C                   EVAL      XL_MISUBC=*BLANKS                                                
C1078 *                                                                                             
C1078C                   EVAL      XL_MILOGU=*BLANKS                                                
C1078C                   EVAL      XL_MILGRT=*BLANKS                                                
C1078C                   EVAL      XL_MIDAT1=*DATE                                                  
C1078C                   EVAL      XL_MIDAT8=*DATE                                                  
C1078C                   EVAL      XL_MIPANT=SDSJOB                                                 
C1078C                   EVAL      XL_MIUSUA=SDSUSR                                                 
C1078C                   TIME                    XL_MIHORA                                          
C1078C                   EVAL      XL_MITFLU=*BLANKS                                                
C1078C                   EVAL      XL_MIALOL=*BLANKS                                                
C1078C                   WRITE     RMSLOAD1                                                         
C1078C                   EVAL      ERRGRL=*OFF                                                      
C1078C                   ENDIF                                                                      
C1078                                                                                               
C1078C                   EVAL      XL_MICIAS=M0CIAS                                                 
C1078C                   EVAL      XL_MIDLGA=P7DLGA                                                 
C1078C                   EVAL      XL_MILGCA=P2ALOGE                                                
C1078C     KMSLOAD       CHAIN     MSLOGI                                                           
C1078C                   IF        NOT%FOUND                                                        
C1078C                   EVAL      MICIAS=M0CIAS                                                    
C1078C                   EVAL      MIDLGA=P7DLGA                                                    
C1078C                   EVAL      MILGCA=P2ALOGE                                                   
C1078C                   EVAL      MIDESC=M0DES1                                                    
C1078C                   EVAL      MITLGC=*BLANKS                                                   
C1078C                   EVAL      MITPRI=*BLANKS                                                   
C1078C                   EVAL      MIMI01=*BLANKS                                                   
C1078C                   EVAL      MIMI02=*BLANKS                                                   
C1078C                   EVAL      MIMI20=*BLANKS                                                   
C1078C                   EVAL      MIMI21=*BLANKS                                                   
C1078C                   EVAL      MIDAT1=*DATE                                                     
C1078C                   EVAL      MIDAT8=*DATE                                                     
C1078C                   EVAL      MIPANT=SDSJOB                                                    
C1078C                   EVAL      MIUSUA=SDSUSR                                                    
C1078C                   TIME                    MIHORA                                             
C1078C                   EVAL      MIUBIB=M0UBIB                                                    
C1078C                   EVAL      MIPUBI=M0PUBI                                                    
C1078 *                  EVAL      MIALOL=M0ALOL                                                    
C1078C                   WRITE     RMSLOGI                                                          
C1078C                   EVAL      ERRGRL=*OFF                                                      
C1078C                   ENDIF                                                                      
C1078C                   ENDIF                                                                      
C1078C     @PCIAS        READE     PMEMPR                                                           
C1078C                   ENDDO                                                                      
C1078C                   ENDIF                                                                      
C1078C                   ENDIF                                                                      
C1078C                   ENDSR                                                                      
