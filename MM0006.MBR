     C     *DTAARA       DEFINE    PURLDA        DSLDA                                              
     C                   IN        DSLDA                                                            
MOVEXC*                  IF        ZZCTBP=' '                                                       
MOVEXC*                  OPEN      AXCODIGO                                                         
MOVEXC*                  ENDIF                                                                      
MOVEX *                                                                                             
MOVEX * Establecer Entorno de Trabajo Movex                                                         
MOVEX *                                                                                             
MOVEXC                   MOVEL     ZZCIAS        @PEDIVI                                            
MOVEXC                   CALL      'GX0150'                                                         
MOVEXC                   PARM                    @PEDIVI                                            
MOVEXC                   PARM      SDSUSR        @PEUSER                                            
MOVEXC                   PARM      *BLANKS       @PEVAL                                             
MOVEXC                   EVAL      ZXVAL=@PEVAL                                                     
MOVEX *                                                                                             
MOVEXC                   MOVE      MXCONO        @PECONOA                                           
MOVEXC                   MOVE      MXDIVI        @PEDIVI                                            
MOVEX *                                                                                             
      * Entrada de parámetros                                                                       
     C     *ENTRY        PLIST                                                                      
     C                   PARM                    @PCIAS                                             
     C                   PARM                    @PMAGA                                             
     C                   PARM                    @POPCI                                             
     C                   PARM                    @PERRO                                             
     C* TITOLS DE PANTALLES (CODIS D'ARXIU DE MISSATGES)                                            
     C                   EVAL      CCCCTIT='TM00005'                                                
      * BUSQUEDA DE PARAMETROS DE SETUP                                                             
     C                   EVAL      PXFMD1=ZZFMD1                                                    
     C                   EVAL      PICIAS=ZZCIAS                                                    
     C                   EVAL      PIPROG='MM0005    '                                              
     C                   EVAL      PIUSU1=ZZUSUA                                                    
     C     KMSSETP       CHAIN     PMSETP                             81                            
     C                   CLEAR                   MM0005                                             
     C     PIDATR        CAT       MM0005:0      MM0005                                             
     C                   MOVEA     MÑSECP        SSSECPA                                            
     C                   IF        MÑSECP=*BLANKS OR @POPCI='1 ' OR                                 
     C                             @POPCI=' 1' OR @POPCI='3 ' OR                                    
     C                             @POPCI=' 3' OR @POPCI='1B'                                       
     C                   EVAL      SSSECPA(1)='A'                                                   
     C                   EVAL      SSSECPA(2)='B'                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      M0CIAS=@PCIAS                                                    
     C                   EVAL      M0MAGA=@PMAGA                                                    
     C                   EVAL      MICIAS=@PCIAS                                                    
     C                   EVAL      MI_MIMAGA=@PMAGA                                                 
C2294C                   EVAL      N1CIAS=@PCIAS                                                    
     C                   EVAL      M4CIAS=@PCIAS                                                    
     C                   EVAL      M4MAGA=@PMAGA                                                    
     C                   EVAL      M3CIAS=@PCIAS                                                    
     C                   EVAL      M3MAGA=@PMAGA                                                    
C1078                                                                                               
C1078C                   EVAL      T5CIAS=@PCIAS                                                    
C1078C                   EVAL      T5MAGA=@PMAGA                                                    
C1078                                                                                               
                                                                                                    
IT244C                   EVAL      P7CIAS=@PCIAS                                                    
IT244C                   EVAL      P7DLGA=*BLANKS                                                   
IT244C     KPMEMPR       CHAIN     PMEMPR                                                           
IT244C                   if        %found                                                           
IT244C                   Eval      nP7EDV3 = (%SubST(p7amp2:11:1)='1')                              
IT244C                   ENDIF                                                                      
      * ENS POSICIONEM EN EL FORMAT DE PANT. SEGONS NECESSITAT.                                     
      * POR DEFECTO IREMOS A LA 2ª PANTALLA                                                         
     C                   EVAL      INDCHG=*ON                                                       
     C                   EVAL      ZXOPT='P2ACLR'                                                   
     C                   IF        SSSECPA(1)<>*BLANKS                                              
     C                   EVAL      ZXOPT='P2'                                                       
     C     ZXOPT         CAT       SSSECPA(1):0  ZXOPT                                              
     C     ZXOPT         CAT       'CLR':0       ZXOPT                                              
     C                   ENDIF                                                                      
                                                                                                    
     C                   SELECT                                                                     
      * CRT                                                                                         
     C                   WHEN      @POPCI=' 1' OR @POPCI='1 '                                       
     C                   EVAL      ZXOPT='P10CLR'                                                   
     C                   EVAL      INDCRT=*ON                                                       
                                                                                                    
     C                   WHEN      @POPCI='1B'                                                      
     C                   EVAL      ZXOPT='P2ACLR'                                                   
     C                   EVAL      INDCRT=*ON                                                       
      * CPY                                                                                         
     C                   WHEN      @POPCI=' 3' OR @POPCI='3 '                                       
     C                   EVAL      ZXOPT='P30CLR'                                                   
     C                   EVAL      INDCPY=*ON                                                       
      * DLT                                                                                         
     C                   WHEN      @POPCI=' 4' OR @POPCI='4 '                                       
     C                   EVAL      ZXOPT='P40CLR'                                                   
     C                   EVAL      INDDLT=*ON                                                       
      * DSP                                                                                         
     C                   WHEN      @POPCI=' 5' OR @POPCI='5 '                                       
     C                   EVAL      INDDSP=*ON                                                       
     C                   EVAL      INDPROT=*ON                                                      
C1078 * PARAMETROS DOM                                                                              
C1078                                                                                               
C1078C                   WHEN      @POPCI='PA'                                                      
C1078C                   EVAL      ZXOPT='P5ACLR'                                                   
C1078C                   MOVE      @PCIAS        @PCIAA            3                                
C1078C                   CALL      'DO0060'                                                         
C1078C                   PARM                    @PCIAA                                             
C1078C                   PARM                    @PMAGA                                             
C1078C                   PARM                    @PERRO                                             
     C                   ENDSL                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL FMT P10                              *                                
      *------------------------------------------------------------*                                
     C     P10MAIN       BEGSR                                                                      
     C                   DOW       ZXOPT1='P10'                                                     
     C     ZXOPT2        CASEQ     'CLR'         P10CLR                                             
     C     ZXOPT2        CASEQ     'INZ'         P10INZ                                             
     C     ZXOPT2        CASEQ     'DSP'         P10DSP                                             
     C     ZXOPT2        CASEQ     'CMD'         P10CMD                                             
     C     ZXOPT2        CASEQ     'CHK'         P10CHK                                             
     C     ZXOPT2        CASEQ     'UPD'         P10UPD                                             
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ DEL FMT P10                       *                                
      *------------------------------------------------------------*                                
     C     P10CLR        BEGSR                                                                      
      * ENS ENCARREGUEM QUE EL PROPER PAS SIGUI VISUALITZAR P10                                     
     C                   EVAL      ZXOPT2='INZ'                                                     
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO10      *IN(60)                                            
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C                   RESET                   Z_P                                                
     C     P10CLRT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ DEL FMT P10                       *                                
      *------------------------------------------------------------*                                
     C     P10INZ        BEGSR                                                                      
      * ENS ENCARREGUEM QUE EL PROPER PAS SIGUI VISUALITZAR P10                                     
     C                   EVAL      ZXOPT2='DSP'                                                     
     C     P10INZT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VISUALITZACIÓ DEL FMT P10                        *                                
      *------------------------------------------------------------*                                
     C     P10DSP        BEGSR                                                                      
      * ENS ENCARREGUEM QUE EL PROPER PAS SIGUI COMPROVAR ENTRADA CMD                               
     C                   EVAL      ZXOPT2='CMD'                                                     
     C                   EVAL      PPPCMD1='CMD7801'                                                
     C                   EXFMT     P10                                                              
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO10      *IN(60)                                            
     C                   EVAL      ERRGRL=*OFF                                                      
     C                   EVAL      MSGER=*BLANKS                                                    
     C     P10DSPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CAMPS DEL FMT P10                 *                                
      *------------------------------------------------------------*                                
     C     P10CMD        BEGSR                                                                      
     C                   EVAL      ZXOPT2='CHK'                                                     
      *VALIDACIONES TECLAS DE FUNCION                                                               
     C                   SELECT                                                                     
      * FINALITZAR EL PROGRAMA                                                                      
     C                   WHEN      EXIT=*ON                                                         
     C                   EVAL      ZXOPT1='END'                                                     
      * SOL·LICITUD AJUDA D'ARTICLES                                                                
     C                   WHEN      HELP=*ON                                                         
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   EXSR      CS_POCUR2                                                        
                                                                                                    
     C                   WHEN      RETRO=*ON                                                        
     C                   EVAL      ZXOPT1='END'                                                     
     C                   ENDSL                                                                      
                                                                                                    
     C     P10CMDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CAMPS DEL FMT P10                 *                                
      *------------------------------------------------------------*                                
     C     P10CHK        BEGSR                                                                      
     C                   EVAL      ZXOPT2='UPD'                                                     
      * Si el almacén es blanco no continuamos                                                      
     C                   IF        P10MAGA=*BLANKS                                                  
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP10CHK                                            
      * El almacén no puede existir                                                                 
     C                   EVAL      M0MAGA=P10MAGA                                                   
     C     KMSALMA       CHAIN (N) MSALMA                             81                            
     C                   IF        CHAIN=*OFF                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ASG1028'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP10CHK                                            
                                                                                                    
     C     TP10CHK       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C     P10CHKT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE ACTUALIZACION DATOS DE  P10                   *                                
      *------------------------------------------------------------*                                
     C     P10UPD        BEGSR                                                                      
      * PASA A LAS PANTALLAS P2X                                                                    
     C                   EVAL      ZXOPT='P2ACLR'                                                   
     C                   EVAL      M0MAGA=P10MAGA                                                   
     C     P10UPDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL FMT P2A                              *                                
      *------------------------------------------------------------*                                
     C     P2AMAIN       BEGSR                                                                      
     C                   EVAL      ZXOPT1='P2A'                                                     
     C                   DOW       ZXOPT1='P2A'                                                     
     C     ZXOPT2        CASEQ     'CLR'         P2ACLR                                             
     C     ZXOPT2        CASEQ     'INZ'         P2AINZ                                             
     C     ZXOPT2        CASEQ     'DSP'         P2ADSP                                             
     C     ZXOPT2        CASEQ     'CMD'         P2ACMD                                             
     C     ZXOPT2        CASEQ     'CHK'         P2ACHK                                             
     C     ZXOPT2        CASEQ     'UPD'         P2AUPD                                             
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA LIMPIEZA  DE P2A                                 *                                
      *------------------------------------------------------------*                                
     C     P2ACLR        BEGSR                                                                      
     C                   EVAL      ZXOPT2='INZ'                                                     
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO10      *IN(60)                                            
     C                   MOVE      *BLANKS       MSGER                                              
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C     P2ACLRT       ENDSR                                                                      
      *                                                                                             
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ DEL FMT P2A                       *                                
      *------------------------------------------------------------*                                
     C     P2AINZ        BEGSR                                                                      
      *                                                                                             
     C                   EVAL      ZXOPT2='DSP'                                                     
     C     *NOKEY        CLEAR     *ALL          RMSALMA                                            
C1078C                   IF        INDDSP=*OFF                                                      
     C     KMSALMA       CHAIN     MSALMA                             81                            
C1078C                   ELSE                                                                       
C1078C     KMSALMA       CHAIN(N)  MSALMA                             81                            
C1078C                   ENDIF                                                                      
     C                   EXSR      P2AMFP                                                           
      * En el caso de altas se pasan los valores por defecto de PURLDA                              
     C                   IF        INDCRT=*ON                                                       
C2165C                   EVAL      *IN88=*OFF                                                       
     C                   EVAL      P2APAIS=ZZPAIS                                                   
C2165C                   ELSE                                                                       
C2165C                   EVAL      *IN88=*ON                                                        
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PASAR DE FICHERO A PANTALLA P2A                  *                                
      *------------------------------------------------------------*                                
     C     P2AMFP        BEGSR                                                                      
      *                                                                                             
     C                   EVAL      P2AMAGA=M0MAGA                                                   
     C                   EVAL      P2ADES1=M0DES1                                                   
MOVEXC*                  EVAL      P2AAUXC=M0AUXC                                                   
MOVEXC                   EVAL      P2AAIT2=M0AIT2                                                   
MOVEXC                   EVAL      P2AAIT3=M0AIT3                                                   
MOVEXC                   EVAL      P2AAIT4=M0AIT4                                                   
MOVEXC                   EVAL      P2AAIT5=M0AIT5                                                   
MOVEXC                   EVAL      P2AAIT6=M0AIT6                                                   
MOVEXC                   EVAL      P2AAIT7=M0AIT7                                                   
     C                   EVAL      ZXPUBI=M0PUBI                                                    
     C                   EVAL      P2ADLGA=M0DLGA                                                   
     C                   EVAL      P2ACL10=M0CL10                                                   
     C                   EVAL      P2APAIS=M0PAIS                                                   
     C                   EVAL      P2AZOPA=M0ZOPA                                                   
     C                   EVAL      P2ASUPA=M0SUPA                                                   
     C                   EVAL      P2AZONC=M0ZONC                                                   
     C                   EVAL      P2ASUPC=M0SUPC                                                   
     C                   EVAL      P2ADIRE=M0DIRE                                                   
     C                   EVAL      P2ADIR1=M0DIR1                                                   
     C                   EVAL      P2ADIR2=M0DIR2                                                   
     C                   EVAL      P2APOST=M0POST                                                   
     C                   EVAL      P2APEGE=M0PEGE                                                   
     C                   EVAL      P2ATLEX=M0TLEX                                                   
     C                   EVAL      P2ATFAX=M0TFAX                                                   
     C                   EVAL      P2ATELE=M0TELE                                                   
     C                   EVAL      P2AEMAI=M0EMAI                                                   
     C                   EVAL      P2ATEL2=M0TEL2                                                   
     C                   EVAL      P2ATAL1=M0TAL1                                                   
     C                   EVAL      ZXTAL10=M0TAL1                                                   
26117C                   EVAL      ZXTAL1=M0TAL1                                                    
     C                   EVAL      P2ATAL2=M0TAL2                                                   
     C                   EVAL      P2ATAL3=M0TAL3                                                   
     C                   EVAL      P2APRVR=M0PRVR                                                   
     C                   EVAL      P2ATDIR=M0TDIR                                                   
     C                   EVAL      P2ALOGE=M0LOGE                                                   
     C                   EVAL      P2ALOGS=M0LOGS                                                   
     C                   EVAL      P2APRSV=M0PRSV                                                   
     C                   EVAL      P2APRES=M0PRES                                                   
     C                   EVAL      ZXTDIR=M0TDIR                                                    
30119C                   EVAL      P2ALOGI=M0LOGI                                                   
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   EVAL      PXNUM=M0NUBB                                                     
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                                              
     C                   PARM                    PXALPH                                             
     C                   PARM                    PXFLDD                                             
     C                   PARM      0             PXDCCD                                             
     C                   PARM                    PXFMD1                                             
     C                   PARM                    PXEDTC                                             
     C                   PARM                    PXNMER                                             
     C                   PARM                    PXTIPA                                             
     C                   MOVE      PXALPH        P2ANUBB                                            
C1631C                   EVAL      P2AEANA=M0EANA                                                   
                                                                                                    
      * PARA EL CASO DE COPIAS CAMBIAREMOS LA CABECERA                                              
     C                   IF        INDCPY=*ON                                                       
     C                   EVAL      ZXTDIR=*BLANKS                                                   
     C                   EVAL      P2AMAGA=P3CMAGA                                                  
     C     *NOKEY        CLEAR     *ALL          RMSALMA                                            
     C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VISUALITZACIÓ DEL FMT P2A                        *                                
      *------------------------------------------------------------*                                
     C     P2ADSP        BEGSR                                                                      
      * ENS ENCARREGUEM QUE EL PROPER PAS SIGUI COMPROVAR ENTRADA CMD                               
     C                   EVAL      ZXOPT2='CMD'                                                     
     C                   EVAL      PPPCMD1='CMD7801'                                                
     C                   EXFMT     P2A                                                              
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO10      *IN(60)                                            
     C                   EVAL      ERRGRL=*OFF                                                      
     C                   EVAL      MSGER=*BLANKS                                                    
     C                   EVAL      CSRFILA=*ZEROS                                                   
     C                   EVAL      CSRCOLU=*ZEROS                                                   
     C     P2ADSPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CMDS DEL FMT P2A                 *                                 
      *------------------------------------------------------------*                                
     C     P2ACMD        BEGSR                                                                      
     C                   EVAL      ZXOPT2='CHK'                                                     
      *VALIDACIONES TECLAS DE FUNCION                                                               
     C                   SELECT                                                                     
      * FINALITZAR EL PROGRAMA                                                                      
     C                   WHEN      EXIT=*ON                                                         
     C                   EVAL      ZXOPT1='END'                                                     
      * SOL·LICITUD AJUDA D'ARTICLES                                                                
     C                   WHEN      HELP=*ON                                                         
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   EXSR      CS_POCUR2                                                        
     C                   EXSR      P2AF4                                                            
      * RETROCESO PANTALLA                                                                          
     C                   WHEN      RETRO=*ON                                                        
     C                   EVAL      Z_P=Z_P-1                                                        
     C                   IF        Z_P<=0                                                           
     C                   EVAL      ZXOPT='END'                                                      
     C                   ELSE                                                                       
     C                   EVAL      ZXOPT1='P2 '                                                     
     C                   MOVE      SSSECPA(Z_P)  ZXOPT1                                             
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
     C                   ENDSL                                                                      
                                                                                                    
     C     TP2ACMD       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C     P2ACMDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE AYUDA EN CAMPOS DEL   FMT P2A                 *                                
      *------------------------------------------------------------*                                
     C     P2AF4         BEGSR                                                                      
     C* No se permite acceso a consulta si estamos en opcion de visualizar                          
     C                   IF        INDDSP=*ON                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           P2AF4T                                             
     C* F4 PARA VALORES QUE UNICAMENTE SE ACCEDE POR PROMPT SEGUN REFERENCIA                        
     C* DEL DICCIONARIO                                                                             
     C                   EVAL      @PEFLD=*BLANKS                                                   
     C                   EVAL      @PEFMT=*BLANKS                                                   
                                                                                                    
     C                   IF        FIELD='P2ATAL1'                                                  
     C                   IF        FIELD='P2ATAL1'                                                  
     C                   EVAL      @PEFLD=ZXFIE4                                                    
     C                   ELSE                                                                       
     C                   EVAL      @PEFLD='SINO'                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   CALL      'MMPROM'                                                         
     C                   PARM      *BLANKS       @PEOPT                                             
     C                   PARM      *BLANKS       @PEPGM                                             
     C                   PARM                    @PEFMT                                             
     C                   PARM                    @PEFLD                                             
     C                   PARM      *BLANKS       @PEERR                                             
                                                                                                    
     C                   IF        @PEERR>'0'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ADP0304'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           P2AF4T                                             
      * Si no han realizado ninguna selección no tocamos nada                                       
     C                   IF        @PEERR='A'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           P2AF4T                                             
      *                                                                                             
     C                   IF        FIELD='P2ATAL1'                                                  
     C                   EVAL      P2ATAL1=@PEOPT                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   GOTO      P2AF4T                                                           
     C                   ENDIF                                                                      
      * Ayudas de logisticas                                                                        
     C                   IF        FIELD='P2ALOGE'                                                  
     C                   CALL      'MM0690'                                                         
     C                   PARM                    @PCIAS                                             
     C                   PARM                    ZZDLGA                                             
     C                   PARM                    P2ALOGE                                            
     C                   PARM      '1'           @PEERR                                             
     C                   GOTO      P2AF4T                                                           
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        FIELD='P2ALOGS'                                                  
     C                   CALL      'MM0690'                                                         
     C                   PARM                    @PCIAS                                             
     C                   PARM                    ZZDLGA                                             
     C                   PARM                    P2ALOGS                                            
     C                   PARM      '2'           @PEERR                                             
     C                   GOTO      P2AF4T                                                           
     C                   ENDIF                                                                      
      * Ayudas en tablas                                                                            
     C                   IF        FIELD='P2ATAL2' OR FIELD='P2ADLGA'                               
     C                             OR FIELD='P2ATA01'                                               
     C                   EVAL      @PCLTA=*BLANKS                                                   
     C                   EVAL      @PCTAB=*BLANKS                                                   
     C                   EVAL      @PCTAB=ZXFIE4                                                    
     C                   IF        FIELD='P2ATAL2'                                                  
     C                   EVAL      @PCLTA=P2ATAL2                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        FIELD='P2ADLGA'                                                  
     C                   EVAL      @PCLTA=P2ADLGA                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   CALL      'MMTABL'                                                         
     C                   PARM                    @PCLTA                                             
     C                   PARM                    @PCTAB                                             
     C                   PARM                    @PCIAS                                             
     C                   PARM                    @PEERR                                             
                                                                                                    
     C                   IF        @PEERR>'0'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ADP0304'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           P2AF4T                                             
      * Si no han realizado ninguna selección no tocamos nada                                       
     C                   IF        @PEERR='A'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           P2AF4T                                             
      *                                                                                             
     C                   IF        FIELD='P2ATAL2'                                                  
     C                   EVAL      P2ATAL2=@PCLTA                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   IF        FIELD='P2ADLGA'                                                  
     C                   EVAL      P2ADLGA=@PCLTA                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   GOTO      P2AF4T                                                           
     C                   ENDIF                                                                      
                                                                                                    
MOVEXC*                  IF        FIELD='P2AAUXC'                                                  
MOVEXC*                  IF        ZZCTBP=' '                                                       
MOVEXC*                  CALL      'HC0620'                                                         
MOVEXC*                  PARM      @PCIAS        EMPRESA                                            
MOVEXC*                  PARM      '01'          AUXTIP                                             
MOVEXC*                  PARM      P2AAUXC       AUXCOD                                             
MOVEXC*                  PARM      *BLANKS       @PERRO                                             
MOVEXC*                  EVAL      P2AAUXC=AUXCOD                                                   
MOVEXC*                  ENDIF                                                                      
MOVEXC*                  GOTO      P2AF4T                                                           
MOVEXC*                  ENDIF                                                                      
