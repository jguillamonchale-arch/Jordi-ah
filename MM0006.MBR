MOVEXC                   PARM      MXCONO        @PECONOA                                           
MOVEXC                   PARM      MXDIVI        @PEDIVI                                            
MOVEXC                   PARM      2             @PEAITP                                            
MOVEXC                   PARM                    P2AAIT2                                            
MOVEXC                   GOTO      P2AF4T                                                           
MOVEXC                   ENDIF                                                                      
