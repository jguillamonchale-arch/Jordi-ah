MOVEX *                                                                                             
      * Validación del Código postal                                                                
      *                                                                                             
     C                   EVAL      N3PAIS=MEPAIS                                                    
     C                   EVAL      N3CIAS=@PCIAS                                                    
     C                   EVAL      N3POST=P2APOST                                                   
      *                                                                                             
     C     KMSCPOS       CHAIN     MSCPOS                             81                            
      * Si solo se valida y se avisa                                                                
     C                   IF        CHAIN=*ON  OR N3BAJA>'0'                                         
     C                   EVAL      WRK34=*ON                                                        
                                                                                                    
     C                   IF        MEVPOS='1'                                                       
     C                   EXFMT     W01                                                              
     C                   SELECT                                                                     
     C                   WHEN      RETRO=*ON                                                        
     C                   EVAL      ERRGRL=*ON                                                       
     C                   GOTO      TP2ACHK                                                          
     C                   ENDSL                                                                      
     C                   ENDIF                                                                      
                                                                                                    
      * Si se valida y no permite                                                                   
     C                   IF        MEVPOS='2'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ASG1004'                                                  
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
                                                                                                    
      * LA ZONA DEL PAIS SOLO SE VALIDA SI NO ES BLANCOS                                            
     C                   IF        P2AZOPA<>*BLANKS                                                 
     C                   EVAL      N4CIAS=@PCIAS                                                    
     C                   EVAL      N4PAIS=P2APAIS                                                   
     C                   EVAL      N4ZOPA=P2AZOPA                                                   
     C     KMSZPAI       CHAIN     MSZPAI                             81                            
     C                   IF        CHAIN=*ON OR N4BAJA>'0'                                          
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MMM0001'                                                  
     C                   EVAL      WRK56=*ON                                                        
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
                                                                                                    
      * LA SUBZONA DEL PAIS SOLO SE VALIDA SI NO ES BLANCOS                                         
     C                   IF        P2ASUPA<>*BLANKS                                                 
     C                   EVAL      N5CIAS=@PCIAS                                                    
     C                   EVAL      N5PAIS=P2APAIS                                                   
     C                   EVAL      N5ZOPA=P2AZOPA                                                   
     C                   EVAL      N5SUPA=P2ASUPA                                                   
     C     KMSSZON       CHAIN     MSSZON                             81                            
     C                   IF        CHAIN=*ON OR N5BAJA>'0'                                          
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MMM0002'                                                  
     C                   EVAL      WRK36=*ON                                                        
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
      * LA ZONA COMERCIAL ES OBLIGATORIA                                                            
     C                   EVAL      TQCIAS=@PCIAS                                                    
     C                   EVAL      TQZONC=P2AZONC                                                   
     C     KCOZZON       CHAIN     COZZON                             81                            
     C                   IF        CHAIN=*ON OR TQBAJA>'0'                                          
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MMM0001'                                                  
     C                   EVAL      WRK62=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
                                                                                                    
      * LA SUBZONA COMERCIAL ES OBLIGATORIA                                                         
     C                   EVAL      TSCIAS=@PCIAS                                                    
     C                   EVAL      TSZONC=P2AZONC                                                   
     C                   EVAL      TSSUPC=P2ASUPC                                                   
     C     KCOZSUB       CHAIN     COZSUB                             81                            
     C                   IF        CHAIN=*ON OR TSBAJA>'0'                                          
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MMM0001'                                                  
     C                   EVAL      WRK63=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
      * Validacion del tipo de almacen                                                              
     C                   EVAL      @PEOPT=*BLANKS                                                   
     C                   EVAL      @PEOPT=P2ATAL1                                                   
     C                   CALL      'MMPROM'                                                         
     C                   PARM                    @PEOPT                                             
     C                   PARM      *BLANKS       @PEPGM                                             
     C                   PARM      *BLANKS       @PEFMT                                             
     C                   PARM      'TAL1      '  @PEFLD                                             
     C                   PARM      'V'           @PEERR                                             
                                                                                                    
     C                   IF        @PEERR>'0'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MMM0220'                                                  
     C                   EVAL      WRK44=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
      * Los almacenes virtuales OL no pueden tener ubicaciones                                      
     C                   IF        P2ATAL1='8' AND M0PUBI>='1'                                      
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MMM0301'                                                  
     C                   EVAL      WRK57=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
      * Los almacenes virtuales OL deben ser compatibles con ZZEPP6>=1                              
     C*                  IF        P2ATAL1='8' AND ZZEPP6<='0'                                      
     C*                  EVAL      ERRGRL=*ON                                                       
     C*                  EVAL      MSGER='MSG0174'                                                  
     C*                  EVAL      WRK57=*ON                                                        
     C*                  ENDIF                                                                      
     C*    ERRGRL        CABEQ     *ON           TP2ACHK                                            
      * Validacion del código de dirección si almacén o parkin interno                              
     C                   IF        P2ATAL1<='1' AND P2ATDIR=*BLANKS                                 
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   EVAL      WRK60=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
      * Los almacenes de transito y proveedor no puede tener ubicaciones                            
     C*                  IF        P2ATAL1>'1' AND M0PUBI>='1'                                      
     C*                  EVAL      ERRGRL=*ON                                                       
     C*                  EVAL      MSGER='MMM0301'                                                  
     C*                  EVAL      WRK60=*ON                                                        
     C*                  ENDIF                                                                      
     C*    ERRGRL        CABEQ     *ON           TP2ACHK                                            
      * Validación de logísticas                                                                    
      * Puesto que existe una incongruencia ya que la logística necesita del alm                    
      * este caso se da de alta el almacén validando la logística, se deja que p                    
      * y copias la validación se omita y se cree el registro en logísticas al f                    
     C                   IF        P2ALOGE=*BLANKS                                                  
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK34=*ON                                                        
     C                   EVAL      MSGER='ADP0130'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
                                                                                                    
     C                   IF        INDCRT<>*ON AND INDCPY<>*ON                                      
     C                   EVAL      MIDLGA=P2ADLGA                                                   
     C                   EVAL      MILGCA=P2ALOGE                                                   
     C     KMSLOGI       CHAIN(N)  MSLOGI                             81                            
     C                   IF        (CHAIN=*ON) OR (MITLGC<>' ' AND                                  
     C                             MITLGC<>'1')                                                     
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK34=*ON                                                        
     C                   EVAL      MSGER='MMM0108'                                                  
     C                   ENDIF                                                                      
C1078 *                                                                                             
C1078C                   IF        INDDSP=*OFF                                                      
C1078C                   EXSR      CS_CRTLOG                                                        
C1078C                   ENDIF                                                                      
C1078 *                                                                                             
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
                                                                                                    
     C                   IF        P2ALOGS=*BLANKS                                                  
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK35=*ON                                                        
     C                   EVAL      MSGER='ADP0130'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
                                                                                                    
     C                   IF        INDCRT<>*ON AND INDCPY<>*ON                                      
     C                   EVAL      MIDLGA=P2ADLGA                                                   
     C                   EVAL      MILGCA=P2ALOGS                                                   
     C     KMSLOGI       CHAIN(N)  MSLOGI                             81                            
     C                   IF        (CHAIN=*ON) OR (MITLGC<>' ' AND                                  
     C                             MITLGC<>'2')                                                     
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK35=*ON                                                        
     C                   EVAL      MSGER='MMM0109'                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
30119 *                                                                                             
30119 * Comprobar Logistica Asociada: Si es almacen de tipo '2', debe informarse                    
30119 * , ser valida y diferente a las logisticas de entrada y salida.                              
30119 * Si el almacen no es de tipo '2', no debe informarse.                                        
30119 *                                                                                             
30119C                   IF        P2ATAL1='2'                                                      
30119 *                                                                                             
30119C                   IF        P2ALOGI=*BLANKS                                                  
30119C                   EVAL      ERRGRL=*ON                                                       
30119C                   EVAL      WRK48=*ON                                                        
30119C                   EVAL      MSGER='MMM0401'                                                  
30119C                   ENDIF                                                                      
30119C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
30119                                                                                               
30119C                   EVAL      MIDLGA=P2ADLGA                                                   
30119C                   EVAL      MILGCA=P2ALOGI                                                   
30119C     KMSLOGI       CHAIN(N)  MSLOGI                             81                            
30119C                   IF        (CHAIN=*ON) OR (MITLGC<>' ' AND                                  
30119C                             MITLGC<>'2')                                                     
30119C                   EVAL      ERRGRL=*ON                                                       
30119C                   EVAL      WRK48=*ON                                                        
30119C                   EVAL      MSGER='MMM0109'                                                  
30119C                   ENDIF                                                                      
30119C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
30119 *                                                                                             
30119 * COMPROBAR QUE LA LOGISTICA ASOCIADA NO SEA A SU VEZ UN ALMACEN                              
30119 * DE TIPO '2'                                                                                 
30119 *                                                                                             
30119C                   EVAL      XL_MICIAS=@PCIAS                                                 
30119C                   EVAL      XL_MIDLGA=P2ADLGA                                                
30119C                   EVAL      XL_MILGCA=P2ALOGI                                                
30119C     KMSLOAD       CHAIN     MSLOAD                             81                            
30119C                   EVAL      XA_M0CIAS=XL_MICIAS                                              
30119C                   EVAL      XA_M0MAGA=XL_MIMAGA                                              
30119C     KMSALMA00     CHAIN     MSALMA00                           81                            
30119C                   IF        CHAIN=*ON OR XA_M0TAL1='8'                                       
30119C                             OR XA_M0TAL1='2'                                                 
30119C                             OR (CHAIN=*OFF AND XA_M0BAJA>='1')                               
30119C                   EVAL      ERRGRL=*ON                                                       
30119C                   EVAL      WRK48=*ON                                                        
30119C                   EVAL      MSGER='MMM0404'                                                  
30119C                   ENDIF                                                                      
30119C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
30119 *                                                                                             
30119C                   IF        P2ALOGI=P2ALOGE OR P2ALOGI=P2ALOGS                               
30119C                   EVAL      ERRGRL=*ON                                                       
30119C                   EVAL      WRK48=*ON                                                        
30119C                   EVAL      MSGER='MMM0402'                                                  
30119C                   ENDIF                                                                      
30119C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
30119 *                                                                                             
30119C                   ELSE                                                                       
30119 *                                                                                             
30119C                   IF        P2ALOGI<>*BLANKS                                                 
30119C                   EVAL      ERRGRL=*ON                                                       
30119C                   EVAL      WRK48=*ON                                                        
30119C                   EVAL      MSGER='MMM0400'                                                  
30119C                   ENDIF                                                                      
30119C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
30119 *                                                                                             
30119C                   ENDIF                                                                      
30119 *                                                                                             
      * Si cambian la dirección o la ponen nueva validaremos que no exista dicha                    
     C                   IF        ZXTDIR<>P2ATDIR                                                  
     C                   CALL      'MM2596'                                                         
     C                   PARM                    @PCIAS                                             
     C                   PARM      P2ATDIR       @PTDIR                                             
     C                   PARM      *BLANKS       @PEERR                                             
     C                   IF        @PEERR>'0'                                                       
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='MSG0006'                                                  
     C                   EVAL      WRK60=*ON                                                        
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
                                                                                                    
      * Validacion de la 2° CLASIFICACION                                                           
     C                   EVAL      PECIAS=@PCIAS                                                    
     C                   EVAL      PECTAB='TAL2      '                                              
     C                   EVAL      PECLTA=*BLANKS                                                   
     C                   EVAL      PECLTA=P2ATAL2                                                   
     C     KPMTABD       CHAIN     PMTABD                             81                            
     C                   IF        CHAIN=*ON OR PEBAJA='1'                                          
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   EVAL      WRK52=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
                                                                                                    
      * SOLO SE ACEPTA CODIGO DE PROVEEDOR SI ES EXTERNO                                            
C4137 *                  IF        P2ATAL1='2'                                                      
C4137 *  C1078C                             OR P2ATAL1='7'                                          
C4406c                   IF        P2ATAL1='2'                                                      
C4406c                                      OR P2ATAL1='7'                                          
IT226C                             OR  (P2ATAL1 = '8'                                               
IT226C                             AND  P2APRVR <> *blanks)                                         
C4137C                   IF        P2APRVR<>*BLANKS                                                 
     C                   EVAL      C0CIAS=@PCIAS                                                    
     C                   EVAL      C0PRVR=P2APRVR                                                   
     C     KPUPROV       CHAIN     PUPROV                             81                            
     C                   IF        CHAIN=*ON                                                        
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='PUR0001'                                                  
     C                   EVAL      WRK47=*ON                                                        
     C                   ENDIF                                                                      
C4406c                   ENDIF                                                                      
C4137 *                  ELSE                                                                       
C4137 *                  IF        P2APRVR<>*BLANKS                                                 
C4137 *                  EVAL      ERRGRL=*ON                                                       
C4137 *                  EVAL      MSGER='PUR0002'                                                  
C4137 *                  EVAL      WRK47=*ON                                                        
C4137 *                  ENDIF                                                                      
C4137 *                  ENDIF                                                                      
C4406c                   ELSE                                                                       
C4406c                   IF        P2APRVR<>*BLANKS                                                 
C4406c                   EVAL      ERRGRL=*ON                                                       
C4406c                   EVAL      MSGER='PUR0002'                                                  
C4406c                   EVAL      WRK47=*ON                                                        
C4406c                   ENDIF                                                                      
C4137C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
                                                                                                    
      * Validaremos los valores numericos para %RESERVA AUTOMATICA                                  
     C                   EVAL      PXDCCD=0                                                         
                                                                                                    
     C                   EVAL      PXALPH=*BLANKS                                                   
     C                   MOVE      P2APRES       PXALPH                                             
     C                   EVAL      PXNUM=0                                                          
     C                   CALL      'PRD650'                                                         
     C                   PARM                    PXNUM                                              
     C                   PARM                    PXALPH                                             
     C                   PARM                    PXFLDD                                             
     C                   PARM                    PXDCCD                                             
     C                   PARM                    PXFMD1                                             
     C                   PARM                    PXEDTC                                             
     C                   PARM                    PXNMER                                             
     C                   PARM                    PXTIPA                                             
     C                   IF        PXNMER<>0                                                        
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK61=*ON                                                        
     C                   EVAL      MSGER='MSG0022'                                                  
     C                   IF        PXNMER=1                                                         
     C                   EVAL      MSGER='MSG0023'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=2                                                         
     C                   EVAL      MSGER='MSG0024'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=3                                                         
     C                   EVAL      MSGER='MSG0025'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=4                                                         
     C                   EVAL      MSGER='MSG0026'                                                  
     C                   ENDIF                                                                      
     C                   IF        PXNMER=5                                                         
     C                   EVAL      MSGER='MSG0032'                                                  
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
     C                   MOVE      PXALPH        P2APRES                                            
                                                                                                    
      * El valor desde no puede superar al valor hasta                                              
     C                   IF        PXNUM<0   OR PXNUM>100                                           
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      WRK61=*ON                                                        
     C                   EVAL      MSGER='MSG0169'                                                  
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
     C     TP2ACHK       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE ACTUALIZACION DEL FMT P2A                     *                                
      *------------------------------------------------------------*                                
     C     P2AUPD        BEGSR                                                                      
     C                   EVAL      Z_P=Z_P+1                                                        
     C                   IF        SSSECPA(Z_P)=*BLANKS                                             
     C                   EVAL      ZXOPT='END'                                                      
     C                   IF        INDCRT=*ON  AND @POPCI<>'1B'                                     
     C                   EVAL      ZXOPT='P10CLR'                                                   
     C                   ENDIF                                                                      
     C                   ELSE                                                                       
     C                   EVAL      ZXOPT1='P2 '                                                     
     C                   MOVE      SSSECPA(Z_P)  ZXOPT1                                             
     C                   EVAL      ZXOPT2='CLR'                                                     
     C                   ENDIF                                                                      
                                                                                                    
      * En el caso de la opción de visualiza no actualizo                                           
     C                   IF        INDDSP=*ON                                                       
     C                   GOTO      P2AUPDT                                                          
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      M0CIAS=@PCIAS                                                    
     C                   EVAL      M0MAGA=P2AMAGA                                                   
     C     KMSALMA       CHAIN     MSALMA                             81                            
                                                                                                    
     C                   EXSR      P2AMPF                                                           
                                                                                                    
     C                   IF        CHAIN=*OFF                                                       
     C                   UPDATE    RMSALMA                                                          
      * Si han cambiado el tipo de almacen hacia o de un OL virtual ,                               
      * cambio todos los registros de logstica.                                                     
     C                   IF        (ZXTAL10<>M0TAL1) AND (ZXTAL10='8' OR                            
     C                              M0TAL1='8')                                                     
     C     KMSLOAD020    CHAIN     MSLOAD02                           81                            
     C                   DOW       CHAIN=*OFF                                                       
     C                   EVAL      MI_MIALOL=*BLANKS                                                
     C                   IF        M0TAL1='8'                                                       
     C                   EVAL      MI_MIALOL='1'                                                    
     C                   ENDIF                                                                      
                                                                                                    
     C                   UPDATE    RMSLOAD                                                          
      * Accedo a su cabecera para actualizar datos                                                  
     C     KMSLOGI       CHAIN     MSLOGI                             83                            
     C                   IF        READ1=*OFF                                                       
     C                   EVAL      MIALOL=*BLANKS                                                   
     C                   IF        M0TAL1='8'                                                       
     C                   EVAL      MIALOL='1'                                                       
     C                   ENDIF                                                                      
     C                   UPDATE    RMSLOGI                                                          
     C                   ENDIF                                                                      
                                                                                                    
     C     KMSLOAD020    READE     MSLOAD02                               81                        
     C                   ENDDO                                                                      
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C     P2AUPDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PASAR DE PANTALLA P2A A FICHERO                  *                                
      *------------------------------------------------------------*                                
     C     P2AMPF        BEGSR                                                                      
      *                                                                                             
     C                   EVAL      M0MAGA=P2AMAGA                                                   
     C                   EVAL      M0DES1=P2ADES1                                                   
MOVEXC*                  EVAL      M0AUXC=P2AAUXC                                                   
MOVEXC                   EVAL      M0AIT2=P2AAIT2                                                   
MOVEXC                   EVAL      M0AIT3=P2AAIT3                                                   
MOVEXC                   EVAL      M0AIT4=P2AAIT4                                                   
MOVEXC                   EVAL      M0AIT5=P2AAIT5                                                   
MOVEXC                   EVAL      M0AIT6=P2AAIT6                                                   
MOVEXC                   EVAL      M0AIT7=P2AAIT7                                                   
     C                   EVAL      M0DLGA=P2ADLGA                                                   
     C                   EVAL      M0PAIS=P2APAIS                                                   
     C                   EVAL      M0ZOPA=P2AZOPA                                                   
     C                   EVAL      M0SUPA=P2ASUPA                                                   
     C                   EVAL      M0ZONC=P2AZONC                                                   
     C                   EVAL      M0SUPC=P2ASUPC                                                   
     C                   EVAL      M0DIRE=P2ADIRE                                                   
     C                   EVAL      M0DIR1=P2ADIR1                                                   
     C                   EVAL      M0DIR2=P2ADIR2                                                   
     C                   EVAL      M0POST=P2APOST                                                   
     C                   EVAL      M0PEGE=P2APEGE                                                   
     C                   EVAL      M0TLEX=P2ATLEX                                                   
     C                   EVAL      M0TFAX=P2ATFAX                                                   
     C                   EVAL      M0TELE=P2ATELE                                                   
     C                   EVAL      M0EMAI=P2AEMAI                                                   
     C                   EVAL      M0TEL2=P2ATEL2                                                   
     C                   EVAL      M0TAL1=P2ATAL1                                                   
26117C                   EVAL      ZXTAL1=P2ATAL1                                                   
     C                   EVAL      M0TAL2=P2ATAL2                                                   
     C                   EVAL      M0TAL3=P2ATAL3                                                   
     C                   EVAL      M0PRVR=P2APRVR                                                   
     C                   EVAL      M0TDIR=P2ATDIR                                                   
     C                   EVAL      M0LOGE=P2ALOGE                                                   
     C                   EVAL      M0LOGS=P2ALOGS                                                   
     C                   EVAL      M0PRSV=P2APRSV                                                   
     C                   EVAL      M0PRES=P2APRES                                                   
30119C                   EVAL      M0LOGI=P2ALOGI                                                   
C1631C                   EVAL      M0EANA=P2AEANA                                                   
      *                                                                                             
     C                   EVAL      M0DAT8=ZZDATS                                                    
     C                   IF        M0DAT8=0                                                         
     C                   EVAL      M0DAT8=*DATE                                                     
     C                   ENDIF                                                                      
     C                   TIME                    M0HORA                                             
     C                   EVAL      M0USUA=ZZUSUA                                                    
     C                   EVAL      M0PANT=SDSJOB                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA CONTROL DEL FMT P2B                              *                                
      *------------------------------------------------------------*                                
     C     P2BMAIN       BEGSR                                                                      
     C                   EVAL      ZXOPT1='P2B'                                                     
     C                   DOW       ZXOPT1='P2B'                                                     
     C     ZXOPT2        CASEQ     'CLR'         P2BCLR                                             
     C     ZXOPT2        CASEQ     'INZ'         P2BINZ                                             
     C     ZXOPT2        CASEQ     'DSP'         P2BDSP                                             
     C     ZXOPT2        CASEQ     'CMD'         P2BCMD                                             
     C     ZXOPT2        CASEQ     'CHK'         P2BCHK                                             
     C     ZXOPT2        CASEQ     'UPD'         P2BUPD                                             
     C                   ENDCS                                                                      
     C                   ENDDO                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA LIMPIEZA  DE P2B                                 *                                
      *------------------------------------------------------------*                                
     C     P2BCLR        BEGSR                                                                      
     C                   EVAL      ZXOPT2='INZ'                                                     
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO10      *IN(60)                                            
     C                   MOVE      *BLANKS       MSGER                                              
     C                   EVAL      CSRFILA=0                                                        
     C                   EVAL      CSRCOLU=0                                                        
     C     P2BCLRT       ENDSR                                                                      
      *                                                                                             
      **************************************************************                                
      * SUBRUTINA INICIALITZACIÓ DEL FMT P2B                       *                                
      *------------------------------------------------------------*                                
     C     P2BINZ        BEGSR                                                                      
      *                                                                                             
     C                   EVAL      ZXOPT2='DSP'                                                     
     C     *NOKEY        CLEAR     *ALL          RMSALMA                                            
     C                   IF        INDCPY=*ON                                                       
     C                   EVAL      M0MAGA=P30MAGA                                                   
     C                   ENDIF                                                                      
     C     KMSALMA       CHAIN     MSALMA                             81                            
     C                   EXSR      P2BMFP                                                           
21048 * Si la empresa tiene activado el parámetro de recalculo inv.per.                             
21048 * y opci=modif. protegemos el campo de inv. permanente                                        
21048C                   IF        @POPCI='2 ' OR @POPCI=' 2'                                       
21048C     KPMEMC        CHAIN     PMEMPR                             81                            
21048C                   IF        P7RAIP>='1' AND CHAIN=*OFF                                       
21048C                   EVAL      WRK64=*ON                                                        
21048C                   ENDIF                                                                      
21048C                   ENDIF                                                                      
      * En el caso de altas se pasan los valores por defecto de PURLDA                              
     C                   IF        INDCRT=*ON                                                       
     C****               EVAL      P2BPUBI='1'                                                      
     C                   EVAL      P2BPUBI=ZZPUBI                                                   
     C                   EVAL      P2BTGST=ZZTGST                                                   
     C                   EVAL      P2BCCO1=ZZCCO1                                                   
     C                   EVAL      P2BCCR1='1'                                                      
     C                   EVAL      P2BNSK1=*BLANKS                                                  
     C                   IF        @PMAGA=ZZMAGA                                                    
     C                   EVAL      P2BAPPL='1'                                                      
     C                   ENDIF                                                                      
     C                   EVAL      P2BAIVT='1'                                                      
     C                   EVAL      P2BASDI='1'                                                      
     C                   EVAL      P2BUBI0=ZZUBI0                                                   
     C                   EVAL      P2BUBIA=ZZUBIA                                                   
     C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PASAR DE FICHERO A PANTALLA P2B                  *                                
      *------------------------------------------------------------*                                
     C     P2BMFP        BEGSR                                                                      
      *                                                                                             
     C                   EVAL      P2BMAGA=M0MAGA                                                   
     C                   EVAL      P2BDES1=M0DES1                                                   
     C                   EVAL      P2BPUBI=M0PUBI                                                   
     C                   EVAL      ZXPUBI=M0PUBI                                                    
     C                   EVAL      P2BNSK1=M0NSK1                                                   
     C                   EVAL      P2BTGST=M0TGST                                                   
     C                   EVAL      P2BTA01=M0TA01                                                   
     C                   EVAL      P2BCCO1=M0CCO1                                                   
     C                   EVAL      P2BAPPL=M0APPL                                                   
     C                   EVAL      P2BCCR1=M0CCR1                                                   
     C                   EVAL      P2BUBI0=M0UBI0                                                   
     C                   EVAL      P2BUBIA=M0UBIA                                                   
     C                   EVAL      P2BPRIE=M0PRIE                                                   
     C                   EVAL      P2BPRIS=M0PRIS                                                   
     C                   EVAL      P2BAIVT=M0AIVT                                                   
     C                   EVAL      P2BIPER=M0IPER                                                   
     C                   EVAL      P2BPPSC=M0PPSC                                                   
     C                   EVAL      P2BASDI=M0ASDI                                                   
     C                   EVAL      P2BCRO2=M0CRO2                                                   
E5659*                                                                                             
E5659C                   IF        INDCRT=*ON OR INDCPY=*ON                                         
E5659C                   EVAL      P2BCRO2='1'                                                      
E5659C                   ENDIF                                                                      
E5659*                                                                                             
     C                   EVAL      P2BZUBE=M0ZUBE                                                   
     C                   EVAL      P2BZUBS=M0ZUBS                                                   
     C                   EVAL      P2BZUBD=M0ZUBD                                                   
     C                   EVAL      ZXTDIR=M0TDIR                                                    
     C                   EVAL      P2BUBIB=M0UBIB                                                   
     C                   EVAL      P2BTFLU=M0TFLU                                                   
     C                   EVAL      P2BTFL2=M0TFL2                                                   
     C                   EVAL      ZXUBIC=M0UBIT                                                    
     C                   EVAL      P2BFILT=ZXFILA1                                                  
     C                   EVAL      P2BCOLT=ZXCOLU1                                                  
     C                   EVAL      P2BNIVT=ZXNIVE1                                                  
26117C                   EVAL      P2BUTTR=M0UTTR                                                   
26117C                   EVAL      P2BMATR=M0MATR                                                   
     C                   EVAL      P2BNPPC=M0NPPC                                                   
FQ876c                   Eval      p2bZPrd=m0ZPrd                                                   
FQ876c                   Eval      p2bASGA = m0ASGA                                                 
FQ876c                   Eval      P2BFTPV=M0FTPV                                                   
C2294c                   Eval      P2BTPDF=M0TPDF                                                   
C2294C                   EVAL      N1TTTA=P2BTPDF                                                   
C2294C     KMSTRTA       CHAIN     MSTRTA                             81                            
C2294C                   IF        %FOUND(MSTRTA)                                                   
C2294C                   MOVEL     N1DES1        P2BDTTA                                            
C2294C                   ENDIF                                                                      
FQ876C                   EVAL      P2BMN35=M0MN35                                                   
                                                                                                    
      * PARA EL CASO DE COPIAS CAMBIAREMOS LA CABECERA                                              
     C                   IF        INDCPY=*ON                                                       
     C                   EVAL      ZXTDIR=*BLANKS                                                   
     C                   EVAL      P2BMAGA=P3CMAGA                                                  
     C     *NOKEY        CLEAR     *ALL          RMSALMA                                            
     C                   ENDIF                                                                      
      * PARA EL CASO DE COPIAS CAMBIAREMOS LA CABECERA Y CODIGO ALTERNATIVO                         
     C                   IF        INDCPY=*ON                                                       
     C                   EVAL      P2BMAGA=P3CMAGA                                                  
     C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VISUALITZACIÓ DEL FMT P2B                        *                                
      *------------------------------------------------------------*                                
     C     P2BDSP        BEGSR                                                                      
      * ENS ENCARREGUEM QUE EL PROPER PAS SIGUI COMPROVAR ENTRADA CMD                               
     C                   EVAL      ZXOPT2='CMD'                                                     
     C                   EVAL      PPPCMD1='CMD7801'                                                
     C                   EXFMT     P2B                                                              
     C                   MOVEA     ZXZERO10      *IN(30)                                            
     C                   MOVEA     ZXZERO10      *IN(40)                                            
     C                   MOVEA     ZXZERO10      *IN(50)                                            
     C                   MOVEA     ZXZERO10      *IN(60)                                            
     C                   EVAL      ERRGRL=*OFF                                                      
     C                   EVAL      MSGER=*BLANKS                                                    
     C                   EVAL      CSRFILA=*ZEROS                                                   
     C                   EVAL      CSRCOLU=*ZEROS                                                   
     C     P2BDSPT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CMDS DEL FMT P2B                 *                                 
      *------------------------------------------------------------*                                
     C     P2BCMD        BEGSR                                                                      
     C                   EVAL      ZXOPT2='CHK'                                                     
      *VALIDACIONES TECLAS DE FUNCION                                                               
     C                   SELECT                                                                     
      * FINALITZAR EL PROGRAMA                                                                      
     C                   WHEN      EXIT=*ON                                                         
     C                   EVAL      ZXOPT1='END'                                                     
      * SOL·LICITUD AJUDA D'ARTICLES                                                                
     C                   WHEN      HELP=*ON                                                         
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   EXSR      CS_POCUR2                                                        
     C                   EXSR      P2BF4                                                            
      * RETROCESO PANTALLA                                                                          
     C                   WHEN      RETRO=*ON                                                        
     C                   EVAL      Z_P=Z_P-1                                                        
     C                   IF        Z_P<=0                                                           
     C                   EVAL      ZXOPT='END'                                                      
     C                   ELSE                                                                       
     C                   EVAL      ZXOPT1='P2 '                                                     
     C                   MOVE      SSSECPA(Z_P)  ZXOPT1                                             
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
     C                   ENDSL                                                                      
                                                                                                    
     C     TP2BCMD       TAG                                                                        
     C                   IF        ERRGRL=*ON                                                       
     C                   EVAL      ZXOPT2='DSP'                                                     
     C                   ENDIF                                                                      
                                                                                                    
     C     P2BCMDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA DE AYUDA EN CAMPOS DEL   FMT P2B                 *                                
      *------------------------------------------------------------*                                
     C     P2BF4         BEGSR                                                                      
     C* No se permite acceso a consulta si estamos en opcion de visualizar                          
     C                   IF        INDDSP=*ON                                                       
