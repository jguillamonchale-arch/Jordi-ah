     C     P2AF4T        ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA VALIDACIÓ DELS CAMPS DEL FMT P2A                 *                                
      *------------------------------------------------------------*                                
     C     P2ACHK        BEGSR                                                                      
     C                   EVAL      ZXOPT2='UPD'                                                     
      * La descripcion no puede ser blancos                                                         
     C                   IF        P2ADES1=*BLANKS                                                  
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   EVAL      WRK30=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
      * La direccion  no puede ser blancos                                                          
                                                                                                    
     C                   IF        P2ADIRE=*BLANKS                                                  
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   EVAL      WRK31=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
      * el pais debe existir en el fichero de paises                                                
     C                   EVAL      MECIAS=@PCIAS                                                    
     C                   EVAL      MEPAIS=P2APAIS                                                   
     C     KMSPAIS       CHAIN     MSPAIS                             81                            
     C                   IF        CHAIN=*ON OR MEBAJA>'0'                                          
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   EVAL      WRK35=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
      * La poblacion  no puede ser blancos Y SI LO ES, EL CODIGO POSTAL                             
      * NO PUEDE SER BLANCOS                                                                        
     C                   IF        P2ADIR2=*BLANKS AND P2APOST=*BLANKS                              
     C                   EVAL      ERRGRL=*ON                                                       
     C                   EVAL      MSGER='ASG1003'                                                  
     C                   EVAL      WRK33=*ON                                                        
     C                   ENDIF                                                                      
     C     ERRGRL        CABEQ     *ON           TP2ACHK                                            
MOVEX * Validacion de tipo de AUXILIAR                                                              
MOVEXC*                  IF        P2AAUXC<>*BLANKS                                                 
MOVEXC*                  IF        ZZCTBP=' '                                                       
MOVEXC*                                                                                             
MOVEXC*                  MOVE      @PCIAS        EMPRESA                                            
MOVEXC*                  EVAL      AUXTIP='01'                                                      
MOVEXC*                  EVAL      AUXCOD=P2AAUXC                                                   
MOVEXC*    KAXCODIGO     CHAIN     AXCODIGO                           81                            
MOVEXC*                  IF        CHAIN=*ON                                                        
MOVEXC*                  EVAL      ERRGRL=*ON                                                       
MOVEXC*                  EVAL      MSGER='MMM0232'                                                  
MOVEXC*                  EVAL      WRK66=*ON                                                        
MOVEXC*                  ENDIF                                                                      
MOVEXC*    ERRGRL        CABEQ     *ON           TP2ACHK                                            
MOVEXC*                  ENDIF                                                                      
MOVEXC*                                                                                             
MOVEXC*                  ENDIF                                                                      
MOVEX *                                                                                             
MOVEX * Validar las 6 Dimensiones (1º con DIVI y luego general)                                     
MOVEX * No son Obligatorias                                                                         
MOVEX *                                                                                             
MOVEXC                   IF        P2AAIT2<>*BLANKS                                                 
MOVEXC                   MOVEL     MXCONO        EACONO                                             
MOVEXC                   MOVEL     MXDIVI        EADIVI                                             
MOVEXC                   MOVE      2             EAAITP                                             
MOVEXC                   MOVEL     P2AAIT2       EAAITM                                             
MOVEXC     KFCHACC00     CHAIN     FCHACC00                                                         
MOVEXC                   IF        NOT %FOUND(FCHACC00)                                             
MOVEXC                   MOVEL     *BLANKS       EADIVI                                             
MOVEXC     KFCHACC00     CHAIN     FCHACC00                                                         
MOVEXC                   IF        NOT %FOUND(FCHACC00)                                             
MOVEXC                   EVAL      ERRGRL=*ON                                                       
MOVEXC                   EVAL      MSGER='ERR3030'                                                  
MOVEXC                   EVAL      WRK62=*ON                                                        
MOVEXC                   ENDIF                                                                      
MOVEXC                   ENDIF                                                                      
MOVEXC     ERRGRL        CABEQ     *ON           TP2ACHK                                            
MOVEXC                   ENDIF                                                                      
