      **************************************************************                                
      * SUBRUTINA DE ACTUALIZACION DEL FMT P2B                     *                                
      *------------------------------------------------------------*                                
     C     P2BUPD        BEGSR                                                                      
     C                   EVAL      Z_P=Z_P+1                                                        
     C                   IF        SSSECPA(Z_P)=*BLANKS                                             
     C                   EVAL      ZXOPT='END'                                                      
     C                   IF        INDCRT=*ON  AND @POPCI<>'1B'                                     
     C                   EVAL      ZXOPT='P10CLR'                                                   
     C                   ENDIF                                                                      
     C                   ELSE                                                                       
     C                   EVAL      ZXOPT1='P2 '                                                     
     C                   MOVE      SSSECPA(Z_P)  ZXOPT1                                             
     C                   EVAL      ZXOPT2='CLR'                                                     
     C                   ENDIF                                                                      
                                                                                                    
      * En el caso de la opción de visualiza no actualizo                                           
     C                   IF        INDDSP=*ON                                                       
     C                   GOTO      P2BUPDT                                                          
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      M0CIAS=@PCIAS                                                    
     C                   EVAL      M0MAGA=P2BMAGA                                                   
     C     KMSALMA       CHAIN     MSALMA                             81                            
                                                                                                    
     C                   IF        INDCRT=*ON OR INDCPY=*ON                                         
     C                   EXSR      P2AMPF                                                           
     C                   ENDIF                                                                      
     C                   EXSR      P2BMPF                                                           
                                                                                                    
     C                   IF        CHAIN=*OFF                                                       
     C                   UPDATE    RMSALMA                                                          
     C                   ELSE                                                                       
     C                   EVAL      M0DAT1=M0DAT8                                                    
     C                   WRITE     RMSALMA                                                          
      * Creo automáticamente la logística si no existía.                                            
     C                   EVAL      @PETLGC=*BLANKS                                                  
     C                   IF        M0LOGE<>M0LOGS                                                   
     C                   EVAL      @PETLGC='1'                                                      
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      @PECIAS=@PCIAS                                                   
     C                   CALL      'MM2610'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM      P2ADLGA       @PEDLGA                                            
     C                   PARM      M0LOGE        @PELGCA                                            
     C                   PARM      M0MAGA        @PEMAGA                                            
     C                   PARM                    @PETLGC                                            
     C                   PARM      *BLANKS       @PEERR                                             
                                                                                                    
     C                   IF        M0LOGE=M0LOGS                                                    
     C                   EVAL      @PETLGC='2'                                                      
     C                   CALL      'MM2610'                                                         
     C                   PARM                    @PECIAS                                            
     C                   PARM      P2ADLGA       @PEDLGA                                            
     C                   PARM      M0LOGS        @PELGCA                                            
     C                   PARM      M0MAGA        @PEMAGA                                            
     C                   PARM                    @PETLGC                                            
     C                   PARM      *BLANKS       @PEERR                                             
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
