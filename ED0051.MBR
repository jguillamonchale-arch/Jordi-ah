b01  C                   IF        EOF=*ON                                                          
s02  C                   SELECT                                                                     
14060 * En el caso de validar la preparación, debe existir el EDTRLP                                
14060 * En caso contrario, No preparamos.                                                           
FQ710C                   WHEN      @PEDAU = '303' And @PINTE = 1                                    
14060C                   EVAL      @PERRO = '1'                                                     
14060C                   EVAL      ZXWIND = '1'                                                     
14060C                   EVAL      ZXINCI = '004'                                                   
14060C                   EXSR      CS_DESERR                                                        
14060 * Validación Altas. (Aún no existe EDTRLP)                                                    
     C                   WHEN      @PEDAU = '001' Or @PEDAU = '010'                                 
     C                             Or @PEDAU = '002'                                                
     C                   EVAL      ZXWIND = '1'                                                     
     C                   EXSR      CS_ARTICUL                                                       
R3820C*                  EXSR      CS_CONTPED_2                                                     
R3820C                   EXSR      CS_CONTPED_3                                                     
FQ942 * Validación Altas. (Aún no existe EDTRLP ni codepe                                           
FQ942C                   WHEN      @PEDAU = '404'                                                   
FQ942C                   EVAL      ZXWIND = '0'                                                     
C1579C                   exsr      CS_POOLWEB                                                       
C1579 * Si es PoolWeb no permitimos altas                                                           
C1579C                   if        zxpweb='1'                                                       
C1579C                   eval      zxinci = '022'                                                   
C1579C                   EVAL      @PERRO = '1'                                                     
C1579C                   EVAL      ZXWIND = '1'                                                     
C1579C                   eval      T0ARVM = @PARV1                                                  
C1579C                   exsr      CS_DESERR                                                        
C1579C                   else                                                                       
FQ942C                   EXSR      CS_ARTIC404                                                      
C1579C                   ENDIF                                                                      
14060 * Validación Algoritmo de decisión. (Aún no existe EDTRLP)                                    
     C                   WHEN      @PEDAU = '403'                                                   
C1579C                   exsr      CS_POOLWEB                                                       
E7146 *     C                   EVAL      ZXWIND = '0'                                              
E7146c                   eval      zxwind = '1'                                                     
     C                   EXSR      CS_ARTICUL                                                       
14060 * Para otros casos miramos si existe en EDTRLX, por si han                                    
14060 * eliminado la linea                                                                          
     C                   OTHER                                                                      
     C                   EXSR      CS_READFIX                                                       
b03  C                   IF        EOF=*OFF                                                         
     C                   EVAL      ZXDEL = '1'                                                      
e03  C                   ENDIF                                                                      
e02  C                   ENDSL                                                                      
e01  C                   ENDIF                                                                      
                                                                                                    
      * Validaciones anteriores a la existéncia de Fichero EDTRLP                                   
b01  C                   IF        EOF=*ON                                                          
b02  C                   IF        @PEDAU = '400' And ZXDEL = '0'                                   
14060C                   EVAL      @PERRO = '1'                                                     
14060C                   EVAL      ZXINCI = '004'                                                   
     C                   EVAL      ZXWIND = '0'                                                     
     C                   EXSR      CS_DESERR                                                        
e02  C                   ENDIF                                                                      
e01  C                   ENDIF                                                                      
                                                                                                    
      * Si ya está eliminado en EDTRLX no valido eventos                                            
b01  C                   IF        ZXDEL = '1'                                                      
14060 * En caso de Confirmar la Preparación, si han eliminado                                       
14060 * EDTRLP, no dejo Confirmar.                                                                  
14060C                   IF        @PEDAU = '305'                                                   
