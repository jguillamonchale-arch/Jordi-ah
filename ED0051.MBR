FQ787C                   WHEN      @PEDAU = '008'                                                   
FQ787C                   EVAL      ZXWIND = '1'                                                     
FQ787C                   EXSR      CS_SERVPRO                                                       
FQ787C                   EXSR      CS_STSPR10                                                       
01070 *  OE Finalizar Ped vtas                                                                      
01070C                   WHEN      @PEDAU = '018'                                                   
