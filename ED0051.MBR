      **********************************************************************                        
      * Validación Artículo Proveedor para Altas desde Comercial                                    
      **********************************************************************                        
     C     CS_ARTICUL    BEGSR                                                                      
                                                                                                    
     C                   EVAL      S5CIAS=@PCIAS                                                    
     C                   EVAL      S5DLGA=@PDLGA                                                    
     C                   EVAL      S5NPCO=@PNPCO                                                    
     C                   EVAL      S5TPED=@PTPED                                                    
     C                   EVAL      S5DATP=@PDATP                                                    
     C                   EVAL      S5NOPL=@PNOPL                                                    
     C                   EVAL      S5LINE=@PLINE                                                    
                                                                                                    
s01  C                   SELECT                                                                     
     C                   WHEN      @PINTE = 1                                                       
     C     KCODEPE       SETLL     CODEPE                                                           
     C     KCODEPE       READE     CODEPE                                                           
     C                   WHEN      @PINTE = 2                                                       
     C     KCODEPE0      SETLL     CODEPE                                                           
     C     KCODEPE0      READE     CODEPE                                                           
s01  C                   ENDSL                                                                      
                                                                                                    
d01  C                   DOW       NOT %EOF(CODEPE)                                                 
C1579C                   if        zxpweb='1'                                                       
C1579C                   EVAL      M5CIAS=S5CIAS                                                    
C1579C                   EVAL      M5ARTI = S5ARTI                                                  
C1579C                   EVAL      M5VARI = S5VARI                                                  
C1579C                   EVAL      M5MODE = S5MODE                                                  
C1579C     KMSARTI00     CHAIN     MSARTI00                                                         
C1579C                   EVAL      C0CIAS=S5CIAS                                                    
C1579C                   EVAL      C0PRVR=zxprvr                                                    
C1579C     KPUPROV       CHAIN     PUPROV                                                           
C1579C                   EXSR      CS_PU2600                                                        
C1579C                   ELSE                                                                       
     C                   EXSR      CS_ARTICU2                                                       
C1579C                   ENDIF                                                                      
                                                                                                    
s02  C                   SELECT                                                                     
     C                   WHEN      @PINTE = 1                                                       
     C     KCODEPE       READE     CODEPE                                                           
     C                   WHEN      @PINTE = 2                                                       
     C     KCODEPE0      READE     CODEPE                                                           
e02  C                   ENDSL                                                                      
                                                                                                    
e01  C                   ENDDO                                                                      
                                                                                                    
     C                   ENDSR                                                                      
FQ942                                                                                               
FQ942 **********************************************************************                        
FQ942 * Validación Artículo Proveedor para Altas desde Comercial                                    
FQ942 * SIN HABER INTRODUCIDO TB LA LÍNEA DE PEDIDO                                                 
FQ942 **********************************************************************                        
FQ942C     CS_ARTIC404   BEGSR                                                                      
FQ942C                   EVAL      S5CIAS=@PCIAS                                                    
FQ942C                   EVAL      S5ARTI=%SUBST(@PARV1:1:15)                                       
FQ942C                   EVAL      S5VARI=%SUBST(@PARV1:16:3)                                       
FQ942C                   EVAL      S5MODE=%SUBST(@PARV1:19:3)                                       
FQ942C                   EVAL      S5CANT=1                                                         
FQ942C                   EXSR      CS_ARTICU2                                                       
FQ942C                   ENDSR                                                                      
      **********************************************************************                        
      * Validación Artículo Proveedor para Altas desde Comercial                                    
      **********************************************************************                        
     C     CS_ARTICU2    BEGSR                                                                      
                                                                                                    
OL205C                   EVAL      M5CIAS=S5CIAS                                                    
OL205C                   EVAL      M5ARTI = S5ARTI                                                  
OL205C                   EVAL      M5VARI = S5VARI                                                  
OL205C                   EVAL      M5MODE = S5MODE                                                  
OL205C     KMSARTI00     CHAIN     MSARTI00                                                         
     C                   EVAL      ZXCANT=S5CANT-S5CANS-S5CANR                                      
b01  C                   IF        ZXCANT<=0                                                        
     C                   EVAL      ZXCANT=0                                                         
e01  C                   ENDIF                                                                      
F-2OL *___________________(MSSTOK.M1PRVR), ___________________________                              
OL205 *F-2OLC                   exsr      SRrecu                                                    
OL205                    zxprvr_dom = SRrecu(s5arti:s5vari:s5mode);                                 
F-2OLc                   if        ZXPRVR_DOM = *blanks                                             
OL205C* Si no es artículo propio                                                                    
OL205C*                  EVAL      M5CIAS=S5CIAS                                                    
OL205C*                  EVAL      M5ARTI = S5ARTI                                                  
OL205C*                  EVAL      M5VARI = S5VARI                                                  
OL205C*                  EVAL      M5MODE = S5MODE                                                  
OL205C*    KMSARTI00     CHAIN     MSARTI00                                                         
C1078C                   EVAL      ZXPRVR_DOM=M5PRVR                                                
F-2OLC                   ENDIF                                                                      
Q4132c                   eval      zxexcepcion =  1                                                 
