E7218C                             and KitAsigPrv=*on                                               
C5958C*                            and KitAsigPrv=*on                                               
      * Si es Conjunto de Ventas y de Compra No lo trataremos como Cjto                             
In178C**                 EVAL      ZXTCOJ=' '                                                       
In178C                   EVAL      ZXTCOJ='1'                                                       
x03  C                   ELSE                                                                       
      * Si es Conjunto de Ventas y No de Compra Si lo tratamos                                      
     C                   EVAL      ZXTCOJ='4'                                                       
e03  C                   ENDIF                                                                      
x02  C                   ELSE                                                                       
      * Si No es Conjunto de Venta , Pues no es Conjunto y punto                                    
     C                   EVAL      ZXTCOJ=' '                                                       
e02  C                   ENDIF                                                                      
FQ942C                   CLOSE(E)  MSCOJC                                                           
      * Es Conjunto                                                                                 
b02  C                   IF        ZXTCOJ='4'                                                       
FQ942 * miramos si a nivel de proveedor existe el cjto                                              
FQ942C                   EXSR      CS_UTCOM0                                                        
FQ94XC*                  IF        @PERRO = *BLANKS                                                 
FQ94XC*                  EXSR      CS_ARTEXIS                                                       
FQ94XC*                  ENDIF                                                                      
FQ942C                   IF        @PERRO = '1'                                                     
FQ942C                             AND ZXINCI='050'                                                 
