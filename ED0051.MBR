C1579c                   if        @pedau='005' or @pedau='006' or                                  
C1579c                             @pedau='007' or @pedau='012' or                                  
C1579c                             @pedau='018' or @pedau='019'                                     
C1589c                   exsr      CS_POOLWEB                                                       
