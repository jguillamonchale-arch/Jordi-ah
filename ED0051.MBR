CR653C                   EVAL      ZXPVEX=' '                                                       
CR653C                   EVAL      C0CIAS=S5CIAS                                                    
C1078C                   EVAL      C0PRVR=ZXPRVR_DOM                                                
C1078C*                  EVAL      C0PRVR=M5PRVR                                                    
CR653C     KPUPROV       CHAIN     PUPROV                                                           
CR653C                   IF        %FOUND(PUPROV) AND C0PEVT='2'                                    
