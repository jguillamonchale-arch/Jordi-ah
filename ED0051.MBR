FQ604C                   WHEN      @PEDAU = '026'                                                   
FQ604C                   EVAL      ZXWIND = '1'                                                     
FQ604C*06051             EXSR      CS_STSPR10                                                       
FQ604C*06051             EXSR      CS_SERVPRO                                                       
FQ710 * Forzar Preparación aunque no llegue al mínimo por Expedición                                
FQ710C                   WHEN      @PEDAU = '029' Or @PEDAU = '030'                                 
FQ710C                   EVAL      ZXWIND = '1'                                                     
FQ710C                   EXSR      CS_COMEDST                                                       
      * Validaciones de desreserva en la productiva                                                 
     C                   WHEN      @PEDAU = '221'                                                   
     C                   EVAL      ZXWIND = '1'                                                     
     C                   EXSR      CS_STSPR10                                                       
     C                   EXSR      CS_STSPR20                                                       
      * Validaciones de cambio permitido logística en la productiva                                 
     C                   WHEN      @PEDAU = '222'                                                   
     C                   EVAL      ZXWIND = '0'                                                     
     C                   EXSR      CS_CHGLOG                                                        
     C                   EXSR      CS_STSPR10                                                       
     C                   EXSR      CS_STSPR20                                                       
C1350 *Validaciones de error de bloqueo de albaranes                                                
C1350C                   WHEN      @PEDAU = '231'                                                   
C1350C                   EVAL      ZXWIND = '1'                                                     
C1350C                   EXSR      CS_PEDHOLD                                                       
C1350C                   EXSR      CS_RISKCLI                                                       
C1350 *                                                                                             
FQ710 * Validaciones cuando Trace prepara a nivel de linea                                          
FQ710C                   WHEN      @PEDAU = '303' And @PINTE = 1                                    
     C                   EVAL      ZXWIND = '0'                                                     
FQ710C                   EXSR      CS_FORPREP                                                       
FQ710C                   IF        @PERRO = '1'                                                     
FQ710C                   LEAVE                                                                      
FQ710C                   ENDIF                                                                      
14060C                   EXSR      CS_LINCERR                                                       
     C                   EXSR      CS_MODCURS                                                       
     C                   EXSR      CS_PEDHOLD                                                       
     C                   EXSR      CS_RISKCLI                                                       
     C                   EXSR      CS_VALCONJ2                                                      
FQ710C                   EXSR      CS_COENVIO                                                       
