e02  C                   ENDIF                                                                      
e01  C                   ENDDO                                                                      
FQ710C     TFINREAD      TAG                                                                        
                                                                                                    
      * Caso auditoría 222                                                                          
b01  C                   IF        @PEDAU='222'                                                     
      * Si no hay ninguna línea que permita logística productiva error                              
b02  C                   IF        ZXNDDP=0                                                         
     C                   EVAL      @PERRO = '1'                                                     
     C                   EVAL      ZXINCI = '012'                                                   
     C                   EXSR      CS_DESERR                                                        
e02  C                   ENDIF                                                                      
e01  C                   ENDIF                                                                      
FQ710                                                                                               
FQ710 * Caso validación preparación para cliente-dirección final                                    
FQ710C                   IF        @PEDAU = '303' And @PINTE = 3                                    
FQ710C                             Or @PEDAU = '305' And @PINTE = 3                                 
C2510C                   EVAL      T4CIAS=T0CIAS                                                    
C2510C                   EVAL      T4CUST=T0CUST                                                    
C2510C     KEDPARC       CHAIN     EDPARC                                                           
C2510C                   IF        %FOUND(EDPARC)                                                   
C2510C**                 IF        T4LIME>0                                                         
C2510C                   EVAL      T3LIME=T4LIME                                                    
C2510C**                 ENDIF                                                                      
C2510C**                 IF        T4DIBE>0                                                         
C2510C                   EVAL      T3DIBE=T4DIBE                                                    
C2510C**                 ENDIF                                                                      
C2510C                   ENDIF                                                                      
FQ710 * añado dias de margen a la reserva mas antigua                                               
FQ710C                   MOVEL     ZXFURE        ZXFURED                                            
FQ710C     ZXFURED       ADDDUR    T3DIBE:*D     ZXFURED                                            
FQ710C                   MOVE      ZXFURED       ZXFURE                                             
FQ710 * si la reserva mas antigua + dias de margen supera la fecha de                               
FQ710 *    hoy y el importe a preparar no llega al límite parametrizado                             
FQ710 *    No dejo preparar.                                                                        
FQ710C                   IF        ZXIMPEXP < T3LIME                                                
FQ710C                             And ZXFURE > *DATE                                               
FQ710C                   EVAL      @PERRO = '1'                                                     
FQ710C                   EVAL      ZXINCI = '016'                                                   
FQ710C                   EXSR      CS_DESERR                                                        
FQ710C                   ENDIF                                                                      
FQ710C                   ENDIF                                                                      
