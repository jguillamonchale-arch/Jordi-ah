C6665C*F-2OL             ENDIF                                                                      
Q4132c                   eval      zxexcepcion =  1                                                 
Q4132c                   exsr      cs_eiexce                                                        
C1078C                   IF        ZXPRVR_7<>*BLANKS                                                
C1078C                   EVAL      ZXPRVR_DOM=ZXPRVR_7                                              
C1078C                   ENDIF                                                                      
     C                   EVAL      ZXUNIM=NDUNIM                                                    
