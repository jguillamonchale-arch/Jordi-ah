     C                   OPEN (E)  CMNDIV00                                                         
     C                   OPEN (E)  ZAQBAL00                                                         
25052C                   OPEN (E)  MITBAL00                                                         
     C                   OPEN (E)  AQPEDI00                                                         
01022C                   OPEN (E)  MITFAC00                                                         
I0184C                   OPEN (E)  ZAQITN00                                                         
I0184C                   OPEN (E)  GMTABD01                                                         
b03  C                   IF        Not %ERROR                                                       
     C                   MOVEL     MXCONO        Z1CONO                                             
