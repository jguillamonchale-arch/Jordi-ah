10O12C                   EVAL      @PINCI = *BLANKS                                                 
FQ942C                   ENDIF                                                                      
FQ942C                   EVAL      ZXES_COMPO='1'                                                   
FQ942                                                                                               
31053C                   EVAL      ZXCANT_CJTO=ZXCANT                                               
     C                   EVAL      NDTCOJ = ZXTCOJ                                                  
