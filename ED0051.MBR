76211C                   IF        Not %ERROR                                                       
79419 *                                                                                             
79419 * Miramos nivel de red de la empresa (Si trabaja con FAB/OL)                                  
79419 *                                                                                             
79419c                   eval      zxFABOL = *off                                                   
79419c                   If        %subst(ppampl:46:1) = '1'                                        
79419c                   eval      zxFABOL = *on                                                    
79419c                   endif                                                                      
79419 *                                                                                             
79419 * Buscamos el almacén de Trace y la delegación del almacén de Trace                           
79419 *                                                                                             
79419c                   eval      zxMagaTr = *blanks                                               
79419c                   eval      zxDlgaTr = *blanks                                               
79419 *                                                                                             
79419c                   Eval      M0CIAS = %int(ppcias)                                            
79419c                   Eval      M0TAL1 = '8'                                                     
79419c     KMsalma08     Chain     Msalma08                                                         
79419c                   if        %found(Msalma08)                                                 
79419c                   movel(p)  m0maga        zxMagaTr                                           
79419c                   movel(p)  m0dlga        zxDlgaTr                                           
79419c                   if        m0dlga =  *blanks and                                            
79419c                             m0m003 <> *blanks                                                
79419c                   movel(p)  m0m003        zxDlgaTr                                           
79419c                   endif                                                                      
79419c                   endif                                                                      
79419 *                                                                                             
79419 * Buscamos clasificación artículo:                                                            
79419c                   eval      zxclas = *blanks                                                 
79419 *                                                                                             
79419c                   If        %subst(ppampl:6:1) = '1'                                         
79419 *===  Por Propuesta de compra                                                                 
79419c                   Eval      M1CIAS = %int(ppcias)                                            
79419c                   Eval      M1MAGA = zxMagaTr                                                
79419c                   Eval      M1ARTI = ZXARTIX                                                 
79419c                   Eval      M1VARI = ZXVARIX                                                 
79419c                   Eval      M1MODE = ZXMODEX                                                 
79419c     KMsstok       Chain     Msstok                                                           
79419c                   if        %found(Msstok)                                                   
79419c                   eval      ZXCLAS = M1CROT                                                  
79419c                   endif                                                                      
79419 *                                                                                             
79419c                   else                                                                       
79419 *===  Por MRP                                                                                 
76211C                   EVAL      m6cias = %int(ppcias)                                            
79419C*76211             EVAL      m6dlga = 'TRACE'                                                 
76211C                   EVAL      m6arti = ZXARTIX                                                 
76211C                   EVAL      m6vari = ZXVARIX                                                 
76211C                   EVAL      m6mode = ZXMODEX                                                 
79419c                   if        zxFABOL = *on                                                    
79419c                   Eval      M6DLGA = *blanks                                                 
79419c                   Eval      M6NETL = 2                                                       
79419c                   Else                                                                       
79419c                   Eval      M6DLGA = zxDlgaTr                                                
79419c                   Eval      M6NETL = 1                                                       
79419c                   endif                                                                      
76211C     KMSSTST       CHAIN     MSSTST                                                           
79419c                   if        %found(MSSTST) And m6omit <> '1'                                 
79419c                   eval      ZXCLAS = M6CLAS                                                  
79419C                   endif                                                                      
76211C                   ENDIF                                                                      
76211C*                                                                                             
79419C                   endif                                                                      
79419C*                                                                                             
     C                   OPEN (E)  MSARTI                                                           
b04  C                   IF        Not %ERROR                                                       
     C                   EVAL      A_M5ARTI = ZXARTIX                                               
     C                   EVAL      A_M5VARI = ZXVARIX                                               
     C                   EVAL      A_M5MODE = ZXMODEX                                               
     C     KMSARTI       CHAIN     MSARTI                                                           
b05  C                   IF        Not %FOUND(MSARTI)                                               
13812C                             Or %FOUND(MSARTI) And A_M5BAJA='1'                               
13812C**                 EVAL      @PERRO = '1'                                                     
13812C**                 EVAL      ZXINCI = '005'                                                   
13812C**                 EXSR      CS_DESERR                                                        
x05  C                   ELSE                                                                       
76211C*                  IF        A_M5CROP <> 'A ' And A_M5CROP <> 'A+'                            
76211C*                            And T0AUCP <> 1                                                  
79419C*76211             IF        (A_M5CROP <> 'A ' And A_M5CROP <> 'A+'                           
79419C*76211                       And T0AUCP <> 1)                                                 
79419C*76211                       or                                                               
79419C*76211                       (%found(MSSTST)   And m6clas <> 'A '                             
79419C*76211                       And m6clas <> 'A+'And T0AUCP <> 1)                               
79419c                   IF        zxclas <>'A ' and zxclas <> 'A+'                                 
79419c                             And T0AUCP <> 1                                                  
     C                   EVAL      @PERRO = '1'                                                     
     C                   EVAL      ZXINCI = '011'                                                   
     C                   EXSR      CS_DESERR                                                        
e06  C                   ENDIF                                                                      
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
                                                                                                    
     C                   CLOSE(E)  MSARTI                                                           
79419C                   CLOSE(E)  MSSTOK                                                           
79419C                   CLOSE(E)  MSSTST                                                           
79419C                   CLOSE(E)  MSALMA08                                                         
                                                                                                    
21350C*                  ELSE                                                                       
21350C*                  ENDIF                                                                      
e02  C                   ENDIF                                                                      
e01  C                   ENDIF                                                                      
                                                                                                    
CR653C                   ENDIF                                                                      
     C                   ENDSR                                                                      
C2559 **********************************************************************                        
C2559 * Comprobar si el artículo en productiva es Contrapedido                                      
C2559 * (Y para Cia Movex si tiene Orden de fabricacion asociada)                                   
C2559 **********************************************************************                        
C2559C     CS_CONTPED_2  BEGSR                                                                      
C2559                                                                                               
C2559 * Si no es proveedor externo                                                                  
C2559C                   IF        ZXPVEX<>'1'                                                      
C2559 * Ya tenemos trazabilidad en Productiva                                                       
C2559C                   IF        T0CIA2 <> 0                                                      
C2559                                                                                               
C2559 * Componente Conjunto                                                                         
C2559C                   IF        T0COM2 <> *BLANKS                                                
C2559C                   EVAL      ZXARVMX = T0COM2                                                 
C2559C                   ELSE                                                                       
C2559 * Artículo Normal                                                                             
C2559C                   EVAL      ZXARVMX = T0ARV2                                                 
C2559C                   ENDIF                                                                      
C2559                                                                                               
C2559C                   MOVEL     T0CIA2        PPCIAS                                             
C2559C     KPMLIBL       CHAIN     PMLIBL                                                           
C2559 * Empresa MOVEX                                                                               
C2559C                   IF        %FOUND(PMLIBL) And PPMVXV = 'V'                                  
C2559 * Buscar Compañía MOVEX                                                                       
C2559C                   EXSR      CS_CIASMVX                                                       
C2559C                   EXSR      CS_MVXLIBL                                                       
C2559 *                                                                                             
C2559 * Si existe orden de fabricacion asociada al pedido de ventas                                 
C2559 * (OBRORC=1)                                                                                  
C2559 *                                                                                             
C2559 * [Mientras las empresas no estén completamente en Movex, no                                  
C2559 * tenemos trazabilidad desde el pedido a la OF y nunca se va                                  
C2559 * a encontrar el registro en OOLINE; por lo que no va a haber                                 
C2559 * problema para cerrar la línea. No se va a generar el error.                                 
C2559 * Esta validación funcionará bien en un futuro cuando se esté                                 
C2559 * trabajando completamente en Movex y dispongamos de completa                                 
C2559 * trazabilidad]                                                                               
P1344C*                  Eval      File_ooline = LIBLMVX + '/OOLINE40'                              
P1344C                   Eval      File_ooline = (%trim(LIBLMVX)) + '/OOLINE40'                     
C2559C                   OPEN (E)  OOLINE40                                                         
P1344C*                  Eval      File_oolin0 = LIBLMVX + '/OOLINE00'                              
P1344C                   Eval      File_oolin0 = (%trim(LIBLMVX)) + '/OOLINE00'                     
R3820C*                  OPEN (E)  OOLINE00                                                         
C2559 *                                                                                             
C2559C                   IF        Not %ERROR                                                       
C2559C                   MOVE      MXCONO        OBCONO                                             
C2559C                   MOVE      T0NPC2        OBORNO                                             
C2559C                   EVAL      OBRORC=1                                                         
C2559C     KOOLINE40     CHAIN     OOLINE40                                                         
C2559C                   IF        %FOUND(OOLINE40)                                                 
C2559C                   EVAL      @PERRO = '1'                                                     
C2559C                   EVAL      ZXINCI = '011'                                                   
C2559C                   EXSR      CS_DESERR                                                        
C2559C                   ENDIF                                                                      
C2559C                   ENDIF                                                                      
R3820C*                                                                                             
R3820C* Validamos que no hayan lineas abiertas en el proveedor                                      
R3820C*                  MOVE      MXCONO        OBCONO                                             
R3820C*                  MOVE      T0NPC2        OBORNO                                             
R3820C*                  MOVE      T0LIN2        OBPONR                                             
R3820C*    KOOLINE00     CHAIN     OOLINE00                                                         
R3820C*                  IF        OBRORC <> 0                                                      
R3820C*                  EVAL      @PERRO = '1'                                                     
R3820C*                  EVAL      ZXINCI = '060'                                                   
R3820C*                  EXSR      CS_DESERR                                                        
R3820C*                  ENDIF                                                                      
R3820C*                                                                                             
R3820C*                  CLOSE(E)  OOLINE00                                                         
R3820C*                                                                                             
R3820C* Validamos que el articulo en el proveedor no sea MTO                                        
R3820C*                  OPEN (E)  ZAQBAL00                                                         
R3820C*                  IF        Not %ERROR                                                       
R3820C*                                                                                             
R3820C*Buscar almacén principal de la planta de la división                                         
R3820C*                  Eval      File_mitfac = LIBLMVX + '/MITFAC00'                              
R3820C*                  OPEN (E)  MITFAC00                                                         
R3820C*                  MOVEL     MXCONO        M9CONO                                             
R3820C*                  EVAL      M9FACI=CCFACI                                                    
R3820C*                  MOVEL     ZXARVMX       M9ITNO                                             
R3820C*    KMITFAC00     CHAIN     MITFAC00                                                         
R3820C*                  IF        %FOUND(MITFAC00)                                                 
R3820C*                  MOVEL     MXCONO        MBCONO                                             
R3820C*                  MOVEL     M9REWH        MBWHLO                                             
R3820C*                  MOVEL     ZXARVMX       MBITNO                                             
R3820C*    KZAQBAL00     CHAIN     ZAQBAL00                                                         
R3820C*                  IF        MBMTSO='MTO'                                                     
R3820C*                  EVAL      @PERRO = '1'                                                     
R3820C*                  EVAL      ZXINCI = '060'                                                   
R3820C*                  EXSR      CS_DESERR                                                        
R3820C*                  ENDIF                                                                      
R3820C*                  ENDIF                                                                      
R3820C*                  CLOSE(E)  MITFAC00                                                         
R3820C*                                                                                             
R3820C*                  Eval      File_mitbal = LIBLMVX + '/MITBAL00'                              
R3820C*                  OPEN (E)  MITBAL00                                                         
R3820C*                  MOVEL     MXCONO        MBCONO                                             
R3820C*                  MOVEL     M9REWH        MBWHLO                                             
R3820C*                  MOVEL     ZXARVMX       MBITNO                                             
R3820C*    KMITBAL00     CHAIN     MITBAL00                                                         
R3820C*                  IF        MBOPLC = 1                                                       
R3820C*                  EVAL      @PERRO = '1'                                                     
R3820C*                  EVAL      ZXINCI = '060'                                                   
R3820C*                  EXSR      CS_DESERR                                                        
R3820C*                  ENDIF                                                                      
R3820C*                  CLOSE(E)  MITBAL00                                                         
R3820C*                                                                                             
R3820C*                  ENDIF                                                                      
C2559C                   ENDIF                                                                      
C2559C                   ENDIF                                                                      
C2559C                   ENDIF                                                                      
C2559C     FI_CONTPED_2  ENDSR                                                                      
R3820 **********************************************************************                        
R3820 * Comprobar si existe orden abierta en el Proveedor                                           
R3820 **********************************************************************                        
R3820C     CS_CONTPED_3  BEGSR                                                                      
R3820                                                                                               
R3820 * En caso de que el pedido este autorizado no validamos                                       
R3820C                   IF        T0AUCP<>1                                                        
R3820 * Si no es proveedor externo                                                                  
R3820C                   IF        ZXPVEX<>'1'                                                      
R3820 * Ya tenemos trazabilidad en Productiva                                                       
R3820C                   IF        T0CIA2 <> 0                                                      
R3820                                                                                               
R3820 * Componente Conjunto                                                                         
R3820C                   IF        T0COM2 <> *BLANKS                                                
R3820C                   EVAL      ZXARVMX = T0COM2                                                 
R3820C                   ELSE                                                                       
R3820 * Artículo Normal                                                                             
R3820C                   EVAL      ZXARVMX = T0ARV2                                                 
R3820C                   ENDIF                                                                      
R3820                                                                                               
R3820C                   MOVEL     T0CIA2        PPCIAS                                             
R3820C     KPMLIBL       CHAIN     PMLIBL                                                           
R3820 * Empresa MOVEX                                                                               
R3820C                   IF        %FOUND(PMLIBL) And PPMVXV = 'V'                                  
R3820 * Buscar Compañía MOVEX                                                                       
R3820C                   EXSR      CS_CIASMVX                                                       
R3820C                   EXSR      CS_MVXLIBL                                                       
R3820 *                                                                                             
P1344C*                  Eval      File_oolin0 = LIBLMVX + '/OOLINE00'                              
P1344C                   Eval      File_oolin0 = (%trim(LIBLMVX)) + '/OOLINE00'                     
R3820C                   OPEN (E)  OOLINE00                                                         
P1344C                   Eval      File_cmndiv = (%trim(LIBLMVX)) + '/CMNDIV00'                     
P1344C                   Eval      File_mitbal = (%trim(LIBLMVX)) + '/MITBAL00'                     
P1344C                   Eval      File_mitfac = (%trim(LIBLMVX)) + '/MITFAC00'                     
P1344C                   OPEN (E)  CMNDIV00                                                         
P1344C                   MOVEL     MXCONO        CCCONO                                             
P1344C                   MOVEL     MXDIVI        CCDIVI                                             
P1344C     KCMNDIV00     CHAIN     CMNDIV00                                                         
R3820C*                                                                                             
R3820C* Validamos que no hayan lineas abiertas en el proveedor                                      
R3820C                   MOVE      MXCONO        OBCONO                                             
R3820C                   MOVE      T0NPC2        OBORNO                                             
R3820C                   MOVE      T0LIN2        OBPONR                                             
R3820C     KOOLINE00     CHAIN     OOLINE00                                                         
76211C                   if        %found                                                           
76211C*                                                                                             
R3820C                   IF        OBRORC <> 0                                                      
R3820C                   EVAL      @PERRO = '1'                                                     
R3820C                   EVAL      ZXINCI = '060'                                                   
R3820C                   EXSR      CS_DESERR                                                        
R3820C                   ENDIF                                                                      
R3820C*                                                                                             
R3820C                   CLOSE(E)  OOLINE00                                                         
R3820C*                                                                                             
R3820C* Validamos que el articulo en el proveedor no sea MTO                                        
R3820C                   OPEN (E)  ZAQBAL00                                                         
I0184C                   OPEN (E)  AQPEDI00                                                         
I0184C                   OPEN (E)  ZAQITN00                                                         
I0184C                   OPEN (E)  GMTABD01                                                         
R3820C                   IF        Not %ERROR                                                       
R3820C*                                                                                             
R3820C*Buscar almacén principal de la planta de la división                                         
P1344C*                  Eval      File_mitfac = LIBLMVX + '/MITFAC00'                              
P1344C                   Eval      File_mitfac = (%trim(LIBLMVX)) + '/MITFAC00'                     
R3820C                   OPEN (E)  MITFAC00                                                         
I0184 *                                                                                             
I0184 *            Ver si estamos en una división Multiplanta                                       
I0184C                   MOVEL(P)  MXCONO        Z1CONO                                             
I0184C                   EVAL      Z1DIVI = MXDIVI                                                  
I0184C     KAQPEDI00     CHAIN     AQPEDI00                                                         
I0184C                   EVAL      ZXMULTIPLA = %FOUND(AQPEDI00)                                    
I0184C                                          AND  Z1L101 = '1'                                   
R3820C                   MOVEL     MXCONO        M9CONO                                             
I0184C**R3820            EVAL      M9FACI=CCFACI                                                    
R3820C                   MOVEL     ZXARVMX       M9ITNO                                             
I0184C                   EVAL      M9FACI=GET_FACI(MXDIVI:CCFACI:M9ITNO)                            
R3820C     KMITFAC00     CHAIN     MITFAC00                                                         
R3820C                   IF        %FOUND(MITFAC00)                                                 
R3820C                   MOVEL     MXCONO        MBCONO                                             
76211C* R3820            MOVEL     M9REWH        MBWHLO                                             
76211C                   MOVEL     OBWHLO        MBWHLO                                             
R3820C                   MOVEL     ZXARVMX       MBITNO                                             
E7345 *                                                                                             
E7345c                   exsr      CS_LOG_WHSE                                                      
E7345c                   eval      MBWHLO = xbwhlo                                                  
E7345c     kZAQBAL00     CHAIN     ZAQBAL00                                                         
E7345c                   if        not %found(ZAQBAL00)                                             
E7345C                   MOVEL     OBWHLO        MBWHLO                                             
R3820C     KZAQBAL00     CHAIN     ZAQBAL00                                                         
E7345c                   endif                                                                      
R3820C                   IF        MBMTSO='MTO'                                                     
R3820C                   EVAL      @PERRO = '1'                                                     
R3820C                   EVAL      ZXINCI ='060'                                                    
R3820C                   EXSR      CS_DESERR                                                        
R3820C                   ENDIF                                                                      
R3820C                   ENDIF                                                                      
R3820C                   CLOSE(E)  MITFAC00                                                         
R3820C*                                                                                             
P1344C*                  Eval      File_mitbal = LIBLMVX + '/MITBAL00'                              
P1344C                   Eval      File_mitbal = (%trim(LIBLMVX)) + '/MITBAL00'                     
R3820C                   OPEN (E)  MITBAL00                                                         
R3820C                   MOVEL     MXCONO        MBCONO                                             
76211C* R3820            MOVEL     M9REWH        MBWHLO                                             
76211C                   MOVEL     OBWHLO        MBWHLO                                             
R3820C                   MOVEL     ZXARVMX       MBITNO                                             
R3820C     KMITBAL00     CHAIN     MITBAL00                                                         
R3820C                   IF        MBOPLC = 3                                                       
R3820C                   EVAL      @PERRO = '1'                                                     
R3820C                   EVAL      ZXINCI = '060'                                                   
R3820C                   EXSR      CS_DESERR                                                        
R3820C                   ENDIF                                                                      
I0184C                   CLOSE(E)  CMNDIV00                                                         
R3820C                   CLOSE(E)  MITBAL00                                                         
I0184C                   CLOSE(E)  ZAQBAL00                                                         
I0184C                   CLOSE(E)  AQPEDI00                                                         
I0184C                   CLOSE(E)  ZAQITN00                                                         
I0184C                   CLOSE(E)  GMTABD01                                                         
R3820C                   ENDIF                                                                      
76211C                   endif                                                                      
R3820C                   ENDIF                                                                      
R3820C                   ENDIF                                                                      
R3820C                   ENDIF                                                                      
R3820C                   ENDIF                                                                      
R3820C*                                                                                             
R3820C     FI_CONTPED_3  ENDSR                                                                      
      **********************************************************************                        
      * Validación Integridad de Conjuntos en Trace                                                 
      **********************************************************************                        
     C     CS_VALCONJ    BEGSR                                                                      
                                                                                                    
CR653C                   IF        ZXPVEX<>'1'                                                      
      * guardo clave lógico 30                                                                      
FQ710C                   EXSR      CS_SAVLOG3                                                       
                                                                                                    
     C                   EVAL      ZXCOE1 = 0                                                       
     C                   EVAL      ZXCOE2 = 0                                                       
     C                   EVAL      ZXCOA1 = 0                                                       
     C                   EVAL      ZXCOA2 = 0                                                       
                                                                                                    
      * leo fichero por la clave principal la linea de Vtas de Comercial                            
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C     KEDTRLP00     READE     EDTRLP00                                                         
d01  C                   DOW       NOT %EOF(EDTRLP00)                                               
                                                                                                    
14060C                   IF        T0TREG < 3                                                       
      * Si hay algún conjunto de Compra-Cial o Venta-Product                                        
b02  C                   IF        T0CFC1 > 0 Or T0CFC2 > 0                                         
14060C                   MOVEL     T0NPC1        ZXNPC1                                             
      * busco cantidad preparada en preparación de Trace                                            
     C                   EVAL      SACIAS = T0CIA3                                                  
     C                   EVAL      SATNPE = ' '                                                     
     C                   MOVEL     T0DLG3        SADLGA                                             
     C                   MOVEL     T0NPC3        SANPCO                                             
     C                   MOVEL     T0TPE3        SATPED                                             
     C                   EVAL      SADATP = T0DAT3                                                  
     C                   EVAL      SANOPL = T0NOP3                                                  
     C                   EVAL      SALINE = T0LIN3                                                  
     C                   EVAL      SANPRP = @PCUST                                                  
     C     KCOAPRP01     CHAIN     COAPRP01                                                         
b03  C                   IF        Not %FOUND(COAPRP01)                                             
     C     KCOAPRP01     CHAIN     COAPR101                                                         
e03  C                   ENDIF                                                                      
      * calculo coeficiente cantidad preparada                                                      
b03  C                   IF        %FOUND(COAPRP01) Or %FOUND(COAPR101)                             
14060 * Si es X-DOC Busco cantidad en X-DOC                                                         
14060C                   IF        SACCPP = '1' And T0CFC1 > 0                                      
14060C                   EVAL      TKCIAS = SACIAS                                                  
14060C                   EVAL      TKDLGA = SADLGA                                                  
14060C                   EVAL      TKNPCO = SANPCO                                                  
14060C                   EVAL      TKTPED = SATPED                                                  
14060C                   EVAL      TKDATP = SADATP                                                  
14060C                   EVAL      TKNOPL = SANOPL                                                  
14060C     KCOXDOC       CHAIN     COXDOC                                                           
14060C                   IF        %FOUND(COXDOC)                                                   
14060C                   EVAL      SACANS = 0                                                       
14060C                   DOW       NOT %EOF(COXDOC)                                                 
14060C                   IF        TKNP01=ZXNPC1 And TKLI01=T0LIN1                                  
14060C                   EVAL      SACANS = SACANS + TKCANT                                         
14060C                   ENDIF                                                                      
14060C     KCOXDOC       READE     COXDOC                                                           
14060C                   ENDDO                                                                      
14060C                   ENDIF                                                                      
14060C                   ENDIF                                                                      
b04  C                   IF        T0CFC1 > 0                                                       
     C                   EVAL      ZXCOE1 = SACANS / T0CFC1                                         
b05  C                   IF        ZXCOE1 = 0                                                       
     C                   EVAL      ZXCOE1 = 999999                                                  
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
b04  C                   IF        T0CFC2 > 0                                                       
     C                   EVAL      ZXCOE2 = SACANS / T0CFC2                                         
b05  C                   IF        ZXCOE2 = 0                                                       
     C                   EVAL      ZXCOE2 = 999999                                                  
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
x03  C                   ELSE                                                                       
b04  C                   IF        T0CFC1 > 0                                                       
     C                   EVAL      ZXCOE1 = 999999                                                  
e04  C                   ENDIF                                                                      
b04  C                   IF        T0CFC2 > 0                                                       
     C                   EVAL      ZXCOE2 = 999999                                                  
e04  C                   ENDIF                                                                      
e03  C                   ENDIF                                                                      
      * si el coeficiente en conjunto compra comercial es diferente                                 
b03  C                   IF        ZXCOA1 > 0 And (ZXCOA1 <> ZXCOE1                                 
     C                                        Or ZXCOA1 = 999999)                                   
     C                   EVAL      @PERRO = '1'                                                     
     C                   EVAL      ZXINCI = '010'                                                   
     C                   EXSR      CS_DESERR                                                        
FQ710C                   LEAVE                                                                      
e03  C                   ENDIF                                                                      
      * si el coeficiente en conjunto venta productiva es diferente                                 
b03  C                   IF        ZXCOA2 > 0 And (ZXCOA2 <> ZXCOE2                                 
     C                                        Or ZXCOA2 = 999999)                                   
     C                   EVAL      @PERRO = '1'                                                     
     C                   EVAL      ZXINCI = '010'                                                   
     C                   EXSR      CS_DESERR                                                        
FQ710C                   LEAVE                                                                      
e03  C                   ENDIF                                                                      
      * guardo valores para siguiente componente                                                    
     C                   EVAL      ZXCOA1 = ZXCOE1                                                  
     C                   EVAL      ZXCOA2 = ZXCOE2                                                  
                                                                                                    
e02  C                   ENDIF                                                                      
14060C                   ENDIF                                                                      
                                                                                                    
     C     KEDTRLP00     READE     EDTRLP00                                                         
e01  C                   ENDDO                                                                      
                                                                                                    
      * recupero clave lógico 30                                                                    
FQ710C                   EXSR      CS_RSTLOG3                                                       
                                                                                                    
CR653C                   ENDIF                                                                      
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Validación Integridad de Conjuntos en Trace                                                 
      **********************************************************************                        
     C     CS_VALCONJ2   BEGSR                                                                      
                                                                                                    
CR653C                   IF        ZXPVEX<>'1'                                                      
      * guardo clave lógico 30                                                                      
FQ710C                   EXSR      CS_SAVLOG3                                                       
                                                                                                    
     C                   EVAL      ZXCOE1 = 0                                                       
     C                   EVAL      ZXCOE2 = 0                                                       
     C                   EVAL      ZXCOA1 = 0                                                       
     C                   EVAL      ZXCOA2 = 0                                                       
14070C                   EVAL      ZXCMI1 = 0                                                       
14070C                   EVAL      ZXCMI2 = 0                                                       
FQ710C                   EVAL      ZXSACANS = 0                                                     
                                                                                                    
      * leo fichero por la clave principal la linea de Vtas de Comercial                            
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C     KEDTRLP00     READE     EDTRLP00                                                         
d01  C                   DOW       NOT %EOF(EDTRLP00)                                               
                                                                                                    
14060C                   IF        T0TREG < 3                                                       
      * Si hay algún conjunto de Compra-Cial o Venta-Product                                        
b02  C                   IF        T0CFC1 > 0 Or T0CFC2 > 0                                         
14060C                   MOVEL     T0NPC1        ZXNPC1                                             
      * busco cantidad pendiente de preparar en CODEPE TRACE                                        
     C                   EVAL      S5CIAS = T0CIA3                                                  
     C                   MOVEL     T0DLG3        S5DLGA                                             
     C                   MOVEL     T0NPC3        S5NPCO                                             
     C                   MOVEL     T0TPE3        S5TPED                                             
     C                   EVAL      S5DATP = T0DAT3                                                  
     C                   EVAL      S5NOPL = T0NOP3                                                  
     C                   EVAL      S5LINE = T0LIN3                                                  
     C     KCODEPE       CHAIN     CODEPE                                                           
      * calculo coeficiente cantidad preparada                                                      
b03  C                   IF        %FOUND(CODEPE)                                                   
     C                   EVAL      ZXCANP = 0                                                       
14060C                   EVAL      ZXCANC = S5CANR-S5CAPP                                           
14060 * Si es X-DOC Busco cantidad en X-DOC                                                         
14060C                   IF        S5CCPP = '1' And T0CFC1 > 0                                      
14060C                   EVAL      TKCIAS = S5CIAS                                                  
14060C                   EVAL      TKDLGA = S5DLGA                                                  
14060C                   EVAL      TKNPCO = S5NPCO                                                  
14060C                   EVAL      TKTPED = S5TPED                                                  
14060C                   EVAL      TKDATP = S5DATP                                                  
14060C                   EVAL      TKNOPL = S5NOPL                                                  
14060C     KCOXDOC       CHAIN     COXDOC                                                           
14060C                   IF        %FOUND(COXDOC) And S5CANR>0                                      
14060C                   EVAL      ZXCANC = 0                                                       
14060C                   DOW       NOT %EOF(COXDOC)                                                 
14060C                   IF        TKNP01=ZXNPC1 And TKLI01=T0LIN1                                  
14060C                   EVAL      ZXCANC = ZXCANC + TKCANT                                         
14060C                   ENDIF                                                                      
14060C     KCOXDOC       READE     COXDOC                                                           
14060C                   ENDDO                                                                      
14060C                   ENDIF                                                                      
14060C                   ENDIF                                                                      
      * Si esta en preparación miro si es la que estoy creando o otra                               
b04  C                   IF        S5MPRP='1'                                                       
      * busco cantidad preparada en preparación de Trace                                            
     C                   EVAL      SACIAS = S5CIAS                                                  
     C                   EVAL      SATNPE = ' '                                                     
     C                   EVAL      SADLGA = S5DLGA                                                  
     C                   EVAL      SANPCO = S5NPCO                                                  
     C                   EVAL      SATPED = S5TPED                                                  
     C                   EVAL      SADATP = S5DATP                                                  
     C                   EVAL      SANOPL = S5NOPL                                                  
     C                   EVAL      SALINE = S5LINE                                                  
     C     KCOAPRP00     CHAIN     COAPR101                                                         
d05  C                   DOW       NOT %EOF(COAPR101)                                               
      * busco status cabecera                                                                       
     C                   EVAL      SBCIAS = SACIAS                                                  
     C                   EVAL      SBDLGA = *BLANKS                                                 
     C                   EVAL      SBNPRP = SANPRP                                                  
     C     KCOAPRC       CHAIN     COAPRC                                                           
b06  C                   IF        %FOUND(COAPRC) And SBSTCO<'20'                                   
     C                   EVAL      ZXCANP = ZXCANP + SACANS                                         
e06  C                   ENDIF                                                                      
     C     KCOAPRP00     READE     COAPR101                                                         
e05  C                   ENDDO                                                                      
e04  C                   ENDIF                                                                      
                                                                                                    
b04  C                   IF        T0CFC1 > 0                                                       
14060C                   EVAL      ZXCOE1 = (ZXCANC+ZXCANP) / T0CFC1                                
b05  C                   IF        ZXCOE1 = 0                                                       
     C                   EVAL      ZXCOE1 = 999999                                                  
14070C                   EVAL      ZXCMI1 = 0                                                       
14070C                   ELSE                                                                       
14070C                   IF        ZXCOE1 < ZXCMI1 Or ZXCOA1 = 0                                    
FQ710C**                 EVAL      ZXCMI1 = ZXCOE1                                                  
FQ710C                   EVAL      ZXCMI1 = %INT(ZXCOE1)                                            
14070C                   ENDIF                                                                      
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
b04  C                   IF        T0CFC2 > 0                                                       
06070C                   EVAL      ZXCOE2 = (ZXCANC+ZXCANP) / T0CFC2                                
b05  C                   IF        ZXCOE2 = 0                                                       
     C                   EVAL      ZXCOE2 = 999999                                                  
14070C                   EVAL      ZXCMI2 = 0                                                       
14070C                   ELSE                                                                       
14070C                   IF        ZXCOE2 < ZXCMI2 Or ZXCOA2 = 0                                    
FQ710C**                 EVAL      ZXCMI2 = ZXCOE2                                                  
FQ710C                   EVAL      ZXCMI2 = %INT(ZXCOE2)                                            
14070C                   ENDIF                                                                      
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
x03  C                   ELSE                                                                       
b04  C                   IF        T0CFC1 > 0                                                       
     C                   EVAL      ZXCOE1 = 999999                                                  
14070C                   EVAL      ZXCMI1 = 0                                                       
e04  C                   ENDIF                                                                      
b04  C                   IF        T0CFC2 > 0                                                       
     C                   EVAL      ZXCOE2 = 999999                                                  
14070C                   EVAL      ZXCMI2 = 0                                                       
e04  C                   ENDIF                                                                      
e03  C                   ENDIF                                                                      
      * si el coeficiente en conjunto compra comercial es diferente                                 
14070C**                 IF        ZXCOA1 > 0 And (ZXCOA1 <> ZXCOE1                                 
14070C**                                      Or ZXCOA1 = 999999)                                   
14070C                   IF        ZXCMI1 = 0 And T0CFC1 > 0                                        
     C                   EVAL      @PERRO = '1'                                                     
     C                   EVAL      ZXINCI = '010'                                                   
     C                   EXSR      CS_DESERR                                                        
FQ710C                   LEAVE                                                                      
e03  C                   ENDIF                                                                      
      * si el coeficiente en conjunto venta productiva es diferente                                 
14070C**                 IF        ZXCOA2 > 0 And (ZXCOA2 <> ZXCOE2                                 
14070C**                                      Or ZXCOA2 = 999999)                                   
14070C                   IF        ZXCMI2 = 0 And T0CFC2 > 0                                        
     C                   EVAL      @PERRO = '1'                                                     
     C                   EVAL      ZXINCI = '010'                                                   
     C                   EXSR      CS_DESERR                                                        
FQ710C                   LEAVE                                                                      
e03  C                   ENDIF                                                                      
      * guardo valores para siguiente componente                                                    
     C                   EVAL      ZXCOA1 = ZXCOE1                                                  
     C                   EVAL      ZXCOA2 = ZXCOE2                                                  
                                                                                                    
e02  C                   ENDIF                                                                      
14060C                   ENDIF                                                                      
                                                                                                    
     C     KEDTRLP00     READE     EDTRLP00                                                         
e01  C                   ENDDO                                                                      
FQ710                                                                                               
FQ710C                   IF        ZXCMI1 > 0                                                       
FQ710C                   EVAL      ZXSACANS = ZXCMI1                                                
FQ710C                   ENDIF                                                                      
FQ710C                   IF        ZXCMI2 > 0                                                       
FQ710C                   EVAL      ZXSACANS = ZXCMI2                                                
FQ710C                   ENDIF                                                                      
                                                                                                    
      * recupero clave lógico 30                                                                    
FQ710C                   EXSR      CS_RSTLOG3                                                       
CR653C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Validación Integridad del X-DOC                                                             
      **********************************************************************                        
     C**   CS_INTXDOC    BEGSR                                                                      
      **                                                                                            
     C**                 ENDSR                                                                      
FQ710 **********************************************************************                        
FQ710 * Validación Coenvio                                                                          
FQ710 **********************************************************************                        
FQ710C     CS_COENVIO    BEGSR                                                                      
CR653C                   IF        ZXPVEX<>'1'                                                      
FQ710                                                                                               
FQ710C                   MOVEL     T0DLG3        @PEDLGA                                            
FQ710C                   MOVEL     T0NPC3        @PENPCO                                            
FQ710C                   MOVEL     T0TPE3        @PETPED                                            
FQ710                                                                                               
FQ710C                   CALL      'CO2696'                                                         
FQ710C                   PARM      T0CIA3        @PECIAS                                            
FQ710C                   PARM                    @PEDLGA                                            
FQ710C                   PARM                    @PENPCO                                            
FQ710C                   PARM                    @PETPED                                            
FQ710C                   PARM      T0DAT3        @PEDATP                                            
FQ710C                   PARM      T0NOP3        @PENOPL                                            
FQ710C                   PARM      T0LIN3        @PELINE                                            
FQ710C                   PARM      *BLANKS       @PEERR                                             
FQ710 *                                                                                             
FQ710C                   IF        @PEERR>'0'                                                       
C3690C                   SELECT                                                                     
C3690C                   WHEN      @PEERR = '5'                                                     
C3690C                   EVAL      ZXINCI = '013'                                                   
C3690C                   EVAL      @PERRO = '1'                                                     
C3690C                   WHEN      @PEERR = '6'                                                     
C3690C                   EVAL      ZXINCI = '007'                                                   
C3690C                   EVAL      @PERRO = '1'                                                     
C3690C                   WHEN      @PEERR = '7'                                                     
C3690C                   EVAL      ZXINCI = '020'                                                   
C3690C                   EVAL      @PERRO = '1'                                                     
C3690C                   OTHER                                                                      
FQ710C                   EVAL      ZXINCI = '017'                                                   
C3690C                   EVAL      @PERRO = '1'                                                     
C3690C                   ENDSL                                                                      
FQ710C*                  EVAL      @PERRO = '1'                                                     
FQ710C*                  EVAL      ZXINCI = '017'                                                   
FQ710C                   EXSR      CS_DESERR                                                        
FQ710C                   ENDIF                                                                      
FQ710                                                                                               
CR653C                   ENDIF                                                                      
FQ710C                   ENDSR                                                                      
FQ710 **********************************************************************                        
FQ710 * Validación Forzar Preparación                                                               
FQ710 **********************************************************************                        
FQ710C     CS_FORPREP    BEGSR                                                                      
FQ710                                                                                               
CR653C                   IF        ZXPVEX<>'1'                                                      
FQ710 * si No han forzado la preparación y teniamos incidencia minimo                               
FQ710 *    por expedición no puedo preparar.                                                        
FQ710C                   IF        T0FOPR = 0  And ZXINCI = '016'                                   
FQ710C                   EVAL      @PERRO = '1'                                                     
FQ710C                   EXSR      CS_DESERR                                                        
FQ710C                   ELSE                                                                       
FQ710C                   EVAL      ZXINCI = *BLANKS                                                 
FQ710C                   ENDIF                                                                      
CR653C                   ENDIF                                                                      
FQ710                                                                                               
FQ710C                   ENDSR                                                                      
FQ710 **********************************************************************                        
FQ710 * Validación importe minimo por expedición en un cliente-direcc.                              
FQ710 **********************************************************************                        
FQ710C     CS_IMPOEXP    BEGSR                                                                      
CR653C                   IF        ZXPVEX<>'1'                                                      
FQ710                                                                                               
FQ710 * Recuperamos valores de selección del OPENQRYFILE                                            
FQ710C                   EVAL      JOLINE=99                                                        
FQ710C     KMJOB         CHAIN     PMJOBC                             81                            
FQ710C                   IF        CHAIN=*OFF                                                       
FQ710C     JODATO        CAT       CO3076:0      CO3076                                             
FQ710C                   ENDIF                                                                      
FQ710                                                                                               
FQ710 * si la linea está reservada, y no tiene errores, acumulo importe                             
FQ710C                   IF        (T0CANR - T0CANP) > 0                                            
FQ710 *           guardo clave lógico 40                                                            
FQ710C                   EXSR      CS_SAVLOG4                                                       
FQ710C                   EVAL      ZXSACANS = 0                                                     
FQ710 * Validación Pedido Trace                                                                     
FQ710C                   IF        YDNPCO > T0NPC3 Or YHNPCO < T0NPC3                               
FQ710C                   EVAL      @PERRO = '1'                                                     
FQ710C                   GOTO      NOMAS                                                            
FQ710C                   ENDIF                                                                      
CR527 *                                                                                             
CR527 * Omitimos todos los condicionantes si es Fluidra Direct Express                              
CR527 *                                                                                             
CR527C                   IF        Z1SFDE<>'1'                                                      
FQ710 * Validación Fecha prevista envio                                                             
FQ710C                   IF        ZDFREP > T0FREP Or ZHFREP < T0FREP                               
FQ710C                   EVAL      @PERRO = '1'                                                     
FQ710C                   GOTO      NOMAS                                                            
FQ710C                   ENDIF                                                                      
CR527C                   ENDIF                                                                      
FQ710 * Validación si la linea esta cerrada                                                         
FQ710C                   EXSR      CS_LINCERR                                                       
FQ710C                   IF        @PERRO = '1'                                                     
FQ710C                   GOTO      NOMAS                                                            
FQ710C                   ENDIF                                                                      
FQ710 * Validación Pedido Retenido                                                                  
FQ710C                   EXSR      CS_PEDHOLD                                                       
FQ710C                   IF        @PERRO = '1'                                                     
FQ710C                   GOTO      NOMAS                                                            
FQ710C                   ENDIF                                                                      
FQ710 * Validación Riesgo Cliente                                                                   
FQ710C                   EXSR      CS_RISKCLI                                                       
FQ710C                   IF        @PERRO = '1'                                                     
FQ710C                   GOTO      NOMAS                                                            
FQ710C                   ENDIF                                                                      
FQ710 * Validación Integridad de Conjuntos en Trace                                                 
FQ710C                   EXSR      CS_VALCONJ2                                                      
FQ710C                   IF        @PERRO = '1'                                                     
FQ710C                   GOTO      NOMAS                                                            
FQ710C                   ENDIF                                                                      
FQ710 * Modificación en Curso                                                                       
FQ710C                   EXSR      CS_MODCURS                                                       
FQ710C                   IF        @PERRO = '1'                                                     
FQ710C                   GOTO      NOMAS                                                            
FQ710C                   ENDIF                                                                      
FQ710 * Coenvio                                                                                     
FQ710C                   EXSR      CS_COENVIO                                                       
FQ710C                   IF        @PERRO = '1'                                                     
FQ710C                   GOTO      NOMAS                                                            
FQ710C                   ENDIF                                                                      
FQ710C     NOMAS         TAG                                                                        
FQ710                                                                                               
FQ710C                   IF        @PERRO = *BLANKS                                                 
FQ710 * busco parámetros de la comercial                                                            
FQ710C                   EVAL      T3CIAS = T0CIAS                                                  
FQ710C                   EVAL      T3DLGA = T0DLGA                                                  
FQ710C     KEDPARM       CHAIN     EDPARM                                                           
FQ710 * acumulo importe de la preparación                                                           
FQ710C                   IF        ZXSACANS > 0                                                     
      ***                                                                                           
15091 * en el caso de conversión de unidades entre comercial y Trace                                
15091C                   IF        T0COFA > 1                                                       
15091C                   IF        T0TCOF = '0'                                                     
15091C                   EVAL(H)   ZXSACANS = ZXSACANS * T0COFA                                     
15091C                   ELSE                                                                       
15091C                   EVAL(H)   ZXSACANS = ZXSACANS / T0COFA                                     
15091C                   ENDIF                                                                      
15091C                   ENDIF                                                                      
15091 * en el caso de que sea Conjunto con coeficiente superior a 1                                 
15091C                   IF        T0CFC1 > 1                                                       
15091C                   EVAL(H)   ZXSACANS = ZXSACANS / T0CFC1                                     
15091C                   ENDIF                                                                      
15091C                   IF        T0CFC2 > 1                                                       
15091C                   EVAL(H)   ZXSACANS = ZXSACANS / T0CFC2                                     
15091C                   ENDIF                                                                      
      ***                                                                                           
FQ710C                   EVAL      ZXIMPEXP = ZXIMPEXP +                                            
FQ710C                             (ZXSACANS * T0IMPO)                                              
FQ710C                   ELSE                                                                       
15091C                   EVAL      ZXSACAN2 = 0                                                     
15091C                   EVAL      ZXSACAN2 = T0CANR - T0CANP                                       
15091 * en el caso de conversión de unidades entre comercial y Trace                                
15091C                   IF        T0COFA > 1                                                       
15091C                   IF        T0TCOF = '0'                                                     
15091C                   EVAL(H)   ZXSACAN2 = ZXSACAN2 * T0COFA                                     
15091C                   ELSE                                                                       
15091C                   EVAL(H)   ZXSACAN2 = ZXSACAN2 / T0COFA                                     
15091C                   ENDIF                                                                      
15091C                   ENDIF                                                                      
15091 * en el caso de que sea Conjunto con coeficiente superior a 1                                 
15091C                   IF        T0CFC1 > 1                                                       
15091C                   EVAL(H)   ZXSACAN2 = ZXSACAN2 / T0CFC1                                     
15091C                   ENDIF                                                                      
15091C                   IF        T0CFC2 > 1                                                       
15091C                   EVAL(H)   ZXSACAN2 = ZXSACAN2 / T0CFC2                                     
15091C                   ENDIF                                                                      
15091C                   EVAL      ZXIMPEXP = ZXIMPEXP +                                            
15091C                             (ZXSACAN2 * T0IMPO)                                              
15091C*                  EVAL      ZXIMPEXP = ZXIMPEXP +                                            
15091C*                            ((T0CANR - T0CANP) * T0IMPO)                                     
FQ710C                   ENDIF                                                                      
FQ710 * si fecha ultima reseva es anterior, la guardo                                               
FQ710C                   IF        T0FURE > 0 And T0FURE < ZXFURE                                   
FQ710C                   EVAL      ZXFURE = T0FURE                                                  
FQ710C                   ENDIF                                                                      
FQ710C                   ENDIF                                                                      
FQ710                                                                                               
FQ710C                   EVAL      ZXINCI = *BLANKS                                                 
FQ710C                   EVAL      @PERRO = *BLANKS                                                 
FQ710 *           recupero clave lógico 40                                                          
FQ710C                   EXSR      CS_RSTLOG4                                                       
FQ710                                                                                               
FQ710C                   ENDIF                                                                      
FQ710                                                                                               
CR653C                   ENDIF                                                                      
FQ710C                   ENDSR                                                                      
FQ710 **********************************************************************                        
FQ710 * Validación importe minimo por expedición en una preparación                                 
FQ710 **********************************************************************                        
FQ710C     CS_IMPOEXP2   BEGSR                                                                      
CR653C                   IF        ZXPVEX<>'1'                                                      
FQ710                                                                                               
CR527 *                                                                                             
CR527 * Omitimos todos los condicionantes si es Fluidra Direct Express                              
CR527 *                                                                                             
CR527C                   IF        Z1SFDE<>'1'                                                      
CR527 *                                                                                             
FQ710C                   EVAL      ZXFOPR = 1                                                       
FQ710 * leo toda la preparación                                                                     
FQ710C                   EVAL      SACIAS = @PCIAS                                                  
FQ710C                   EVAL      SANPRP = @PCUST                                                  
FQ710C     KCOAPRP       CHAIN     COAPR1                             83                            
FQ710C                   IF        %FOUND(COAPR1)                                                   
FQ710C                   EVAL      ZXCONS = 1                                                       
FQ710C                   ELSE                                                                       
FQ710C     KCOAPRP       CHAIN     COAPRP                             83                            
FQ710C                   EVAL      ZXCONS = 0                                                       
FQ710C                   ENDIF                                                                      
FQ710                                                                                               
FQ710C                   DOW       *IN83=*OFF                                                       
FQ710                                                                                               
FQ710C                   EVAL      ZXIMPO = 0                                                       
FQ710C                   EVAL      ZXSACANS = 0                                                     
FQ710 * leo todos los registros de EDTRLP con la clave de TRACE                                     
FQ710C                   EVAL      T0CIA3 = SACIAS                                                  
FQ710C                   EVAL      T0DLG3 = SADLGA                                                  
FQ710C                   EVAL      T0NPC3 = SANPCO                                                  
FQ710C                   EVAL      T0TPE3 = SATPED                                                  
FQ710C                   EVAL      T0DAT3 = SADATP                                                  
FQ710C                   EVAL      T0NOP3 = SANOPL                                                  
FQ710C                   EVAL      T0LIN3 = SALINE                                                  
FQ710C                   EVAL      T0CIAS = 0                                                       
FQ710C                   EVAL      T0DLGA = *BLANKS                                                 
FQ710C                   EVAL      T0NPCO = *BLANKS                                                 
FQ710C                   EVAL      T0TPED = *BLANKS                                                 
FQ710C                   EVAL      T0DATP = 0                                                       
FQ710C                   EVAL      T0NOPL = 0                                                       
FQ710C                   EVAL      T0LINE = 0                                                       
FQ710C                   EVAL      T0ARV1 = *BLANKS                                                 
FQ710C                   EVAL      T0COM2 = *BLANKS                                                 
FQ710C     KEDTRLP300    SETLL     EDTRLP30                                                         
FQ710C     KEDTRLP30     READE(N)  EDTRLP30                                                         
FQ710                                                                                               
FQ710 * busco parámetros de la comercial                                                            
FQ710C                   EVAL      T3CIAS = T0CIAS                                                  
FQ710C                   EVAL      T3DLGA = T0DLGA                                                  
FQ710C     KEDPARM       CHAIN     EDPARM                                                           
FQ710                                                                                               
FQ710C                   DOW       NOT %EOF(EDTRLP30)                                               
FQ710C                   IF        T0TREG = 0 Or T0TREG = 3                                         
FQ710 * si fecha ultima reseva es anterior, la guardo                                               
FQ710C                   IF        T0FURE > 0 And T0FURE < ZXFURE                                   
FQ710C                   EVAL      ZXFURE = T0FURE                                                  
FQ710C                   ENDIF                                                                      
FQ710 * si no han forzado preparación lo marco                                                      
FQ710C                   IF        T0FOPR = 0                                                       
FQ710C                   EVAL      ZXFOPR = 0                                                       
FQ710C                   ENDIF                                                                      
FQ710 * en el caso de x-doc la cantidad la cojo del EDTRLP                                          
FQ710C                   IF        T0XDOC = 1                                                       
FQ710C                   EVAL      ZXSACANS = T0CAN3                                                
FQ710C                   ELSE                                                                       
FQ710C                   EVAL      ZXSACANS = SACANS                                                
FQ710C                   ENDIF                                                                      
FQ710 * en el caso de conversión de unidades entre comercial y Trace                                
FQ710C                   IF        T0COFA > 1                                                       
FQ710C                   IF        T0TCOF = '0'                                                     
FQ710C                   EVAL(H)   ZXSACANS = ZXSACANS * T0COFA                                     
FQ710C                   ELSE                                                                       
FQ710C                   EVAL(H)   ZXSACANS = ZXSACANS / T0COFA                                     
FQ710C                   ENDIF                                                                      
FQ710C                   ENDIF                                                                      
FQ710 * en el caso de que sea Conjunto con coeficiente superior a 1                                 
FQ710C                   IF        T0CFC1 > 1                                                       
FQ710C                   EVAL(H)   ZXSACANS = ZXSACANS / T0CFC1                                     
FQ710C                   ENDIF                                                                      
FQ710C                   IF        T0CFC2 > 1                                                       
FQ710C                   EVAL(H)   ZXSACANS = ZXSACANS / T0CFC2                                     
FQ710C                   ENDIF                                                                      
FQ710                                                                                               
FQ710 * acumulo importe de la linea de la preparación                                               
FQ710C                   EVAL(H)   ZXIMPEXP = ZXIMPEXP +                                            
FQ710C                                        (ZXSACANS * T0IMPO)                                   
FQ710                                                                                               
FQ710C                   ENDIF                                                                      
FQ710C     KEDTRLP30     READE(N)  EDTRLP30                                                         
FQ710C                   ENDDO                                                                      
FQ710                                                                                               
FQ710C                   IF        ZXCONS = 0                                                       
FQ710C     KCOAPRP       READE     COAPRP                                 83                        
FQ710C                   ELSE                                                                       
FQ710C     KCOAPRP       READE     COAPR1                                 83                        
FQ710C                   ENDIF                                                                      
FQ710C                   ENDDO                                                                      
CR527                                                                                               
CR527C                   ENDIF                                                                      
CR527                                                                                               
FQ710                                                                                               
CR653C                   ENDIF                                                                      
FQ710C                   ENDSR                                                                      
      **********************************************************************                        
      * Lectura Fichero Trazas Según Origen e Integridad Datos                                      
      **********************************************************************                        
     C     CS_READFIL    BEGSR                                                                      
                                                                                                    
      * Monto claves en función del Origen                                                          
FQ710C                   IF        @PEDAU = '303' And @PINTE = 3                                    
FQ710C                   MOVEL     @PARV1        @PJOBC                                             
FQ710C                   EVAL      @PARV1 = *BLANKS                                                 
FQ710C                   ENDIF                                                                      
b01  C                   IF        @PEDAU <> '305'                                                  
     C                   EVAL      T0CUST = @PCUST                                                  
     C                   EVAL      T0TDI1 = @PTDI1                                                  
e01  C                   ENDIF                                                                      
s01  C                   SELECT                                                                     
FQ710C                   WHEN      @PLOGI = 0 And @PINTE <> 3                                       
     C                   EVAL      T0CIAS = @PCIAS                                                  
     C                   EVAL      T0DLGA = @PDLGA                                                  
     C                   EVAL      T0NPCO = @PNPCO                                                  
     C                   EVAL      T0TPED = @PTPED                                                  
     C                   EVAL      T0DATP = @PDATP                                                  
     C                   EVAL      T0NOPL = @PNOPL                                                  
     C                   EVAL      T0LINE = @PLINE                                                  
FQ710C                   WHEN      @PLOGI = 1 And @PINTE <> 3                                       
     C                   EVAL      T0CIA1 = @PCIAS                                                  
     C                   EVAL      T0DLG1 = @PDLGA                                                  
     C                   EVAL      T0NPC1 = @PNPCO                                                  
     C                   EVAL      T0TPE1 = @PTPED                                                  
     C                   EVAL      T0DAT1 = @PDATP                                                  
     C                   EVAL      T0NOP1 = @PNOPL                                                  
     C                   EVAL      T0LIN1 = @PLINE                                                  
     C                   EVAL      T0ARV1 = @PARV1                                                  
FQ710C                   WHEN      @PLOGI = 2 And @PINTE <> 3                                       
     C                   EVAL      T0CIA2 = @PCIAS                                                  
     C                   EVAL      T0DLG2 = @PDLGA                                                  
     C                   EVAL      T0NPC2 = @PNPCO                                                  
     C                   EVAL      T0TPE2 = @PTPED                                                  
     C                   EVAL      T0DAT2 = @PDATP                                                  
     C                   EVAL      T0NOP2 = @PNOPL                                                  
     C                   EVAL      T0LIN2 = @PLINE                                                  
     C                   EVAL      T0COM2 = @PCOM2                                                  
FQ710C                   WHEN      @PLOGI = 3 And @PINTE <> 3                                       
     C                   EVAL      T0CIA3 = @PCIAS                                                  
     C                   EVAL      T0DLG3 = @PDLGA                                                  
     C                   EVAL      T0NPC3 = @PNPCO                                                  
     C                   EVAL      T0TPE3 = @PTPED                                                  
     C                   EVAL      T0DAT3 = @PDATP                                                  
     C                   EVAL      T0NOP3 = @PNOPL                                                  
     C                   EVAL      T0LIN3 = @PLINE                                                  
FQ710C                   WHEN      @PINTE = 3                                                       
FQ710C                   EVAL      T0CIAS = @PCIAS                                                  
FQ710C                   EVAL      T0CUST = @PCUST                                                  
FQ710C                   EVAL      T0TDI1 = @PTDI1                                                  
e01  C                   ENDSL                                                                      
01070                                                                                               
01070C                   EVAL      S5CIAS=@PCIAS                                                    
01070C                   EVAL      S5DLGA=@PDLGA                                                    
01070C                   EVAL      S5NPCO=@PNPCO                                                    
01070C                   EVAL      S5TPED=@PTPED                                                    
01070C                   EVAL      S5DATP=@PDATP                                                    
01070C                   EVAL      S5NOPL=@PNOPL                                                    
01070C                   EVAL      S5LINE=@PLINE                                                    
                                                                                                    
      * Leo lógicos en función a la Integridad de datos a Comprobar                                 
s01  C                   SELECT                                                                     
     C                   WHEN      @PLOGI = 0 And @PINTE = 1                                        
     C     KEDTRLP00     SETLL     EDTRLP00                                                         
     C     KEDTRLP00     READE     EDTRLP00                               82                        
     C                   WHEN      @PLOGI = 0 And @PINTE = 2                                        
     C     KEDTRLP00P    SETLL     EDTRLP00                                                         
     C     KEDTRLP00P    READE     EDTRLP00                               82                        
01070C                   EVAL      S5LINE=T0LINE                                                    
     C                   WHEN      @PLOGI = 1 And @PINTE = 1                                        
     C                             And @PARV1 = *BLANKS                                             
     C     KEDTRLP10     SETLL     EDTRLP10                                                         
     C     KEDTRLP10     READE     EDTRLP10                               82                        
01070C                   EVAL      S5CIAS=T0CIAS                                                    
01070C                   EVAL      S5DLGA=T0DLGA                                                    
01070C                   EVAL      S5NPCO=T0NPCO                                                    
01070C                   EVAL      S5TPED=T0TPED                                                    
01070C                   EVAL      S5DATP=T0DATP                                                    
01070C                   EVAL      S5NOPL=T0NOPL                                                    
01070C                   EVAL      S5LINE=T0LINE                                                    
     C                   WHEN      @PLOGI = 1 And @PINTE = 1                                        
     C                             And @PARV1 <> *BLANKS                                            
     C     KEDTRLP10X    SETLL     EDTRLP10                                                         
     C     KEDTRLP10X    READE     EDTRLP10                               82                        
01070C                   EVAL      S5CIAS=T0CIAS                                                    
01070C                   EVAL      S5DLGA=T0DLGA                                                    
01070C                   EVAL      S5NPCO=T0NPCO                                                    
01070C                   EVAL      S5TPED=T0TPED                                                    
01070C                   EVAL      S5DATP=T0DATP                                                    
01070C                   EVAL      S5NOPL=T0NOPL                                                    
01070C                   EVAL      S5LINE=T0LINE                                                    
     C                   WHEN      @PLOGI = 1 And @PINTE = 2                                        
     C     KEDTRLP10P    SETLL     EDTRLP10                                                         
     C     KEDTRLP10P    READE     EDTRLP10                               82                        
01070C                   EVAL      S5CIAS=T0CIAS                                                    
01070C                   EVAL      S5DLGA=T0DLGA                                                    
01070C                   EVAL      S5NPCO=T0NPCO                                                    
01070C                   EVAL      S5TPED=T0TPED                                                    
01070C                   EVAL      S5DATP=T0DATP                                                    
01070C                   EVAL      S5NOPL=T0NOPL                                                    
01070C                   EVAL      S5LINE=T0LINE                                                    
     C                   WHEN      @PLOGI = 2 And @PINTE = 1                                        
     C                             And @PCOM2 = *BLANKS                                             
     C     KEDTRLP20     SETLL     EDTRLP20                                                         
     C     KEDTRLP20     READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI = 2 And @PINTE = 1                                        
     C                             And @PCOM2 <> *BLANKS                                            
     C     KEDTRLP20X    SETLL     EDTRLP20                                                         
     C     KEDTRLP20X    READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI = 2 And @PINTE = 2                                        
     C     KEDTRLP20P    SETLL     EDTRLP20                                                         
     C     KEDTRLP20P    READE     EDTRLP20                               82                        
01070C                   EVAL      S5LINE=T0LIN2                                                    
     C                   WHEN      @PLOGI = 3 And @PINTE = 1                                        
     C                             And @PEDAU <> '303' And @PEDAU <> '305'                          
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C     KEDTRLP30     READE(N)  EDTRLP30                               82                        
     C                   WHEN      @PLOGI = 3 And @PINTE = 2                                        
     C                             And @PEDAU <> '303' And @PEDAU <> '305'                          
     C     KEDTRLP30P    SETLL     EDTRLP30                                                         
     C     KEDTRLP30P    READE(N)  EDTRLP30                               82                        
01070C                   EVAL      S5LINE=T0LIN3                                                    
     C                   WHEN      @PLOGI = 3 And @PINTE = 1                                        
     C                             And (@PEDAU = '303' Or @PEDAU = '305')                           
     C     KEDTRLP30     SETLL     EDTRLP30                                                         
     C     KEDTRLP30     READE     EDTRLP30                               82                        
     C                   WHEN      @PLOGI = 3 And @PINTE = 2                                        
     C                             And (@PEDAU = '303' Or @PEDAU = '305')                           
     C     KEDTRLP30P    SETLL     EDTRLP30                                                         
     C     KEDTRLP30P    READE     EDTRLP30                               82                        
01070C                   EVAL      S5LINE=T0LIN3                                                    
     C                   WHEN      (@PLOGI=0 Or @PLOGI=1 Or @PLOGI=2                                
     C                             Or @PLOGI = 3) And @PINTE = 3                                    
     C     KEDTRLP40     SETLL     EDTRLP40                                                         
     C     KEDTRLP40     READE     EDTRLP40                               82                        
01070C                   EVAL      S5LINE=T0LINE                                                    
e01  C                   ENDSL                                                                      
                                                                                                    
01070C     KCODEPE       CHAIN     CODEPE                                                           
01070                                                                                               
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Lectura Fichero Eliminados Según Origen e Integridad Datos                                  
      **********************************************************************                        
     C     CS_READFIX    BEGSR                                                                      
                                                                                                    
      * Monto claves en función del Origen                                                          
b01  C                   IF        @PEDAU <> '305'                                                  
     C                   EVAL      T0CUST = @PCUST                                                  
     C                   EVAL      T0TDI1 = @PTDI1                                                  
e01  C                   ENDIF                                                                      
s01  C                   SELECT                                                                     
FQ710C                   WHEN      @PLOGI = 0 And @PINTE <> 3                                       
     C                   EVAL      T0CIAS = @PCIAS                                                  
     C                   EVAL      T0DLGA = @PDLGA                                                  
     C                   EVAL      T0NPCO = @PNPCO                                                  
     C                   EVAL      T0TPED = @PTPED                                                  
     C                   EVAL      T0DATP = @PDATP                                                  
     C                   EVAL      T0NOPL = @PNOPL                                                  
     C                   EVAL      T0LINE = @PLINE                                                  
FQ710C                   WHEN      @PLOGI = 1 And @PINTE <> 3                                       
     C                   EVAL      T0CIA1 = @PCIAS                                                  
     C                   EVAL      T0DLG1 = @PDLGA                                                  
     C                   EVAL      T0NPC1 = @PNPCO                                                  
     C                   EVAL      T0TPE1 = @PTPED                                                  
     C                   EVAL      T0DAT1 = @PDATP                                                  
     C                   EVAL      T0NOP1 = @PNOPL                                                  
     C                   EVAL      T0LIN1 = @PLINE                                                  
     C                   EVAL      T0ARV1 = @PARV1                                                  
FQ710C                   WHEN      @PLOGI = 2 And @PINTE <> 3                                       
     C                   EVAL      T0CIA2 = @PCIAS                                                  
     C                   EVAL      T0DLG2 = @PDLGA                                                  
     C                   EVAL      T0NPC2 = @PNPCO                                                  
     C                   EVAL      T0TPE2 = @PTPED                                                  
     C                   EVAL      T0DAT2 = @PDATP                                                  
     C                   EVAL      T0NOP2 = @PNOPL                                                  
     C                   EVAL      T0LIN2 = @PLINE                                                  
     C                   EVAL      T0COM2 = @PCOM2                                                  
FQ710C                   WHEN      @PLOGI = 3 And @PINTE <> 3                                       
     C                   EVAL      T0CIA3 = @PCIAS                                                  
     C                   EVAL      T0DLG3 = @PDLGA                                                  
     C                   EVAL      T0NPC3 = @PNPCO                                                  
     C                   EVAL      T0TPE3 = @PTPED                                                  
     C                   EVAL      T0DAT3 = @PDATP                                                  
     C                   EVAL      T0NOP3 = @PNOPL                                                  
     C                   EVAL      T0LIN3 = @PLINE                                                  
FQ710C                   WHEN      @PINTE = 3                                                       
FQ710C                   EVAL      T0CIAS = @PCIAS                                                  
FQ710C                   EVAL      T0CUST = @PCUST                                                  
FQ710C                   EVAL      T0TDI1 = @PTDI1                                                  
e01  C                   ENDSL                                                                      
                                                                                                    
      * Leo lógicos en función a la Integridad de datos a Comprobar                                 
s01  C                   SELECT                                                                     
     C                   WHEN      @PLOGI = 0 And @PINTE = 1                                        
     C     KEDTRLP00     SETLL     EDTRLX00                                                         
     C     KEDTRLP00     READE     EDTRLX00                               82                        
     C                   WHEN      @PLOGI = 0 And @PINTE = 2                                        
     C     KEDTRLP00P    SETLL     EDTRLX00                                                         
     C     KEDTRLP00P    READE     EDTRLX00                               82                        
     C                   WHEN      @PLOGI = 1 And @PINTE = 1                                        
     C                             And @PARV1 = *BLANKS                                             
     C     KEDTRLP10     SETLL     EDTRLX10                                                         
     C     KEDTRLP10     READE     EDTRLX10                               82                        
     C                   WHEN      @PLOGI = 1 And @PINTE = 1                                        
     C                             And @PARV1 <> *BLANKS                                            
     C     KEDTRLP10X    SETLL     EDTRLX10                                                         
     C     KEDTRLP10X    READE     EDTRLX10                               82                        
     C                   WHEN      @PLOGI = 1 And @PINTE = 2                                        
     C     KEDTRLP10P    SETLL     EDTRLX10                                                         
     C     KEDTRLP10P    READE     EDTRLX10                               82                        
     C                   WHEN      @PLOGI = 2 And @PINTE = 1                                        
     C                             And @PCOM2 = *BLANKS                                             
     C     KEDTRLP20     SETLL     EDTRLX20                                                         
     C     KEDTRLP20     READE     EDTRLX20                               82                        
     C                   WHEN      @PLOGI = 2 And @PINTE = 1                                        
     C                             And @PCOM2 <> *BLANKS                                            
     C     KEDTRLP20X    SETLL     EDTRLX20                                                         
     C     KEDTRLP20X    READE     EDTRLX20                               82                        
     C                   WHEN      @PLOGI = 2 And @PINTE = 2                                        
     C     KEDTRLP20P    SETLL     EDTRLX20                                                         
     C     KEDTRLP20P    READE     EDTRLX20                               82                        
     C                   WHEN      @PLOGI = 3 And @PINTE = 1                                        
     C                             And @PEDAU <> '303' And @PEDAU <> '305'                          
     C     KEDTRLP30     SETLL     EDTRLX30                                                         
     C     KEDTRLP30     READE(N)  EDTRLX30                               82                        
     C                   WHEN      @PLOGI = 3 And @PINTE = 2                                        
     C                             And @PEDAU <> '303' And @PEDAU <> '305'                          
     C     KEDTRLP30P    SETLL     EDTRLX30                                                         
     C     KEDTRLP30P    READE(N)  EDTRLX30                               82                        
     C                   WHEN      @PLOGI = 3 And @PINTE = 1                                        
     C                             And (@PEDAU = '303' Or @PEDAU = '305')                           
     C     KEDTRLP30     SETLL     EDTRLX30                                                         
     C     KEDTRLP30     READE     EDTRLX30                               82                        
     C                   WHEN      @PLOGI = 3 And @PINTE = 2                                        
     C                             And (@PEDAU = '303' Or @PEDAU = '305')                           
     C     KEDTRLP30P    SETLL     EDTRLX30                                                         
     C     KEDTRLP30P    READE     EDTRLX30                               82                        
     C                   WHEN      (@PLOGI=0 Or @PLOGI=1 Or @PLOGI=2                                
     C                             Or @PLOGI = 3) And @PINTE = 3                                    
     C     KEDTRLP40     SETLL     EDTRLX40                                                         
     C     KEDTRLP40     READE     EDTRLX40                               82                        
e01  C                   ENDSL                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Lectura Fichero Trazas Según Origen e Integridad Datos                                      
      **********************************************************************                        
     C     CS_READFI2    BEGSR                                                                      
                                                                                                    
01070C                   EVAL      S5CIAS=@PCIAS                                                    
01070C                   EVAL      S5DLGA=@PDLGA                                                    
01070C                   EVAL      S5NPCO=@PNPCO                                                    
01070C                   EVAL      S5TPED=@PTPED                                                    
01070C                   EVAL      S5DATP=@PDATP                                                    
01070C                   EVAL      S5NOPL=@PNOPL                                                    
01070C                   EVAL      S5LINE=@PLINE                                                    
01070                                                                                               
      * Leo lógicos en función a la Integridad de datos a Comprobar                                 
s01  C                   SELECT                                                                     
     C                   WHEN      @PLOGI = 0 And @PINTE = 1                                        
     C     KEDTRLP00     READE     EDTRLP00                               82                        
     C                   WHEN      @PLOGI = 0 And @PINTE = 2                                        
     C     KEDTRLP00P    READE     EDTRLP00                               82                        
01070C                   EVAL      S5CIAS=@PCIAS                                                    
01070C                   EVAL      S5DLGA=@PDLGA                                                    
01070C                   EVAL      S5NPCO=@PNPCO                                                    
01070C                   EVAL      S5TPED=@PTPED                                                    
01070C                   EVAL      S5DATP=@PDATP                                                    
01070C                   EVAL      S5NOPL=@PNOPL                                                    
01070C                   EVAL      S5LINE=T0LINE                                                    
01070C     KCODEPE       CHAIN     CODEPE                                                           
     C                   WHEN      @PLOGI = 1 And @PINTE = 1                                        
     C                             And @PARV1 = *BLANKS                                             
     C     KEDTRLP10     READE     EDTRLP10                               82                        
01070C                   EVAL      S5CIAS=@PCIAS                                                    
01070C                   EVAL      S5DLGA=@PDLGA                                                    
01070C                   EVAL      S5NPCO=@PNPCO                                                    
01070C                   EVAL      S5TPED=@PTPED                                                    
01070C                   EVAL      S5DATP=@PDATP                                                    
01070C                   EVAL      S5NOPL=@PNOPL                                                    
01070C                   EVAL      S5LINE=T0LINE                                                    
     C                   WHEN      @PLOGI = 1 And @PINTE = 1                                        
     C                             And @PARV1 <> *BLANKS                                            
     C     KEDTRLP10X    READE     EDTRLP10                               82                        
01070C                   EVAL      S5CIAS=@PCIAS                                                    
01070C                   EVAL      S5DLGA=@PDLGA                                                    
01070C                   EVAL      S5NPCO=@PNPCO                                                    
01070C                   EVAL      S5TPED=@PTPED                                                    
01070C                   EVAL      S5DATP=@PDATP                                                    
01070C                   EVAL      S5NOPL=@PNOPL                                                    
01070C                   EVAL      S5LINE=T0LINE                                                    
     C                   WHEN      @PLOGI = 1 And @PINTE = 2                                        
     C     KEDTRLP10P    READE     EDTRLP10                               82                        
01070C                   EVAL      S5CIAS=@PCIAS                                                    
01070C                   EVAL      S5DLGA=@PDLGA                                                    
01070C                   EVAL      S5NPCO=@PNPCO                                                    
01070C                   EVAL      S5TPED=@PTPED                                                    
01070C                   EVAL      S5DATP=@PDATP                                                    
01070C                   EVAL      S5NOPL=@PNOPL                                                    
01070C                   EVAL      S5LINE=T0LINE                                                    
     C                   WHEN      @PLOGI = 2 And @PINTE = 1                                        
     C                             And @PCOM2 = *BLANKS                                             
     C     KEDTRLP20     READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI = 2 And @PINTE = 1                                        
     C                             And @PCOM2 <> *BLANKS                                            
     C     KEDTRLP20X    READE     EDTRLP20                               82                        
     C                   WHEN      @PLOGI = 2 And @PINTE = 2                                        
     C     KEDTRLP20P    READE     EDTRLP20                               82                        
01070C                   EVAL      S5LINE=T0LIN2                                                    
     C                   WHEN      @PLOGI = 3 And @PINTE = 1                                        
     C                             And @PEDAU <> '303' And @PEDAU <> '305'                          
     C     KEDTRLP30     READE(N)  EDTRLP30                               82                        
     C                   WHEN      @PLOGI = 3 And @PINTE = 2                                        
     C                             And @PEDAU <> '303' And @PEDAU <> '305'                          
     C     KEDTRLP30P    READE(N)  EDTRLP30                               82                        
01070C                   EVAL      S5LINE=T0LIN3                                                    
     C                   WHEN      @PLOGI = 3 And @PINTE = 1                                        
     C                             And (@PEDAU = '303' Or @PEDAU = '305')                           
     C     KEDTRLP30     READE     EDTRLP30                               82                        
     C                   WHEN      @PLOGI = 3 And @PINTE = 2                                        
     C                             And (@PEDAU = '303' Or @PEDAU = '305')                           
     C     KEDTRLP30P    READE     EDTRLP30                               82                        
01070C                   EVAL      S5LINE=T0LIN3                                                    
     C                   WHEN      (@PLOGI=0 Or @PLOGI=1 Or @PLOGI=2                                
     C                             Or @PLOGI = 3) And @PINTE = 3                                    
     C     KEDTRLP40     READE     EDTRLP40                               82                        
01070C                   EVAL      S5LINE=T0LINE                                                    
e01  C                   ENDSL                                                                      
01070                                                                                               
01070C     KCODEPE       CHAIN     CODEPE                                                           
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Lectura Fichero Eliminados Según Origen e Integridad Datos                                  
      **********************************************************************                        
     C     CS_READFX2    BEGSR                                                                      
                                                                                                    
      * Leo lógicos en función a la Integridad de datos a Comprobar                                 
s01  C                   SELECT                                                                     
     C                   WHEN      @PLOGI = 0 And @PINTE = 1                                        
     C     KEDTRLP00     READE     EDTRLX00                               82                        
     C                   WHEN      @PLOGI = 0 And @PINTE = 2                                        
     C     KEDTRLP00P    READE     EDTRLX00                               82                        
     C                   WHEN      @PLOGI = 1 And @PINTE = 1                                        
     C                             And @PARV1 = *BLANKS                                             
     C     KEDTRLP10     READE     EDTRLX10                               82                        
     C                   WHEN      @PLOGI = 1 And @PINTE = 1                                        
     C                             And @PARV1 <> *BLANKS                                            
     C     KEDTRLP10X    READE     EDTRLX10                               82                        
     C                   WHEN      @PLOGI = 1 And @PINTE = 2                                        
     C     KEDTRLP10P    READE     EDTRLX10                               82                        
     C                   WHEN      @PLOGI = 2 And @PINTE = 1                                        
     C                             And @PCOM2 = *BLANKS                                             
     C     KEDTRLP20     READE     EDTRLX20                               82                        
     C                   WHEN      @PLOGI = 2 And @PINTE = 1                                        
     C                             And @PCOM2 <> *BLANKS                                            
     C     KEDTRLP20X    READE     EDTRLX20                               82                        
     C                   WHEN      @PLOGI = 2 And @PINTE = 2                                        
     C     KEDTRLP20P    READE     EDTRLX20                               82                        
     C                   WHEN      @PLOGI = 3 And @PINTE = 1                                        
     C                             And @PEDAU <> '303' And @PEDAU <> '305'                          
     C     KEDTRLP30     READE(N)  EDTRLX30                               82                        
     C                   WHEN      @PLOGI = 3 And @PINTE = 2                                        
     C                             And @PEDAU <> '303' And @PEDAU <> '305'                          
     C     KEDTRLP30P    READE(N)  EDTRLX30                               82                        
     C                   WHEN      @PLOGI = 3 And @PINTE = 1                                        
     C                             And (@PEDAU = '303' Or @PEDAU = '305')                           
     C     KEDTRLP30     READE     EDTRLX30                               82                        
     C                   WHEN      @PLOGI = 3 And @PINTE = 2                                        
     C                             And (@PEDAU = '303' Or @PEDAU = '305')                           
     C     KEDTRLP30P    READE     EDTRLX30                               82                        
     C                   WHEN      (@PLOGI=0 Or @PLOGI=1 Or @PLOGI=2                                
     C                             Or @PLOGI = 3) And @PINTE = 3                                    
     C     KEDTRLP40     READE     EDTRLX40                               82                        
e01  C                   ENDSL                                                                      
                                                                                                    
     C                   ENDSR                                                                      
