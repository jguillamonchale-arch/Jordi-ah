      * Validaciones Modificaciones/anulaciones Comercial                                           
FQ787C*                  WHEN      @PEDAU = '007' Or @PEDAU = '008'                                 
FQ787C                   WHEN      @PEDAU = '007'                                                   
15090C**                           Or @PEDAU = '011' Or @PEDAU = '012'                              
15090C                             Or @PEDAU = '011'                                                
01070C                             Or @PEDAU = '013'                                                
     C                   EVAL      ZXWIND = '1'                                                     
     C                   EXSR      CS_SERVPRO                                                       
     C                   EXSR      CS_VALXDOC                                                       
     C**                 EXSR      CS_STSPR20                                                       
     C                   EXSR      CS_STSPR10                                                       
IN950C                   IF        @PEDAU<> '013'                                                   
     C                   EXSR      CS_CONTPED                                                       
ERRORC                   EXSR      CS_CONTPED_3                                                     
IN950C                   ENDIF                                                                      
R3820C*                  EXSR      CS_CONTPED_2                                                     
ERROR *                  EXSR      CS_CONTPED_3                                                     
15090C                   WHEN      @PEDAU = '012'                                                   
