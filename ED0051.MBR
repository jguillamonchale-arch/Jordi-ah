I0184 *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Validación Cambio de logística en productiva                                                
      **********************************************************************                        
     C     CS_CHGLOG     BEGSR                                                                      
                                                                                                    
      *Sumaré líneas que si permiten servir logística productiva                                    
b01  C                   IF        T0EDDP = 1                                                       
     C                   EVAL      ZXNDDP=ZXNDDP + 1                                                
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Validación Cantidad Servida aunque sea Parcial y no importa                                 
      * quien la ha servido si Trace o Productiva.                                                  
      **********************************************************************                        
     C     CS_CANTSER    BEGSR                                                                      
                                                                                                    
b01  C                   IF        T0CANS<>0                                                        
     C                   EVAL      @PERRO = '1'                                                     
     C                   EVAL      ZXINCI = '009'                                                   
     C                   EXSR      CS_DESERR                                                        
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
14060 **********************************************************************                        
14060 * Validación si la linea esta cerrada                                                         
14060 **********************************************************************                        
14060C     CS_LINCERR    BEGSR                                                                      
14060                                                                                               
14060C                   IF        T0EDST = '95'                                                    
14060C                   EVAL      @PERRO = '1'                                                     
14060C                   EVAL      ZXINCI = '015'                                                   
14060C                   EXSR      CS_DESERR                                                        
14060C                   ENDIF                                                                      
14060                                                                                               
14060C                   ENDSR                                                                      
FQ942                                                                                               
FQ942 **********************************************************************                        
FQ942 * Comprobar si es Conjunto en Productiva                                                      
FQ942 **********************************************************************                        
FQ942C     CS_CONJPRO    BEGSR                                                                      
FQ942                                                                                               
FQ942C                   IF        ZXES_COMPO<'1'                                                   
FQ942C                   CLEAR                   ZXCJTO_PROD                                        
FQ942C                   EVAL      ZXARVMX = ZYARVM                                                 
FQ942                                                                                               
FQ942C                   MOVEL     ZXCIAD        PPCIAS                                             
FQ942C     KPMLIBL       CHAIN     PMLIBL                                                           
FQ942 * MOVEX                                                                                       
FQ942C                   IF        %FOUND(PMLIBL) And PPMVXV = 'V'                                  
FQ942 * Buscar Compañía MOVEX                                                                       
FQ942C                   EXSR      CS_CIASMVX                                                       
FQ942C                   EXSR      CS_MVXLIBL                                                       
FQ942 * Busco Planta por defecto en la División                                                     
P1344C*                  Eval      File_cmndiv = LIBLMVX + '/CMNDIV00'                              
P1344C                   Eval      File_cmndiv = (%trim(LIBLMVX)) + '/CMNDIV00'                     
FQ942C                   OPEN (E)  CMNDIV00                                                         
FQ942C                   IF        Not %ERROR                                                       
FQ942C                   MOVEL     MXCONO        CCCONO                                             
FQ942C                   MOVEL     MXDIVI        CCDIVI                                             
FQ942C     KCMNDIV00     CHAIN     CMNDIV00                                                         
FQ942C                   IF        %FOUND(CMNDIV00)                                                 
FQ942 * Busco Si es Conjunto                                                                        
P1344C*                  Eval      File_mpdhed = LIBLMVX + '/MPDHED00'                              
P1344C                   Eval      File_mpdhed = (%trim(LIBLMVX)) + '/MPDHED00'                     
FQ942C                   OPEN (E)  MPDHED00                                                         
I0184C                   OPEN (E)  AQPEDI00                                                         
I0184C                   OPEN (E)  ZAQITN00                                                         
I0184C                   OPEN (E)  GMTABD01                                                         
I0184C                   OPEN (E)  MITFAC00                                                         
FQ942C                   IF        Not %ERROR                                                       
I0184 *                                                                                             
I0184 *             Ver si estamos en una división Multiplanta                                      
I0184C                   MOVEL(P)  MXCONO        Z1CONO                                             
I0184C                   EVAL      Z1DIVI = MXDIVI                                                  
I0184C     KAQPEDI00     CHAIN     AQPEDI00                                                         
I0184C                   EVAL      ZXMULTIPLA = %FOUND(AQPEDI00)                                    
I0184C                                          AND  Z1L101 = '1'                                   
FQ942C                   MOVEL     MXCONO        H_PHCONO                                           
I0184C**FQ942            MOVEL     CCFACI        H_PHFACI                                           
FQ942C                   MOVEL     ZXARVMX       H_PHPRNO                                           
I0184C                   EVAL      H_PHFACI = GET_FACI(MXDIVI:CCFACI:H_PHPRNO)                      
FQ942C                   MOVEL     'KIT'         H_PHSTRT                                           
FQ942C     KMPDHED00     CHAIN     MPDHED00                                                         
FQ942C                   IF        %FOUND(MPDHED00) And                                             
FQ942C                             H_PHSTAT >= '20' And H_PHSTAT < '90'                             
FQ942C                   EVAL      ZXCJTO_PROD='1'                                                  
FQ942C                   ENDIF                                                                      
FQ942C                   CLOSE(E)  MPDHED00                                                         
I0184C                   CLOSE(E)  AQPEDI00                                                         
I0184C                   CLOSE(E)  ZAQITN00                                                         
I0184C                   CLOSE(E)  GMTABD01                                                         
I0184C                   CLOSE(E)  MITFAC00                                                         
FQ942C                   ENDIF                                                                      
FQ942C                   ENDIF                                                                      
FQ942C                   ENDIF                                                                      
FQ942C                   CLOSE(E)  CMNDIV00                                                         
FQ942C                   ENDIF                                                                      
      *                                                                                             
FQ942 * AS400                                                                                       
FQ942C                   IF        %FOUND(PMLIBL) And PPMVXV <> 'V'                                 
FQ942 * Busco Si es Conjunto                                                                        
FQ942C                   EVAL      FileCojc_erp= 'PURLIBF' + PPCIAS +                               
FQ942C                                          '/MSCOJC'                                           
FQ942C                   OPEN (E)  MSCOJC                                                           
FQ942C                   IF        Not %ERROR                                                       
FQ942C                   EVAL      NDCIAS = ZXCIAD                                                  
FQ942C                   EVAL      NDARTI = ZXARTIX                                                 
FQ942C                   EVAL      NDVARI = ZXVARIX                                                 
FQ942C                   EVAL      NDMODE = ZXMODEX                                                 
FQ942C                   EVAL      NDTCOJ = '4'                                                     
FQ942C     KMSCOJC       CHAIN     MSCOJC                                                           
FQ942C                   IF        %FOUND(MSCOJC) AND NDBAJA<'1'                                    
FQ942C                   EVAL      ZXCJTO_PROD='1'                                                  
FQ942C                   ENDIF                                                                      
FQ942C                   CLOSE(E)  MSCOJC                                                           
FQ942C                   ENDIF                                                                      
FQ942C                   CLOSE(E)  MSCOJC                                                           
FQ942C                   ENDIF                                                                      
                                                                                                    
FQ942                                                                                               
FQ942C                   IF        ZXCJTO_PROD='1'     AND                                          
FQ942C                             ZXTCOJ<>'1'                                                      
FQ942C                   EVAL      @PERRO = '1'                                                     
FQ942C                   EVAL      ZXINCI = '050'                                                   
FQ942C                   EXSR      CS_DESERR                                                        
FQ942C                   ENDIF                                                                      
FQ942C                   ENDIF                                                                      
FQ942C                   ENDSR                                                                      
CR653 **************************************************************                                
CR653 * COMPROBAR SI EL PROVEEDOR ES DE ENTREGAS DIRECTAS          *                                
CR653 *------------------------------------------------------------*                                
CR653C     CS_PRV2       BEGSR                                                                      
CR653C                   CALL      'XBB001'                                                         
CR653C                   PARM      S5CIAS        @XCIAS                                             
CR653C                   PARM      S5ARTI        @XARTI                                             
CR653C                   PARM      S5VARI        @XVARI                                             
CR653C                   PARM      S5MODE        @XMODE                                             
CR653C                   PARM      *BLANKS       @XPRVR                                             
CR653C                   PARM      *BLANKS       @XGRUP                                             
CR653C                   PARM      *BLANKS       @XPEVT                                             
CR653C                   ENDSR                                                                      
C1579 **********************************************************************                        
C1579 * Validación en confirmación de pedidos PoolWeb (procedencia=50)                              
C1579 * No podremos cambiar la clase del pedido (TPE4=2)                                            
C1579 **********************************************************************                        
C1579C     CS_POOLWEB    Begsr                                                                      
C1579                                                                                               
C1579C                   eval      zxpweb='0'                                                       
C1579                                                                                               
C1579C                   eval      s0cias=@pcias                                                    
C1579C                   eval      s0dlga=@pdlga                                                    
C1579C                   eval      s0npco=@pnpco                                                    
C1579C                   eval      s0tped=@ptped                                                    
C1579C                   eval      s0datp=@pdatp                                                    
C1579C                   eval      s0nopl=@pnopl                                                    
C1579C     kcocape       chain     cocape                                                           
C1579 *                                                                                             
C1579 * Para saber si es un proveedor Poolweb,lo buscamos en la tabla                               
C1579 * PWEB con la procedencia del pedido.                                                         
C1579 *                                                                                             
C1579C                   if        %found(cocape)                                                   
C1579C                   eval      pecias=@pcias                                                    
C1579C                   eval      pectab='PWEB'                                                    
C1579C                   eval      peclta=s0pped                                                    
C1579C     kpmtabd       chain     pmtabd                                                           
C1579                                                                                               
C1579C                   if        %found(pmtabd)                                                   
C1579C                   eval      zxpweb='1'                                                       
C1579C                   movel     pedesc        zxprvr                                             
C1579 *                                                                                             
C1579C                   eval      c0cias=s0cias                                                    
C1579C                   eval      c0prvr=zxprvr                                                    
C1579C     kpuprov       chain     puprov                                                           
C1579 *                                                                                             
C1579c                   if        %found(puprov)                                                   
C1570C                   eval      zxprvd=c0des1                                                    
C1579C                   endif                                                                      
C1579                                                                                               
C1579C                   endif                                                                      
C1579C                   endif                                                                      
C1579                                                                                               
C1579C                   endsr                                                                      
Q4132**********************************************************************                        
Q4132*  Excepciones                                                *                               
Q4132**********************************************************************                        
Q4132c     cs_eiexce     begsr                                                                      
Q4132c                   eval      z0file = 'ED0051'                                                
Q4132c                   eval      z0cias = @PCIAS                                                  
Q4132c                   eval      z0cust =M5PRV2                                                   
Q4132c                   eval      z0grp2 = *blanks                                                 
Q4132c                   eval      z0camp = 'M5PRVR     '                                           
Q4132c     keiexce       chain     eiexce                                                           
Q4132c                   if        %found(eiexce)                                                   
Q4132C                   EVAL      ZXPRVR_DOM=M5PRV2                                                
Q4132C                   EVAL      M5PRVR=M5PRV2                                                    
Q4132c                   endif                                                                      
Q4132c                   endsr                                                                      
E7345 ******************************************************************************************    
E7345 * CS_LOG_WHSE: convertim la logística (virtual) en magatzem M3                                
E7345 ******************************************************************************************    
E7345c     CS_LOG_WHSE   begsr                                                                      
E7345c                   eval      pecias=@pcias                                                    
E7345c                   eval      pectab='INO2'                                                    
E7345c                   eval      peclta='MAGA'+s5loge                                             
E7345c     kpmtabd       chain     pmtabd                                                           
E7345c                   if        %found(pmtabd)                                                   
E7345c                   eval      xbwhlo=%trim(pedesc)                                             
E7345c                   else                                                                       
E7345c                   eval      xbwhlo=*blanks                                                   
E7345c                   endif                                                                      
E7345c                   endsr                                                                      
                                                                                                    
      ******************************************************************                            
OL205 *F-2OL *   Recuperar almacén a partir de la logística del pedido venta                        
OL205 *F-2OL **********************************************************************                 
OL205 *F-2OLC     SRrecu        BEGSR                                                               
OL205 *F-2OLC                   eval      @pECIA = s5cias                                           
OL205 *F-2OLC                   eval      @palma = s5loge                                           
OL205 *F-2OLC                   eval      @ptipo = '1'                                              
OL205 *F-2OLC                   eval      @pdlga = s5dlga                                           
OL205 *F-2OL *                                                                                      
OL205 *F-2OLC                   CALL      'MM1411'                                                  
OL205 *F-2OLC                   PARM                    @PECIA                                      
OL205 *F-2OLC                   PARM                    @PALMA                                      
OL205 *F-2OLC                   PARM                    @PTIPO                                      
OL205 *F-2OLC                   PARM                    @PDLGA                                      
OL205 *F-2OLC                   PARM      *blanks       @PRESP                                      
OL205 *F-2OL *                                                                                      
OL205 *F-2OLC                   if        @PRESP <>*blanks                                          
OL205 *F-2OLC                                                                                       
OL205 *           ol_m1maga = @PRESP;                                                               
OL205 *           chain (s5cias:s5arti:s5vari:s5mode:ol_m1maga) msstok01;                           
OL205 *                                                                                             
OL205 *F-2OLC                   IF        %FOUND                                                    
OL205 *F-2OLC                   IF        ol_m1prvr <> *blanks                                      
OL205 *F-2OLC                   movel     ol_M1PRVR     ZXPRVR_DOM                                  
OL205 *2OLC                   ENDIF                                                  ECSTK <= *Z    
OL205 *2OLC                   ENDIF                                                  ECSTK <= *Z    
OL205 *F-2OLC                   endif                                                               
OL205 *F-2OLC                   ENDSR                                                               
OL205 *      ******************************************************************                     
OL205 *F-2OL *   Recuperar almacén a partir de la logística del pedido venta                        
OL205 *F-2OL **********************************************************************                 
OL205 *F-2OLC     SRrecu2       BEGSR                                                               
OL205 *F-2OLC                   eval      @pECIA = s5cias                                           
OL205 *F-2OLC                   eval      @palma = s5loge                                           
OL205 *F-2OLC                   eval      @ptipo = '1'                                              
OL205 *F-2OLC                   eval      @pdlga = s5dlga                                           
OL205 *F-2OL *                                                                                      
OL205 *F-2OLC                   CALL      'MM1411'                                                  
OL205 *F-2OLC                   PARM                    @PECIA                                      
OL205 *F-2OLC                   PARM                    @PALMA                                      
OL205 *F-2OLC                   PARM                    @PTIPO                                      
OL205 *F-2OLC                   PARM                    @PDLGA                                      
OL205 *F-2OLC                   PARM      *blanks       @PRESP                                      
OL205 *F-2OL *                                                                                      
OL205 *F-2OLC                   if        @PRESP <>*blanks                                          
OL205 *F-2OLC                                                                                       
OL205 *           ol_m1maga = @PRESP;                                                               
OL205 *           chain (s5cias:ndcomp:ndvar2:ndmod2:ol_m1maga) msstok01;                           
OL205 *                                                                                             
OL205 *F-2OLC                   IF        %FOUND                                                    
OL205 *F-2OLC                   IF        ol_m1prvr <> *blanks                                      
OL205 *F-2OLC                   movel     ol_M1PRVR     ZXPRVR_DOM                                  
OL205 *2OLC                   ENDIF                                                  ECSTK <= *Z    
OL205 *2OLC                   ENDIF                                                  ECSTK <= *Z    
OL205 *F-2OLC                   endif                                                               
OL205 *F-2OLC                   ENDSR                                                               
OL205 // Add tot el procediment                                                                     
       dcl-proc SRrecu;                                                                             
       dcl-pi *n like(m0prvr);                                                                      
         pArti like (s5arti);                                                                       
         pVari like (s5vari);                                                                       
         pMode like (s5mode);                                                                       
       end-pi;                                                                                      
       //Tool per virtuals i d'altres                                                              
       dcl-pr pMM1411 extpgm('MM1411');                                                             
           @cias  like(s5cias) const;                                                               
           @maga  like(m0maga) const;                                                               
           @tipo  char(1) const;                                                                    
           @dlga  like(s0dlga) const;                                                               
           @resp  like(@presp);                                                                     
       end-pr;                                                                                      
       dcl-s xloge like(m0maga) inz;                                                                
       dcl-s xmaga like(m0maga) inz;                                                                
                                                                                                    
         if g0LOGE <> *blanks;                                                                      
           xloge = g0LOGE;                                                                          
         else;                                                                                      
           xloge = s5loge;                                                                          
         endif;                                                                                     
                                                                                                    
         pMM1411(s5cias:xloge:'1':s5dlga:@presp);                                                   
                                                                                                    
         if @presp <> *blanks;                                                                      
           xmaga = @presp;                                                                          
           chain (s5cias:parti:pvari:pmode:xmaga) msstok01;                                         
           if %found(msstok01);                                                                     
             if ol_m1prvr <> *blanks;                                                               
               return ol_m1prvr;                                                                    
             endif;                                                                                 
           endif;                                                                                   
           chain (s5cias:xmaga) msalma;                                                             
           if %found(msalma);                                                                       
             return m0prvr;                                                                         
           endif;                                                                                   
         endif;                                                                                     
         return *blanks;                                                                            
                                                                                                    
       end-proc;                                                                                    
OL205 // End tot el procediment                                                                     
I0184 ******************************************************************************************    
I0184 * OBTENER PLANTA PARA ACCEDER A DATOS DEL ARTÍCULO                                            
I0184 ******************************************************************************************    
I0184 *                                                                                             
I0184P GET_FACI        B                                                                            
I0184D GET_FACI        PI                  LIKE(MMCIAS)                                             
I0184D   @DIVI                             LIKE(MMPROP) VALUE                                       
I0184D   @FACI                             LIKE(MMCIAS) VALUE                                       
I0184D   @ITNO                             LIKE(MMITNO) VALUE                                       
I0184 *                                                                                             
I0184C                   IF        ZXMULTIPLA                                                       
I0184 *                                                                                             
I0184 * Si existe registro en ZAQITN en el que la división es propietaria, entonces                 
I0184 * se devuelve la planta propietaria del artículo.                                             
I0184 *                                                                                             
I0184C                   MOVEL(P)  MXCONO        MMCONO                                             
I0184C                   EVAL      MMITNO = @ITNO                                                   
I0184C     KZAQITN00     CHAIN     ZAQITN00                                                         
I0184C                   IF        %FOUND  AND  MMPROP = @DIVI  AND                                 
I0184C                             MMCIAS <> *BLANKS                                                
I0184C                   RETURN    MMCIAS                                                           
I0184C                   ENDIF                                                                      
I0184 *                                                                                             
I0184 * Si la división no es la propietaria, se hace bucle sobre la tabla FACP y                    
I0184 * se devuelve la primera para la que exista MITFAC                                            
I0184 *                                                                                             
I0184C                   MOVEL(P)  MXCONO        M9CONO                                             
I0184C                   EVAL      M9ITNO = @ITNO                                                   
I0184 *                                                                                             
I0184C                   EVAL      T1CTAB = 'FACP'                                                  
I0184C                   EVAL      T1DESC = @DIVI                                                   
I0184C     KGMTABD01     SETLL     GMTABD01                                                         
I0184C     KGMTABD01     READE     GMTABD01                                                         
I0184 *                                                                                             
I0184C                   DOW       NOT %EOF                                                         
I0184 *                                                                                             
I0184C                   EVAL      M9FACI = T1CELE                                                  
I0184C     KMITFAC00     SETLL     MITFAC00                                                         
I0184C                   IF        %EQUAL                                                           
I0184C                   RETURN    M9FACI                                                           
I0184C                   ENDIF                                                                      
I0184 *                                                                                             
I0184C     KGMTABD01     READE     GMTABD01                                                         
I0184C                   ENDDO                                                                      
I0184 *                                                                                             
I0184C                   ENDIF                                                                      
I0184 *                                                                                             
I0184 * Si la división no es multiplanta, o la búsqueda anterior no ha dado frutos,                 
I0184 * devolver la planta entrada                                                                  
I0184 *                                                                                             
I0184C                   RETURN    @FACI                                                            
I0184 *                                                                                             
I0184P                 E                                                                            
