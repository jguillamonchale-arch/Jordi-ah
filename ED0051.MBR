CR653C                   IF        ZXPVEX<>'1'                                                      
b01  C                   IF        T0STCP >= '10'                                                   
     C                   EVAL      @PERRO = '1'                                                     
     C                   EVAL      ZXINCI = '006'                                                   
     C                   EXSR      CS_DESERR                                                        
e01  C                   ENDIF                                                                      
CR653C                   ENDIF                                                                      
                                                                                                    
