      **********************************************************************                        
      * Modificación en Curso                                                                       
      **********************************************************************                        
     C     CS_MODCURS    BEGSR                                                                      
                                                                                                    
b01  C                   IF        T0MODI = 1                                                       
                                                                                                    
      * Si No es Material Propio                                                                    
b02  C                   IF        T0CIA1 > 0                                                       
      * Busco modificación en TR0036 de comercial                                                   
b03  C                   IF        T0CIA1 > 0                                                       
     C                   MOVEL     T0CIA1        PPCIAS                                             
     C                   EVAL      FileTr36_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/TR003602'                                         
     C                   OPEN (E)  TR003602                                                         
b04  C                   IF        Not %ERROR                                                       
     C                   EVAL      C5CIAS=T0CIA1                                                    
     C                   EVAL      C5DLGA=T0DLG1                                                    
     C                   EVAL      C5NPCO=T0NPC1                                                    
     C                   EVAL      C5TPED=T0TPE1                                                    
     C                   EVAL      C5DATP=T0DAT1                                                    
     C                   EVAL      C5NOPL=T0NOP1                                                    
     C                   EVAL      C5LINE=T0LIN1                                                    
     C     KTR003602     CHAIN     TR003602                                                         
b05  C                   IF        %FOUND(TR003602)                                                 
FQ710C                             And C5DEST='AS400OL'                                             
     C                   EVAL      @PERRO = '1'                                                     
     C                   GOTO      TERROR                                                           
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
     C                   CLOSE(E)  TR003602                                                         
e03  C                   ENDIF                                                                      
                                                                                                    
      * Busco modificación en WR0036 de Productiva                                                  
b03  C                   IF        T0CIA1 > 0                                                       
     C                   MOVEL     T0CIA2        PPCIAS                                             
     C                   EVAL      FileWr36_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/WR003602'                                         
     C                   OPEN (E)  WR003602                                                         
b04  C                   IF        Not %ERROR                                                       
     C                   EVAL      C5CIAS=T0CIA1                                                    
     C                   EVAL      C5DLGA=T0DLG1                                                    
     C                   EVAL      C5NPCO=T0NPC1                                                    
     C                   EVAL      C5TPED=T0TPE1                                                    
     C                   EVAL      C5DATP=T0DAT1                                                    
     C                   EVAL      C5NOPL=T0NOP1                                                    
     C                   EVAL      C5LINE=T0LIN1                                                    
     C     KTR003602     CHAIN     WR003602                                                         
b05  C                   IF        %FOUND(WR003602)                                                 
     C                   EVAL      @PERRO = '1'                                                     
     C                   GOTO      TERROR                                                           
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
     C                   CLOSE(E)  WR003602                                                         
e03  C                   ENDIF                                                                      
                                                                                                    
      * Busco modificación en TR0026 de Productiva                                                  
b03  C                   IF        T0CIA2 > 0                                                       
     C                   MOVEL     T0CIA2        PPCIAS                                             
     C                   EVAL      FileTr26_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/TR002602'                                         
     C                   OPEN (E)  TR002602                                                         
b04  C                   IF        Not %ERROR                                                       
01070C                   EVAL      TR_S5CIAS=T0CIA2                                                 
01070C                   EVAL      TR_S5DLGA=T0DLG2                                                 
01070C                   EVAL      TR_S5NPCO=T0NPC2                                                 
01070C                   EVAL      TR_S5TPED=T0TPE2                                                 
01070C                   EVAL      TR_S5DATP=T0DAT2                                                 
01070C                   EVAL      TR_S5NOPL=T0NOP2                                                 
01070C                   EVAL      TR_S5LINE=T0LIN2                                                 
     C     KTR002602     CHAIN     TR002602                                                         
b05  C                   IF        %FOUND(TR002602)                                                 
FQ710C                             And TR_S5DEST='AS400OL'                                          
     C                   EVAL      @PERRO = '1'                                                     
     C                   GOTO      TERROR                                                           
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
     C                   CLOSE(E)  TR002602                                                         
e03  C                   ENDIF                                                                      
                                                                                                    
      * Busco modificación en WR0026 de Trace                                                       
b03  C                   IF        T0CIA2 > 0                                                       
     C                   MOVEL     T0CIA3        PPCIAS                                             
     C                   EVAL      FileWr26_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/WR002602'                                         
     C                   OPEN (E)  WR002602                                                         
b04  C                   IF        Not %ERROR                                                       
01070C                   EVAL      TR_S5CIAS=T0CIA2                                                 
01070C                   EVAL      TR_S5DLGA=T0DLG2                                                 
01070C                   EVAL      TR_S5NPCO=T0NPC2                                                 
01070C                   EVAL      TR_S5TPED=T0TPE2                                                 
01070C                   EVAL      TR_S5DATP=T0DAT2                                                 
01070C                   EVAL      TR_S5NOPL=T0NOP2                                                 
01070C                   EVAL      TR_S5LINE=T0LIN2                                                 
     C     KTR002602     CHAIN     WR002602                                                         
b05  C                   IF        %FOUND(WR002602)                                                 
     C                   EVAL      @PERRO = '1'                                                     
     C                   GOTO      TERROR                                                           
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
     C                   CLOSE(E)  WR002602                                                         
e03  C                   ENDIF                                                                      
                                                                                                    
x02  C                   ELSE                                                                       
      * Si es Material Propio                                                                       
                                                                                                    
      * Busco modificación en TR0026 de Comercial                                                   
b03  C                   IF        T0CIAS > 0                                                       
     C                   MOVEL     T0CIAS        PPCIAS                                             
     C                   EVAL      FileTr26_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/TR002602'                                         
     C                   OPEN (E)  TR002602                                                         
b04  C                   IF        Not %ERROR                                                       
01070C                   EVAL      TR_S5CIAS=T0CIAS                                                 
01070C                   EVAL      TR_S5DLGA=T0DLGA                                                 
01070C                   EVAL      TR_S5NPCO=T0NPCO                                                 
01070C                   EVAL      TR_S5TPED=T0TPED                                                 
01070C                   EVAL      TR_S5DATP=T0DATP                                                 
01070C                   EVAL      TR_S5NOPL=T0NOPL                                                 
01070C                   EVAL      TR_S5LINE=T0LINE                                                 
     C     KTR002602     CHAIN     TR002602                                                         
b05  C                   IF        %FOUND(TR002602)                                                 
FQ710C                             And TR_S5DEST='AS400OL'                                          
     C                   EVAL      @PERRO = '1'                                                     
     C                   GOTO      TERROR                                                           
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
     C                   CLOSE(E)  TR002602                                                         
e03  C                   ENDIF                                                                      
                                                                                                    
      * Busco modificación en WR0026 de Trace                                                       
b03  C                   IF        T0CIAS > 0                                                       
     C                   MOVEL     T0CIA3        PPCIAS                                             
     C                   EVAL      FileWr26_erp= 'PURLIBF' + PPCIAS +                               
     C                                          '/WR002602'                                         
     C                   OPEN (E)  WR002602                                                         
b04  C                   IF        Not %ERROR                                                       
01070C                   EVAL      TR_S5CIAS=T0CIAS                                                 
01070C                   EVAL      TR_S5DLGA=T0DLGA                                                 
01070C                   EVAL      TR_S5NPCO=T0NPCO                                                 
01070C                   EVAL      TR_S5TPED=T0TPED                                                 
01070C                   EVAL      TR_S5DATP=T0DATP                                                 
01070C                   EVAL      TR_S5NOPL=T0NOPL                                                 
01070C                   EVAL      TR_S5LINE=T0LINE                                                 
     C     KTR002602     CHAIN     WR002602                                                         
b05  C                   IF        %FOUND(WR002602)                                                 
     C                   EVAL      @PERRO = '1'                                                     
     C                   GOTO      TERROR                                                           
e05  C                   ENDIF                                                                      
e04  C                   ENDIF                                                                      
     C                   CLOSE(E)  WR002602                                                         
e03  C                   ENDIF                                                                      
e02  C                   ENDIF                                                                      
                                                                                                    
     C     TERROR        TAG                                                                        
b02  C                   IF        @PERRO = '1'                                                     
     C                   EVAL      ZXINCI = '014'                                                   
     C                   EXSR      CS_DESERR                                                        
x02  C                   ELSE                                                                       
      * Si ya no existen registros pendientes de procesar elimino el                                
      * campo de Modificación                                                                       
FQ710C                   IF        @PINTE <> 3                                                      
     C                   EVAL      T0MODI=0                                                         
     C                   UPDATE    REDTRLP30                                                        
FQ710C                   ENDIF                                                                      
e02  C                   ENDIF                                                                      
                                                                                                    
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Validación Pedido Retenido                                                                  
      **********************************************************************                        
     C     CS_PEDHOLD    BEGSR                                                                      
                                                                                                    
b01  C                   IF        T0PHLD = 1                                                       
     C                   EVAL      @PERRO = '1'                                                     
     C                   EVAL      ZXINCI = '013'                                                   
     C                   EXSR      CS_DESERR                                                        
e01  C                   ENDIF                                                                      
                                                                                                    
