     C                   EVAL      @PERRO = '1'                                                     
     C                   EVAL      ZXINCI = '007'                                                   
C1350C                   IF        T0RISK = 2                                                       
C1350C                   EVAL      ZXINCI = '020'                                                   
C1350C                   ENDIF                                                                      
     C                   EXSR      CS_DESERR                                                        
