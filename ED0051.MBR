FQ942C                   EVAL      ZXES_COMPO=*BLANKS                                               
      * Miramos si es Conjunto de Venta                                                             
     C                   EVAL      ZXTCOJ=' '                                                       
     C                   EVAL      NDCIAS=S5CIAS                                                    
     C                   EVAL      NDARTI=S5ARTI                                                    
     C                   EVAL      NDMODE=S5MODE                                                    
     C                   EVAL      NDVARI=S5VARI                                                    
     C                   EVAL      NDTCOJ='4'                                                       
     C     KMSCOJC       CHAIN     MSCOJC                                                           
b02  C                   IF        %FOUND(MSCOJC) AND NDBAJA<'1'                                    
I0164 *                                                                                             
I0164 * Miramos que el conjunto está asignado al proveedor para poder comprarse como Kit;           
I0164 * sino, deberán de comprarse por los componentes de venta (no existira como Kit)              
I0164 *                                                                                             
C5958C*                  EVAL      KitAsigPrv=*on                                                   
I0164 *     Primero miramos si existe alguna asignación para el Kit                                 
C5958C*                  EVAL      P_C3CIAS=S5CIAS                                                  
C5958C*                  EVAL      P_C3ARVM=S5ARTI                                                  
C5958C*                  EVAL      P_C3TCOJ='1'                                                     
C5958C*    KPUPRCJa      CHAIN     PUPRCJ                                                           
I0164 *                                                                                             
I0164 *     Si existe, miramos si existe para nuestro proveedor                                     
C5958C*                  IF        %FOUND(PUPRCJ)                                                   
C5958C*                  EVAL      P_C3PRVR=ZXPRVR                                                  
C5958C*    KPUPRCJ       CHAIN     PUPRCJ                                                           
C5958C*                  IF        not %FOUND(PUPRCJ)                                               
C5958C*                  EVAL      KitAsigPrv=*off                                                  
C5958C*                  ENDIF                                                                      
C5958C*                  ENDIF                                                                      
I0164 *                                                                                             
E7218 *                                                                                             
E7218C                   EVAL      KitAsigPrv=*oFF                                                  
E7218C                   EVAL      P_C3CIAS=S5CIAS                                                  
E7218C                   EVAL      P_C3ARVM=S5ARTI                                                  
E7218C                   EVAL      P_C3TCOJ='1'                                                     
E7218C                   EVAL      P_C3PRVR=ZXPRVR                                                  
E7218C     KPUPRCJ       CHAIN     PUPRCJ                                                           
E7218C                   IF        NOT %FOUND(PUPRCJ)                                               
E7218C     KPUPRCJa      CHAIN     PUPRCJ                                                           
E7218C                   IF        %FOUND(PUPRCJ)                                                   
E7218C                   EVAL      KitAsigPrv=*off                                                  
E7218C                   ELSE                                                                       
E7218C                   EVAL      KitAsigPrv=*oN                                                   
E7218C                   ENDIF                                                                      
E7218C                   ELSE                                                                       
E7218C                   EVAL      KitAsigPrv=*oN                                                   
E7218C                   ENDIF                                                                      
E7218 *                                                                                             
