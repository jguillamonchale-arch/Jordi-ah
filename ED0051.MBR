      * En función del código de Auditoria hago las validaciones                                    
s02  C                   SELECT                                                                     
C1983 * Validaciones No permitir modificar pedidos PoolWeb/por usuario                              
C1983C                   WHEN      @PEDAU='005'   AND ZXPWEB='1'                                    
C1983C                             OR @PEDAU='006'   AND ZXPWEB='1'                                 
C1983C                             OR @PEDAU='007'   AND ZXPWEB='1'                                 
C1983C                             OR @PEDAU='008'   AND ZXPWEB='1'                                 
C1983C                             OR @PEDAU='011'   AND ZXPWEB='1'                                 
C1983C                             OR @PEDAU='012'   AND ZXPWEB='1'                                 
C1983C                             OR @PEDAU='018'   AND ZXPWEB='1'                                 
C1983C                             OR @PEDAU='019'   AND ZXPWEB='1'                                 
C1983C                             OR @PEDAU='026'   AND ZXPWEB='1'                                 
C1983C* Si pedido PoolWeb comprobar usuario que intenta modificar                                   
C1983C                   EVAL      PECIAS=@PCIAS                                                    
C1983C                   EVAL      PECTAB='USPW'                                                    
C1983C                   EVAL      PECLTA=SDSUSR                                                    
C1983C     KPMTABD       CHAIN     PMTABD                                                           
C1983C                   IF        NOT%FOUND(PMTABD)                                                
C1983C                   EVAL      zxinci = '024'                                                   
C1983C                   EVAL      @PERRO = '1'                                                     
C1983C                   EVAL      ZXWIND = '1'                                                     
C1983C                   EXSR      CS_DESERR                                                        
C1983C                   ENDIF                                                                      
      * Validaciones Anulación línea Comercial                                                      
     C                   WHEN      @PEDAU = '005'                                                   
     C                              OR @PEDAU = '009'                                               
