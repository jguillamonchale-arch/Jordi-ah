FQ710C                   EVAL      ZXNPC34 = T0NPC3                                                 
FQ710C                   EVAL      ZXLIN34 = T0LIN3                                                 
FQ710                                                                                               
FQ710C                   ENDSR                                                                      
FQ710 **********************************************************************                        
FQ710 * Restauro clave lógico 30                                                                    
FQ710 **********************************************************************                        
FQ710C     CS_RSTLOG3    BEGSR                                                                      
FQ710                                                                                               
FQ710C                   IF        T0CIA3<>ZXCIA3 Or T0DLG3<>ZXDLG3 Or                              
FQ710C                             T0NPC3<>ZXNPC3 Or T0TPE3<>ZXTPE3 Or                              
FQ710C                             T0DAT3<>ZXDAT3 Or T0NOP3<>ZXNOP3 Or                              
FQ710C                             T0LIN3<>ZXLIN3                                                   
FQ710C                             Or T0CIAS<>ZXCIAS3 Or T0DLGA<>ZXDLGA3                            
FQ710C                             Or T0NPCO<>ZXNPCO3 Or T0TPED<>ZXTPED3                            
FQ710C                             Or T0DATP<>ZXDATP3 Or T0NOPL<>ZXNOPL3                            
FQ710C                             Or T0LINE<>ZXLINE3 Or T0ARV1<>ZXARV13                            
FQ710C                             Or T0COM2<>ZXCOM23                                               
FQ710C                   EVAL      T0CIA3 = ZXCIA3                                                  
FQ710C                   EVAL      T0DLG3 = ZXDLG3                                                  
FQ710C                   EVAL      T0NPC3 = ZXNPC3                                                  
FQ710C                   EVAL      T0TPE3 = ZXTPE3                                                  
FQ710C                   EVAL      T0DAT3 = ZXDAT3                                                  
FQ710C                   EVAL      T0NOP3 = ZXNOP3                                                  
FQ710C                   EVAL      T0LIN3 = ZXLIN3                                                  
FQ710C                   EVAL      T0CIAS = ZXCIAS3                                                 
FQ710C                   EVAL      T0DLGA = ZXDLGA3                                                 
FQ710C                   EVAL      T0NPCO = ZXNPCO3                                                 
FQ710C                   EVAL      T0TPED = ZXTPED3                                                 
FQ710C                   EVAL      T0DATP = ZXDATP3                                                 
FQ710C                   EVAL      T0NOPL = ZXNOPL3                                                 
FQ710C                   EVAL      T0LINE = ZXLINE3                                                 
FQ710C                   EVAL      T0ARV1 = ZXARV13                                                 
FQ710C                   EVAL      T0COM2 = ZXCOM23                                                 
FQ710C     KEDTRLP300    CHAIN(N)  EDTRLP30                                                         
FQ710C                   ENDIF                                                                      
FQ710                                                                                               
FQ710C                   ENDSR                                                                      
FQ710 **********************************************************************                        
FQ710 * Restauro clave lógico 40                                                                    
FQ710 **********************************************************************                        
FQ710C     CS_RSTLOG4    BEGSR                                                                      
FQ710                                                                                               
FQ710C                   IF        T0CIAS<>ZXCIAS4 Or T0CUST<>ZXCUST4 Or                            
FQ710C                             T0TDI1<>ZXTDI14 Or T0DLGA<>ZXDLGA4 Or                            
FQ710C                             T0NPCO<>ZXNPCO4 Or T0TPED<>ZXTPED4 Or                            
FQ710C                             T0DATP<>ZXDATP4 Or T0NOPL<>ZXNOPL4 Or                            
FQ710C                             T0LINE<>ZXLINE4 Or T0ARV1<>ZXARV14 Or                            
FQ710C                             T0COM2<>ZXCOM24 Or T0NPC3<>ZXNPC34 Or                            
FQ710C                             T0LIN3<>ZXLIN34                                                  
FQ710C                   EVAL      T0CIAS = ZXCIAS4                                                 
FQ710C                   EVAL      T0CUST = ZXCUST4                                                 
FQ710C                   EVAL      T0TDI1 = ZXTDI14                                                 
FQ710C                   EVAL      T0DLGA = ZXDLGA4                                                 
FQ710C                   EVAL      T0NPCO = ZXNPCO4                                                 
FQ710C                   EVAL      T0TPED = ZXTPED4                                                 
FQ710C                   EVAL      T0DATP = ZXDATP4                                                 
FQ710C                   EVAL      T0NOPL = ZXNOPL4                                                 
FQ710C                   EVAL      T0LINE = ZXLINE4                                                 
FQ710C                   EVAL      T0ARV1 = ZXARV14                                                 
FQ710C                   EVAL      T0COM2 = ZXCOM24                                                 
FQ710C                   EVAL      T0NPC3 = ZXNPC34                                                 
FQ710C                   EVAL      T0LIN3 = ZXLIN34                                                 
FQ710C     KEDTRLP400    CHAIN     EDTRLP40                                                         
FQ710C                   ENDIF                                                                      
FQ710                                                                                               
FQ710C                   ENDSR                                                                      
      **********************************************************************                        
      * Descripción Errores                                                                         
      **********************************************************************                        
     C     CS_DESERR     BEGSR                                                                      
                                                                                                    
      * Monto extensión del Error                                                                   
     C                   MOVEL     *BLANKS       WWEXTE                                             
                                                                                                    
     C                   EVAL      @PINCI = ZXINCI                                                  
FQ710                                                                                               
FQ710C                   IF        @PINTE <> 3 Or @PEDAU = '305'                                    
s01  C                   SELECT                                                                     
      * Errores en Alta linea comercial                                                             
     C                   WHEN      ZXINCI = '001' Or ZXINCI = '002'                                 
     C                             Or ZXINCI = '003' Or ZXINCI = '005'                              
CR528C                             or ZXINCI='019'                                                  
     C                   EVAL      S01TLIN = 'Lín'                                                  
     C                   MOVEL     S5LINE        S01LINE                                            
     C                   EVAL      S01TART = 'Art'                                                  
     C                   EVAL      S01ARTI = M5ARTI                                                 
     C                   EVAL      S01TPRO = 'Pro'                                                  
C1078C*                  EVAL      S01PROV = M5PRVR                                                 
C1078C                   EVAL      S01PROV = ZXPRVR_DOM                                             
      * Errores en modificaciones/bajas linea comercial                                             
     C                   WHEN      ZXINCI = '006'                                                   
     C                             Or ZXINCI = '007' Or ZXINCI = '008'                              
     C                             Or ZXINCI = '009' Or ZXINCI = '011'                              
     C                             Or ZXINCI = '012' Or ZXINCI = '013'                              
14060C                             Or ZXINCI = '014' Or ZXINCI = '015'                              
FQ710C                             Or ZXINCI = '018'                                                
C1350C                             Or ZXINCI = '020'                                                
C1579C                             Or ZXINCI = '021'                                                
C1579C                             Or ZXINCI = '022'                                                
C1983C                             Or ZXINCI = '024'                                                
     C                   EVAL      S01TLIN = 'Lín'                                                  
     C                   MOVEL     T0LINE        S01LINE                                            
     C                   EVAL      S01TART = 'Art'                                                  
     C                   MOVEL     T0ARVM        S01ARTI                                            
     C                   EVAL      S01TPRO = 'Cli'                                                  
     C                   MOVEL     T0CUST        S01PROV                                            
      * Errores en trazabilidad EDTRLP                                                              
     C                   WHEN      ZXINCI = '004'                                                   
     C                   EVAL      S01TLIN = 'Lín'                                                  
     C                   MOVEL     T0LINE        S01LINE                                            
     C                   EVAL      S01TART = 'Ped'                                                  
     C                   MOVEL     T0NPCO        S01ARTI                                            
     C                   EVAL      S01TPRO = 'Cli'                                                  
     C                   MOVEL     T0CUST        S01PROV                                            
      * Errores en integridad conjunto en Trace                                                     
     C                   WHEN      ZXINCI = '010'                                                   
FQ710C                             Or ZXINCI = '016' Or ZXINCI = '017'                              
     C                   EVAL      S01TLIN = 'Lín'                                                  
     C                   MOVEL     T0LIN3        S01LINE                                            
     C                   EVAL      S01TART = 'Art'                                                  
b02  C                   IF        SAARTI <> *BLANKS                                                
     C                   MOVEL     SAARTI        S01ARTI                                            
x02  C                   ELSE                                                                       
     C                   MOVEL     S5ARTI        S01ARTI                                            
e02  C                   ENDIF                                                                      
     C                   EVAL      S01TPRO = 'Ped'                                                  
     C                   MOVEL     T0NPC3        S01PROV                                            
e01  C                   ENDSL                                                                      
                                                                                                    
      * Busco el numero de error que toca                                                           
     C                   EVAL      ZW=1                                                             
     C     *BLANKS       LOOKUP    SERROR(ZW)                             81                        
                                                                                                    
      * Busco descripción error y lleno las series                                                  
     C                   EVAL      NZCTAB = 'EDER'                                                  
     C                   EVAL      NZCLTA = ZXINCI                                                  
     C                   EVAL      NZIDIO = P7IDIO                                                  
     C     KMSTRG1       CHAIN     MSTRG1                                                           
b01  C                   IF        %FOUND(MSTRG1)                                                   
     C                   MOVEL     NZDESC        SERROR(ZW)                                         
     C                   MOVEL     WWEXTE        SDERROR(ZW)                                        
x01  C                   ELSE                                                                       
     C                   EVAL      PECTAB = 'EDER'                                                  
     C                   EVAL      PECLTA = ZXINCI                                                  
     C     KPMTAB2       CHAIN     PMTAB2                                                           
b02  C                   IF        %FOUND(PMTAB2)                                                   
     C                   MOVEL     PEDESC        SERROR(ZW)                                         
     C                   MOVEL     WWEXTE        SDERROR(ZW)                                        
e02  C                   ENDIF                                                                      
e01  C                   ENDIF                                                                      
FQ710C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Mostrar Pantalla Error                                                                      
      **********************************************************************                        
     C     CS_WINDOW     BEGSR                                                                      
                                                                                                    
b01  C                   IF        @PTIPJ>'0' And ZXWIND = '1'                                      
     C                             And @PERRO = '1'                                                 
      * Grabo campos de Pantallas si hay errores en las series                                      
     C                   EVAL      ZW=1                                                             
     C     *BLANKS       LOOKUP    SERROR(ZW)                             81                        
                                                                                                    
b02  C                   IF        ZW>1                                                             
     C                   EVAL      ZW=ZW-1                                                          
      * Grabo fichero de Control                                                                    
f03  C                   FOR       X=1 to ZW                                                        
s04  C                   SELECT                                                                     
     C                   WHEN      X=1                                                              
     C                   MOVEL     SERROR(X)     W01ERR1                                            
     C                   MOVEL     SDERROR(X)    W01EXT1                                            
     C                   WHEN      X=2                                                              
     C                   MOVEL     SERROR(X)     W01ERR2                                            
     C                   MOVEL     SDERROR(X)    W01EXT2                                            
     C                   WHEN      X=3                                                              
     C                   MOVEL     SERROR(X)     W01ERR3                                            
     C                   MOVEL     SDERROR(X)    W01EXT3                                            
     C                   WHEN      X=4                                                              
     C                   MOVEL     SERROR(X)     W01ERR4                                            
     C                   MOVEL     SDERROR(X)    W01EXT4                                            
     C                   WHEN      X=5                                                              
     C                   MOVEL     SERROR(X)     W01ERR5                                            
     C                   MOVEL     SDERROR(X)    W01EXT5                                            
     C                   OTHER                                                                      
     C                   LEAVE                                                                      
e04  C                   ENDSL                                                                      
                                                                                                    
e03  C                   ENDFOR                                                                     
e02  C                   ENDIF                                                                      
                                                                                                    
      * Visualizo Pantalla                                                                          
     C                   EXFMT     W01                                                              
                                                                                                    
e01  C                   ENDIF                                                                      
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Recuperar Compañía de MOVEX                                                                 
      **********************************************************************                        
     C     CS_CIASMVX    BEGSR                                                                      
                                                                                                    
      *          Establecer Entorno de Trabajo Movex                                                
     C                   MOVEL     PPCIAS        @PEDIVI                                            
     C                   CALL      'GX0150'                                                         
     C                   PARM                    @PEDIVI                                            
     C                   PARM      SDSUSR        @PEUSER                                            
     C                   PARM      *BLANKS       @PEVAL                                             
     C                   EVAL      ZXVAL=@PEVAL                                                     
                                                                                                    
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Recuperar Biblioteca de Movex                                                               
      **********************************************************************                        
     C     CS_MVXLIBL    BEGSR                                                                      
                                                                                                    
     C                   EVAL      LIBLMVX = *BLANKS                                                
                                                                                                    
s01  C                   SELECT                                                                     
     C                   WHEN      %SUBST(PPBIBL:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIBL:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIBL                                                 
     C                   WHEN      %SUBST(PPBIB1:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB1:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB1                                                 
     C                   WHEN      %SUBST(PPBIB2:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB2:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB2                                                 
     C                   WHEN      %SUBST(PPBIB3:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB3:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB3                                                 
     C                   WHEN      %SUBST(PPBIB4:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB4:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB4                                                 
     C                   WHEN      %SUBST(PPBIB5:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB5:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB5                                                 
     C                   WHEN      %SUBST(PPBIB6:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB6:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB6                                                 
     C                   WHEN      %SUBST(PPBIB7:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB7:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB7                                                 
     C                   WHEN      %SUBST(PPBIB8:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB8:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB8                                                 
     C                   WHEN      %SUBST(PPBIB9:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBIB9:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBIB9                                                 
     C                   WHEN      %SUBST(PPBI10:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI10:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI10                                                 
     C                   WHEN      %SUBST(PPBI11:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI11:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI11                                                 
     C                   WHEN      %SUBST(PPBI12:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI12:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI12                                                 
     C                   WHEN      %SUBST(PPBI13:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI13:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI13                                                 
     C                   WHEN      %SUBST(PPBI14:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI14:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI14                                                 
     C                   WHEN      %SUBST(PPBI15:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI15:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI15                                                 
     C                   WHEN      %SUBST(PPBI16:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI16:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI16                                                 
     C                   WHEN      %SUBST(PPBI17:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI17:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI17                                                 
     C                   WHEN      %SUBST(PPBI18:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI18:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI18                                                 
     C                   WHEN      %SUBST(PPBI19:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI19:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI19                                                 
     C                   WHEN      %SUBST(PPBI20:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI20:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI20                                                 
     C                   WHEN      %SUBST(PPBI21:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI21:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI21                                                 
     C                   WHEN      %SUBST(PPBI22:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI22:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI22                                                 
     C                   WHEN      %SUBST(PPBI23:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI23:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI23                                                 
     C                   WHEN      %SUBST(PPBI24:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI24:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI24                                                 
     C                   WHEN      %SUBST(PPBI25:1:7) = 'MVXJDTA'                                   
19D12C                             Or %SUBST(PPBI25:1:5) = 'M3EDB'                                  
     C                   EVAL      LIBLMVX = PPBI25                                                 
     C                   OTHER                                                                      
     C                   EVAL      LIBLMVX = 'MVXJDTA'                                              
e01  C                   ENDSL                                                                      
                                                                                                    
I0184C                   EVAL      LIBLAQA = *BLANKS                                                
I0184                                                                                               
I0184C                   SELECT                                                                     
I0184C                   WHEN      %SUBST(PPBIBL:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBIBL                                                 
I0184C                   WHEN      %SUBST(PPBIB1:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBIB1                                                 
I0184C                   WHEN      %SUBST(PPBIB2:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBIB2                                                 
I0184C                   WHEN      %SUBST(PPBIB3:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBIB3                                                 
I0184C                   WHEN      %SUBST(PPBIB4:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBIB4                                                 
I0184C                   WHEN      %SUBST(PPBIB5:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBIB5                                                 
I0184C                   WHEN      %SUBST(PPBIB6:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBIB6                                                 
I0184C                   WHEN      %SUBST(PPBIB7:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBIB7                                                 
I0184C                   WHEN      %SUBST(PPBIB8:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBIB8                                                 
I0184C                   WHEN      %SUBST(PPBIB9:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBIB9                                                 
I0184C                   WHEN      %SUBST(PPBI10:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI10                                                 
I0184C                   WHEN      %SUBST(PPBI11:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI11                                                 
I0184C                   WHEN      %SUBST(PPBI12:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI12                                                 
I0184C                   WHEN      %SUBST(PPBI13:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI13                                                 
I0184C                   WHEN      %SUBST(PPBI14:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI14                                                 
I0184C                   WHEN      %SUBST(PPBI15:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI15                                                 
I0184C                   WHEN      %SUBST(PPBI16:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI16                                                 
I0184C                   WHEN      %SUBST(PPBI17:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI17                                                 
I0184C                   WHEN      %SUBST(PPBI18:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI18                                                 
I0184C                   WHEN      %SUBST(PPBI19:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI19                                                 
I0184C                   WHEN      %SUBST(PPBI20:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI20                                                 
I0184C                   WHEN      %SUBST(PPBI21:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI21                                                 
I0184C                   WHEN      %SUBST(PPBI22:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI22                                                 
I0184C                   WHEN      %SUBST(PPBI23:1:5) = 'M3AQA'                                     
I0184C                   EVAL      LIBLAQA = PPBI23                                                 
I0184C                   WHEN      %SUBST(PPBI24:1:5) = 'M3AQA'                                     
