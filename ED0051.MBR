     C* '0' SIGNIFICA BATCH                                                                         
     C* '1' SIGNIFICA INTERACTIVO                                                                   
     C                   CALL      'RTVTIJ'                                                         
     C                   PARM      *BLANKS       @PTIPJ                                             
                                                                                                    
     C                   EVAL      P7CIAS=@PCIAS                                                    
     C                   EVAL      P7DLGA=@PDLGA                                                    
     C     KPMEMPR       CHAIN     PMEMPR                                                           
                                                                                                    
      * Si estoy en Interactivo abro fichero pantalla                                               
b01  C                   IF        @PTIPJ>'0'                                                       
     C                   OPEN      ED0051FM                                                         
     C                   EVAL      CCCCTIT='TED0051'                                                
     C                   EVAL      PPPCMD1='CMD7805'                                                
x01  C                   ELSE                                                                       
e01  C                   ENDIF                                                                      
                                                                                                    
      * Inicializo Series                                                                           
FQ710C                   EVAL      ZXINCI = @PINCI                                                  
     C                   MOVEA     *BLANKS       SERROR                                             
     C                   MOVEA     *BLANKS       SDERROR                                            
     C                   EVAL      @PERRO = ' '                                                     
     C                   EVAL      ZXWIND = '0'                                                     
     C                   EVAL      ZXVAL = *BLANKS                                                  
     C                   EVAL      ZXNDDP=0                                                         
     C                   EVAL      @PINCI = *BLANKS                                                 
FQ710C                   EVAL      ZXIMPEXP = 0                                                     
FQ710C                   MOVEL     *DATE         ZXFURE                                             
                                                                                                    
FQ710 * Validación de Confirmación de toda una preparación en TRACE                                 
FQ710C                   IF        @PEDAU = '305' And @PINTE = 3                                    
FQ710C                   EVAL      ZXWIND = '1'                                                     
FQ710C                   EXSR      CS_IMPOEXP2                                                      
FQ710C                   IF        ZXFOPR = 1                                                       
FQ710C                   GOTO      TPROCESO                                                         
FQ710C                   ENDIF                                                                      
FQ710C                   GOTO      TFINREAD                                                         
FQ710C                   ENDIF                                                                      
