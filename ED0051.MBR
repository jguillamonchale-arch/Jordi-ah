14060C                   EVAL      ZXWIND = '1'                                                     
14060C                   EVAL      ZXINCI = '004'                                                   
14060C                   EXSR      CS_DESERR                                                        
14060C                   ENDIF                                                                      
     C                   GOTO      TPROCESO                                                         
e01  C                   ENDIF                                                                      
