     C                   EVAL      ZXVARIBS=M5VARI                                                  
     C                   EVAL      ZXMODEBS=M5MODE                                                  
     C                   EVAL      ZXUNIMBS=NXUNIM                                                  
     C                   EXSR      CS_CNVUBS                                                        
     C                   EVAL      ZXCANT=ZXAUXIBS                                                  
