     C                   MOVEL     '20'          ZXDATD                                             
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
      *                                                                                             
15070C                   EVAL      M5CIAS=NXCIAS                                                    
15070C                   EVAL      M5ARTI=NXARTI                                                    
