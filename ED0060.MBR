      **********************************************************************                        
      * Entrada de parámetros                                                                       
      **********************************************************************                        
      *                                                                                             
     C     *ENTRY        PLIST                                                                      
     C                   PARM                    @PCIAS                                             
     C                   PARM                    @PDLGA                                             
     C                   PARM                    @PNPCO                                             
     C                   PARM                    @PTPED                                             
     C                   PARM                    @PDATP                                             
     C                   PARM                    @PNOPL                                             
     C                   PARM                    @PLINE                                             
     C                   PARM                    @PCHKS                                             
      *                                                                                             
      **********************************************************************                        
      * Estructura de Programa                                                                      
      **********************************************************************                        
C1369                                                                                               
C1369C                   EVAL      T3CIAS=@PCIAS                                                    
C1369C                   EVAL      T3DLGA=@PDLGA                                                    
C1369C     KEDPARM       CHAIN     EDPARM                                                           
      *                                                                                             
     C                   EVAL      ZXEDSN=0                                                         
      *                                                                                             
     C                   EXSR      CS_LOGOL                                                         
      *                                                                                             
     C                   EVAL      T2CIAS=@PCIAS                                                    
     C                   EVAL      T2DLGA=@PDLGA                                                    
     C                   EVAL      T2NPCO=@PNPCO                                                    
     C                   EVAL      T2TPED=@PTPED                                                    
     C                   EVAL      T2DATP=@PDATP                                                    
     C                   EVAL      T2NOPL=@PNOPL                                                    
     C                   EVAL      T2LINE=@PLINE                                                    
      *                                                                                             
      * Si me llega Nº de línea, sólo debo comprobar esa línea                                      
      *                                                                                             
     C                   IF        @PLINE<>0                                                        
      *                                                                                             
     C     KED0050W      CHAIN     ED0050W                                                          
     C                   IF        %FOUND(ED0050W)                                                  
      *                                                                                             
     C                   EXSR      CS_DETVTA                                                        
      *                                                                                             
      * Si es ED entonces generá fichero de control                                                 
C2638 * (Si la linea no está cerrada)                                                               
      *                                                                                             
     C                   IF        T2ENTD=1                                                         
C2638C                   IF        ZXENTD='1'                                                       
      *                                                                                             
     C                   IF        T2FORZ=1                                                         
     C                   EVAL      @FDEDAU='002'                                                    
     C                   ELSE                                                                       
     C                   EVAL      @FDEDAU='001'                                                    
     C                   ENDIF                                                                      
      *                                                                                             
     C                   EXSR      CS_GENERAED                                                      
     C                   EXSR      CS_SINCROCOMP                                                    
C2638C                   ENDIF                                                                      
      *                                                                                             
     C                   EVAL      ZXEDSN=1                                                         
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ELSE                                                                       
      *                                                                                             
      * Si no me llega Nº de línea, comprobar todas                                                 
      *                                                                                             
     C     KED0050W      SETLL     ED0050W                                                          
     C     KED0050W0     READE     ED0050W                                                          
     C                   DOW       NOT %EOF(ED0050W)                                                
      *                                                                                             
     C                   EXSR      CS_DETVTA                                                        
PJ933C                   IF        S0STCO>='20'                                                     
PJ933C                   EVAL      @PECABE='1'                                                      
PJ933C                   ENDIF                                                                      
      *                                                                                             
      * Si es ED entonces generá fichero de control                                                 
C2638 * (Si la linea no está cerrada)                                                               
      *                                                                                             
     C                   IF        T2ENTD=1                                                         
C2638C                   IF        ZXENTD='1'                                                       
      *                                                                                             
     C                   IF        T2FORZ=1                                                         
     C                   EVAL      @FDEDAU='002'                                                    
     C                   ELSE                                                                       
     C                   EVAL      @FDEDAU='001'                                                    
     C                   ENDIF                                                                      
      *                                                                                             
     C                   EXSR      CS_GENERAED                                                      
     C                   EXSR      CS_SINCROCOMP                                                    
C2638C                   ENDIF                                                                      
      *                                                                                             
     C                   EVAL      ZXEDSN=1                                                         
     C                   ENDIF                                                                      
      *                                                                                             
      * Graba histórico algorítmo decisión ED                                                       
     C                   EXSR      CS_HISALG                                                        
      *                                                                                             
     C     KED0050W0     READE     ED0050W                                                          
     C                   ENDDO                                                                      
      *                                                                                             
     C                   ENDIF                                                                      
C1078                                                                                               
C1078C*                                                                                             
C1078 * Graba histórico algorítmo decisión DOM                                                      
X1078C*                  IF        T3ADOM='1'                                                       
X1078C*                  IF        T3ADOM='1' AND S0STCO<'20'                                       
C1078C*                  EXSR      CS_HISDOM                                                        
C1078C*                  ENDIF                                                                      
C1078C*                                                                                             
      *                                                                                             
      * Actualiza cabecera de pedido de venta                                                       
      *                                                                                             
     C                   EXSR      CS_CABVTA                                                        
X1078                                                                                               
X1078C*                                                                                             
X1078 * Graba histórico algorítmo decisión DOM                                                      
X1078C                   IF        T3ADOM='1' AND S0STCO<'20'                                       
X1078C                   EXSR      CS_HISDOM                                                        
X1078C                   ENDIF                                                                      
X1078C*                                                                                             
      *                                                                                             
      * Llama a ED0015 para enviar TR de cabeceras de compra                                        
      * mediante @PEFIN                                                                             
      *                                                                                             
      * Si me viene PCHKS=1 quiere decir que me han creado una línea en                             
      * un pedido ya confirmado con anterioridad en CO0180 o CO0181                                 
      * entonces no hace falta que envíe la cabecera                                                
      *                                                                                             
     C                   IF        @PCHKS=0                                                         
     C                   CALL      'ED0015'                                                         
     C                   PARM                    @PCIAS                                             
     C                   PARM                    @PDLGA                                             
     C                   PARM                    @PNPCO                                             
     C                   PARM                    @PTPED                                             
     C                   PARM                    @PDATP                                             
     C                   PARM                    @PNOPL                                             
     C                   PARM                    @PLINE                                             
     C                   PARM                    @FDEDAU                                            
     C                   PARM      *BLANKS       @PEJOBT          18                                
     C                   PARM      1             @PEFIN                                             
     C                   ENDIF                                                                      
      *                                                                                             
     C                   SETON                                        LR                            
      **********************************************************************                        
      * Generar registro en fichero de control de ED                                                
      **********************************************************************                        
     C     CS_GENERAED   BEGSR                                                                      
      *                                                                                             
     C                   EVAL      @FDCIAS=T2CIAS                                                   
     C                   EVAL      @FDDLGA=T2DLGA                                                   
     C                   EVAL      @FDNPCO=T2NPCO                                                   
     C                   EVAL      @FDTPED=T2TPED                                                   
     C                   EVAL      @FDDATP=T2DATP                                                   
     C                   EVAL      @FDNOPL=T2NOPL                                                   
     C                   EVAL      @FDLINE=T2LINE                                                   
     C                   EVAL      @FDCIA2=0                                                        
     C                   EVAL      @FDDLG2=*BLANKS                                                  
     C                   EVAL      @FDNPC2=*BLANKS                                                  
     C                   EVAL      @FDTPE2=*BLANKS                                                  
     C                   EVAL      @FDDAT2=0                                                        
     C                   EVAL      @FDNOP2=0                                                        
     C                   EVAL      @FDLIN2=0                                                        
     C                   EVAL      @FDCUST=*BLANKS                                                  
     C                   EVAL      @FDTDI1=*BLANKS                                                  
     C                   EVAL      @FDLOGI=0                                                        
     C                   EVAL      @FDERAV=*BLANKS                                                  
     C                   EVAL      @FDTEXT=*BLANKS                                                  
     C                   EVAL      @FDDATO=*BLANKS                                                  
     C                   EVAL      @FDWAUD=1                                                        
     C                   EVAL      @FDCANT=S5CANT                                                   
      *                                                                                             
     C                   CALL      'ED0100'                                                         
     C                   PARM                    @FDCIAS                                            
     C                   PARM                    @FDDLGA                                            
     C                   PARM                    @FDNPCO                                            
     C                   PARM                    @FDTPED                                            
     C                   PARM                    @FDDATP                                            
     C                   PARM                    @FDNOPL                                            
     C                   PARM                    @FDLINE                                            
     C                   PARM                    @FDCIA2                                            
