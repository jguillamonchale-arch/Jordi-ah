C1078C                   EVAL      D1NOPL=@PNOPL                                                    
C1078                                                                                               
C1078C     KDO0051       SETLL     DOH051                                                           
C1078C     KDO0051       READE     DOH051                                                           
C1078C                   DOW       NOT%EOF                                                          
C1078C                   EVAL      D1BAJA='1'                                                       
C1078C                   UPDATE    RDOH051                                                          
C1078C     KDO0051       READE     DOH051                                                           
C1078C                   ENDDO                                                                      
C1078C                                                                                              
C1078C                   CLEAR                   RDOH050                                            
C1078C                   CLEAR                   RDOH051                                            
C1078C                   CLEAR                   RDOH052                                            
C1078C                                                                                              
C1078                                                                                               
C1078C                   ENDSR                                                                      
C2384 **************************************************************                                
C2384 * Actualizar dirección de almacén de consigna en pedido      *                                
C2384 **************************************************************                                
C2384C     CS_DIRCNSG    BEGSR                                                                      
C2384 *                                                                                             
C2384 * Si el pedido es de consigna y tiene dirección de consigna                                   
C2384 * se actualizará en CODIPE como dirección 'Varios'                                            
C2384 * Buscaremos el almacén de la logística de consigna para                                      
C2384 * después buscar la dirección.                                                                
C2384 *                                                                                             
C2384C                   IF        S0TDIG<>*BLANKS                                                  
C2384C                   EVAL      S2CIAS=S5CIAS                                                    
C2384C                   EVAL      S2DLGA=S5DLGA                                                    
C2384C                   EVAL      S2NPCO=S5NPCO                                                    
C2384C                   EVAL      S2TPED=S5TPED                                                    
C2384C                   EVAL      S2DATP=S5DATP                                                    
C2384C                   EVAL      S2NOPL=S5NOPL                                                    
C2384C                   EVAL      S2CDIR='1'                                                       
C2384C     KCODIPE       CHAIN     CODIPE                                                           
C2384C                   IF        %FOUND(CODIPE)                                                   
C2384C                   EVAL      C_M0CIAS=S0CIAS                                                  
C2384C                   EVAL      C_M0LOGE=S0LGCG                                                  
C2384C     KMSALMA05     CHAIN     MSALMA05                                                         
C2384C                   EVAL      D_C2CIAS=C_M0CIAS                                                
C2384C                   EVAL      D_C2MAGA=C_M0MAGA                                                
C2384C                   EVAL      D_C2TDIR=S0TDIG                                                  
C2384C     KCODIMA       CHAIN     CODIMA                             81                            
C2384C                   IF        %FOUND(CODIMA)                                                   
C2384C                   EVAL      S2DIRE=D_C2DIRE                                                  
C2384C                   EVAL      S2DIR2=D_C2DIR2                                                  
C2384C                   EVAL      S2POBL=D_C2POBL                                                  
C2384C                   EVAL      S2POST=D_C2POST                                                  
C2384C                   EVAL      S2TELE=D_C2TELE                                                  
C2384C                   EVAL      S2TEL2=D_C2TEL2                                                  
C2384C                   EVAL      S2TLEX=D_C2TLEX                                                  
C2384C                   EVAL      S2TFAX=D_C2TFAX                                                  
C2384C                   EVAL      S2EMAI=D_C2EMAI                                                  
C2384C                   EVAL      S2PAIS=D_C2PAIS                                                  
C2384C                   EVAL      S2PEGE=D_C2PEGE                                                  
C2384C                   EVAL      S2OB50=D_C2OB50                                                  
C2384C                   EVAL      S2OB51=D_C2OB51                                                  
C2384C                   EVAL      S2TDVA='1'                                                       
C2384C                   UPDATE    RCODIPE                                                          
C2384C                   ENDIF                                                                      
C2384C                   ENDIF                                                                      
C2384 *                                                                                             
C2384 * Buscaremos en el cliente qué código es la dirección Varios                                  
C2384 * para actualizarla en COCAPE.                                                                
C2384 *                                                                                             
C2384C                   EVAL      S2CUST=S0CUST                                                    
C2384C     KCODIPR0      SETLL     RCODIPR                                                          
C2384C     KCODIPR0      READE     RCODIPR                                                          
C2384C                   DOW       NOT %EOF(CODIPR)                                                 
C2384C                   IF        S2TDVA='1'                                                       
C2384C                   EVAL      S0TDI1=S2TDIR                                                    
C2384C                   LEAVE                                                                      
C2384C                   ENDIF                                                                      
C2384C     KCODIPR0      READE     RCODIPR                                                          
C2384C                   ENDDO                                                                      
C2384 *                                                                                             
C2384C                   ENDIF                                                                      
C2384 *                                                                                             
C2384C                   ENDSR                                                                      
C2384 **************************************************************                                
      *C2384C     CS_LOGDFT     BEGSR                                                               
      *IT228C                   IF        (%lookup(S5LOGE:T_logol)=0)                               
      *IT228C                   EXSR      CS_LOGDFT                                                 
      *IT228C                   ENDIF                                                               
      *IT228C                   IF        LOEDL<>*BLANKS                                            
      *IT228C                   EVAL      S5LOGE=loEdl                                              
      *IT228C                   ELSE                                                                
      *IT228C                   EVAL      S5LOGE=loEEM                                              
      *IT228C                   ENDIF                                                               
      *IT228C                   ENDSR                                                               
      // it228 add                                                                                  
           begsr  cs_logdft;                                                                        
             if   (%lookup(S5LOGE:T_logol)=0);                                                      
               PgmOL(@PCIAS:s5dlga:pPointer);                                                       
               pDsPgmOl = pPointer;                                                                 
               if loedl <> *blanks;                                                                 
                 s5loge = loEdl;                                                                    
               else;                                                                                
                 s5loge = loEem;                                                                    
               endif;                                                                               
             endif;                                                                                 
           endsr;                                                                                   
      // it228 end                                                                                  
IT225 * ----------------------------------------------------------------------------------------    
IT225 * Add-begin  - Procedure GetLogV                                                              
       // IT225 -> Add proc GetLogV                                                                 
       //  Function per rucuperar la logística virtual associada al magatzem OL                     
       //                                                                                           
       dcl-proc GetLogV;                                                                            
        dcl-pi *n like(T3LVIR);                                                                     
          xdlga  like(s5dlga);                                                                      
        end-pi;                                                                                     
        //Vars propies                                                                              
        dcl-s alma like(m0maga);                                                                    
        dcl-s dlga like(s5dlga);                                                                    
        dcl-s tipo char(1);                                                                         
        dcl-s resp like(m0maga);                                                                    
        dcl-s  i int(10);                                                                           
        //-----------------------------                                                             
        // Cerca del magatzem OL per defecte de la delegació de la comanda                          
          PgmOL(@PCIAS:xdlga:pPointer);                                                             
          pDsPgmOl = pPointer;                                                                      
          // Ja tenim els magatzems OL per defecte. Cerquem la logística virtual                    
          alma = zoldl;  //mag def deleg. Si ha d'esser el de la cia s'ha de posar zolem            
          tipo = *blanks;                                                                           
          dlga = *blanks;                                                                           
          PgmOL2(@PCIAS:alma:tipo:xdlga:resp);                                                      
          return %subst(resp:1:3);                                                                  
                                                                                                    
       end-proc;                                                                                    
IT225 * Add-end    - Procedure GetLogV                                                              
