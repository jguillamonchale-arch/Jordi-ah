IT225 * add-begin                                                                                   
        dcl-s xpebl64 char(10); // PEBL64                                                           
        dcl-s xpedesc char(30); // PEDESC                                                           
        dcl-s auxLVIR like(T3LVIR) inz;                                                             
        dcl-s pPointer pointer;                                                                     
        dcl-s pDsPgmOL pointer;                                                                     
        dcl-ds DsPgmOL based(pDsPgmOL);                                                             
              zoldl like(m0maga);                                                                   
              loEdl like(M0LOGE) ;                                                                  
              loSdl like(M0LOGS) ;                                                                  
              zolem like(m0maga);                                                                   
              loEem like(M0LOGE) ;                                                                  
              loSem like(M0LOGS) ;                                                                  
              zolgc like(m0maga);                                                                   
              loEgc like(M0LOGE) ;                                                                  
              loSgc like(M0LOGS) ;                                                                  
              zolgm like(m0maga);                                                                   
              loEgm like(M0LOGE) ;                                                                  
              loSgm like(M0LOGS) ;                                                                  
              zolgt like(m0maga);                                                                   
              loEgt like(M0LOGE) ;                                                                  
              loSgt like(M0LOGS) ;                                                                  
        end-ds;                                                                                     
        dcl-pr pgmOL   extpgm('MM1410');                                                            
           xCIAS   like(s5cias) const;   // cia                                                     
           xDLGA   like(s5dlga) const;   // delega                                                  
           xptr    pointer       ;        // pointer                                                
        end-pr;                                                                                     
        dcl-pr pgmOL2  extpgm('MM1411');                                                            
           xCIAS   like(s5cias);                                                                    
           xPALMA  like(m0maga) ;                                                                   
           xPTIPO  char(1)      ;                                                                   
           xDLGA   like(s5DLGA) ;                                                                   
           xPRESP  like(m0maga) ;                                                                   
        end-pr;                                                                                     
IT225 * add-end                                                                                     
