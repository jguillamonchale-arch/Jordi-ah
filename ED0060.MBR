      **********************************************************************                        
      * Sincroniza el pedido de ventas con el pedido de compras                                     
      **********************************************************************                        
     C     CS_SINCROCOMP BEGSR                                                                      
      *                                                                                             
      *                                                                                             
      * Si me viene PCHKS=1 quiere decir que me han creado una línea en                             
      * un pedido ya confirmado con anterioridad en CO0180 o CO0181                                 
      *                                                                                             
     C                   IF        @PCHKS=1                                                         
     C                   EVAL      @PEFIN=8                                                         
     C                   ELSE                                                                       
     C                   EVAL      @PEFIN=0                                                         
     C                   ENDIF                                                                      
      *                                                                                             
     C                   CALL      'ED0015'                                                         
     C                   PARM                    @PCIAS                                             
     C                   PARM                    @PDLGA                                             
     C                   PARM                    @PNPCO                                             
     C                   PARM                    @PTPED                                             
     C                   PARM                    @PDATP                                             
     C                   PARM                    @PNOPL                                             
     C                   PARM      T2LINE        @PLINE                                             
     C                   PARM                    @FDEDAU                                            
     C                   PARM      *BLANKS       @PEJOBT          18                                
     C                   PARM                    @PEFIN                                             
PJ933C                   PARM                    @PECABE           1                                
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Actualiza detalle de pedido de ventas                                                       
      **********************************************************************                        
     C     CS_DETVTA     BEGSR                                                                      
      *                                                                                             
C2638C                   EVAL      ZXENTD='0'                                                       
     C                   EVAL      S5CIAS=@PCIAS                                                    
     C                   EVAL      S5DLGA=@PDLGA                                                    
     C                   EVAL      S5NPCO=@PNPCO                                                    
     C                   EVAL      S5TPED=@PTPED                                                    
     C                   EVAL      S5DATP=@PDATP                                                    
     C                   EVAL      S5NOPL=@PNOPL                                                    
     C                   EVAL      S5LINE=T2LINE                                                    
     C     KCODEPE       CHAIN     CODEPE                                                           
     C                   IF        %FOUND(CODEPE)                                                   
CR653C*                                                                                             
CR653C                   CALL      'XBB001'                                                         
CR653C                   PARM      S5CIAS        @YCIAS                                             
CR653C                   PARM      S5ARTI        @YARTI                                             
CR653C                   PARM      S5VARI        @YVARI                                             
CR653C                   PARM      S5MODE        @YMODE                                             
CR653C                   PARM      *BLANKS       @YPRVR                                             
CR653C                   PARM      *BLANKS       @YGRUP                                             
CR653C                   PARM      *BLANKS       @YPEVT                                             
CR653C*                                                                                             
     C                   IF        T2ENTD=1                                                         
C2638 *                                                                                             
C2638 * Solo cambiaremos ED y logisticas si la linea no está cerrada                                
C2638C                   IF        S5STUL<>'5'AND S5CAPP=0                                          
C2638C                   EVAL      ZXENTD='1'                                                       
     C                   EVAL      S5TPE4='2'                                                       
FDX01 *                                                                                             
FDX01 * Comprobar si es conjunto de venta, y en tal caso, sólo que                                  
FDX01 * uno de los componentes sea material propio (M5SIOL=2)                                       
FDX01 * entonces ponemos la linea del Padre en CODEPE con Logística OL                              
CR653 * EXCEPTO SI EL PROVEEDOR ES DE ENTREGAS EXTERNAS                                             
FDX01 *                                                                                             
FDX01C                   MOVE      *BLANKS       ZXSIOL            1                                
FDX01C                   EXSR      CS_CONJUNTO                                                      
CR653C*                  IF        ZXSIOL='2' AND @YPEVT<>'2'                                       
FDX01C*                  EVAL      S5LOGE=ZXLOGOL                                                   
FDX01C*                  ELSE                                                                       
FDX01 *                                                                                             
     C*    KMSARTI00     CHAIN     MSARTI00                                                         
CR653C*                  IF        M5SIOL='2' AND @YPEVT<>'2'                                       
     C*                  EVAL      S5LOGE=ZXLOGOL                                                   
     C*                  ENDIF                                                                      
FDX01 *                                                                                             
FDX01C*                  ENDIF                                                                      
FDX01 *                                                                                             
C2426C*                                                                                             
IT228C* SI S5LOGE ESTÁ EN LA TABLA DE OLs SE QUEDA, SI NO RECUPERAR DEFECTO                         
IT228C                   IF        ZXSIOL='2'                                                       
IT228C*                  EVAL      S5LOGE=ZXLOGOL                                                   
IT228C                   EXSR      CS_LOGDFT                                                        
C2426C                   ELSE                                                                       
C2426C     KMSARTI00     CHAIN     MSARTI00                                                         
C2426C                   IF        M5SIOL='2'                                                       
IT228C*                  EVAL      S5LOGE=ZXLOGOL                                                   
IT228C                   EXSR      CS_LOGDFT                                                        
C2426C                   ENDIF                                                                      
C2426C                   ENDIF                                                                      
C2426C*                                                                                             
     C                   ELSE                                                                       
     C                   IF        S5TPE4='2'                                                       
     C                   EVAL      S5TPE4=*BLANKS                                                   
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
C1369                                                                                               
C1369C                   IF        S5TPE4='2'                                                       
IT225 *C1369C                   IF        T3LVIR<>*BLANKS AND S5LOGE<>ZXLOGOL                       
IT225 * Add-Begin                                                                                   
                         auxLVIR = GetLogV (s5dlga);                                                
                         if auxLVIR <> *blanks and %lookup(s5loge:T_logol)=0;                       
IT225 * Add-end                                                                                     
C1369C                   EVAL      C_M0CIAS=@PCIAS                                                  
C1369C                   EVAL      C_M0LOGE=S5LOGE                                                  
C1369C     KMSALMA05     CHAIN     MSALMA05                                                         
C1369C                   IF        C_M0APPL='1' AND %FOUND(MSALMA05)                                
C1078C                             AND C_M0TAL1<'7'                                                 
IT225 *C1369C                   EVAL      S5LOGE=T3LVIR                                             
IT225c                   eval      s5loge = auxLVIR                                                 
C1369C                   ENDIF                                                                      
C1369C                   ENDIF                                                                      
C1369C                   ENDIF                                                                      
C2384 *                                                                                             
C2384 * Si el pedido FD es de consigna actualizamos con la logística de                             
C2384 * la consigna si esta viene informada                                                         
C2384 *                                                                                             
C2384C                   IF        S5TPE4='2'                                                       
C2384C                   EVAL      S0CIAS=@PCIAS                                                    
C2384C                   EVAL      S0DLGA=@PDLGA                                                    
C2384C                   EVAL      S0NPCO=@PNPCO                                                    
C2384C                   EVAL      S0TPED=@PTPED                                                    
C2384C                   EVAL      S0DATP=@PDATP                                                    
C2384C                   EVAL      S0NOPL=@PNOPL                                                    
C2384C     KCOCAPE       CHAIN     COCAPE                                                           
C2384C                   IF        %FOUND(COCAPE) AND                                               
C2384C                             S0CNSG='1' AND S0LGCG<>*BLANKS                                   
IT225 *C2384C                   IF        S5LOGE<>ZXLOGOL                                           
IT225c                   if        %lookup(s5loge:T_logol)=0                                        
C2384C                   EVAL      S5LOGE=S0LGCG                                                    
C2384C                   ENDIF                                                                      
C2384C                   EXSR      CS_DIRCNSG                                                       
C2384C                   ENDIF                                                                      
C2384C                   UPDATE    RCOCAPE                                                          
C2384C                   ENDIF                                                                      
C1369                                                                                               
CR964C                   EXSR      CS_BUSROTNEW                                                     
C2638C                   ENDIF                                                                      
C2638 *                                                                                             
     C                   UPDATE    RCODEPE                                                          
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Actualiza cabecera de pedido de ventas                                                      
      **********************************************************************                        
     C     CS_CABVTA     BEGSR                                                                      
      *                                                                                             
     C                   EVAL      S0CIAS=@PCIAS                                                    
     C                   EVAL      S0DLGA=@PDLGA                                                    
     C                   EVAL      S0NPCO=@PNPCO                                                    
     C                   EVAL      S0TPED=@PTPED                                                    
     C                   EVAL      S0DATP=@PDATP                                                    
     C                   EVAL      S0NOPL=@PNOPL                                                    
     C     KCOCAPE       CHAIN     COCAPE                                                           
     C                   IF        %FOUND(COCAPE)                                                   
     C                   IF        ZXEDSN=1                                                         
     C                   EVAL      S0TPE4='2'                                                       
     C                   ELSE                                                                       
     C                   IF        S0TPE4='2'                                                       
     C                   EVAL      S0TPE4=*BLANKS                                                   
     C                   ENDIF                                                                      
     C                   ENDIF                                                                      
     C                   UPDATE    RCOCAPE                                                          
     C                   ENDIF                                                                      
      *                                                                                             
     C                   ENDSR                                                                      
      **********************************************************************                        
      * Graba histórico algorítmo decisión ED                                                       
      **********************************************************************                        
     C     CS_HISALG     BEGSR                                                                      
                                                                                                    
     C                   EVAL      T2DAT1=*DATE                                                     
FQ606C**                 TIME                    T2HORA                                             
FQ606C                   EVAL      T2HORA=ZXHORA                                                    
     C                   EVAL      T2USUA=SDSUSR                                                    
     C                   EVAL      T2PANT=SDSJOB                                                    
     C                   WRITE     REDH050                                                          
                                                                                                    
     C                   ENDSR                                                                      
      **************************************************************                                
      * GUARDA LOGISTICA DEL OL                                    *                                
      *------------------------------------------------------------*                                
     C     CS_LOGOL      BEGSR                                                                      
      *                                                                                             
IT225 *     C     @PCIAS        SETLL     MSALMA                                                    
IT225 *     C     @PCIAS        READE     MSALMA                                                    
IT225 *     C                   DOW       NOT %EOF(MSALMA)                                          
IT225 *     C                   IF        M0TAL1='8' AND M0BAJA<>'1'                                
IT225 *     C                   EVAL      ZXLOGOL=M0LOGS                                            
IT225 *     C                   LEAVE                                                               
IT225 *     C                   ENDIF                                                               
IT225 *     C     @PCIAS        READE     MSALMA                                 84                 
IT225 *     C                   ENDDO                                                               
IT225 * Add-begin                                                                                   
                  i2ol = *zero;                                                                     
                  open msalma08;                                                                    
                  setll (@PCIAS:'8') msalma08;                                                      
                  reade (@PCIAS:'8') msalma08;                                                      
                  dow not %eof(msalma08);                                                           
                    if m0tal1 = '8' and m0baja <> '1' and                                           
                        i2OL < %elem(T_logol) ;                                                     
                      i2OL += 1;                                                                    
                      T_logol(i2OL) = m0logs;                                                       
                    endif;                                                                          
                    reade (@PCIAS:'8') msalma08;                                                    
                  enddo;                                                                            
                  close msalma08;                                                                   
IT225 * Add-end                                                                                     
      *                                                                                             
     C                   ENDSR                                                                      
FDX01 **********************************************************************                        
FDX01 * Comprobar si es conjunto y sus componentes mat. propio                                      
FDX01 **********************************************************************                        
FDX01C     CS_CONJUNTO   BEGSR                                                                      
FDX01 *                                                                                             
FDX01 * Miramos si es Conjunto de Venta                                                             
FDX01 *                                                                                             
FDX01C                   MOVE      *BLANKS       ZXTCOJ            1                                
FDX01C                   EVAL      NDARTI=S5ARTI                                                    
FDX01C                   EVAL      NDMODE=S5MODE                                                    
FDX01C                   EVAL      NDVARI=S5VARI                                                    
FDX01C                   EVAL      NDTCOJ='4'                                                       
FDX01C     KMSCOJC       CHAIN     MSCOJC                                                           
FDX01C                   IF        %FOUND(MSCOJC) AND NDBAJA<'1'                                    
FDX01 *                                                                                             
FDX01 * Miramos si es Conjunto de Compra                                                            
FDX01 *                                                                                             
FDX01C                   EVAL      NDTCOJ='1'                                                       
FDX01C     KMSCOJC       CHAIN     MSCOJC                                                           
FDX01C                   IF        %FOUND(MSCOJC) AND NDBAJA<'1'                                    
FDX01 *                                                                                             
FDX01 * Si es Conjunto de Ventas y de Compra No lo trataremos como Cjto                             
FDX01 *                                                                                             
FDX01C                   EVAL      ZXTCOJ=' '                                                       
FDX01C                   ELSE                                                                       
FDX01 *                                                                                             
FDX01 * Si es Conjunto de Ventas y No de Compra Si lo tratamos                                      
FDX01 *                                                                                             
FDX01C                   EVAL      ZXTCOJ='4'                                                       
FDX01C                   ENDIF                                                                      
FDX01C                   ELSE                                                                       
FDX01 *                                                                                             
FDX01 * Si No es Conjunto de Venta , Pues no es Conjunto y punto                                    
FDX01 *                                                                                             
FDX01C                   EVAL      ZXTCOJ=' '                                                       
FDX01C                   ENDIF                                                                      
FDX01 *                                                                                             
FDX01 * Es Conjunto                                                                                 
FDX01 *                                                                                             
FDX01C                   IF        ZXTCOJ='4'                                                       
FDX01 *                                                                                             
FDX01C                   EVAL      NDARTI=S5ARTI                                                    
FDX01C                   EVAL      NDMODE=S5MODE                                                    
FDX01C                   EVAL      NDVARI=S5VARI                                                    
FDX01C                   EVAL      NDTCOJ=ZXTCOJ                                                    
FDX01C     KMSCOJC       SETLL     MSCOJD                                                           
FDX01C     KMSCOJC       READE     MSCOJD                                                           
FDX01C                   DOW       NOT %EOF(MSCOJD)                                                 
FDX01 *                                                                                             
FDX01C                   IF        NDBAJA <> '1'                                                    
FDX01C     KMSARTICO     CHAIN     MSARTI00                                                         
FDX01C                   IF        %FOUND(MSARTI00) AND                                             
CR653C                             M5SIOL='2' AND @YPEVT<>'2'                                       
FDX01C                   EVAL      ZXSIOL='2'                                                       
FDX01C                   LEAVE                                                                      
FDX01C                   ENDIF                                                                      
FDX01C                   ENDIF                                                                      
FDX01 *                                                                                             
FDX01C     KMSCOJC       READE     MSCOJD                                                           
FDX01C                   ENDDO                                                                      
FDX01 *                                                                                             
FDX01C                   ENDIF                                                                      
FDX01 *                                                                                             
FDX01 * Recuperamos registro de MSARTI del Padre                                                    
FDX01 *                                                                                             
FDX01C                   EVAL      M5ARTI=S5ARTI                                                    
FDX01C                   EVAL      M5VARI=S5VARI                                                    
FDX01C                   EVAL      M5MODE=S5MODE                                                    
FDX01C     KMSARTI00     CHAIN     MSARTI00                                                         
FDX01 *                                                                                             
FDX01C                   ENDSR                                                                      
CR964 **************************************************************                                
CR964 * COMMON SUBRUTINE (CS_) :                                   *                                
CR964 * Recuperar CATERORIA ROTACIÓN CONSERVARLA PARA ANALISIS TCT *                                
CR964 *------------------------------------------------------------*                                
CR964C     CS_BUSROTNEW  BEGSR                                                                      
CR964 * BLANQUEAMOS VALORES A BUSCAR                                                                
CR964C                   EVAL      S5CROT=*BLANKS                                                   
CR964C                   EVAL      S5CROP=*BLANKS                                                   
CR964C                   EVAL      S5CROTA=*BLANKS                                                  
CR964C                   EVAL      S5CROTB=*BLANKS                                                  
CR964C                   EVAL      S5CROTC=*BLANKS                                                  
CR964C                                                                                              
CR964C                   EVAL      @QCIAS=S5CIAS                                                    
CR964C                   EVAL      @QDLGA=S5DLGA                                                    
CR964C                   EVAL      @QLOGE=S5LOGE                                                    
CR964C                   EVAL      @QARTI=S5ARTI                                                    
CR964C                   EVAL      @QVARI=S5VARI                                                    
CR964C                   EVAL      @QMODE=S5MODE                                                    
CR964C                   EVAL      @QTCOJ=S5TCOJ                                                    
CR964C                   EVAL      @QCROT=*BLANKS                                                   
CR964C                   EVAL      @QCROTA=*BLANKS                                                  
CR964C                   EVAL      @QCROTB=*BLANKS                                                  
CR964C                   EVAL      @QCROTC=*BLANKS                                                  
CR964                                                                                               
CR964C                   EVAL      @QLOFD=' '                                                       
CR964C                   IF        S5TPE4='2'                                                       
CR964C                   EVAL      @QLOFD='1'                                                       
CR964C                   ENDIF                                                                      
CR964                                                                                               
CR964C                   CALL      'CO2755'                                                         
CR964C                   PARM                    @QCIAS                                             
CR964C                   PARM                    @QDLGA                                             
CR964C                   PARM                    @QLOGE                                             
CR964C                   PARM                    @QARTI                                             
CR964C                   PARM                    @QVARI                                             
CR964C                   PARM                    @QMODE                                             
CR964C                   PARM                    @QTCOJ                                             
CR964C                   PARM                    @QCROT                                             
CR964C                   PARM                    @QCROTA                                            
CR964C                   PARM                    @QCROTB                                            
CR964C                   PARM                    @QCROTC                                            
CR964C                   PARM                    @QLOFD                                             
CR964 *                                                                                             
CR964C                   EVAL      S5CROT=%SUBST(@QCROT:1:1)                                        
CR964C                   EVAL      S5CROP=%SUBST(@QCROT:2:1)                                        
CR964 *                                                                                             
CR964C                   IF        S5TCOJ='4'                                                       
CR964C                   MOVE      @QCROTA       S5CROTA                                            
CR964C                   MOVE      @QCROTB       S5CROTB                                            
CR964C                   MOVE      @QCROTC       S5CROTC                                            
CR964C                   ENDIF                                                                      
CR964                                                                                               
CR964C                   ENDSR                                                                      
