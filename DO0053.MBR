FQ765C                   EVAL      M5VARI=ZXVARI                                                    
FQ765C                   EVAL      M5MODE=ZXMODE                                                    
FQ765C     KMSARTI00     CHAIN     MSARTI00                                                         
FQ766C                   IF        %FOUND AND M5BAJA<>'1'                                           
FQ765C                   EVAL      PECTAB='TIPG'                                                    
FQ765C                   EVAL      PECLTA=M5TIPG                                                    
FQ766C     KPMTABD       CHAIN     PMTABD                             81                            
