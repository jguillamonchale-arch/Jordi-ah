      **************************************************************                                
      * SUBRUTINA DE ACTUALIZACION DEL FMT P2A                     *                                
      *------------------------------------------------------------*                                
     C     P2AUPD        BEGSR                                                                      
     C                   EVAL      ZXOPT='END'                                                      
                                                                                                    
      * En el caso de la opción de visualiza no actualizo                                           
     C                   IF        INDDSP=*ON                                                       
     C                   GOTO      P2AUPDT                                                          
     C                   ENDIF                                                                      
                                                                                                    
     C                   EVAL      T3DLGA=P2ADLGA                                                   
     C     KEDPAR2       CHAIN     EDPAR2                                                           
     C     KEDPARM       CHAIN     EDPARM                                                           
     C                   EXSR      P2AMPF                                                           
     C                   IF        %FOUND(EDPARM)                                                   
     C                   UPDATE    REDPARM                                                          
     C                   ELSE                                                                       
     C                   EVAL      T3DAT1=*DATE                                                     
     C                   WRITE     REDPARM                                                          
     C                   ENDIF                                                                      
     C                   IF        %FOUND(EDPAR2)                                                   
     C                   UPDATE    REDPAR2                                                          
     C                   ELSE                                                                       
     C                   EVAL      T4DAT1=*DATE                                                     
     C                   WRITE     REDPAR2                                                          
     C                   ENDIF                                                                      
      *                                                                                             
      * En el caso que sea una copia                                                                
      *                                                                                             
     C                   IF        INDCPY=*ON                                                       
     C                   ENDIF                                                                      
                                                                                                    
     C     P2AUPDT       ENDSR                                                                      
      **************************************************************                                
      * SUBRUTINA PASAR DE PANTALLA P2A A FICHERO                  *                                
      *------------------------------------------------------------*                                
     C     P2AMPF        BEGSR                                                                      
      *                                                                                             
FQ798C                                                                                              
FQ798C                   IF        %FOUND(EDPARM)                                                   
FQ798C                   IF        T3NIMF<>P2ANIMF OR                                               
FQ798C                             T3OBSO<>P2AOBSO OR                                               
FQ798C                             T3SSTO<>P2ASSTO OR                                               
FQ798C                             T3PEXP<>P2APEXP OR                                               
FQ798C                             T3ENIN<>P2AENIN OR                                               
FQ798C                             T3DIBE<>P2ADIBE OR                                               
FQ798C                             T3NCLF<>P2ANCLF OR                                               
FQ798C                             T3LOGI<>P2ALOGI OR                                               
FQ798C                             T3STCK<>P2ASTCK OR                                               
FQ798C                             T3EDFO<>P2AEDFO OR                                               
FH009C                             T3RESE<>P2ARESE OR                                               
FH009C                             T3RTRE<>P2ARTRE OR                                               
SE257C                             T3ARMP<>P2AARMP or                                               
FQ798C                             T3ARVM<>P2AARVM                                                  
C2238C                             OR T3OFEX<>P2AOFEX                                               
FQ798C                   EVAL      T3DA82=*DATE                                                     
FQ798C                   EVAL      T3USU2=SDSUSR                                                    
FQ798C                   EVAL      T3PAN2=SDSJOB                                                    
FQ798C                   TIME                    T3HO82                                             
FQ798C                   WRITE     REDHPAR                                                          
FQ798C                   ENDIF                                                                      
FQ798C                   ENDIF                                                                      
